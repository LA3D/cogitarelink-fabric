# Endpoint-specific SHACL 1.2 shapes for cogitarelink-fabric node
# Layer 3 (D9): endpoint SHACL — constrains observations stored at this node.
# sh:agentInstruction follows Experiment 9 pattern: machine-readable guidance
# for RLM agents navigating this endpoint.
#
# NOTE: {base} is substituted at serve time by /.well-known/shacl endpoint
# (same pattern as VoID and SPARQL examples).

@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix sosa:  <http://www.w3.org/ns/sosa/> .
@prefix sio:   <http://semanticscience.org/resource/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix fabric: <https://w3id.org/cogitarelink/fabric#> .

# --- Metadata -----------------------------------------------------------

# sh:declare requires owl:Ontology subject per SHACL spec (sh:declare rdfs:domain owl:Ontology)
<{base}/.well-known/shacl>
    a owl:Ontology ;
    dct:title "cogitarelink-fabric node SHACL shapes" ;
    dct:description "Endpoint-specific constraints for SOSA observations at this node." ;
    sh:declare [
        sh:prefix "sosa" ;
        sh:namespace "http://www.w3.org/ns/sosa/"^^xsd:anyURI ;
    ] , [
        sh:prefix "xsd" ;
        sh:namespace "http://www.w3.org/2001/XMLSchema#"^^xsd:anyURI ;
    ] , [
        sh:prefix "time" ;
        sh:namespace "http://www.w3.org/2006/time#"^^xsd:anyURI ;
    ] ,
    [ sh:prefix "prov" ;
      sh:namespace "http://www.w3.org/ns/prov#"^^xsd:anyURI ;
    ] ,
    [ sh:prefix "sio" ;
      sh:namespace "http://semanticscience.org/resource/"^^xsd:anyURI ;
    ] .

# --- sosa:Observation shape ---------------------------------------------

fabric:ObservationShape
    a sh:NodeShape ;
    sh:targetClass sosa:Observation ;
    dct:description "Constraints on SOSA Observations stored in /graph/observations." ;

    # Agent instruction: how an RLM agent should query this endpoint.
    # Observations use one of two result patterns:
    #   (A) Simple scalar:  sosa:hasSimpleResult "<value>"^^xsd:double
    #   (B) SIO chain:      sio:has-attribute <MeasuredValue> ; <MeasuredValue> sio:has-value "<value>"^^xsd:double
    # Check which pattern is present before assuming either.
    sh:agentInstruction """Observations use one of two result patterns.
Pattern A (simple scalar):
  SELECT ?obs ?result ?time FROM <{base}/graph/observations>
  WHERE { ?obs a sosa:Observation ; sosa:hasSimpleResult ?result ; sosa:resultTime ?time }

Pattern B (SIO measurement chain):
  PREFIX sio: <http://semanticscience.org/resource/>
  SELECT ?obs ?value ?time FROM <{base}/graph/observations>
  WHERE { ?obs a sosa:Observation ; sosa:resultTime ?time ;
               sio:has-attribute ?mv . ?mv sio:has-value ?value . }

If Pattern A returns empty, try Pattern B.""" ;

    # Result: either sosa:hasSimpleResult (scalar) or sio:has-attribute → MeasuredValue chain
    sh:property [
        sh:path sosa:hasSimpleResult ;
        sh:maxCount 1 ;
        sh:description "Simple scalar result. Present when measurement is encoded directly on the observation." ;
    ] ;

    sh:property [
        sh:path sio:has-attribute ;
        sh:maxCount 1 ;
        sh:class sio:MeasuredValue ;
        sh:severity sh:Info ;
        sh:description "SIO measurement chain. Links to a sio:MeasuredValue node carrying sio:has-value and optionally sio:has-unit." ;
    ] ;

    sh:property [
        sh:path sosa:resultTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:description "ISO-8601 timestamp when the result was produced." ;
    ] ;

    sh:property [
        sh:path sosa:observedProperty ;
        sh:maxCount 1 ;
        sh:description "The property that was observed (optional but recommended)." ;
    ] ;

    sh:property [
        sh:path sosa:madeBySensor ;
        # sh:class sosa:Sensor is informational (sh:Info severity) — entity type assertions
        # live in /graph/entities, not /graph/observations, so hard validation would false-positive.
        sh:class sosa:Sensor ;
        sh:severity sh:Info ;
        sh:nodeKind sh:IRI ;
        sh:pattern "^{base}/entity/" ;
        sh:description "The sensor that made this observation. Sensor IRIs use the node entity namespace ({base}/entity/)." ;
    ] .
