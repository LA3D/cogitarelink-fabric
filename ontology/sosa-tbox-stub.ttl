# SOSA TBox stub — Phase 1 local cache (D9 L2)
# Minimal class/property declarations for RLM routing without external dereferencing
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology declaration ---

sosa: a owl:Ontology ;
    rdfs:label "SOSA TBox Stub" ;
    rdfs:comment "Minimal SOSA class/property declarations for RLM routing (D9 L2)." .

# --- Classes ---

sosa:Observation a owl:Class ;
    rdfs:label "Observation" ;
    rdfs:comment "Act of carrying out an Observation to estimate a value of an ObservableProperty." .

sosa:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "Device, agent, or software that can observe an ObservableProperty." .

sosa:ObservableProperty a owl:Class ;
    rdfs:label "Observable Property" ;
    rdfs:comment "An observable quality of a FeatureOfInterest." .

sosa:FeatureOfInterest a owl:Class ;
    rdfs:label "Feature Of Interest" ;
    rdfs:comment "The thing whose property is being observed." .

sosa:Result a owl:Class ;
    rdfs:label "Result" ;
    rdfs:comment "The result of an Observation." .

# --- Datatype properties ---

sosa:hasSimpleResult a owl:DatatypeProperty ;
    rdfs:label "has simple result" ;
    rdfs:comment "The simple value of an Observation." ;
    rdfs:domain sosa:Observation .

sosa:resultTime a owl:DatatypeProperty ;
    rdfs:label "result time" ;
    rdfs:comment "The instant of time when the Observation activity was completed." ;
    rdfs:domain sosa:Observation ;
    rdfs:range xsd:dateTime .

# --- Object properties ---

sosa:madeBySensor a owl:ObjectProperty ;
    rdfs:label "made by sensor" ;
    rdfs:domain sosa:Observation ;
    rdfs:range sosa:Sensor .

sosa:observedProperty a owl:ObjectProperty ;
    rdfs:label "observed property" ;
    rdfs:domain sosa:Observation ;
    rdfs:range sosa:ObservableProperty .

sosa:hasFeatureOfInterest a owl:ObjectProperty ;
    rdfs:label "has feature of interest" ;
    rdfs:domain sosa:Observation ;
    rdfs:range sosa:FeatureOfInterest .

sosa:hasResult a owl:ObjectProperty ;
    rdfs:label "has result" ;
    rdfs:domain sosa:Observation ;
    rdfs:range sosa:Result .
