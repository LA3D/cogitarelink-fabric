sio:SIO_011123 a owl:Class ;
    rdfs:label "chemical data"@en ;
    dcterms:description "A chemical datum is a scientific data item which conforms to some specification, either for how it is calculated or for how it is measured, and is commonly used in the domain of chemistry to name and differentiate different numeric properties (both calculated and measured) which are about chemical entities."@en ;
    rdfs:subClassOf sio:SIO_000472 ;
    skos:exactMatch "CHEMINF:000123" .

sio:SIO_011130 a owl:Class ;
    rdfs:label "PDB file"@en ;
    dcterms:description "A PDB file is a molecular structure file specified by the Protein DataBank (PDB)."@en ;
    rdfs:subClassOf sio:SIO_011120 .

sio:SIO_011131 a owl:Class ;
    rdfs:label "collection of 3d molecular structure models"@en ;
    dcterms:description "A collection of 3D molecular structure models is just that."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000059 ;
            owl:someValuesFrom sio:SIO_010530 ],
        sio:SIO_000616 .

sio:broaderThan a owl:AnnotationProperty .

sio:equivalentTo a owl:AnnotationProperty .

sio:example a owl:AnnotationProperty .

sio:hasSynonym a owl:AnnotationProperty .

sio:similarTo a owl:AnnotationProperty .

sio:subset a owl:AnnotationProperty .

skos:exactMatch a owl:AnnotationProperty .

skos:example a owl:AnnotationProperty .

foaf:homepage a owl:AnnotationProperty .

sio:SIO_000010 a owl:Class ;
    rdfs:label "social structure"@en ;
    dcterms:description "A social structure is a social entity which consists of relationships between two or more entities."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000776 ;
            owl:onProperty sio:SIO_000059 ],
        sio:SIO_000009 .

sio:SIO_000020 a owl:ObjectProperty ;
    rdfs:label "denotes"@en ;
    dcterms:description "denotes is a relation between an entity and what it is a sign or indication of, or what specifically means."@en ;
    rdfs:subPropertyOf sio:SIO_000210 ;
    owl:inverseOf sio:SIO_000060 ;
    skos:example "the symbol '%' denotes a proportion in relation to a whole."@en .

sio:SIO_000027 a owl:Class ;
    rdfs:label "process quality"@en ;
    dcterms:description "A process quality is quality that is associated with a process."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000218 ;
            owl:someValuesFrom sio:SIO_000006 ],
        sio:SIO_000005 .

sio:SIO_000034 a owl:Class ;
    rdfs:label "completed"@en ;
    dcterms:description "completed is that status of a process that successfully unfolds."@en ;
    rdfs:subClassOf sio:SIO_000033 .

sio:SIO_000035 a owl:Class ;
    rdfs:label "ongoing"@en ;
    dcterms:description "ongoing is the status of a process that is not yet complete."@en ;
    rdfs:subClassOf sio:SIO_000033 .

sio:SIO_000036 a owl:Class ;
    rdfs:label "predicted"@en ;
    dcterms:description "predicted is the quality of an entity that is thought to exist, as evidenced by some rational procedure."@en ;
    rdfs:subClassOf sio:SIO_001186 .

sio:SIO_000039 a owl:Class ;
    rdfs:label "depth"@en ;
    dcterms:description "depth is the dimensional extent into a plane of a 3D projection of the object."@en ;
    rdfs:subClassOf sio:SIO_000038 .

sio:SIO_000045 a owl:Class ;
    rdfs:label "area"@en ;
    dcterms:description "area is a quantity that pertains to the extent of a two-dimensional surface or shape, or planar lamina, in the plane."@en ;
    rdfs:subClassOf sio:SIO_000044 .

sio:SIO_000046 a owl:Class ;
    rdfs:label "length of perimeter"@en ;
    dcterms:description "A perimeter is a length of the outline that surrounds a two-dimensional shape. "@en ;
    rdfs:subClassOf sio:SIO_000044 .

sio:SIO_000054 a owl:ObjectProperty ;
    rdfs:label "has boundary"@en ;
    dcterms:description "has boundary is a mereological relation between a whole and boundary located at its periphery."@en ;
    rdfs:subPropertyOf sio:SIO_000053 ;
    owl:inverseOf sio:SIO_000096 ;
    skos:example "the surface of an apple is a 2D boundary of the apple."@en .

sio:SIO_000055 a owl:Class ;
    rdfs:label "shape"@en ;
    dcterms:description "shape is the quality of a bearer that relates to its spatial extent."@en ;
    rdfs:subClassOf sio:SIO_000026 .

sio:SIO_000060 a owl:ObjectProperty ;
    rdfs:label "is denoted by"@en ;
    rdfs:subPropertyOf sio:SIO_000205 .

sio:SIO_000063 a owl:ObjectProperty ;
    rdfs:label "is agent in"@en ;
    dcterms:description "is agent in is a relation between an entity and a process, where the entity is present throughout the process, no permanent material change occurs, and is a causal participant in the process."@en ;
    sio:subset "sadi"@en ;
    rdfs:subPropertyOf sio:SIO_000062 ;
    owl:inverseOf sio:SIO_000139 ;
    skos:example "hexokinase is an agent in the conversion of glucose to glucose-6-phosphate"@en .

sio:SIO_000066 a owl:ObjectProperty ;
    rdfs:label "has provider"@en ;
    dcterms:description "is provided by is a relation between an entity and the entity that provides it."@en ;
    sio:equivalentTo "dc:source" ;
    rdfs:subPropertyOf sio:SIO_000253 .

sio:SIO_000073 a owl:Class ;
    rdfs:label "polar coordinate"@en ;
    dcterms:description "A polar coordinate is a position characterized by a distance from a fixed point and an angle from a fixed direction."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000327 ],
        sio:SIO_000071 .

sio:SIO_000076 a owl:Class ;
    rdfs:label "plan"@en ;
    dcterms:description "A plan is a set of intended actions, through which one expects to achieve a goal."@en ;
    rdfs:subClassOf sio:SIO_000091 .

sio:SIO_000081 a owl:Class ;
    rdfs:label "image"@en ;
    dcterms:alternative "depiction"@en ;
    dcterms:description "An image is an affine projection of a visual entity to a two dimensional surface."@en ;
    rdfs:subClassOf sio:SIO_000080 .

sio:SIO_000082 a owl:Class ;
    rdfs:label "photograph"@en ;
    dcterms:alternative "photo"@en ;
    dcterms:description "A photograph is an image created by light falling on a light-sensitive surface."@en ;
    rdfs:subClassOf sio:SIO_000081 .

sio:SIO_000094 a owl:Class ;
    rdfs:label "algorithm"@en ;
    dcterms:description "An algorithm is an effective method expressed as a finite list of well-defined instructions for calculating a function."@en ;
    rdfs:subClassOf sio:SIO_000075 .

sio:SIO_000108 a owl:Class ;
    rdfs:label "character"@en ;
    dcterms:description "A character is a language symbol used to construct words."@en ;
    rdfs:subClassOf sio:SIO_000078 .

sio:SIO_000120 a owl:Class ;
    rdfs:label "scientific name"@en ;
    dcterms:description "A scientific name is a name given through scientific nomenclature."@en ;
    rdfs:subClassOf sio:SIO_000116 .

sio:SIO_000128 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is contained in"@en ;
    dcterms:description "A is contained in B iff the spatial region occupied by A is part of the spatial region occupied by B and A is not part of B. [T]"@en ;
    sio:equivalentTo "OBO_REL:contained_in" ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000061 ;
    owl:inverseOf sio:SIO_000202 .

sio:SIO_000133 a owl:Class ;
    rdfs:label "descriptor"@en ;
    dcterms:description "A descriptor (index term, subject term, subject heading) is a term that captures the essence of the topic of a document."@en ;
    rdfs:subClassOf sio:SIO_000275 .

sio:SIO_000143 a owl:Class ;
    rdfs:label "exclusion criterion"@en ;
    dcterms:description "An exclusion criterion is a criterion that must be absent to satistify the objective."@en ;
    rdfs:subClassOf sio:SIO_000141 .

sio:SIO_000154 a owl:Class ;
    rdfs:label "article"@en ;
    dcterms:description "An article is a publication that is stand-alone section of a larger work."@en ;
    rdfs:subClassOf sio:SIO_000087 .

sio:SIO_000159 a owl:Class ;
    rdfs:label "edited publication"@en ;
    dcterms:description "An edited publication is a publication that has been examined and potentially changed by an editor."@en ;
    rdfs:subClassOf sio:SIO_000087 .

sio:SIO_000166 a owl:Class ;
    rdfs:label "honor's thesis"@en ;
    dcterms:description "An honor's thesis is a thesis prepared as a requirement for an honor's undergraduate degree."@en ;
    rdfs:subClassOf sio:SIO_000165 .

sio:SIO_000167 a owl:Class ;
    rdfs:label "master's thesis"@en ;
    dcterms:description "A Master's thesis is a thesis prepared as a requirement for a Master's degree."@en ;
    rdfs:subClassOf sio:SIO_000165 .

sio:SIO_000168 a owl:Class ;
    rdfs:label "phd thesis"@en ;
    dcterms:description "A PhD thesis is a thesis prepared as a requirement for a doctoral degree."@en ;
    rdfs:subClassOf sio:SIO_000165 .

sio:SIO_000183 a owl:Class ;
    rdfs:label "personal name"@en ;
    dcterms:alternative "full name" ;
    dcterms:description "A personal name is a name to identify an individual person and usually comprises of a first name and a last name."@en ;
    rdfs:subClassOf sio:SIO_000116 .

sio:SIO_000208 a owl:ObjectProperty ;
    rdfs:label "is supporting evidence for"@en ;
    rdfs:subPropertyOf sio:SIO_000773 .

sio:SIO_000209 a owl:ObjectProperty ;
    rdfs:label "is disputing evidence for"@en ;
    rdfs:subPropertyOf sio:SIO_000773 .

sio:SIO_000211 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is positionally after"@en ;
    dcterms:description "is positionally after is a relation between entities placed on a dimensional axis in which the projection of the position of the first entity is numerically greater than the projection of the position of the second entity."@en ;
    rdfs:subPropertyOf sio:SIO_000203 ;
    owl:inverseOf sio:SIO_000240 .

sio:SIO_000213 a owl:ObjectProperty ;
    rdfs:label "has concretization"@en ;
    dcterms:description "A has concretization B iff A is an informational entity and B is the a quality of some material entity."@en ;
    rdfs:subPropertyOf sio:SIO_000425 ;
    owl:inverseOf sio:SIO_000214 .

sio:SIO_000222 a owl:ObjectProperty ;
    rdfs:label "is unit of"@en ;
    dcterms:description "is unit of is a relation between a unit and a quantity that it is a multiple of."@en ;
    rdfs:domain sio:SIO_000074 ;
    rdfs:subPropertyOf sio:SIO_000011 .

sio:SIO_000226 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is function of"@en ;
    dcterms:description "is function of is a relation between a function and an entity that it is a property of."@en ;
    rdfs:domain sio:SIO_000017 ;
    rdfs:subPropertyOf sio:SIO_000236 .

sio:SIO_000234 a owl:ObjectProperty ;
    rdfs:label "has implementation"@en ;
    dcterms:description "has implementation is a relation between a specification and an implementation that conforms to it."@en ;
    rdfs:subPropertyOf sio:SIO_000008 .

sio:SIO_000235 a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has disposition"@en ;
    dcterms:description "has disposition is the relation between an entity and a disposition that it bears."@en ;
    rdfs:range sio:SIO_000014 ;
    rdfs:subPropertyOf sio:SIO_000586 ;
    owl:inverseOf sio:SIO_000236 .

sio:SIO_000242 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is directly before"@en ;
    dcterms:description "is directly before is a relation between entities placed on a dimensional axis in which the projection of the position of the first entity is numerically less than the projection of the position of the second entity, and the entities are adjacent to one another."@en ;
    rdfs:subPropertyOf sio:SIO_000240,
        sio:SIO_000652 .

sio:SIO_000247 a owl:ObjectProperty ;
    rdfs:label "is immediately derived from"@en ;
    dcterms:description "A non-transitive temporal relation in which one entity is immediately derived from a non-identical entity such that there are no intermediate entities between them."@en ;
    rdfs:subPropertyOf sio:SIO_000244 .

sio:SIO_000248 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "precedes"@en ;
    dcterms:description "A transitive, temporal relation in which one process precedes (has occured earlier than) another process."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000352 ;
    owl:inverseOf sio:SIO_000249 .

sio:SIO_000251 a owl:ObjectProperty ;
    rdfs:label "is immediately preceded by"@en ;
    dcterms:description "A non-transitive temporal relation in which one process is immediately preceded by another process, such that there is no interval of time between the two processes."@en ;
    rdfs:subPropertyOf sio:SIO_000249 .

sio:SIO_000255 a owl:ObjectProperty ;
    rdfs:label "has annotation"@en ;
    dcterms:alternative "is annotated with"@en,
        "was annotated with"@en ;
    dcterms:description "has annotation is a relation between an entity and some textual anntotation."@en ;
    rdfs:range sio:SIO_000078 ;
    rdfs:subPropertyOf sio:SIO_000008 ;
    skos:example "document x is annotated with the keywords 'ontology','semantic web'"@en .

sio:SIO_000266 a owl:Class ;
    rdfs:label "valid argument"@en ;
    dcterms:description "A valid argument is an argument where the truth of the conclusion is a logical consequence of the premises and (consequently) its corresponding conditional is a necessary truth."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000053 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000262 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000217 ;
                                owl:someValuesFrom sio:SIO_000270 ] ) ] ],
        sio:SIO_000259 .

sio:SIO_000278 a owl:ObjectProperty ;
    rdfs:label "is cited by"@en ;
    dcterms:description "is cited by is a relation from an object that is referred to by way of example, authority or proof."@en ;
    rdfs:subPropertyOf sio:SIO_000252 .

sio:SIO_000279 a owl:Class ;
    rdfs:label "mass"@en ;
    dcterms:description "mass is the quality of the amount of substance."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_000004 ],
        sio:SIO_000037 .

sio:SIO_000280 a owl:Class ;
    rdfs:label "disjunction (or)"@en ;
    dcterms:description "OR is a logical operator that results in true whenever one or more of its operands are true." ;
    rdfs:subClassOf sio:SIO_000238 .

sio:SIO_000286 a owl:ObjectProperty ;
    rdfs:label "is subsequent version of"@en ;
    dcterms:description "A is subsequent version of B iff A is a variant of B and A derives from B."@en ;
    rdfs:subPropertyOf sio:SIO_000497 .

sio:SIO_000287 a owl:Class ;
    rdfs:label "social relation"@en ;
    dcterms:description "A social relation is a social entity that describes a relationship  between two or more individuals or groups."@en ;
    rdfs:subClassOf sio:SIO_000009 .

sio:SIO_000288 a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "is covalently connected to (transitive)"@en ;
    rdfs:domain sio:SIO_010044 ;
    rdfs:range sio:SIO_010044 ;
    rdfs:subPropertyOf sio:SIO_000203 .

sio:SIO_000293 a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "is weakly interacting with (transitive)"@en ;
    dcterms:description "is weakly interacting with is a symmetric relation between two molecular entities (or any part thereof) that are interacting through some weak force (van der waals, hydrogen bonds, electrostatic interactions)"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( sio:SIO_011125 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000068 ;
                        owl:someValuesFrom sio:SIO_011125 ] ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( sio:SIO_011125 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000068 ;
                        owl:someValuesFrom sio:SIO_011125 ] ) ] ;
    rdfs:subPropertyOf sio:SIO_000203 .

sio:SIO_000298 a owl:Class ;
    rdfs:label "excerpt"@en ;
    dcterms:description "An excerpt is a contiguous or discontiguous portion of a document."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_000651 ],
        sio:SIO_000651 .

sio:SIO_000302 a owl:Class ;
    rdfs:label "web page"@en ;
    dcterms:description "A web page is a document that is published according to World Wide Web standards."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_000311 a owl:ObjectProperty ;
    rdfs:label "is product of"@en ;
    dcterms:description "is product of is a relation between an entity and a process, where the entity is present at the end  of the process as a result of a transformation in the process target."@en ;
    sio:subset "sadi"@en ;
    rdfs:subPropertyOf sio:SIO_000232 ;
    owl:inverseOf sio:SIO_000312 ;
    skos:example "glucose-6-phosphate is the product of the hexokinase-mediated conversion of glucose to glucose-6-phosphate."@en .

sio:SIO_000316 a owl:Class ;
    rdfs:label "design specification"@en ;
    dcterms:description "A design specification is a specification that provides precise and explicit information about the requirements for a product design."@en ;
    rdfs:subClassOf sio:SIO_000315 .

sio:SIO_000317 a owl:Class ;
    rdfs:label "spatial specification"@en ;
    dcterms:description "A specification for spatial location is an effective specification towards representation spatial position or spatial data."@en ;
    rdfs:subClassOf sio:SIO_000315 .

sio:SIO_000319 a owl:Class ;
    rdfs:label "latitude"@en ;
    dcterms:description "Latitude is a geographic coordinate which refers to the angle from a point on the Earth's surface to the equatorial plane"@en ;
    rdfs:subClassOf sio:SIO_000013 .

sio:SIO_000324 a owl:ObjectProperty ;
    rdfs:label "surrounds"@en ;
    dcterms:description "A 'surrounds' B iff the A 'contains' B and A 'is adjacent to' B or A 'is directly connected to' B."@en ;
    rdfs:subPropertyOf sio:SIO_000202 .

sio:SIO_000325 a owl:ObjectProperty,
        owl:ReflexiveProperty,
        owl:SymmetricProperty ;
    rdfs:label "overlaps with"@en ;
    dcterms:description "A overlaps with B iff there is some C that is part of both A and B. [S][R]"@en ;
    rdfs:subPropertyOf sio:SIO_000322 ;
    owl:propertyChainAxiom ( sio:SIO_000325 sio:SIO_000068 ) .

sio:SIO_000326 a owl:Class ;
    rdfs:label "concept"@en ;
    dcterms:description "A concept is term that refers to a generalization of a set of attributes or entities."@en ;
    rdfs:subClassOf sio:SIO_000275 .

sio:SIO_000327 a owl:Class ;
    rdfs:label "polar coordinate system"@en ;
    dcterms:description "A polar coordinate system is a two-dimensional coordinate system in which each point on a plane is determined by a distance from a fixed point and an angle from a fixed direction."@en ;
    rdfs:subClassOf sio:SIO_000320 .

sio:SIO_000333 a owl:Class ;
    rdfs:label "3D cartesian coordinate"@en ;
    dcterms:description "A 3D cartesian coordinate is a coordinate that is composed of an x, y and z coordinate."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onClass sio:SIO_000400 ;
                        owl:onProperty sio:SIO_000273 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] [ a owl:Restriction ;
                        owl:onClass sio:SIO_000401 ;
                        owl:onProperty sio:SIO_000273 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] [ a owl:Restriction ;
                        owl:onClass sio:SIO_000402 ;
                        owl:onProperty sio:SIO_000273 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] ) ],
        sio:SIO_000072 .

sio:SIO_000344 a owl:Class ;
    rdfs:label "to record"@en ;
    dcterms:description "to record is the capability to detect and transcribe information in a specified format on some physical medium."@en ;
    rdfs:seeAlso "http://purl.obolibrary.org/obo/OBI_0000368"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_000346 a owl:Class ;
    rdfs:label "to heat"@en ;
    dcterms:description "to heat is a capability to increase the internal kinetic energy of a material."@en ;
    rdfs:subClassOf sio:SIO_000351 .

sio:SIO_000347 a owl:Class ;
    rdfs:label "to cool"@en ;
    dcterms:description "to cool is the capability to decrease the internal kinetic energy of a material."@en ;
    rdfs:seeAlso "http://purl.obolibrary.org/obo/OBI_0000387"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_000374 .

sio:SIO_000354 a owl:Class ;
    rdfs:label "dysfunction"@en ;
    dcterms:description "dysfunction is a capability to act in a manner that is abnormal or opposite  to the object's typical function."@en ;
    rdfs:subClassOf sio:SIO_000112 .

sio:SIO_000360 a owl:Class ;
    rdfs:label "belief"@en ;
    dcterms:description "A belief is a proposition that is believed to be true."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000269 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000218 ;
                                owl:someValuesFrom sio:SIO_000256 ] ) ] ],
        sio:SIO_000256 .

sio:SIO_000363 a owl:ObjectProperty ;
    rdfs:label "is satisfied by"@en ;
    rdfs:subPropertyOf sio:SIO_000011 .

sio:SIO_000365 a owl:ObjectProperty ;
    rdfs:label "is creator of"@en ;
    dcterms:alternative "is created by"@en ;
    dcterms:description "is creator of is a relation between a creator and an entity.."@en ;
    rdfs:subPropertyOf sio:SIO_000219 .

sio:SIO_000372 a owl:Class ;
    rdfs:label "to inject"@en ;
    dcterms:description "to inject is the capability to administer a substance into some object through its external barrier."@en ;
    rdfs:subClassOf sio:SIO_000343 .

sio:SIO_000380 a owl:Class ;
    rdfs:label "to contain"@en ;
    dcterms:description "to contain is the capability to bound or constrain a physical entity in some site."@en ;
    rdfs:subClassOf sio:SIO_000392 .

sio:SIO_000390 a owl:Class ;
    rdfs:label "to transport"@en ;
    dcterms:description "to transport is the capability to displace a material from one location to another."@en ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_000392 a owl:Class ;
    rdfs:label "to change spatially"@en ;
    dcterms:description "to change spatially is the capability to affect the physical movement of some entity."@en ;
    rdfs:subClassOf sio:SIO_000343 .

sio:SIO_000404 a owl:Class ;
    rdfs:label "professor"@en ;
    dcterms:description "A professor is an individual that is a scholarly teacher."@en ;
    rdfs:subClassOf sio:SIO_000406 .

sio:SIO_000405 a owl:Class ;
    rdfs:label "student"@en ;
    dcterms:description "A student is an individual who is attends an educational institution."@en ;
    rdfs:subClassOf sio:SIO_000406 .

sio:SIO_000409 a owl:Class ;
    rdfs:label "mutual disposition"@en ;
    dcterms:description "A mutual disposition is a disposition that simulataneously invokes another disposition when realized."@en ;
    rdfs:subClassOf sio:SIO_000014 .

sio:SIO_000410 a owl:Class ;
    rdfs:label "anger"@en ;
    dcterms:description "anger is disgust directed toward an equal status individual."@en ;
    rdfs:subClassOf sio:SIO_000828 .

sio:SIO_000413 a owl:Class ;
    rdfs:label "geolegal region"@en ;
    dcterms:description "A geolegal region is a geographic region which has causal powers confered by a legal entity."@en ;
    rdfs:subClassOf sio:SIO_000414 ;
    skos:example "The 50 kph zones in Ottawa; the geographic region occupied by France."@en .

sio:SIO_000420 a owl:ObjectProperty ;
    rdfs:label "has expression"@en ;
    rdfs:subPropertyOf sio:SIO_000425 ;
    owl:inverseOf sio:SIO_000421 ;
    skos:example "the story 'war of worlds' is expressed as every language edition of the book 'war of the worlds'"@en .

sio:SIO_000421 a owl:ObjectProperty ;
    rdfs:label "is expression of"@en ;
    dcterms:description "is expression of is a relation between more concrete expression of some conceptualization."@en ;
    rdfs:subPropertyOf sio:SIO_000425 ;
    skos:example "every language edition of 'war of the worlds' are expressions of the story of 'war of the worlds'"@en .

sio:SIO_000422 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is broader than (t)"@en ;
    dcterms:description "A is broader than B (t) iff for A is broader than B."@en ;
    sio:equivalentTo "http://www.w3.org/2004/02/skos/core#narrowerTransitive" ;
    rdfs:domain sio:SIO_000275 ;
    rdfs:range sio:SIO_000275 ;
    rdfs:subPropertyOf sio:SIO_000283 ;
    owl:inverseOf sio:SIO_000424 .

sio:SIO_000427 a owl:ObjectProperty ;
    rdfs:label "is narrower than"@en ;
    dcterms:description "A is narrower than B iff the meaning of term A is narrower in scope than the meaning of term B"@en ;
    sio:equivalentTo "http://www.w3.org/2004/02/skos/core#broader" ;
    rdfs:subPropertyOf sio:SIO_000424 ;
    owl:inverseOf sio:SIO_000477 .

sio:SIO_000428 a owl:Class ;
    rdfs:label "year"@en ;
    dcterms:description "A year is a period of time taken by a planet to make one revolution around the sun."@en ;
    rdfs:subClassOf sio:SIO_000417 .

sio:SIO_000429 a owl:Class ;
    rdfs:label "month"@en ;
    dcterms:description "A month is a period of time that divides the year."@en ;
    rdfs:subClassOf sio:SIO_000417 .

sio:SIO_000430 a owl:Class ;
    rdfs:label "day"@en ;
    dcterms:description "A day is a period of 24 hours."@en ;
    rdfs:subClassOf sio:SIO_000417 .

sio:SIO_000431 a owl:Class ;
    rdfs:label "century"@en ;
    dcterms:description "A century is a period of one hundred years."@en ;
    rdfs:subClassOf sio:SIO_000417 .

sio:SIO_000432 a owl:Class ;
    rdfs:label "millennium"@en ;
    dcterms:description "A millenium is a period of 1000 years"@en ;
    rdfs:subClassOf sio:SIO_000417 .

sio:SIO_000433 a owl:Class ;
    rdfs:label "hour"@en ;
    dcterms:description "An hour is a period of 60 minutes."@en ;
    rdfs:subClassOf sio:SIO_000417 .

sio:SIO_000434 a owl:Class ;
    rdfs:label "minute"@en ;
    dcterms:description "A minute is a period of 60 seconds."@en ;
    rdfs:subClassOf sio:SIO_000417 .

sio:SIO_000435 a owl:Class ;
    rdfs:label "second"@en ;
    dcterms:description "A second (symbol: s) is the base unit of time in the International System of Units (SI) and is the second division of the hour by sixty, the first division by 60 being the minute."@en ;
    rdfs:subClassOf sio:SIO_000417 .

sio:SIO_000447 a owl:Class ;
    rdfs:label "line-bar graph"@en ;
    dcterms:description "A line-bar graph statistical graph that contains both lines and bars."@en ;
    rdfs:subClassOf sio:SIO_000083 ;
    skos:example "Graph 8 in http://tinyurl.com/opwnvm"@en .

sio:SIO_000453 a owl:Class ;
    rdfs:label "y-axis"@en ;
    dcterms:alternative "vertical axis" ;
    dcterms:description "A y-axis is a Cartesian coordinate axis that is spatially oriented perpendicular to the x-axis."@en ;
    rdfs:subClassOf sio:SIO_000451 .

sio:SIO_000454 a owl:Class ;
    rdfs:label "z-axis"@en ;
    dcterms:description "A z-axis is a Cartesian coordinate axis that is spatially oriented normal to the plane formed by the x- and y-axes."@en ;
    rdfs:subClassOf sio:SIO_000451 .

sio:SIO_000456 a owl:Class ;
    rdfs:label "primary category axis"@en ;
    dcterms:description "A primary category axis is a category axis that either defines the sole value range or holds the larger set of categorical values specified by the secondary category axis."@en ;
    rdfs:subClassOf sio:SIO_000455 ;
    owl:disjointWith sio:SIO_000457 ;
    skos:example """The category axis that corresponds to years in Graph 1 of 
http://tinyurl.com/opwnvm"""@en .

sio:SIO_000463 a owl:Class ;
    rdfs:label "logarithmic value axis"@en ;
    dcterms:description "A logarithmic value axis is a scaled value axis that corresponds to a scaling factor of the logarithm of the value range."@en ;
    rdfs:subClassOf sio:SIO_000461 .

sio:SIO_000465 a owl:Class ;
    rdfs:label "data point"@en ;
    dcterms:description "A data point is a point that which corresponds to the projection of the values of measurement data against the axes of a statistical graph."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000020 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000507 .

sio:SIO_000468 a owl:Class ;
    rdfs:label "legend"@en ;
    dcterms:description "A legend is a part of a figure that associates textual descriptions with symbols pertaining to plotted entities."@en ;
    rdfs:subClassOf sio:SIO_000448 ;
    skos:example """The colored line segments and the adjacent textual descriptions in 
Graph 1 of http://tinyurl.com/opwnvm"""@en .

sio:SIO_000479 a owl:Class ;
    rdfs:label "variant role"@en ;
    dcterms:description "A variant role is a comparative role in which the value of an attribute differs when compared to another entity"@en ;
    rdfs:subClassOf sio:SIO_000721 .

sio:SIO_000492 a owl:Class ;
    rdfs:label "to consume"@en ;
    dcterms:description "to consume is the capability to internalize a material entity."@en ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_000496 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is opposite to"@en ;
    dcterms:description "is opposite to is a relation between two entities in which one is diametrically opposed to the other. "@en ;
    rdfs:subPropertyOf sio:SIO_000495 ;
    skos:example "hot is the opposite of cold; left is opposite of right"@en .

sio:SIO_000499 a owl:Class ;
    rdfs:label "to decrease the rate of formation"@en ;
    dcterms:description "to decrease the rate of formation is to regulate the rate of formation in a manner that decreases this rate relative to a reference process."@en ;
    rdfs:subClassOf sio:SIO_000536 .

sio:SIO_000500 a owl:Class ;
    rdfs:label "polygon vertex"@en ;
    dcterms:description "A polygon vertex is a terminal point at which two polygon edges meet and are part of a polygon."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_000501 ;
            owl:onProperty sio:SIO_000313 ],
        [ a owl:Restriction ;
            owl:onClass sio:SIO_000541 ;
            owl:onProperty sio:SIO_000369 ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        sio:SIO_001335 .

sio:SIO_000503 a owl:Class ;
    rdfs:label "polygonal face"@en ;
    dcterms:description "A polygonal face is a polygon bounded by a circuit of polygon edges, and includes the flat (plane) region inside the boundary."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_000505 ],
        sio:SIO_000506 .

sio:SIO_000508 a owl:Class ;
    rdfs:label "endpoint"@en ;
    dcterms:description """An endpoint is a terminal point that is the last of an ordered 
pair of points."""@en ;
    rdfs:subClassOf sio:SIO_000532 .

sio:SIO_000509 a owl:Class ;
    rdfs:label "start point"@en ;
    dcterms:description """A start point is a terminal point which is the first of an ordered 
pair of points."""@en ;
    rdfs:subClassOf sio:SIO_000532 .

sio:SIO_000517 a owl:Class ;
    rdfs:label "quadrilateral"@en ;
    dcterms:description "A quadrilateral is a polygon with composed of four points and four line segments, in which each point is fully connected to two other points."@en ;
    rdfs:subClassOf sio:SIO_000505 .

sio:SIO_000518 a owl:Class ;
    rdfs:label "rectangle"@en ;
    dcterms:description "A rectangle is a quadrilateral in which one pair of line segments are  parallel and the other pair are perpendicular to the first pair."@en ;
    rdfs:subClassOf sio:SIO_000517 .

sio:SIO_000524 a owl:Class ;
    rdfs:label "double arrowed line segment"@en ;
    dcterms:description "A double arrowed line is an arrowed line in which both terminal points are  tangentially part of different triangles that bisect the line."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_000520 ;
            owl:onProperty sio:SIO_000369 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_000522 .

sio:SIO_000538 a owl:Class ;
    rdfs:label "straight"@en ;
    dcterms:description "straight is a quality of a bearer that is free of curves, bends, or angles."@en ;
    rdfs:seeAlso "PATO:0002180 [for material entities]" ;
    rdfs:subClassOf sio:SIO_000537 .

sio:SIO_000541 a owl:Class ;
    rdfs:label "vertex normal"@en ;
    dcterms:description "A vertext normal is the normalized average of the surface normals of the faces that contain that vertex."@en ;
    rdfs:subClassOf sio:SIO_000540 .

sio:SIO_000549 a owl:Class ;
    rdfs:label "to reduce the activation energy"@en ;
    dcterms:alternative "to activate" ;
    dcterms:description "to reduce the activation energy is to require a smaller amount of energy in order to form or break a chemical bond."@en ;
    rdfs:subClassOf sio:SIO_000551 ;
    owl:disjointWith sio:SIO_000550 .

sio:SIO_000552 a owl:ObjectProperty ;
    rdfs:label "has parameter"@en ;
    dcterms:description "has parameter is a relation between a process and an information content entity which modulates the behaviour of some participant."@en ;
    sio:subset "sadi"@en ;
    rdfs:subPropertyOf sio:SIO_000230 ;
    owl:inverseOf sio:SIO_000553 .

sio:SIO_000553 a owl:ObjectProperty ;
    rdfs:label "is parameter in"@en ;
    dcterms:description "is parameter in is a relation between a data item and some data transformation process."@en ;
    rdfs:subPropertyOf sio:SIO_000231 .

sio:SIO_000554 a owl:Class ;
    rdfs:label "normal"@en ;
    dcterms:description "A quality that has a value that is normal or average."@en ;
    sio:equivalentTo "PATO:0000461" ;
    rdfs:subClassOf sio:SIO_000307 ;
    owl:disjointWith sio:SIO_000555 .

sio:SIO_000558 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is orthologous to"@en ;
    dcterms:description "is orthologous to is a relation between two biological entities that share a common ancestor and occur in different species."@en ;
    rdfs:subPropertyOf sio:SIO_010302 .

sio:SIO_000566 a owl:Class ;
    rdfs:label "movement equation"@en ;
    dcterms:description "A movement equation describes the displacement of an object in space over time."@en ;
    rdfs:subClassOf sio:SIO_000368 .

sio:SIO_000573 a owl:Class ;
    rdfs:label "passive movement"@en ;
    dcterms:description "passive movement is the process in which an object is spatially displaced without an expenditure of energy contained in molecular bonds." ;
    rdfs:subClassOf sio:SIO_000570 .

sio:SIO_000574 a owl:Class ;
    rdfs:label "active movement"@en ;
    dcterms:description "active movement is the process in which an object is spatially displaced using some chemical energy."@en ;
    rdfs:subClassOf sio:SIO_000570 .

sio:SIO_000575 a owl:Class ;
    rdfs:label "transporting"@en ;
    dcterms:description "transporting is a  process in which one object physically moves another object from one location to another."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000355 ;
                        owl:someValuesFrom sio:SIO_000390 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000355 ;
                        owl:someValuesFrom sio:SIO_010368 ] ) ],
        sio:SIO_000593 .

sio:SIO_000580 a owl:Class ;
    rdfs:label "antiport enabled secondary active transport"@en ;
    dcterms:description "antiport enabled secondary active transport is a secondary active transfort in which both ion and molecule are transported in opposite directions simultaneously."@en ;
    rdfs:subClassOf sio:SIO_000578 .

sio:SIO_000594 a owl:Class ;
    rdfs:label "data transformation"@en ;
    dcterms:description "data transformation is the process of applying an algorithmic procedure to some input data and producing some output data."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000230 ;
            owl:someValuesFrom sio:SIO_000069 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000229 ;
            owl:someValuesFrom sio:SIO_000069 ],
        sio:SIO_000649 .

sio:SIO_000596 a owl:Class ;
    rdfs:label "data storage device"@en ;
    dcterms:description "A data storage device is a device that is capable of storing information."@en ;
    rdfs:subClassOf sio:SIO_000956 .

sio:SIO_000598 a owl:Class ;
    rdfs:label "hard disk drive"@en ;
    dcterms:description "A hard disk drive (HDD) is a non-volatile, random access device for digital data. It features rotating rigid platters on a motor-driven spindle within a protective enclosure. Data is magnetically read and written on the platter by read/write heads that float on a film of air above the platters."@en ;
    rdfs:subClassOf sio:SIO_000596 .

sio:SIO_000600 a owl:Class ;
    rdfs:label "structure"@en ;
    dcterms:description "structure is the specification that refers to the composition and arrangement of parts of an object."@en ;
    rdfs:subClassOf sio:SIO_000315 .

sio:SIO_000610 a owl:Class ;
    rdfs:label "regulation of capability"@en ;
    dcterms:description "regulation of capability is the regulation of the ability of one party by another."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_001158 ;
            owl:someValuesFrom sio:SIO_000112 ],
        sio:SIO_000589 .

sio:SIO_000619 a owl:Class ;
    rdfs:label "regulatory authority"@en ;
    dcterms:description "A regulatory authority is an organization responsible for  exercising regulatory or supervisory capacity in some area of human activity."@en ;
    rdfs:subClassOf sio:SIO_000012 .

sio:SIO_000624 a owl:Class ;
    rdfs:label "chemical functional group"@en ;
    dcterms:alternative "chemical group"@en ;
    dcterms:description "A chemical functional group is a submolecule that confers specific chemical properties."@en ;
    rdfs:subClassOf sio:SIO_010441 .

sio:SIO_000629 a owl:ObjectProperty ;
    rdfs:label "is subject of"@en ;
    rdfs:subPropertyOf sio:SIO_000557 .

sio:SIO_000633 a owl:ObjectProperty ;
    rdfs:label "is modelled by"@en ;
    rdfs:subPropertyOf sio:SIO_000205 .

sio:SIO_000635 a owl:ObjectProperty ;
    rdfs:label "has trigger"@en ;
    dcterms:description "has trigger is a relation between a realizable and the factor that causes it to be realized."@en ;
    rdfs:subPropertyOf sio:SIO_000294 ;
    owl:inverseOf sio:SIO_000636 .

sio:SIO_000636 a owl:ObjectProperty ;
    rdfs:label "is trigger for"@en ;
    rdfs:subPropertyOf sio:SIO_000352 .

sio:SIO_000641 a owl:ObjectProperty ;
    rdfs:label "has basis"@en ;
    dcterms:description "has basis is a relation between a realizable entity and the quality that forms the basis for it."@en ;
    rdfs:domain sio:SIO_000340 ;
    rdfs:range sio:SIO_000005 ;
    rdfs:subPropertyOf sio:SIO_000008 ;
    owl:inverseOf sio:SIO_000642 ;
    skos:example "the solubility of salt (the disposition) is based on the molecular structure of NaCl (the quality) that allows the polarized water-molecules (the trigger)  to break the ion bonds (the realization)."@en .

sio:SIO_000642 a owl:ObjectProperty ;
    rdfs:label "is base for"@en ;
    dcterms:description "is base for is a relation between a quality and the realizable entity that it is the basis for."@en ;
    rdfs:domain sio:SIO_000005 ;
    rdfs:range sio:SIO_000340 ;
    rdfs:subPropertyOf sio:SIO_000011 ;
    skos:example "the solubility of salt (the disposition) is based on the molecular structure of NaCl (the quality) that allows the polarized water-molecules (the trigger)  to break the ion bonds (the realization)."@en .

sio:SIO_000648 a owl:Class ;
    rdfs:label "object model"@en ;
    dcterms:description "An object model is a representation of an object."@en ;
    rdfs:subClassOf sio:SIO_000510 .

sio:SIO_000650 a owl:Class ;
    rdfs:label "wave"@en ;
    dcterms:description "A wave is a physical entity that travels through space and time, consist of oscillations or vibrations and may be accompanied by the transfer of energy."@en ;
    rdfs:subClassOf sio:SIO_010462 .

sio:SIO_000655 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "transforms into"@en ;
    dcterms:description "A transitive temporal relation in which an entity mainstains identity from one state to another."@en ;
    rdfs:subPropertyOf sio:SIO_000294 ;
    owl:inverseOf sio:SIO_000657 .

sio:SIO_000658 a owl:ObjectProperty ;
    rdfs:label "is immediately transformed from"@en ;
    dcterms:description "A  temporal relation in which an entity mainstains identity from one state to another."@en ;
    rdfs:subPropertyOf sio:SIO_000657 .

sio:SIO_000664 a owl:Class ;
    rdfs:label "country"@en ;
    dcterms:description "A country is a region legally identified as a distinct entity in political geography. "@en ;
    rdfs:subClassOf sio:SIO_000415 .

sio:SIO_000667 a owl:Class ;
    rdfs:label "software execution"@en ;
    dcterms:description "software execution is the process of executing software on a computing device."@en ;
    rdfs:subClassOf sio:SIO_000649 .

sio:SIO_000673 a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has unique identifier"@en ;
    dcterms:description "has unique identifier is an inverse functional relation between an entity and an identifier that uniquely identifies it."@en ;
    rdfs:range sio:SIO_000675 ;
    rdfs:subPropertyOf sio:SIO_000671 ;
    owl:inverseOf sio:SIO_000674 .

sio:SIO_000676 a owl:Class ;
    rdfs:label "social role"@en ;
    dcterms:description "A social role is a role that is ascribed to individuals in a community."@en ;
    rdfs:subClassOf sio:SIO_000016 .

sio:SIO_000682 a owl:ObjectProperty ;
    rdfs:label "is start time of"@en ;
    rdfs:domain sio:SIO_000418 ;
    rdfs:subPropertyOf sio:SIO_000029 .

sio:SIO_000683 a owl:Class ;
    rdfs:label "justification"@en ;
    dcterms:description "A justification is a proposition that defends, explains or excuses some argument."@en ;
    rdfs:subClassOf sio:SIO_000256 .

sio:SIO_000684 a owl:ObjectProperty ;
    rdfs:label "is end time of"@en ;
    rdfs:domain sio:SIO_000418 ;
    rdfs:subPropertyOf sio:SIO_000029 .

sio:SIO_000690 a owl:Class ;
    rdfs:label "to associate"@en ;
    dcterms:description "to associate is the capability to physically interact with another object."@en ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_000698 a owl:Class ;
    rdfs:label "to disassemble"@en ;
    dcterms:description "to disassemble is to physically separate the parts of an object."@en ;
    rdfs:subClassOf sio:SIO_000376 .

sio:SIO_000699 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is greater than or equal to"@en ;
    dcterms:description "is greater than or equal to is a comparison relation between two quantities in which the first has a value larger or equal to the second."@en ;
    rdfs:subPropertyOf sio:SIO_000737 ;
    owl:inverseOf sio:SIO_000733 .

sio:SIO_000705 a owl:Class ;
    rdfs:label "design"@en ;
    dcterms:description "A specification of an object, manifested by an agent, intended to accomplish goals, in a particular environment, using a set of primitive components, satisfying a set of requirements, subject to constraints."@en ;
    rdfs:subClassOf sio:SIO_000315 .

sio:SIO_000707 a owl:Class ;
    rdfs:label "student role"@en ;
    dcterms:description "A student role is the role of an individual that is enrolled in courses at an academic institution."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000227 ;
            owl:someValuesFrom sio:SIO_000405 ],
        sio:SIO_000711 ;
    owl:disjointWith sio:SIO_000708 .

sio:SIO_000708 a owl:Class ;
    rdfs:label "professor role"@en ;
    dcterms:description "A professor role is the role of an individual that is involved in teaching of students (undergraduate and/or graduate) at a post-secondary academic institution."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000227 ;
            owl:someValuesFrom sio:SIO_000404 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000710 ;
            owl:someValuesFrom sio:SIO_000707 ],
        sio:SIO_000711 .

sio:SIO_000710 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is mutual role of"@en ;
    dcterms:description "a is mutual role of b if and only if the realization of role  a necessarily causes the realization of role b."@en ;
    rdfs:subPropertyOf sio:SIO_000709 .

sio:SIO_000713 a owl:Class ;
    rdfs:label "doctor role"@en ;
    dcterms:alternative "physician"@en ;
    dcterms:description "A doctor role is the role of an individual who practices medicine, which is concerned with promoting, maintaining or restoring human health through the study, diagnosis, and treatment of disease, injury, and other physical and mental impairments."@en ;
    rdfs:subClassOf sio:SIO_000712 .

sio:SIO_000714 a owl:Class ;
    rdfs:label "nurse role"@en ;
    dcterms:description "A nurse role is the role of an individual that is involved in the protection, promotion, and optimization of health and abilities, prevention of illness and injury, alleviation of suffering through the diagnosis and treatment of human response, and advocacy in the care of individuals, families, communities, and populations."@en ;
    rdfs:subClassOf sio:SIO_000712 .

sio:SIO_000715 a owl:Class ;
    rdfs:label "patient role"@en ;
    dcterms:description "A patient role is the role of an individual that is the recepient of medical care."@en ;
    rdfs:subClassOf sio:SIO_000712 .

sio:SIO_000719 a owl:Class ;
    rdfs:label "to translocate"@en ;
    dcterms:alternative "to move"@en ;
    dcterms:description "to translocate is the capability to displace oneself from one location to another."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000697 ;
            owl:someValuesFrom sio:SIO_000720 ],
        sio:SIO_000701 ;
    owl:disjointWith sio:SIO_000720 .

sio:SIO_000722 a owl:Class ;
    rdfs:label "to be compared"@en ;
    dcterms:description "to be compared is the capability of an object to be examined in order to note the similarities or differences among a set of objects."@en ;
    rdfs:subClassOf sio:SIO_000725 .

sio:SIO_000723 a owl:Class ;
    rdfs:label "to compare"@en ;
    dcterms:description "to compare is the capability to examine in order to note the similarities or differences among a set of objects."@en ;
    rdfs:subClassOf sio:SIO_000724 .

sio:SIO_000725 a owl:Class ;
    rdfs:label "to be examined"@en ;
    dcterms:description "to be examined is the capability of an object to be observed in a detailed manner."@en ;
    rdfs:subClassOf sio:SIO_000696 .

sio:SIO_000726 a owl:Class ;
    rdfs:label "administrative role"@en ;
    dcterms:description "An administrative role is the role of an individual that performs administrative tasks for some organization."@en ;
    rdfs:subClassOf sio:SIO_000706 .

sio:SIO_000728 a owl:Class ;
    rdfs:label "chemical identifier"@en ;
    dcterms:description "A chemical identifier is an identifier for a chemical entity"@en ;
    rdfs:subClassOf sio:SIO_000730 .

sio:SIO_000729 a owl:Class ;
    rdfs:label "record identifier"@en ;
    dcterms:description "A record identifier is an identifier for a database entry."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000672 ;
            owl:someValuesFrom sio:SIO_000756 ],
        sio:SIO_000731 .

sio:SIO_000730 a owl:Class ;
    rdfs:label "physical entity identifier"@en ;
    dcterms:description "A physical entity identifier is an identifier for a physical entity."@en ;
    rdfs:subClassOf sio:SIO_000115 .

sio:SIO_000735 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is lesser than"@en ;
    dcterms:description "is lesser than to is a comparison relation between two quantities in which the first has a value smaller than the second."@en ;
    rdfs:subPropertyOf sio:SIO_000733 .

sio:SIO_000742 a owl:Class ;
    rdfs:label "local maximum stationary point"@en ;
    dcterms:description "A local maximum stationary point is a point that has a higher value in  some axis than adjacent points."@en ;
    rdfs:subClassOf sio:SIO_000741 .

sio:SIO_000743 a owl:Class ;
    rdfs:label "local minimum stationary point"@en ;
    dcterms:description "A local minimum stationary point is a point that has a lower value in  some axis than adjacent points."@en ;
    rdfs:subClassOf sio:SIO_000741 .

sio:SIO_000756 a owl:Class ;
    rdfs:label "database entry"@en ;
    dcterms:alternative "database record" ;
    dcterms:description "A database entry is a single, implicitly structured data item in a table."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000750 ],
        sio:SIO_000602 .

sio:SIO_000758 a owl:Class ;
    rdfs:label "disordered"@en ;
    dcterms:description "disordered is a structural quality in which the parts of an object are non-rigid."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000218 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000000 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000217 ;
                                owl:someValuesFrom sio:SIO_000555 ] ) ] ],
        sio:SIO_001092 ;
    owl:disjointWith sio:SIO_001093 .

sio:SIO_000775 a owl:ObjectProperty ;
    rdfs:label "is refuting evidence for"@en ;
    rdfs:subPropertyOf sio:SIO_000773 .

sio:SIO_000779 a owl:Class ;
    rdfs:label "primer"@en ;
    dcterms:description "A primer is a nucleic acid that enables the synthesis of a complement strand of DNA by binding to it and acting as a point of transcription initiation."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_010008 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000586 ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( sio:SIO_000780 [ a owl:Restriction ;
                                            owl:onProperty sio:SIO_000586 ;
                                            owl:someValuesFrom sio:SIO_010094 ] [ a owl:Restriction ;
                                            owl:onProperty sio:SIO_000668 ;
                                            owl:someValuesFrom [ a owl:Class ;
                                                    owl:intersectionOf ( sio:SIO_010008 [ a owl:Restriction ;
                                                                owl:onProperty sio:SIO_000586 ;
                                                                owl:someValuesFrom sio:SIO_010091 ] ) ] ] ) ] ] ) ] .

sio:SIO_000780 a owl:Class ;
    rdfs:label "to bind to"@en ;
    dcterms:description "to bind to is the capability to physically interact with another object through a set of non-covalent interactions."@en ;
    rdfs:subClassOf sio:SIO_000690 .

sio:SIO_000783 a owl:Class ;
    rdfs:label "spatial boundary"@en ;
    dcterms:description "A spatial boundary is the closure minus the interior of a subset of a topological space."@en ;
    rdfs:subClassOf sio:SIO_000370 .

sio:SIO_000797 a owl:Class ;
    rdfs:label "substrate role"@en ;
    dcterms:description "The role of a chemical entity that is modified in a chemical reaction."@en ;
    rdfs:subClassOf sio:SIO_000879 .

sio:SIO_000799 a owl:Class ;
    rdfs:label "cofactor role"@en ;
    dcterms:description "The role of a chemical entity involved in the mechanism for enzyme-mediated catalysis."@en ;
    rdfs:subClassOf sio:SIO_000889 .

sio:SIO_000807 a owl:Class ;
    rdfs:label "partial positive charge"@en ;
    dcterms:description "A partial negative charge is a negative charge where the value of the charge is negative."@en ;
    rdfs:subClassOf sio:SIO_000809 ;
    owl:disjointWith sio:SIO_000808 .

sio:SIO_000814 a owl:Class ;
    rdfs:label "annoyance"@en ;
    dcterms:description "Annoyance is an unpleasant emtion that is characterized by a abnormal or excessive sensitivity to some external stimulus."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000815 a owl:Class ;
    rdfs:label "anxiety"@en ;
    dcterms:description "anxiety is an emotion charactersized by intense feeling of fear and concern coupled with a physical response."@en ;
    rdfs:subClassOf sio:SIO_000949 .

sio:SIO_000822 a owl:Class ;
    rdfs:label "contentment"@en ;
    dcterms:description "contentment is an emotion characterized by acknowledgement and satisfaction of the current state of affairs."@en ;
    rdfs:subClassOf sio:SIO_000840 .

sio:SIO_000829 a owl:Class ;
    rdfs:label "dread"@en ;
    dcterms:description "dread is the instense negative emotion that induces fear and apprehension."@en ;
    rdfs:subClassOf sio:SIO_000837 .

sio:SIO_000834 a owl:Class ;
    rdfs:label "envy"@en ;
    dcterms:description "envy is an emotion that occurs when a person lacks another's (perceived) superior quality, achievement or possession and wishes that the other lacked it."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000844 a owl:Class ;
    rdfs:label "hostility"@en ;
    dcterms:description "Hostility is the intense negative emotion of being in conflict or opposition to someone or something."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000847 a owl:Class ;
    rdfs:label "indifference"@en ;
    dcterms:description "indifference is an emotion characterized by lack of interest, concern, or sympathy."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Class ;
                        owl:complementOf [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000217 ;
                                owl:someValuesFrom sio:SIO_001210 ] ] [ a owl:Class ;
                        owl:complementOf [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000217 ;
                                owl:someValuesFrom sio:SIO_001211 ] ] ) ],
        sio:SIO_000276 .

sio:SIO_000848 a owl:Class ;
    rdfs:label "interest"@en ;
    dcterms:description "interest is the emotion of wanting to know or learn about something or someone."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000861 a owl:Class ;
    rdfs:label "regret"@en ;
    dcterms:description "regret is a feeling of sadness, repentance, or disappointment over something that has happened or been done."@en ;
    rdfs:subClassOf sio:SIO_000873 .

sio:SIO_000864 a owl:Class ;
    rdfs:label "satisfaction"@en ;
    dcterms:description "satisfaction is an emotion of fulfillment of one's wishes, expectations, or needs, or the pleasure derived from this."@en ;
    rdfs:subClassOf sio:SIO_000822 .

sio:SIO_000870 a owl:Class ;
    rdfs:label "surprise"@en ;
    dcterms:description "surprise is a brief emotion experienced as the result of an unexpected event. "@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000873 a owl:Class ;
    rdfs:label "worry"@en ;
    dcterms:description "worry is the emotion characterized by concer over a real or imaginary issue."@en ;
    rdfs:subClassOf sio:SIO_000949 .

sio:SIO_000891 a owl:Class ;
    rdfs:label "toxic role"@en ;
    dcterms:description "A toxic role is the role of a chemical substance that is poisonous."@en ;
    rdfs:subClassOf sio:SIO_000888 .

sio:SIO_000892 a owl:ObjectProperty ;
    rdfs:label "in relation from"@en ;
    dcterms:description "a in relation from b is a comparative relation in a is the object of reference in a relation with b. "@en ;
    rdfs:subPropertyOf sio:SIO_000212 .

sio:SIO_000894 a owl:Class ;
    rdfs:label "to luminesce"@en ;
    dcterms:description "to luminesce is to emit light through cold body radiation"@en ;
    rdfs:subClassOf sio:SIO_000692 .

sio:SIO_000898 a owl:Class ;
    rdfs:label "statistical association"@en ;
    dcterms:description "A statistical association is any relationship between two measured quantities that renders them statistically dependent."@en ;
    rdfs:subClassOf sio:SIO_000897 .

sio:SIO_000901 a owl:ObjectProperty ;
    rdfs:label "is frequency of"@en ;
    dcterms:description "is frequency of is a relation between a temporal unit and an object or event"@en ;
    rdfs:subPropertyOf sio:SIO_000215 .

sio:SIO_000907 a owl:Class ;
    rdfs:label "heatmap"@en ;
    dcterms:description "A heatmap is a graphical representation of data where the individual values contained in a matrix are represented as colors."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000911 a owl:Class ;
    rdfs:label "histogram"@en ;
    dcterms:description "A histogram is a graphical representation of data which consists of tabular frequencies, shown as adjacent rectangles, over discrete intervals (bins) , with an area equal to the frequency of the observations in the interval."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000913 a owl:Class ;
    rdfs:label "nomimal scale"@en ;
    dcterms:description "A nominal scale of measurement only specifies a limited set of categories."@en ;
    rdfs:subClassOf sio:SIO_000912 .

sio:SIO_000914 a owl:Class ;
    rdfs:label "binary scale"@en ;
    dcterms:description "A binary scale is a measurement scale that specifies a choice between two values."@en ;
    rdfs:subClassOf sio:SIO_000912 .

sio:SIO_000919 a owl:Class ;
    rdfs:label "reproducing"@en ;
    dcterms:description "reproducing is a process characterized by creation of an entity that is similar or exactly the same as the template from which it is derived."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000230 ;
                        owl:someValuesFrom sio:SIO_000776 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000312 ;
                        owl:someValuesFrom sio:SIO_000776 ] ) ],
        sio:SIO_000588 .

sio:SIO_000920 a owl:Class ;
    rdfs:label "independent variable"@en ;
    dcterms:description "An independent variable is a variable that may take on different values independent of other elements in a system."@en ;
    rdfs:subClassOf sio:SIO_000367 .

sio:SIO_000931 a owl:Class ;
    rdfs:label "network diagram"@en ;
    dcterms:description "A network diagram consists of a set of vertices connected by edges."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000934 a owl:Class ;
    rdfs:label "stack graph"@en ;
    dcterms:description "A stack graph is a statistical graph which presents multiple series in which the distance between one series and another indicates the relative contribution to the total for any x-value."@en ;
    rdfs:subClassOf sio:SIO_000083 .

sio:SIO_000944 a owl:Class ;
    rdfs:label "interval"@en ;
    dcterms:description "An interval is a set of real numbers that includes all numbers between any two numbers in the set."@en ;
    rdfs:subClassOf sio:SIO_000075 .

sio:SIO_000945 a owl:Class ;
    rdfs:label "tree diagram"@en ;
    dcterms:description "A tree diagram is a hierarchical network diagram in which a root vertex is connected to one or more other vertices through a directed edge, which in turn may be connected to other vertices."@en ;
    rdfs:subClassOf sio:SIO_001332 .

sio:SIO_000960 a owl:Class ;
    rdfs:label "real"@en ;
    dcterms:description "real is the quality of an entity that exists in real space and time."@en ;
    rdfs:subClassOf sio:SIO_000959 ;
    owl:disjointWith sio:SIO_000961,
        sio:SIO_000962 .

sio:SIO_000961 a owl:Class ;
    rdfs:label "fictional"@en ;
    dcterms:description "fictional is the quality of an entity that exists only in a creative work of fiction."@en ;
    rdfs:subClassOf sio:SIO_001186 .

sio:SIO_000962 a owl:Class ;
    rdfs:label "virtual"@en ;
    dcterms:description "virtual is the quality of an entity that exists only in a virtual setting such as a simulation or game environment."@en ;
    rdfs:subClassOf sio:SIO_000959 .

sio:SIO_000968 a owl:Class ;
    rdfs:label "poison role"@en ;
    dcterms:description "A poison role is the role of a substance that causes some negative disturbance in an organism."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000227 ;
            owl:someValuesFrom sio:SIO_010076 ],
        sio:SIO_000891 .

sio:SIO_000971 a owl:ObjectProperty ;
    rdfs:label "has first part"@en ;
    dcterms:description "has first part is a proper part relation in which the part is the first of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system."@en ;
    rdfs:subPropertyOf sio:SIO_000974 .

sio:SIO_000973 a owl:ObjectProperty ;
    rdfs:label "is last part of"@en ;
    dcterms:description "is last part of is a proper part relation in which the part is the last of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system."@en ;
    rdfs:subPropertyOf sio:SIO_000975 .

sio:SIO_000976 a owl:Class ;
    rdfs:label "observational study"@en ;
    dcterms:description "observational study draws inferences about the possible effect of a treatment on subjects, where the assignment of subjects into a treated group versus a control group is outside the control of the investigator"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000268 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000218 ;
                                owl:someValuesFrom sio:SIO_000284 ] ) ] ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000132 ;
            owl:someValuesFrom sio:SIO_000284 ],
        sio:SIO_000994 .

sio:SIO_000984 a owl:Class ;
    rdfs:label "genome"@en ;
    dcterms:description "A genome is a collection of nucleic acids."@en ;
    rdfs:subClassOf sio:SIO_010046 .

sio:SIO_000985 a owl:Class ;
    rdfs:label "protein coding gene"@en ;
    dcterms:description "A gene that contains an open reading frame which codes for a protein."@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/SO_0001217"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_010035 .

sio:SIO_000995 a owl:Class ;
    rdfs:label "suspended"@en ;
    dcterms:description "suspended is the status of a process that is no longer progressing towards completion."@en ;
    rdfs:subClassOf sio:SIO_000033 .

sio:SIO_000997 a owl:Class ;
    rdfs:label "aborted"@en ;
    dcterms:description "aborted is a process status in which a started process will not complete as intended."@en ;
    rdfs:subClassOf sio:SIO_000033 .

sio:SIO_001001 a owl:Class ;
    rdfs:label "medical diagnosis"@en ;
    dcterms:description "A medical diagnosis (often simply termed diagnosis) refers to the process of attempting to determine or identify a possible disease or disorder."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000229 ;
            owl:someValuesFrom sio:SIO_001003 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000230 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_010046 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000217 ;
                                owl:someValuesFrom sio:SIO_000758 ] ) ] ],
        sio:SIO_001024 .

sio:SIO_001003 a owl:Class ;
    rdfs:label "diagnostic opinion"@en ;
    dcterms:description "A diagnostic opinion is an opinion resulting from a medical diagnostic procedure."@en ;
    rdfs:subClassOf sio:SIO_001004 .

sio:SIO_001005 a owl:Class ;
    rdfs:label "chemical effect"@en ;
    dcterms:description "A chemical effect is a chemical interaction in which a chemical elicits a marked characteristic of a biological system."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000139 ;
            owl:someValuesFrom sio:SIO_010038 ],
        sio:SIO_010013 .

sio:SIO_001009 a owl:Class ;
    rdfs:label "toxic"@en ;
    dcterms:description "toxic is the quality of a substance imparing the normal functioning of a  system."@en ;
    rdfs:subClassOf sio:SIO_001008 ;
    owl:disjointWith sio:SIO_001010 .

sio:SIO_001014 a owl:Class ;
    rdfs:label "ethnicity"@en ;
    dcterms:description "ethnicity is the biological quality of membership in a social group based on a common heritage."@en ;
    rdfs:subClassOf sio:SIO_000475 .

sio:SIO_001015 a owl:Class ;
    rdfs:label "race"@en ;
    dcterms:description "race is a characteristic of an individual by heritable phenotypic characteristics, geographic ancestry, physical appearance, ethnicity, and social status."@en ;
    rdfs:subClassOf sio:SIO_000475 .

sio:SIO_001019 a owl:Class ;
    rdfs:label "dose"@en ;
    dcterms:description "A dose is the quantity of a chemical substance administered to a biological system."@en ;
    rdfs:subClassOf sio:SIO_000258 .

sio:SIO_001026 a owl:Class ;
    rdfs:label "report"@en ;
    dcterms:description "A report is a textual document made that present focused, salient content to a specific audience."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_001033 a owl:Class ;
    rdfs:label "text quality"@en ;
    dcterms:description "text quality is the quality of a textual entity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000218 ;
            owl:someValuesFrom sio:SIO_000651 ],
        sio:SIO_000026 .

sio:SIO_001035 a owl:Class ;
    rdfs:label "peer-reviewed"@en ;
    dcterms:description "peer-reviewed is the quality of a textual entity that has been examined and commented by a peer expert reviewer."@en ;
    rdfs:subClassOf sio:SIO_001034 ;
    owl:disjointWith sio:SIO_001038 .

sio:SIO_001038 a owl:Class ;
    rdfs:label "editor reviewed"@en ;
    dcterms:description "editor reviewed is the quality of a textual entity that has been examined and commented on by an editor."@en ;
    rdfs:subClassOf sio:SIO_001034 .

sio:SIO_001040 a owl:Class ;
    rdfs:label "morpheme"@en ;
    dcterms:description "A morpheme is the smallest semantically meaningful unit in a language."@en ;
    rdfs:subClassOf sio:SIO_000078 .

sio:SIO_001041 a owl:Class ;
    rdfs:label "study design"@en ;
    dcterms:alternative "study protocol" ;
    dcterms:description "A study design is a protocol for the proper execution of a study which normally requires a carefullly crafted research question or hypothesis and at least one variable under observation and observed values for that variable."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Restriction ;
                    owl:onProperty sio:SIO_000068 ;
                    owl:someValuesFrom sio:SIO_000747 ] ;
            owl:onProperty sio:SIO_000341 ],
        sio:SIO_001043 .

sio:SIO_001048 a owl:Class ;
    rdfs:label "intervention study"@en ;
    dcterms:description "An intervention study has the objective of improving the condition of an individual or a group of individuals, and demonstrates the magnitude of that capability by comparing it to a control group."@en ;
    rdfs:subClassOf sio:SIO_000994 .

sio:SIO_001053 a owl:Class ;
    rdfs:label "reason"@en ;
    dcterms:description "A reason is a justification that specifies the motive for an action or a determination."@en ;
    rdfs:subClassOf sio:SIO_000683 .

sio:SIO_001055 a owl:Class ;
    rdfs:label "observing"@en ;
    dcterms:alternative "observation"@en ;
    dcterms:description "observing is a process of passive interaction in which one entity makes note of attributes of one or more entities."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000230 ;
            owl:someValuesFrom sio:SIO_000000 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000229 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000593 .

sio:SIO_001061 a owl:Class ;
    rdfs:label "population"@en ;
    dcterms:description "A population is all the organisms that both belong to the same group or species and live in the same geographical area."@en ;
    rdfs:subClassOf sio:SIO_000620 .

sio:SIO_001062 a owl:Class ;
    rdfs:label "human population"@en ;
    dcterms:description "A human population refers to a collection of human beings."@en ;
    rdfs:subClassOf sio:SIO_001061 .

sio:SIO_001080 a owl:Class ;
    rdfs:label "vocabulary"@en ;
    dcterms:description "A vocabulary is a collection of terms."@en ;
    rdfs:subClassOf sio:SIO_000315,
        sio:SIO_000621 .

sio:SIO_001091 a owl:Class ;
    rdfs:label "heterogeneous"@en ;
    dcterms:description "homogeneous is a quality that describes the varied composition of an object."@en ;
    rdfs:subClassOf sio:SIO_000051 .

sio:SIO_001093 a owl:Class ;
    rdfs:label "rigid"@en ;
    dcterms:description "rigid is the quality of maintaining structural integrity (and not bending) under pressure."@en ;
    rdfs:subClassOf sio:SIO_001092 .

sio:SIO_001094 a owl:Class ;
    rdfs:label "bent"@en ;
    dcterms:description "bent is the quality of a line being sharply curved or having an angle."@en ;
    rdfs:subClassOf sio:SIO_000537 .

sio:SIO_001095 a owl:Class ;
    rdfs:label "curved"@en ;
    dcterms:description "curved is the quality of a line that deviates from straightness in a smooth, continuous fashion."@en ;
    rdfs:subClassOf sio:SIO_000537 .

sio:SIO_001097 a owl:ObjectProperty ;
    rdfs:label "is generalization of"@en ;
    dcterms:description "is generalization of is a relation between a more general instance (in terms of spatial/temporal localization & other attributres) than the other."@en ;
    rdfs:subPropertyOf sio:SIO_000272 .

sio:SIO_001098 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is alternate of"@en ;
    dcterms:description "is alternate of relates two specialized instances."@en ;
    sio:equivalentTo "http://www.w3.org/ns/prov#alternateOf"^^xsd:anyURI ;
    rdfs:subPropertyOf sio:SIO_000272 ;
    owl:inverseOf sio:SIO_001098 ;
    skos:example "two weather forecasts for the city of London produced at different times or by different organizations (etc) are alternates of each other, and instances of / specializations of forecasts for the city of London."@en .

sio:SIO_001117 a owl:Class ;
    rdfs:label "intersection"@en ;
    dcterms:description "An intersection is a list of only the values of an attribute for the entities in the defined set where all entities have that value."@en ;
    rdfs:subClassOf sio:SIO_000150 .

sio:SIO_001155 a owl:ObjectProperty ;
    rdfs:label "is regulated by"@en ;
    rdfs:subPropertyOf sio:SIO_000352 .

sio:SIO_001156 a owl:ObjectProperty ;
    rdfs:label "results in"@en ;
    rdfs:subPropertyOf sio:SIO_000294 ;
    owl:inverseOf sio:SIO_001157 .

sio:SIO_001157 a owl:ObjectProperty ;
    rdfs:label "is result of"@en ;
    rdfs:subPropertyOf sio:SIO_000352 .

sio:SIO_001158 a owl:ObjectProperty ;
    rdfs:label "affects"@en ;
    rdfs:subPropertyOf sio:SIO_000229 ;
    owl:inverseOf sio:SIO_001159 .

sio:SIO_001159 a owl:ObjectProperty ;
    rdfs:label "is affected by"@en ;
    rdfs:subPropertyOf sio:SIO_000062 .

sio:SIO_001171 a owl:Class ;
    rdfs:label "database cross-reference"@en ;
    dcterms:alternative "dbxref" ;
    dcterms:description "A database cross-reference is an association between one data item and another."@en ;
    rdfs:subClassOf sio:SIO_000897 .

sio:SIO_001175 a owl:Class ;
    rdfs:label "positive nucleic acid strand"@en ;
    dcterms:alternative "forward strand"@en ;
    dcterms:description "The positive nucleic acid strand refers to the strand that is to be read 5' to 3'."@en ;
    rdfs:subClassOf sio:SIO_001174 .

sio:SIO_001176 a owl:Class ;
    rdfs:label "negative nucleic acid strand"@en ;
    dcterms:alternative "reverse strand"@en ;
    dcterms:description "The negative nucleic acid strand is the strand that is that is complimentary to the forward strand and appears from 3' to 5'."@en ;
    rdfs:subClassOf sio:SIO_001174 .

sio:SIO_001178 a owl:Class ;
    rdfs:label "double stranded RNA"@en ;
    dcterms:description "double stranded nucleic acid is a molecular complex composed of two weakly connected ribonucleic acids."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_010009 ;
            owl:onProperty sio:SIO_000053 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_001177 .

sio:SIO_001183 a owl:Class ;
    rdfs:label "statement"@en ;
    dcterms:description "A statement is a proposition that is either (a) a meaningful declarative sentence that is either true or false, or (b) that which a true or false declarative sentence asserts."@en ;
    rdfs:subClassOf sio:SIO_000256 .

sio:SIO_001188 a owl:Class ;
    rdfs:label "SADI semantic web service"@en ;
    dcterms:description "a SADI semantic web service is a semantic web service that follows the SADI specification"@en ;
    sio:subset "sadi"@en ;
    rdfs:seeAlso "http://en.wikipedia.org/wiki/SADI"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_001189 .

sio:SIO_001189 a owl:Class ;
    rdfs:label "semantic web service"@en ;
    dcterms:description "a semantic web service is a web service that provides a formal, machine understanble description of its functionality."@en ;
    rdfs:subClassOf sio:SIO_000140 .

sio:SIO_001192 a owl:Class ;
    rdfs:label "web service invocation"@en ;
    dcterms:description "A web service invocation involves the execution of a web service."@en ;
    rdfs:subClassOf sio:SIO_000667 .

sio:SIO_001195 a owl:Class ;
    rdfs:label "behaviour"@en ;
    dcterms:description "Behaviour is the set of actions and mannerisms made by systems (biological or otherwise) in response to stimuli or inputs, whether internal or external, conscious or subconscious, overt or covert, and voluntary or involuntary."@en ;
    sio:subset "behaviour+",
        "core" ;
    rdfs:subClassOf sio:SIO_000006 .

sio:SIO_001197 a owl:Class ;
    rdfs:label "structural motif"@en ;
    dcterms:description "A structural motif is a pattern in a structure formed by a spatial arrangement of objects (e.g. atoms)."@en ;
    rdfs:subClassOf sio:SIO_000130 .

sio:SIO_001213 a owl:Class ;
    rdfs:label "mild"@en ;
    dcterms:description "mild is a qualitative intensity value that is more intense than weak, but less intense than moderate."@en ;
    rdfs:subClassOf sio:SIO_001212 .

sio:SIO_001214 a owl:Class ;
    rdfs:label "moderate"@en ;
    dcterms:description "moderate is a qualitative intensity value that is more intense than mild, but less intense than strong."@en ;
    rdfs:subClassOf sio:SIO_001212 .

sio:SIO_001215 a owl:Class ;
    rdfs:label "severe"@en ;
    dcterms:description "severe is a qualitative intensity value that is more intense than strong, but less intense than fatal."@en ;
    rdfs:subClassOf sio:SIO_001212 .

sio:SIO_001216 a owl:Class ;
    rdfs:label "fatal"@en ;
    dcterms:description "fatal is a qualitative intensity value that is more intense than severe, leading to the death/non-functioning of a system."@en ;
    rdfs:subClassOf sio:SIO_001212 .

sio:SIO_001217 a owl:Class ;
    rdfs:label "strong"@en ;
    dcterms:description "strong is a qualitative intensity value that is more intense than moderate, but less intense than severe."@en ;
    rdfs:subClassOf sio:SIO_001212 .

sio:SIO_001218 a owl:Class ;
    rdfs:label "weak"@en ;
    dcterms:description "weak is a qualitative intensity value that is more intense than none, but less intense than mild."@en ;
    rdfs:subClassOf sio:SIO_001212 .

sio:SIO_001221 a owl:Class ;
    rdfs:label "to describe"@en ;
    dcterms:description "to describe is the capabilty to communicate facts about an entity."@en ;
    rdfs:subClassOf sio:SIO_000639 .

sio:SIO_001224 a owl:Class ;
    rdfs:label "amino acid"@en ;
    dcterms:description "An amino acid is an organic molecule composed of a carbon bonded to four different groups: a carboxyl group, an amino group, an R group, and a hydrogen atom. In the case of glycine, the R group is another hydrogen atom."@en ;
    rdfs:subClassOf sio:SIO_010072 .

sio:SIO_001227 a owl:Class ;
    rdfs:label "small cytoplasmic RNA (scRNA) gene"@en ;
    dcterms:description "A small cytoplasmic RNA (scRNA) gene is a gene that encodes a small (7S; 129 nucleotides) RNA molecule found in the cytosol and rough endoplasmic reticulum that are normally associated with proteins that are involved in specific selection and transport of other proteins."@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/SO_0001266"^^xsd:anyURI ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010078 ;
            owl:someValuesFrom sio:SIO_001231 ],
        sio:SIO_000790 .

sio:SIO_001231 a owl:Class ;
    rdfs:label "small cytoplasmic RNA (scRNA)"@en ;
    dcterms:alternative "scRNA"@en ;
    dcterms:description "A small cytoplasmic RNA (scRNA) molecule is a small (7S; 129 nucleotides) RNA molecule found in the cytosol and rough endoplasmic reticulum that are normally associated with proteins that are involved in specific selection and transport of other proteins."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010079 ;
            owl:someValuesFrom sio:SIO_001227 ],
        sio:SIO_001235 .

sio:SIO_001232 a owl:Class ;
    rdfs:label "transfer RNA (tRNA)"@en ;
    dcterms:alternative "tRNA"@en ;
    dcterms:description "A transfer RNA (tRNA) is an RNA molecule that aids in the translation of a messenger RNA (mRNA) to produce a protein product."@en ;
    rdfs:subClassOf sio:SIO_001235 .

sio:SIO_001233 a owl:Class ;
    rdfs:label "small nuclear RNA (snRNA)"@en ;
    dcterms:alternative "snRNA"@en ;
    dcterms:description "A small nuclear RNA (snRNA) is a small RNA molecule that is located in the nucleus of a cell."@en ;
    rdfs:subClassOf sio:SIO_001235 .

sio:SIO_001234 a owl:Class ;
    rdfs:label "small nucleolar RNA (snoRNA)"@en ;
    dcterms:alternative "snoRNA"@en ;
    dcterms:description "A small nucleolar RNA (snoRNA) is a small RNA that are associated with the eukaryotic nucleus as components of small nucleolar ribonucleoproteins."@en ;
    rdfs:subClassOf sio:SIO_001235 .

sio:SIO_001243 a owl:Class ;
    rdfs:label "likelihood"@en ;
    dcterms:description "Likelihood is the hypothetical probability that an event that has already occurred would yield a specific outcome."@en ;
    rdfs:subClassOf sio:SIO_000052 .

sio:SIO_001251 a owl:Class ;
    rdfs:label "left open interval"@en ;
    dcterms:description "a left open interval is an interval in which there is no element that is smaller than all other elements."@en ;
    rdfs:subClassOf sio:SIO_001246 .

sio:SIO_001252 a owl:Class ;
    rdfs:label "right open interval"@en ;
    dcterms:description "a right open interval is an interval in which there is no element that is greater than all other elements."@en ;
    rdfs:subClassOf sio:SIO_001246 .

sio:SIO_001253 a owl:Class ;
    rdfs:label "right closed interval"@en ;
    dcterms:description "a right closed interval is an interval in which there is a real number that is larger than all of its elements."@en ;
    rdfs:subClassOf sio:SIO_001246 .

sio:SIO_001254 a owl:Class ;
    rdfs:label "left closed interval"@en ;
    dcterms:description "a left closed interval is an interval in which there is a real number that is smaller than all its elements."@en ;
    rdfs:subClassOf sio:SIO_001246 .

sio:SIO_001264 a owl:Class ;
    rdfs:label "homozygous"@en ;
    dcterms:description "homozygous is the quality of a biological organism in which there are two identical alleles at a given locus." ;
    rdfs:subClassOf sio:SIO_001263 .

sio:SIO_001265 a owl:Class ;
    rdfs:label "heterozygous"@en ;
    dcterms:description "homozygous is the quality of a biological organism in which there are two different alleles at a given locus." ;
    rdfs:subClassOf sio:SIO_001263 .

sio:SIO_001266 a owl:Class ;
    rdfs:label "hemizygous"@en ;
    dcterms:description "hemizygous is the quality of a biological organism in which, based on the ploidy of the organism, there is half the number of alleles than normal at a given locus." ;
    rdfs:subClassOf sio:SIO_001263 .

sio:SIO_001267 a owl:Class ;
    rdfs:label "nullizygous"@en ;
    dcterms:description "nullizygous is the quality of a biological organism in which there are no allelles at a given locus." ;
    rdfs:subClassOf sio:SIO_001263 .

sio:SIO_001270 a owl:Class ;
    rdfs:label "paternally transmitted"@en ;
    dcterms:description "paternally transmitted is the quality of a biological organism in which the (genetic) material is transmitted from the paternal line." ;
    rdfs:subClassOf sio:SIO_001268 .

sio:SIO_001274 a owl:Class ;
    rdfs:label "right-handed helical"@en ;
    dcterms:description "right-handed helical quality is the quality in which a clockwise screwing motion moves the helix away from the observed along the line of sight along the helix's axis."@en ;
    rdfs:subClassOf sio:SIO_001271 .

sio:SIO_001278 a owl:ObjectProperty ;
    rdfs:label "is data item in"@en ;
    dcterms:description "'is data item in' is a relation between an entity that is described or referenced in a dataset." ;
    sio:subset "core" ;
    rdfs:range sio:SIO_000089 ;
    rdfs:subPropertyOf sio:SIO_000628 .

sio:SIO_001280 a owl:ObjectProperty ;
    rdfs:label "is phenotype of"@en ;
    dcterms:description "is phenotype of is a relation between an observable/measurable characteristic and an object." ;
    rdfs:subPropertyOf sio:SIO_000011 .

sio:SIO_001289 a owl:Class ;
    rdfs:label "never"@en ;
    dcterms:alternative "none of the time" ;
    dcterms:description "never refers to in none of the occasions." ;
    rdfs:subClassOf sio:SIO_001288 .

sio:SIO_001290 a owl:Class ;
    rdfs:label "some of the time"@en ;
    dcterms:alternative "some of the time" ;
    dcterms:description "some refers to in the minority of occasions" ;
    rdfs:subClassOf sio:SIO_001288 .

sio:SIO_001291 a owl:Class ;
    rdfs:label "most of the time"@en ;
    dcterms:alternative "most of the time" ;
    dcterms:description "most refers to in the majority of occasions" ;
    rdfs:subClassOf sio:SIO_001288 .

sio:SIO_001292 a owl:Class ;
    rdfs:label "always"@en ;
    dcterms:alternative "all of the time" ;
    dcterms:description "always indicates that the event occurs at all times." ;
    rdfs:subClassOf sio:SIO_001288 .

sio:SIO_001294 a owl:Class ;
    rdfs:label "very poor quality"@en ;
    rdfs:subClassOf sio:SIO_001293 .

sio:SIO_001295 a owl:Class ;
    rdfs:label "poor quality"@en ;
    rdfs:subClassOf sio:SIO_001293 .

sio:SIO_001296 a owl:Class ;
    rdfs:label "neither good nor poor quality"@en ;
    rdfs:subClassOf sio:SIO_001293 .

sio:SIO_001297 a owl:Class ;
    rdfs:label "good quality"@en ;
    rdfs:subClassOf sio:SIO_001293 .

sio:SIO_001298 a owl:Class ;
    rdfs:label "very good quality"@en ;
    rdfs:subClassOf sio:SIO_001293 .

sio:SIO_001302 a owl:Class ;
    rdfs:label "assertion ovopub"@en ;
    dcterms:description "An assertion ovopub is an ovopub that contains and links to an assertion subgraph with one or more statements that may be true or false, as well as statements describing its provenance."@en ;
    rdfs:subClassOf sio:SIO_001300 .

sio:SIO_001316 a owl:Class ;
    rdfs:label "ordered list"@en ;
    dcterms:description "an ordered list is a list in which items are sequentially ordered." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000053 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_001260 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000008 ;
                                owl:someValuesFrom sio:SIO_000613 ] ) ] ],
        sio:SIO_000150 .

sio:SIO_001317 a owl:Class ;
    rdfs:label "middle name"@en ;
    dcterms:description "a middle name is a name assigned to an individual that is not the first or last name." ;
    rdfs:subClassOf sio:SIO_000116 .

sio:SIO_001332 a owl:Class ;
    rdfs:label "directed acyclic graph"@en ;
    dcterms:alternative "dag"@en ;
    dcterms:description "a directed acyclic graph or DAG is a network digram that contains directed edges in which nodes may have multiple parents, but there are no cycles."@en ;
    rdfs:subClassOf sio:SIO_000931 .

sio:SIO_001335 a owl:Class ;
    rdfs:label "node"@en ;
    dcterms:alternative "vertex"@en ;
    dcterms:description "a node or vertex is a point in a graph."@en ;
    rdfs:subClassOf sio:SIO_000507 .

sio:SIO_001336 a owl:Class ;
    rdfs:label "epimer"@en ;
    dcterms:description "An epimer is a stereoisomer that differs in configuration at only one stereogenic center."@en ;
    rdfs:subClassOf sio:SIO_010775 .

sio:SIO_001338 a owl:Class ;
    rdfs:label "mereological quality"@en ;
    dcterms:description "a mereological quality is a quality of an entity vis-a-vis containment or parthood"@en ;
    rdfs:subClassOf sio:SIO_000026 .

sio:SIO_001358 a owl:Class ;
    rdfs:label "to retrieve"@en ;
    dcterms:description "the capability to retrieve a (digitial/physical/mental) object from a location." ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_001368 a owl:Class ;
    rdfs:label "speed"@en ;
    dcterms:description "Speed is the rate of change of an object's position."@en ;
    rdfs:subClassOf sio:SIO_001365 .

sio:SIO_001370 a owl:Class ;
    rdfs:label "slide"@en ;
    dcterms:description "A slide is an visual representation meant to communicate some information."@en ;
    rdfs:subClassOf sio:SIO_001194 .

sio:SIO_001381 a owl:Class ;
    rdfs:label "genomic sequence variant"@en ;
    dc:description "a genomic sequence variant is part of a nucleic acid which is compositionally different than another reference genomic part."@en ;
    dcterms:alternative "variant"@en ;
    rdfs:subClassOf sio:SIO_010335 .

sio:SIO_001386 a owl:Class ;
    rdfs:label "chemical notation"@en ;
    dc:description "a notation to describe a chemical entity"@en ;
    rdfs:subClassOf sio:SIO_001385 .

sio:SIO_001388 a owl:Class ;
    rdfs:label "sequence variation notation"@en ;
    rdfs:subClassOf sio:SIO_001385 .

sio:SIO_001403 a owl:ObjectProperty ;
    rdfs:label "is associated with"@en ;
    dc:description "x is associated with y when x and y are logically or statistically related to one another."@en ;
    rdfs:subPropertyOf sio:SIO_000001 .

sio:SIO_001405 a owl:Class ;
    rdfs:label "intersex"@en ;
    dcterms:description "intersex is a biological sex characterised by birth with genitalia and/or secondary sexual characteristics of indeterminate sex, or which combine features of both sexes."@en ;
    rdfs:subClassOf sio:SIO_010029 ;
    owl:disjointWith sio:SIO_010052 .

sio:SIO_001414 a owl:Class ;
    rdfs:label "quantile"@en ;
    dcterms:description "A quantile is a quantity that divides the range of a probability distribution into continuous intervals with equal probabilities, or dividing the observations in a sample in the same way."@en ;
    rdfs:subClassOf sio:SIO_000257 .

sio:SIO_001416 a owl:Class ;
    rdfs:label "duplicate role"@en ;
    dcterms:description "a duplicate role is a comparative role that holds when one item is an exact copy of another in a specific set."@en ;
    rdfs:subClassOf sio:SIO_000721 .

sio:SIO_001417 a owl:Class ;
    rdfs:label "replicate role"@en ;
    dcterms:description "a replicate role is a comparative role that holds  when one item is a reproduction, facsimile, or a copy of another."@en ;
    rdfs:subClassOf sio:SIO_000721 .

sio:SIO_001418 a owl:Class ;
    rdfs:label "replicate"@en ;
    dcterms:description "a replicate is an object that is a facsimile, reproduction, or copy of another item."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000228 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_001417 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000668 ;
                                owl:someValuesFrom sio:SIO_000776 ] ) ] ],
        sio:SIO_001259 .

sio:SIO_001420 a owl:Class ;
    rdfs:label "duplicate"@en ;
    dcterms:description "a duplicate is an object that is an exact copy of another item"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000228 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_001416 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000668 ;
                                owl:someValuesFrom sio:SIO_000776 ] ) ] ],
        sio:SIO_001259 .

sio:SIO_001432 a owl:Class ;
    rdfs:label "vector space"@en ;
    dcterms:description "a vector space is a set of vectors."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_001430 ;
            owl:onProperty sio:SIO_000059 ],
        sio:SIO_000075 .

sio:SIO_001441 a owl:Class ;
    rdfs:label "imaginary number"@en ;
    dcterms:description "An imaginary number is a complex number whose real part is zero e.g. 0 + bi, and is expressed as a multiple of the square root of -1."@en ;
    sio:example "5i is an imaginary number, and its square is -25."@en ;
    rdfs:subClassOf sio:SIO_001443 ;
    owl:disjointWith sio:SIO_001442 .

sio:SIO_010002 a owl:Class ;
    rdfs:label "tissue"@en ;
    dcterms:description "A tissue is a mereologically maximal collection of cells that together perform some function."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_010001 ],
        sio:SIO_010046 .

sio:SIO_010003 a owl:Class ;
    rdfs:label "organ"@en ;
    dcterms:description "An organ is a collection of tissues joined in structural unit to serve a common function."@en ;
    rdfs:subClassOf sio:SIO_010046 .

sio:SIO_010014 a owl:Class ;
    rdfs:label "primary structure descriptor"@en ;
    dcterms:description "A primary structure descriptor describes a biomolecular object in terms of a 1D or 2D topology."@en ;
    rdfs:subClassOf sio:SIO_011119 .

sio:SIO_010023 a owl:Class ;
    rdfs:label "tertiary structure descriptor"@en ;
    dcterms:description "A tertiary structure descriptor describes 3D topological patterns in a biopolymer."@en ;
    rdfs:subClassOf sio:SIO_011119 .

sio:SIO_010033 a owl:Class ;
    rdfs:label "hydrogen bond"@en ;
    dcterms:description "A hydrogen bond is a weak submolecular interaction formed between a hydrogen atom and a electronegative atom."@en ;
    rdfs:subClassOf sio:SIO_010005 .

sio:SIO_010037 a owl:Class ;
    rdfs:label "chemical element"@en ;
    dcterms:description "A chemical element is a (effectively) homogeneous substance composed of one type of atom."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_010044 ;
            owl:onProperty sio:SIO_000273 ],
        sio:SIO_010463 .

sio:SIO_010040 a owl:Class ;
    rdfs:label "binding site"@en ;
    dcterms:description "A binding site is a molecular site which when occupied with particular ligands leads to structural transformations that initiatiate new moelcular processes. "@en ;
    rdfs:subClassOf sio:SIO_010049 .

sio:SIO_010048 a owl:Class ;
    rdfs:label "male"@en ;
    dcterms:description "male is a biological sex of an individual with male sexual organs."@en ;
    sio:equivalentTo "PATO:0000384" ;
    rdfs:subClassOf sio:SIO_010029 ;
    owl:disjointWith sio:SIO_010052 .

sio:SIO_010051 a owl:Class ;
    rdfs:label "biological fluid"@en ;
    dcterms:description "A biological fluid is a fluid of biological origin."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000244 ;
            owl:someValuesFrom sio:SIO_010046 ],
        sio:SIO_010046 .

sio:SIO_010054 a owl:Class ;
    rdfs:label "cell line"@en ;
    dcterms:description "A cell line is a collection of genetically identifical cells."@en ;
    rdfs:subClassOf sio:SIO_010046 .

sio:SIO_010056 a owl:Class ;
    rdfs:label "phenotype"@en ;
    dcterms:description "A phenotype is an observable characteristic of an individual."@en ;
    rdfs:subClassOf sio:SIO_000475 .

sio:SIO_010076 a owl:Class ;
    rdfs:label "poison"@en ;
    dcterms:description "A poison is a drug that is harzardous or toxic to an organism when ingested at a certain quantity."@en ;
    rdfs:subClassOf sio:SIO_010038 .

sio:SIO_010077 a owl:Class ;
    rdfs:label "active ingredient"@en ;
    dcterms:description "An active ingredient is a molecular entity that exhibits biological activity."@en ;
    rdfs:subClassOf sio:SIO_010338 .

sio:SIO_010083 a owl:ObjectProperty ;
    rdfs:label "is translated from"@en ;
    rdfs:subPropertyOf sio:SIO_010079 .

sio:SIO_010090 a owl:Class ;
    rdfs:label "to serve as a template for RNA synthesis"@en ;
    dcterms:description "to serve as a template for RNA synthesis is the capability of a chemical entity to provide the necessary information or scaffold by which an RNA molecule may be produced."@en ;
    rdfs:subClassOf sio:SIO_010088 .

sio:SIO_010094 a owl:Class ;
    rdfs:label "to serve as a primer for DNA synthesis"@en ;
    dcterms:description "to serve as a primer for DNA synthesis is the capability of a short nucleic acid to bind to the 5' end of single strand of DNA template and help initiate DNA replication."@en ;
    rdfs:subClassOf sio:SIO_000542 .

sio:SIO_010096 a owl:Class ;
    rdfs:label "mature mRNA"@en ;
    dcterms:description "A mature RNA is a ribonucleic acid that contains an untranslated region (UTR) and protein coding sequence and lacks introns."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:complementOf [ a owl:Restriction ;
                    owl:onProperty sio:SIO_000245 ;
                    owl:someValuesFrom sio:SIO_010450 ] ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_010082 ;
            owl:someValuesFrom sio:SIO_010043 ],
        [ a owl:Class ;
            owl:complementOf [ a owl:Restriction ;
                    owl:onProperty sio:SIO_000053 ;
                    owl:someValuesFrom sio:SIO_010443 ] ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000244 ;
            owl:someValuesFrom sio:SIO_010450 ],
        sio:SIO_010099 .

sio:SIO_010283 a owl:Class ;
    rdfs:label "chemical transport"@en ;
    dcterms:description "chemical transport is the directed movement of a chemical entity by some agent (e.g. transporter)."@en ;
    sio:equivalentTo "biopax:Transport" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000132 ;
            owl:someValuesFrom sio:SIO_010004 ],
        sio:SIO_000575 .

sio:SIO_010289 a owl:Class ;
    rdfs:label "biochemical inhibition"@en ;
    dcterms:description "biochemical inhibition is a molecular interaction that decreases the catalytic rate of the target enzyme."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000355 ;
            owl:someValuesFrom sio:SIO_000550 ],
        sio:SIO_000611 .

sio:SIO_010295 a owl:Class ;
    rdfs:label "process up-regulation"@en ;
    dcterms:alternative "positive regulation"@en ;
    dcterms:description "process up-regulation is a process that increases the frequency, rate or extent of one or more processes in relation to a reference state."@en ;
    rdfs:subClassOf sio:SIO_000609 ;
    owl:disjointWith sio:SIO_010296 .

sio:SIO_010310 a owl:Class ;
    rdfs:label "anabolism"@en ;
    dcterms:description "Anabolism is the set of metabolic processes that construct larger chemical entities units from smaller chemical entities."@en ;
    rdfs:subClassOf sio:SIO_010308 .

sio:SIO_010336 a owl:Class ;
    rdfs:label "deoxyribonucleotide residue"@en ;
    dcterms:description "A deoxyribonucleotide residue is a part of a molecule that derives from a deoxyribonucleotide."@en ;
    rdfs:subClassOf sio:SIO_010075 ;
    owl:disjointWith sio:SIO_010337 .

sio:SIO_010342 a owl:Class ;
    rdfs:label "chemical complex"@en ;
    dcterms:description "A chemical complex is a chemical substance composed of weakly connected molecules and ions in a known stoichiometry."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000028 ;
            owl:someValuesFrom [ a owl:Restriction ;
                    owl:onProperty sio:SIO_000335 ;
                    owl:someValuesFrom sio:SIO_000004 ] ],
        sio:SIO_011126 .

sio:SIO_010344 a owl:Class ;
    rdfs:label "catalyst"@en ;
    dcterms:description "A catalyst is a molecule that has the capability to reduce the activation energy of a reaction and hence increase the overall rate of reaction."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000586 ;
            owl:someValuesFrom sio:SIO_000549 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000586 ;
            owl:someValuesFrom sio:SIO_000536 ],
        sio:SIO_011126 .

sio:SIO_010358 a owl:Class ;
    rdfs:label "to oxidize"@en ;
    dcterms:description "to oxidize is the capability to remove an electron or an increase in oxidation state of a chemical entity."@en ;
    rdfs:subClassOf sio:SIO_010360 .

sio:SIO_010359 a owl:Class ;
    rdfs:label "to reduce"@en ;
    dcterms:description "to reduce is the capability to add an electron or an decrease in oxidation state of a chemical entity."@en ;
    rdfs:subClassOf sio:SIO_010360 .

sio:SIO_010367 a owl:Class ;
    rdfs:label "to be combined"@en ;
    dcterms:description "to be combined is the capability to be modified in a way that the object is merged with another object to form a new object or substance."@en ;
    rdfs:subClassOf sio:SIO_010364 .

sio:SIO_010368 a owl:Class ;
    rdfs:label "to be transported"@en ;
    dcterms:description "to be transported is the disposition to undergo motion."@en ;
    rdfs:subClassOf sio:SIO_000692 .

sio:SIO_010411 a owl:Class ;
    rdfs:label "reagent"@en ;
    dcterms:description "A reagent is a substance that is added to a system in order to bring about a chemical reaction, or added to see if a reaction occurs."@en ;
    rdfs:subClassOf sio:SIO_010462 .

sio:SIO_010415 a owl:Class ;
    rdfs:label "host"@en ;
    dcterms:description "A host is an organism that harbors a parasite, or a mutual or commensal symbiont, typically providing nourishment and shelter."@en ;
    rdfs:subClassOf sio:SIO_010000 .

sio:SIO_010416 a owl:Class ;
    rdfs:label "buffer"@en ;
    dcterms:description "A buffer is a dissolved chemical substance that resists change in pH upon addition of small amounts of acid or base."@en ;
    rdfs:subClassOf sio:SIO_010427 .

sio:SIO_010423 a owl:Class ;
    rdfs:label "target"@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_011125 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000292 ;
                        owl:someValuesFrom sio:SIO_000006 ] ) ] .

sio:SIO_010425 a owl:Class ;
    rdfs:label "supernatant"@en ;
    dcterms:description "A supernatent is a liquid substance that remains after centrifugation."@en ;
    rdfs:subClassOf sio:SIO_010426 .

sio:SIO_010439 a owl:Class ;
    rdfs:label "messenger"@en ;
    dcterms:description "A mesenger is a molecule involved in either signal detection or signal propagation from receptors on the cell surface to target molecules inside the cell, in the cytoplasm or nucleus."@en ;
    rdfs:subClassOf sio:SIO_010437 .

sio:SIO_010443 a owl:Class ;
    rdfs:label "intron"@en ;
    dcterms:description "An intron is a region of a gene that is removed from the final protein open reading frame."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_010035 ],
        sio:SIO_010444 .

sio:SIO_010447 a owl:Class ;
    rdfs:label "start codon"@en ;
    dcterms:description "A start codon is the first codon of a messenger RNA (mRNA) transcript translated by a ribosome. The start codon is almost always preceded by an untranslated region 5' UTR."@en ;
    rdfs:subClassOf sio:SIO_010095 ;
    owl:disjointWith sio:SIO_010448 .

sio:SIO_010457 a owl:Class ;
    rdfs:label "cation"@en ;
    dcterms:description "An anion is an atom or molecule with a net positive electrical charge."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_010461 ],
        sio:SIO_010456 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_010456 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000217 ;
                        owl:someValuesFrom sio:SIO_010461 ] ) ] .

sio:SIO_010458 a owl:Class ;
    rdfs:label "anion"@en ;
    dcterms:description "An anion is an atom or molecule with a net negative electrical charge."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_010464 ],
        sio:SIO_010456 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_010456 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000217 ;
                        owl:someValuesFrom sio:SIO_010464 ] ) ] .

sio:SIO_010460 a owl:Class ;
    rdfs:label "nonpolar solvent"@en ;
    dcterms:description "A non-polar solvent is a solvent that exhibits a non-polar quality."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_001047 ],
        sio:SIO_010417 .

sio:SIO_010496 a owl:Class ;
    rdfs:label "ionic interaction"@en ;
    dcterms:description "An ionic interaction is a weak submolecular interaction between a charged submolecules."@en ;
    rdfs:subClassOf sio:SIO_010005 .

sio:SIO_010498 a owl:Class ;
    rdfs:label "single bond"@en ;
    dcterms:description "A single bond is a covalent bond between a pair of atoms in which one pair of electrons are shared."@en ;
    rdfs:subClassOf sio:SIO_011118 .

sio:SIO_010516 a owl:Class ;
    rdfs:label "organic reaction"@en ;
    dcterms:description "An organic reaction is a chemical reaction involving at least one organic molecule."@en ;
    rdfs:subClassOf sio:SIO_010345 .

sio:SIO_010520 a owl:Class ;
    rdfs:label "non-polar addition reaction"@en ;
    dcterms:description "A non-polar addition reaction is an addition reaction involving non-polar residues."@en ;
    rdfs:subClassOf sio:SIO_010518 .

sio:SIO_010530 a owl:Class ;
    rdfs:label "3d structure model"@en ;
    dcterms:description "A 3D structure model is a representation of the spatial arrangement of one or more chemical entities."@en ;
    rdfs:subClassOf sio:SIO_010023 .

sio:SIO_010532 a owl:Class ;
    rdfs:label "metabolic pathway"@en ;
    dcterms:description "A metabolic pathway is a series of biochemical reactions that begins with one or more substrates and ends with one or more products."@en ;
    rdfs:subClassOf sio:SIO_010525 ;
    owl:disjointWith sio:SIO_010533 .

sio:SIO_010674 a owl:Class ;
    rdfs:label "binary compound"@en ;
    dcterms:description "A binary compound is a mereological maximum sum of two kinds of weakly connected entities."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_011125 ;
            owl:onProperty sio:SIO_000273 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_011126 .

sio:SIO_010782 a owl:Class ;
    rdfs:label "heterocyclic ring"@en ;
    dcterms:description "A heterocyclic ring is a ring containing a hetero atom."@en ;
    rdfs:subClassOf sio:SIO_010780 ;
    owl:disjointWith sio:SIO_010783 .

sio:SIO_010785 a owl:Class ;
    rdfs:label "allotrope"@en ;
    dcterms:description "An allotrope is a structural variant of a chemical element."@en ;
    rdfs:subClassOf sio:SIO_010037 .

sio:SIO_011002 a owl:Class ;
    rdfs:label "hydrogen atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:49637" .

sio:SIO_011007 a owl:Class ;
    rdfs:label "oxygen atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:25805" .

sio:SIO_011120 a owl:Class ;
    rdfs:label "molecular structure file"@en ;
    dcterms:description "A molecular structure file is a file that contains a description of molecular structure."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000028 ;
            owl:someValuesFrom sio:SIO_000072 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000028 ;
            owl:someValuesFrom sio:SIO_011121 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000214 ;
            owl:someValuesFrom sio:SIO_011119 ],
        sio:SIO_000396 .

sio:SIO_000009 a owl:Class ;
    rdfs:label "social entity"@en ;
    dcterms:description "A social entity pertains to the interaction among individuals and groups."@en ;
    rdfs:subClassOf sio:SIO_000015 .

sio:SIO_000017 a owl:Class ;
    rdfs:label "function"@en ;
    dcterms:description "A function is a capability that satisfies some agentive objective, or (evolutionary) optimization."@en ;
    sio:subset "core" ;
    rdfs:subClassOf sio:SIO_000112 ;
    owl:disjointWith sio:SIO_000354 .

sio:SIO_000019 a owl:Class ;
    rdfs:label "site"@en ;
    dcterms:description "A site is a spatial region bounded (in part or in whole) by material entities and may be occupied by material entities."@en ;
    rdfs:subClassOf sio:SIO_000370 ;
    skos:example "A nostril; the interior of the heart valve; the interior of a bottle."@en .

sio:SIO_000029 a owl:ObjectProperty ;
    rdfs:label "is time boundary of"@en ;
    rdfs:domain sio:SIO_000418 ;
    rdfs:subPropertyOf sio:SIO_000096 ;
    owl:inverseOf sio:SIO_000679 .

sio:SIO_000044 a owl:Class ;
    rdfs:label "2D extent quantity"@en ;
    dcterms:description "A quantity that extends in two dimensions."@en ;
    rdfs:subClassOf sio:SIO_000037 .

sio:SIO_000051 a owl:Class ;
    rdfs:label "compositional quality"@en ;
    dcterms:description "composition quality is a quality that describes its composition or anatomy."@en ;
    rdfs:subClassOf sio:SIO_000026 .

sio:SIO_000061 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is located in"@en ;
    dcterms:description "A is located in B iff the spatialtemporial region occupied by A is part of the spatialtemporal region occupied by B. [T][R]"@en ;
    sio:equivalentTo "OBO_REL:located_in" ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000322 ;
    owl:inverseOf sio:SIO_000145 ;
    skos:example "A parasite in the interior of a person's intestine is located in their intestinal lumen."@en .

sio:SIO_000071 a owl:Class ;
    rdfs:label "coordinate"@en ;
    dcterms:description "A coordinate is a measurement of position in n-dimensional space."@en ;
    rdfs:subClassOf sio:SIO_000056 .

sio:SIO_000088 a owl:Class ;
    rdfs:label "record"@en ;
    dcterms:description "A record is a document containing a collection of statements about some entity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000673 ;
            owl:someValuesFrom sio:SIO_000115 ],
        sio:SIO_000148 .

sio:SIO_000101 a owl:Class ;
    rdfs:label "software application"@en ;
    dcterms:description "A software application is software that can be directly executed by some processing unit."@en ;
    rdfs:subClassOf sio:SIO_000097 .

sio:SIO_000114 a owl:Class ;
    rdfs:label "word"@en ;
    dcterms:description "A word is the smallest free form (an item that may be expressed in isolation with semantic or pragmatic content) in a language."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000028 ;
            owl:someValuesFrom sio:SIO_001040 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_000108 ],
        sio:SIO_000078 .

sio:SIO_000141 a owl:Class ;
    rdfs:label "criterion"@en ;
    dcterms:description "A criterion is a specification to describe properties used for evaluation."@en ;
    rdfs:subClassOf sio:SIO_000316 .

sio:SIO_000144 a owl:Class ;
    rdfs:label "parameter"@en ;
    dcterms:description "A parameter is variable whose value changes the characteristics of a system or a function."@en ;
    rdfs:subClassOf sio:SIO_000920 .

sio:SIO_000202 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "contains"@en ;
    dcterms:description "A contains B iff the spatial region occupied by A has the spatial region occupied by B as a part, and B is not part of A. [T]"@en ;
    rdfs:subPropertyOf sio:SIO_000145 .

sio:SIO_000205 a owl:ObjectProperty ;
    rdfs:label "is represented by"@en ;
    dcterms:description "is represented by: a relation between an entity and some symbol."@en ;
    rdfs:subPropertyOf sio:SIO_000212 ;
    owl:inverseOf sio:SIO_000210 .

sio:SIO_000214 a owl:ObjectProperty ;
    rdfs:label "is concretization of"@en ;
    dcterms:description "A is concretization of B iff A is a quality of a material entity and B is an informational entity."@en ;
    rdfs:subPropertyOf sio:SIO_000425 .

sio:SIO_000215 a owl:ObjectProperty ;
    rdfs:label "is measurement value of"@en ;
    dcterms:description "is measurement value of is a relation between a value and the entity that it is a measurement of."@en ;
    rdfs:domain sio:SIO_000070 ;
    rdfs:subPropertyOf sio:SIO_000011 ;
    owl:inverseOf sio:SIO_000216 .

sio:SIO_000219 a owl:ObjectProperty ;
    rdfs:label "is source of"@en ;
    dcterms:description "is source of is a relation between a source of information about some entity."@en ;
    rdfs:subPropertyOf sio:SIO_000011 ;
    owl:inverseOf sio:SIO_000253 .

sio:SIO_000221 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has unit"@en ;
    dcterms:description "has unit is a relation between a quantity and the unit it is a multiple of."@en ;
    sio:subset "core" ;
    rdfs:domain sio:SIO_000075 ;
    rdfs:range sio:SIO_000074 ;
    rdfs:subPropertyOf sio:SIO_000008 ;
    owl:inverseOf sio:SIO_000222 .

sio:SIO_000223 a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has property"@en ;
    dcterms:description "has property is a relation between an entity and the quality, capability or role that it and it alone bears."@en ;
    rdfs:subPropertyOf sio:SIO_000008 ;
    owl:inverseOf sio:SIO_000224 ;
    skos:example "michel's hair has the quality of being brown in colour."@en .

sio:SIO_000240 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is positionally before"@en ;
    dcterms:description "is positionally before is a relation between entities placed on a dimensional axis in which the projection of the position of the first entity is numerically less than the projection of the position of the second entity."@en ;
    rdfs:subPropertyOf sio:SIO_000203 .

sio:SIO_000249 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is preceded by"@en ;
    sio:equivalentTo "OBO_REL:preceded_by" ;
    rdfs:subPropertyOf sio:SIO_000294 .

sio:SIO_000252 a owl:ObjectProperty ;
    rdfs:label "is referenced by"@en ;
    dcterms:description "is reference for is a relation between a document that provides information about an entity."@en ;
    rdfs:subPropertyOf sio:SIO_000212 ;
    owl:inverseOf sio:SIO_000631 .

sio:SIO_000261 a owl:Class ;
    rdfs:label "premise"@en ;
    dcterms:description "A premise is a proposition of an argument from which the conclusion is drawn."@en ;
    rdfs:subClassOf sio:SIO_000256 .

sio:SIO_000284 a owl:Class ;
    rdfs:label "hypothesis"@en ;
    dcterms:description "A hypothesis is a proposed explanation for a phenomenon."@en ;
    rdfs:subClassOf sio:SIO_000256 .

sio:SIO_000285 a owl:Class ;
    rdfs:label "academic organization"@en ;
    dcterms:description "An academic organization is a lawfully recognized organization that confers diplomas, degrees and other forms of recognition of academic achievement."@en ;
    rdfs:subClassOf sio:SIO_000012 .

sio:SIO_000307 a owl:Class ;
    rdfs:label "normality"@en ;
    dcterms:description "normality is the quality in which the value may differ from normal or average"@en ;
    rdfs:subClassOf sio:SIO_000005 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_000554 sio:SIO_000555 ) ] .

sio:SIO_000321 a owl:Class ;
    rdfs:label "cartesian coordinate system"@en ;
    dcterms:description "A Cartesian coordinate system specifies each point uniquely in a plane by a pair of numerical coordinates, which are the signed distances from the point to two fixed perpendicular directed lines, measured in the same unit of length."@en ;
    rdfs:subClassOf sio:SIO_000320 .

sio:SIO_000341 a owl:ObjectProperty ;
    rdfs:label "is manifested as"@en ;
    dcterms:description "is manifested as is a relation between an expression and its manifestations."@en ;
    rdfs:subPropertyOf sio:SIO_000425 ;
    owl:inverseOf sio:SIO_000426 ;
    skos:example "the english language version of 'war of the worlds' is manifested as a collection of english language versions of the book."@en .

sio:SIO_000349 a owl:Class ;
    rdfs:label "to separate"@en ;
    dcterms:description "to separate is the capability to i) distinguish some entities based on some attribute(s) and ii) subsequently physically displace them."@en ;
    rdfs:subClassOf sio:SIO_000343 .

sio:SIO_000350 a owl:Class ;
    rdfs:label "to ionize"@en ;
    dcterms:description "to ionize is the capability to physically convert an atom or molecule into an ion by adding or removing charged particles such as electrons or other ions."@en ;
    rdfs:subClassOf sio:SIO_001087 .

sio:SIO_000353 a owl:Class ;
    rdfs:label "to observe"@en ;
    dcterms:description "to observe is the capability to watch attentively."@en ;
    rdfs:subClassOf sio:SIO_000639 .

sio:SIO_000362 a owl:ObjectProperty ;
    rdfs:label "satisfies"@en ;
    dcterms:description "satisfies is a relation between an entity and the specification or objective that it conforms to."@en ;
    rdfs:domain sio:SIO_000000 ;
    rdfs:range sio:SIO_000136 ;
    rdfs:subPropertyOf sio:SIO_000008 ;
    owl:inverseOf sio:SIO_000363 .

sio:SIO_000366 a owl:Class ;
    rdfs:label "number"@en ;
    dcterms:alternative "rank 0 tensor"@en ;
    dcterms:description "A number is a tensor of rank 0."@en ;
    rdfs:subClassOf sio:SIO_001431 .

sio:SIO_000368 a owl:Class ;
    rdfs:label "equation"@en ;
    dcterms:description "An equation is a mathematical statement that asserts the equality of two expressions."@en ;
    rdfs:subClassOf sio:SIO_000075 .

sio:SIO_000374 a owl:Class ;
    rdfs:label "to reduce energy"@en ;
    dcterms:description "to reduce energy is the capability to remove energy from a source."@en ;
    rdfs:subClassOf sio:SIO_000385 .

sio:SIO_000396 a owl:Class ;
    rdfs:label "file"@en ;
    dcterms:description "A file is an information-bearing object that contains a physical embodiment of some information using a particular character encoding."@en ;
    sio:equivalentTo "http://www.w3.org/ns/dcat#Distribution"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_001194 .

sio:SIO_000403 a owl:Class ;
    rdfs:label "study group"@en ;
    dcterms:description "A study group is a group of individuals that are subjects in an observational or intervention study."@en ;
    rdfs:subClassOf sio:SIO_000620 .

sio:SIO_000406 a owl:Class ;
    rdfs:label "academic"@en ;
    dcterms:description "An academic is an individual that participates in education and scholarship."@en ;
    rdfs:subClassOf sio:SIO_000498 .

sio:SIO_000408 a owl:Class ;
    rdfs:label "to investigate"@en ;
    dcterms:description "to investigate is the capability to uncover facts."@en ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_000414 a owl:Class ;
    rdfs:label "geographic region"@en ;
    dcterms:description "A geographic region is a spatial region whose boundaries are typically defined against some material frame of reference (like the earth)."@en ;
    rdfs:subClassOf sio:SIO_000370 ;
    skos:example "The spatial region occupied by the province of ontario; the spatial region occupied by a lake."@en .

sio:SIO_000424 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is narrower than (t)"@en ;
    dcterms:description "A is narrower than B (t) iff for A is narrower than B."@en ;
    sio:equivalentTo "http://www.w3.org/2004/02/skos/core#broaderTransitive" ;
    rdfs:domain sio:SIO_000275 ;
    rdfs:range sio:SIO_000275 ;
    rdfs:subPropertyOf sio:SIO_000283 .

sio:SIO_000450 a owl:Class ;
    rdfs:label "axis"@en ;
    dcterms:description """An axis is a line segment that is part of a statistical graph in which the 
position along the line corresponds to a numeric or categorical value."""@en ;
    schema1:comment "The value of a plotted geometric objects (e.g. point) can be obtained from the perpendicular projection of the position of the object onto the axis. Axis may also be associated with a textual description of what the values on the axis represents." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000313 ;
            owl:someValuesFrom sio:SIO_000083 ],
        sio:SIO_000521 ;
    skos:example """The left vertical and bottom horizontal lines with tickmarks in 
Graph 1 http://tinyurl.com/opwnvm"""@en .

sio:SIO_000455 a owl:Class ;
    rdfs:label "category axis"@en ;
    dcterms:description "A category axis is an axis in which the position along the line is partioned into categories."@en ;
    rdfs:subClassOf sio:SIO_000450 ;
    owl:disjointWith sio:SIO_000458 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_000456 sio:SIO_000457 ) ] ;
    skos:example """The horizontal axis corresponding to months of the year in graph 4 
of http://tinyurl.com/opwnvm"""@en .

sio:SIO_000457 a owl:Class ;
    rdfs:label "secondary category axis"@en ;
    dcterms:description "A secondary category axis is a category axis that defines a finer granular part (or subset) of the value range of the primary category axis."@en ;
    rdfs:subClassOf sio:SIO_000455 ;
    skos:example """The category axis that corresponds to months in Graph 1 of 
http://tinyurl.com/opwnvm"""@en .

sio:SIO_000459 a owl:Class ;
    rdfs:label "left value axis"@en ;
    dcterms:description "A left value axis is a value axis that is spatially positioned to the left of the plot area."@en ;
    rdfs:subClassOf sio:SIO_000458 ;
    skos:example "The value axis that ranges from 3.0 to 7.4 and corresponds to billions of dollars in Graph 1 of http://tinyurl.com/opwnvm"@en .

sio:SIO_000460 a owl:Class ;
    rdfs:label "right value axis"@en ;
    dcterms:description "A right value axis is a value axis that is spatially positioned to the right of the plot area."@en ;
    rdfs:subClassOf sio:SIO_000458 .

sio:SIO_000461 a owl:Class ;
    rdfs:label "scaled value axis"@en ;
    dcterms:description "A scaled value axis is a value axis in which the value range was subject to a mathematic transformation."@en ;
    rdfs:subClassOf sio:SIO_000458 .

sio:SIO_000470 a owl:Class ;
    rdfs:label "primary title"@en ;
    dcterms:description "A primary title is a title that should be first used in describing some entity."@en ;
    rdfs:subClassOf sio:SIO_000185 .

sio:SIO_000472 a owl:Class ;
    rdfs:label "scientific data"@en ;
    dcterms:description "scientific data is data obtained from some scientific procedure."@en ;
    rdfs:subClassOf sio:SIO_000069 .

sio:SIO_000476 a owl:Class ;
    rdfs:label "cellular quality"@en ;
    dcterms:description "cellular quality is the quality of a cell"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000218 ;
            owl:someValuesFrom sio:SIO_010001 ],
        sio:SIO_000475 .

sio:SIO_000477 a owl:ObjectProperty ;
    rdfs:label "is broader than"@en ;
    sio:equivalentTo "http://www.w3.org/2004/02/skos/core#narrower" ;
    rdfs:subPropertyOf sio:SIO_000422 .

sio:SIO_000478 a owl:Class ;
    rdfs:label "sequence variant role"@en ;
    dcterms:description "A sequence variant role is a comparative role in which the composition of characters in a sequence differs when compared to another entity of similar type."@en ;
    rdfs:subClassOf sio:SIO_000479 .

sio:SIO_000495 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is dissimilar to"@en ;
    dcterms:description "is dissimilar to is a relation between two entities in which one is considered dissimilar to the other based on some criteria."@en ;
    rdfs:subPropertyOf sio:SIO_000272 .

sio:SIO_000497 a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "is version of"@en ;
    dcterms:description "is version of is a relation that holds between any two versions in which one is a subsequent or alternate version of (through a branch)."@en ;
    rdfs:subPropertyOf sio:SIO_000272 .

sio:SIO_000501 a owl:Class ;
    rdfs:label "polygon edge"@en ;
    dcterms:description "A polygon edge is a line segment joining two polygon vertices."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_000505 ],
        [ a owl:Restriction ;
            owl:onClass sio:SIO_000500 ;
            owl:onProperty sio:SIO_000369 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_000512 .

sio:SIO_000510 a owl:Class ;
    rdfs:label "model"@en ;
    dcterms:description "A model is a representation of some thing."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000210 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000612 .

sio:SIO_000513 a owl:Class ;
    rdfs:label "tick mark"@en ;
    dcterms:description "A tick mark is a line segment that is spatially positioned perpendicular to the axis of a statistical graph and indicates the position of a specific numeric value (which may be indicated by an adjacent value label) on a value axis, or is one of a pair of tick marks that delineates the boundary of a categorical value (which may be indicated by an adjacent category label) on the categorical axis."@en ;
    rdfs:subClassOf sio:SIO_000512 .

sio:SIO_000521 a owl:Class ;
    rdfs:label "directed line segment"@en ;
    dcterms:description """A directed line segment is a line segment that is contained by an ordered pair 
of endpoints (a start point and an endpoint)."""@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_000509 ;
            owl:onProperty sio:SIO_000369 ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass sio:SIO_000508 ;
            owl:onProperty sio:SIO_000369 ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        sio:SIO_000512 .

sio:SIO_000522 a owl:Class ;
    rdfs:label "arrowed line segment"@en ;
    dcterms:description "An arrowed line is a directed line segment in which one or both endpoints is tangentially part of a triangle that bisects the line."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_000520 ;
            owl:onProperty sio:SIO_000369 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000028 ;
            owl:someValuesFrom sio:SIO_000520 ],
        sio:SIO_000521 .

sio:SIO_000534 a owl:Class ;
    rdfs:label "positionally oriented line"@en ;
    dcterms:description "A positionally oriented line is a line that is positioned against some axis of reference."@en ;
    rdfs:subClassOf sio:SIO_000511 .

sio:SIO_000535 a owl:Class ;
    rdfs:label "statistical graph line"@en ;
    dcterms:description "A statistical graph line is a line used in a statistical graph to communicate some trend or feature of the embedded data."@en ;
    rdfs:subClassOf sio:SIO_000511 .

sio:SIO_000539 a owl:Class ;
    rdfs:label "infinite line"@en ;
    dcterms:description "An infinite line is a line that extends outwards in both directions of a single dimensional and is not bounded by terminal points."@en ;
    rdfs:subClassOf sio:SIO_000511 .

sio:SIO_000540 a owl:Class ;
    rdfs:label "vector line"@en ;
    dcterms:description "A vector line is a line which that is bounded by a startpoint and extends outwards along one dimension."@en ;
    rdfs:subClassOf sio:SIO_000516 .

sio:SIO_000550 a owl:Class ;
    rdfs:label "to increase the activation energy"@en ;
    dcterms:alternative "to inhibit" ;
    dcterms:description "to increase the activation energy is to require a larger amount of energy in order to form or break a chemical bond."@en ;
    rdfs:subClassOf sio:SIO_000551 .

sio:SIO_000551 a owl:Class ;
    rdfs:label "to change the activation energy"@en ;
    dcterms:description "to change the activation energy is to change the amount of energy required to form or break a chemical bond."@en ;
    rdfs:subClassOf sio:SIO_000385 .

sio:SIO_000556 a owl:Class ;
    rdfs:label "lipid residue"@en ;
    dcterms:description "A lipid residue is a part of an organic molecule that was derived from a lipid molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_010011 ],
        sio:SIO_010071 .

sio:SIO_000557 a owl:ObjectProperty ;
    rdfs:label "is described by"@en ;
    dcterms:description "is described by is a relation between one entity and another entity that provides a description (detailed account) of it."@en ;
    rdfs:subPropertyOf sio:SIO_000212 ;
    owl:inverseOf sio:SIO_000563 .

sio:SIO_000569 a owl:Class ;
    rdfs:label "differential equation"@en ;
    dcterms:description "A differential equation is a mathematical equation for an unknown function of one or several variables that relates the values of the function itself and its derivatives of various orders."@en ;
    rdfs:subClassOf sio:SIO_000368 .

sio:SIO_000570 a owl:Class ;
    rdfs:label "movement"@en ;
    dcterms:description "movement is the process in which an object is spatially displaced."@en ;
    sio:subset "core" ;
    rdfs:subClassOf sio:SIO_000006 .

sio:SIO_000576 a owl:Class ;
    rdfs:label "membrane transport"@en ;
    dcterms:description "membrane transport is the movement of molecules across a membrane."@en ;
    rdfs:subClassOf sio:SIO_010283 .

sio:SIO_000589 a owl:Class ;
    rdfs:label "regulating"@en ;
    dcterms:alternative "regulation"@en ;
    dcterms:description "regulating is a process that modulates the attributes of an object or process."@en ;
    rdfs:subClassOf sio:SIO_000593 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_001132 sio:SIO_010295 sio:SIO_010296 ) ] .

sio:SIO_000590 a owl:Class ;
    rdfs:label "biosynthesis"@en ;
    dcterms:description "biosynthesis is the synthesis of an organic compound in a living organism, usually aided by enzymes."@en ;
    rdfs:subClassOf sio:SIO_000559 .

sio:SIO_000591 a owl:Class ;
    rdfs:label "destroying"@en ;
    dcterms:alternative "destruction"@en ;
    dcterms:description "destroying is a process in which something is broken down and/or ceases to exist."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000905 ;
            owl:someValuesFrom sio:SIO_000776 ],
        sio:SIO_000593 .

sio:SIO_000611 a owl:Class ;
    rdfs:label "regulation of catalytic capability"@en ;
    dcterms:description "the regulation of the enzymatic activity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_001154 ;
            owl:someValuesFrom sio:SIO_000376 ],
        sio:SIO_000610 .

sio:SIO_000612 a owl:Class ;
    rdfs:label "representation"@en ;
    dcterms:description "A representation is a entity that in some way represents another entity (or attribute thereof)."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000632 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000015 .

sio:SIO_000621 a owl:Class ;
    rdfs:label "formal specification"@en ;
    dcterms:description "A formal specification is a mathematical description of software or hardware that may be used to develop an implementation."@en ;
    rdfs:subClassOf sio:SIO_000315 .

sio:SIO_000625 a owl:Class ;
    rdfs:label "chemical structure"@en ;
    dcterms:description "chemical structure is the structure of a chemical entity in terms of its molecular geometry and electronic structure."@en ;
    rdfs:subClassOf sio:SIO_000600 .

sio:SIO_000657 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is transformed from"@en ;
    dcterms:description "A transitive temporal relation in which an entity mainstains identity from one state to another."@en ;
    rdfs:subPropertyOf sio:SIO_000352 .

sio:SIO_000671 a owl:ObjectProperty ;
    rdfs:label "has identifier"@en ;
    dcterms:description "a relation between an entity and an identifier." ;
    rdfs:range sio:SIO_000115 ;
    rdfs:subPropertyOf sio:SIO_000008 ;
    owl:inverseOf sio:SIO_000672 .

sio:SIO_000677 a owl:Class ;
    rdfs:label "processual role"@en ;
    dcterms:description "A processual role is a role that can only be realized in a process."@en ;
    rdfs:subClassOf sio:SIO_000016 .

sio:SIO_000678 a owl:Class ;
    rdfs:label "abstract role"@en ;
    dcterms:description "An abstract role is a role whose basis lies in spatial/temporal or comparative relations. "@en ;
    rdfs:subClassOf sio:SIO_000016 .

sio:SIO_000687 a owl:ObjectProperty ;
    rdfs:label "exists at"@en ;
    dcterms:description "exists at is a relation between an entity and a time measurement."@en ;
    sio:subset "core" ;
    rdfs:range sio:SIO_000391 ;
    rdfs:subPropertyOf sio:SIO_000322 .

sio:SIO_000694 a owl:Class ;
    rdfs:label "to be passively interacted with"@en ;
    dcterms:description "to be passively interacted with is the capability of an object to be observed."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000709 ;
            owl:someValuesFrom sio:SIO_000639 ],
        sio:SIO_000702 .

sio:SIO_000696 a owl:Class ;
    rdfs:label "to be observed"@en ;
    dcterms:description "to be observed is the capability of an object to be perceived."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000697 ;
            owl:someValuesFrom sio:SIO_000353 ],
        sio:SIO_000694 .

sio:SIO_000716 a owl:Class ;
    rdfs:label "medical practitioner"@en ;
    dcterms:description "A medical practioner is an individual that provides medical care."@en ;
    rdfs:subClassOf sio:SIO_000498 .

sio:SIO_000720 a owl:Class ;
    rdfs:label "to be translocated"@en ;
    dcterms:alternative "to be moved"@en ;
    dcterms:description "to be translocated is the capability to be physically displaced from one location to another"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000697 ;
            owl:someValuesFrom sio:SIO_000719 ],
        sio:SIO_000702 .

sio:SIO_000724 a owl:Class ;
    rdfs:label "to examine"@en ;
    dcterms:description "to examine is the capability to make detailed observation. "@en ;
    rdfs:subClassOf sio:SIO_000353 .

sio:SIO_000732 a owl:Class ;
    rdfs:label "molecular identifier"@en ;
    dcterms:description "A molecular identifier is an identifier for a molecular entity."@en ;
    rdfs:subClassOf sio:SIO_000728 .

sio:SIO_000733 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is lesser than or equal to"@en ;
    dcterms:description "is greater than to is a comparison relation between two quantities in which the first has a value smaller or equal to the second."@en ;
    rdfs:subPropertyOf sio:SIO_000737 .

sio:SIO_000734 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is greater than"@en ;
    dcterms:description "is greater than to is a comparison relation between two quantities in which the first has a value larger than the second."@en ;
    rdfs:subPropertyOf sio:SIO_000699 ;
    owl:inverseOf sio:SIO_000735 .

sio:SIO_000741 a owl:Class ;
    rdfs:label "stationary point"@en ;
    dcterms:description "A stationary point is a point that is part of a curve in which the derivative at that point is zero, and hence its value is at least a local maximum or minimum."@en ;
    rdfs:subClassOf sio:SIO_000465 .

sio:SIO_000750 a owl:Class ;
    rdfs:label "database"@en ;
    dcterms:description "A database is a set of tables."@en ;
    rdfs:subClassOf sio:SIO_000602 .

sio:SIO_000751 a owl:Class ;
    rdfs:label "decreased"@en ;
    dcterms:description "A quality that has a value that is decreased compared to normal or average."@en ;
    sio:equivalentTo "PATO:0002301" ;
    rdfs:subClassOf sio:SIO_000555 .

sio:SIO_000752 a owl:Class ;
    rdfs:label "row"@en ;
    dcterms:description "A row represents a single, implicitly structured data item in a table. "@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000053 ;
            owl:someValuesFrom sio:SIO_000755 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000671 ;
            owl:someValuesFrom sio:SIO_000115 ],
        sio:SIO_000602 .

sio:SIO_000753 a owl:Class ;
    rdfs:label "column"@en ;
    dcterms:description "A column is a vertical sequence of cells in a cellular automata."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_000116 ;
            owl:onProperty sio:SIO_000008 ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000755 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000300 ;
                                owl:someValuesFrom rdfs:Literal ] [ a owl:Restriction ;
                                owl:allValuesFrom rdfs:Literal ;
                                owl:onProperty sio:SIO_000300 ] ) ] ;
            owl:onProperty sio:SIO_000338 ],
        sio:SIO_000602 .

sio:SIO_000754 a owl:Class ;
    rdfs:label "database table"@en ;
    dcterms:description "A database table is a set of named columns with zero or more rows composed of cells that contain column values and is part of a database."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000750 ],
        sio:SIO_000602 .

sio:SIO_000789 a owl:Class ;
    rdfs:label "sequence element position"@en ;
    dcterms:description "A sequence element position is the position of an element of a linear sequence."@en ;
    rdfs:subClassOf sio:SIO_000788 .

sio:SIO_000795 a owl:Class ;
    rdfs:label "chemical entity role"@en ;
    dcterms:description "A chemical role is a processual role held by a chemical entity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000227 ;
            owl:someValuesFrom sio:SIO_010004 ],
        sio:SIO_000677 .

sio:SIO_000800 a owl:Class ;
    rdfs:label "co-enzyme role"@en ;
    dcterms:description "A co-factor role in which the chemical entity is modified during catalysis and must be regenerated."@en ;
    rdfs:subClassOf sio:SIO_000797,
        sio:SIO_000799 .

sio:SIO_000806 a owl:Class ;
    rdfs:label "uncharged"@en ;
    dcterms:description "The quality of not having a charge."@en ;
    rdfs:subClassOf sio:SIO_010442 .

sio:SIO_000808 a owl:Class ;
    rdfs:label "partial negative charge"@en ;
    dcterms:description "A partial positive charge is a partial charge where the value of the charge is positive."@en ;
    rdfs:subClassOf sio:SIO_000809 .

sio:SIO_000809 a owl:Class ;
    rdfs:label "partial charge"@en ;
    dcterms:description "The quality of having a charge that is not a full multiple of 1 unit charge."@en ;
    rdfs:subClassOf sio:SIO_000805 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_000807 sio:SIO_000808 ) ] .

sio:SIO_000810 a owl:Class ;
    rdfs:label "complete charge"@en ;
    dcterms:description "A complete charge is a charge where the value of the charge is a multiple of 1."@en ;
    rdfs:subClassOf sio:SIO_000805 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_010461 sio:SIO_010464 ) ] .

sio:SIO_000837 a owl:Class ;
    rdfs:label "fear"@en ;
    dcterms:description "Fear is a negative emotion induced by a perceived threat that induces one to hide or move quickly away from the location of the perceived threat."@en ;
    rdfs:subClassOf sio:SIO_000949 .

sio:SIO_000876 a owl:Class ;
    rdfs:label "student advisor role"@en ;
    dcterms:description "A student advisor role is the role of an individual employed at an academic organization that is involved in advising students."@en ;
    rdfs:subClassOf sio:SIO_000711 .

sio:SIO_000879 a owl:Class ;
    rdfs:label "reactant role"@en ;
    dcterms:description "The role of a chemical entity present at the beginning of a chemical reaction."@en ;
    rdfs:subClassOf sio:SIO_000889 .

sio:SIO_000881 a owl:Class ;
    rdfs:label "investigational role"@en ;
    dcterms:description "An investigational role is a role held by participants involved in an investigation."@en ;
    rdfs:subClassOf sio:SIO_000677 .

sio:SIO_000884 a owl:Class ;
    rdfs:label "publishing role"@en ;
    dcterms:description "A publishing role is the role of an individual that is involved in the preparation and issue of creative works for consumption by a wider audience."@en ;
    rdfs:subClassOf sio:SIO_000706 .

sio:SIO_000902 a owl:Class ;
    rdfs:label "top value axis"@en ;
    dcterms:description "A top value axis is a value axis that is spatially positioned to the top of the plot area."@en ;
    rdfs:subClassOf sio:SIO_000458 .

sio:SIO_000903 a owl:Class ;
    rdfs:label "bottom value axis"@en ;
    dcterms:description "A bottom value axis is a value axis that is spatially positioned to the bottom of the plot area."@en ;
    rdfs:subClassOf sio:SIO_000458 .

sio:SIO_000905 a owl:ObjectProperty ;
    rdfs:label "has substrate"@en ;
    dcterms:description "has substrate is a relation between a process and an object where the object is destroyed by its participation in the process."@en ;
    rdfs:subPropertyOf sio:SIO_000291 .

sio:SIO_000940 a owl:Class ;
    rdfs:label "mereological chart"@en ;
    dcterms:description "A mereological chart is a chart that illustrates the parts in the context of the whole."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000943 a owl:Class ;
    rdfs:label "start position"@en ;
    dcterms:description "A start position is the proximal position of an object relative to an origin in a linear system."@en ;
    rdfs:subClassOf sio:SIO_000788 .

sio:SIO_000953 a owl:Class ;
    rdfs:label "end position"@en ;
    dcterms:alternative "stop position" ;
    dcterms:description "An end position is the distal position of an object relative to an origin in a linear system."@en ;
    rdfs:subClassOf sio:SIO_000788 .

sio:SIO_000957 a owl:Class ;
    rdfs:label "communication device"@en ;
    dcterms:description "A communication device is a device that facilitates the transmission of information through encoded in an audio or digital signal between a sender and a receiver."@en ;
    rdfs:subClassOf sio:SIO_000956 .

sio:SIO_000965 a owl:Class ;
    rdfs:label "agreement quality"@en ;
    dcterms:description "agreement quality is a quality that exhibits the degree of consensus for some set of assertions."@en ;
    rdfs:subClassOf sio:SIO_000436 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_000966 sio:SIO_000967 ) ] .

sio:SIO_000974 a owl:ObjectProperty ;
    rdfs:label "has ordered part"@en ;
    dcterms:description "has ordered part of is a proper part relation in which the part is one of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system."@en ;
    rdfs:subPropertyOf sio:SIO_000053 .

sio:SIO_000983 a owl:Class ;
    rdfs:label "gene-disease association"@en ;
    dcterms:description "A gene-disease association is an association between a gene and a disease."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000628 ;
            owl:someValuesFrom sio:SIO_010035 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000628 ;
            owl:someValuesFrom sio:SIO_010299 ],
        sio:SIO_000897 .

sio:SIO_001004 a owl:Class ;
    rdfs:label "opinion"@en ;
    dcterms:description "An opinion is a belief that is the result of emotion or interpretation of facts. "@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000311 ;
            owl:someValuesFrom sio:SIO_001001 ],
        sio:SIO_000360 .

sio:SIO_001008 a owl:Class ;
    rdfs:label "toxicity"@en ;
    dcterms:description "toxicity is the quality of a chemical substance to cause injury to an organism in a dose dependent manner."@en ;
    rdfs:subClassOf sio:SIO_001011 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_001009 sio:SIO_001010 ) ] .

sio:SIO_001010 a owl:Class ;
    rdfs:label "non toxic"@en ;
    dcterms:description "non toxic is the quality of a substance having no damaging effect to a system."@en ;
    rdfs:subClassOf sio:SIO_001008 .

sio:SIO_001034 a owl:Class ;
    rdfs:label "reviewed"@en ;
    dcterms:description "reviewed is the quality of a textual entity that has been examined and commented on by another party."@en ;
    rdfs:subClassOf sio:SIO_001039 .

sio:SIO_001045 a owl:Class ;
    rdfs:label "polar quality"@en ;
    dcterms:description "The quality of being polar or not polar."@en ;
    rdfs:subClassOf sio:SIO_001011 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_001046 sio:SIO_001047 ) ] .

sio:SIO_001046 a owl:Class ;
    rdfs:label "polar"@en ;
    dcterms:description "polar is the quality of having a dipole."@en ;
    rdfs:subClassOf sio:SIO_001045 ;
    owl:disjointWith sio:SIO_001047 .

sio:SIO_001050 a owl:Class ;
    rdfs:label "sample"@en ;
    dcterms:description "A sample is a limited quantity of something (e.g. an individual or set of individuals from a population, or a portion of a substance) to be used for testing, analysis, inspection, investigation, demonstration, or trial use."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000095 ;
                        owl:someValuesFrom sio:SIO_000616 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000244 ;
                        owl:someValuesFrom sio:SIO_000776 ] ) ],
        sio:SIO_010462 .

sio:SIO_001071 a owl:Class ;
    rdfs:label "text span start position"@en ;
    dcterms:description "text span start position is the position (offset) of the first character of a text span in relation the text it is from."@en ;
    rdfs:subClassOf sio:SIO_000943 .

sio:SIO_001072 a owl:Class ;
    rdfs:label "text span end position"@en ;
    dcterms:description "text span end position is the position (offset) of the last character of a text span in relation the text it is from." ;
    rdfs:subClassOf sio:SIO_000953 .

sio:SIO_001074 a owl:Class ;
    rdfs:label "t-statistic"@en ;
    dcterms:description "A t-statistic is a ratio of the departure of an estimated parameter from its notional value and its standard error. "@en ;
    rdfs:subClassOf sio:SIO_001018 .

sio:SIO_001078 a owl:Class ;
    rdfs:label "differential gene expression ratio"@en ;
    dcterms:description "A differential gene expression ratio is the ratio of gene expression values from a test sample compared to a control sample."@en ;
    rdfs:subClassOf sio:SIO_001018 .

sio:SIO_001087 a owl:Class ;
    rdfs:label "to modify electronically"@en ;
    dcterms:description "to modify electronically is the capability to change the electronic properties of an object."@en ;
    rdfs:subClassOf sio:SIO_000385 .

sio:SIO_001107 a owl:Class ;
    rdfs:label "pathway"@en ;
    dcterms:alternative "biological pathway" ;
    dcterms:description "A pathway is an effective specification that outlines a set of actions that forms a way to achieve an objective."@en ;
    rdfs:subClassOf sio:SIO_000091 .

sio:SIO_001119 a owl:Class ;
    rdfs:label "gene-disease association linked with causal mutation"@en ;
    dcterms:description "A gene-variant disease association in which a mutation in the gene/protein results in the development or maintenance of the disease."@en ;
    rdfs:subClassOf sio:SIO_001122 .

sio:SIO_001126 a owl:Class ;
    rdfs:label "regulation of translation"@en ;
    dcterms:description "A process that modulates the frequency, rate or extent of translation."@en ;
    rdfs:subClassOf sio:SIO_010287 .

sio:SIO_001127 a owl:Class ;
    rdfs:label "regulation of molecular quantity"@en ;
    dcterms:description "A process that modulates the frequency, rate or extent of process involved in the creation or destruction of a molecule."@en ;
    rdfs:subClassOf sio:SIO_001145 .

sio:SIO_001132 a owl:Class ;
    rdfs:label "process maintenance"@en ;
    dcterms:description "The process of maintaining some the frequency, rate or extent of another process."@en ;
    rdfs:subClassOf sio:SIO_000609 .

sio:SIO_001162 a owl:Class ;
    rdfs:label "difference in number of objects produced"@en ;
    dcterms:description "A difference in number of objects produced is a count of the number of objects produced with respect to a second variable (space, time, etc)"@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_001174 a owl:Class ;
    rdfs:label "nucleic acid strand"@en ;
    dcterms:description "A nucleic acid strand is a single-stranded nucleic acid that is part of a double stranded nucleic acid complex."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_001177 ],
        sio:SIO_010008 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_001175 sio:SIO_001176 ) ] .

sio:SIO_001209 a owl:Class ;
    rdfs:label "assertional qualifier"@en ;
    dcterms:description "An assertional qualifier is the quality of affirmation, either being positive or negative."@en ;
    rdfs:subClassOf sio:SIO_000005 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_001210 sio:SIO_001211 ) ] .

sio:SIO_001258 a owl:Class ;
    rdfs:label "set item"@en ;
    dcterms:description "set item is an item in a set."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000095 ;
            owl:someValuesFrom sio:SIO_000289 ],
        sio:SIO_000075 .

sio:SIO_001259 a owl:Class ;
    rdfs:label "collection item"@en ;
    dcterms:description "a collection item is an item in a collection."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000095 ;
            owl:someValuesFrom sio:SIO_000616 ],
        sio:SIO_001258 .

sio:SIO_001268 a owl:Class ;
    rdfs:label "parental transmission"@en ;
    dcterms:description "parental transmition is the quality of a biological organism in which the (genetic) material is transmitted from a parental unit." ;
    rdfs:subClassOf sio:SIO_000475 .

sio:SIO_001300 a owl:Class ;
    rdfs:label "ovopub"@en ;
    dcterms:description "An ovopub is an information content entity that contains and links to one or more resources and/or statements, including those describing its provenance, and is itself a dereferenceable resource."@en ;
    sio:subset "ovopub+" ;
    rdfs:subClassOf sio:SIO_000602 .

sio:SIO_001341 a owl:Class ;
    rdfs:label "containment quality"@en ;
    dcterms:description "a containment quality is a quality of being able to contain another entity."@en ;
    rdfs:subClassOf sio:SIO_001338 .

sio:SIO_001342 a owl:Class ;
    rdfs:label "gene-disease association linked with modifying mutation"@en ;
    dcterms:description "A gene-disease association in which a gene mutation is known to modify the clinical presentation of the disease."@en ;
    rdfs:subClassOf sio:SIO_001122 .

sio:SIO_001359 a owl:Class ;
    rdfs:label "information translation"@en ;
    rdfs:subClassOf sio:SIO_000649 .

sio:SIO_001365 a owl:Class ;
    rdfs:label "rate of change"@en ;
    dcterms:description "The amount of change accumulated per unit time."@en ;
    rdfs:subClassOf sio:SIO_000258 .

sio:SIO_001385 a owl:Class ;
    rdfs:label "notation"@en ;
    dc:description "a notation is a series or system of written symbols used to represent numbers, amounts, or elements."@en ;
    rdfs:subClassOf sio:SIO_000090 .

sio:SIO_001395 a owl:Class ;
    rdfs:label "carbohydrate"@en ;
    dcterms:alternative "oligosaccharide"@en,
        "saccharide"@en ;
    dcterms:description "a carbohydrate is an organic molecule composed of two or more monosaccharides."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010334 ;
            owl:onProperty sio:SIO_000273 ],
        sio:SIO_010346 .

sio:SIO_001422 a owl:Class ;
    rdfs:label "chemical salt"@en ;
    dcterms:alternative "salt"@en ;
    dcterms:description "a chemical salt is a molecular complex composed of an ionic assembly of cations and anions."@en ;
    rdfs:subClassOf sio:SIO_010506 .

sio:SIO_001428 a owl:Class ;
    rdfs:label "ingredient"@en ;
    dcterms:description "an ingredient is a chemical substance that forms part of a mixture."@en ;
    rdfs:subClassOf sio:SIO_011126 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_011126 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000245 ;
                        owl:someValuesFrom sio:SIO_011126 ] ) ] .

sio:SIO_001430 a owl:Class ;
    rdfs:label "vector"@en ;
    dcterms:alternative "rank 1 tensor"@en ;
    dcterms:description "a vector is a rank 1 tensor that is described by n-dimension of scalars."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_001431 ;
            owl:onProperty sio:SIO_000053 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_001432 ],
        sio:SIO_001434 .

sio:SIO_001431 a owl:Class ;
    rdfs:label "scalar"@en ;
    dcterms:alternative "rank 0 tensor"@en ;
    dcterms:description "a scalar is a rank 0 tensor and is an element of a field that is used to define a vector space."@en ;
    rdfs:subClassOf sio:SIO_001429 .

sio:SIO_001434 a owl:Class ;
    rdfs:label "rank nonzero tensor"@en ;
    dcterms:description "a rank nonzero tensor is a tensor with a rank greater than zero."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_001429 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000008 ;
                                owl:someValuesFrom sio:SIO_000613 ] ) ] ;
            owl:onProperty sio:SIO_000053 ],
        sio:SIO_001429 .

sio:SIO_001442 a owl:Class ;
    rdfs:label "real number"@en ;
    dcterms:description "a real number is a complex number whose imaginary part is zero, e.g. a + 0i."@en ;
    rdfs:subClassOf sio:SIO_001443 .

sio:SIO_001443 a owl:Class ;
    rdfs:label "complex number"@en ;
    dcterms:description "a complex number is an element of a number system that extends the real numbers with an imaginary unit i. Every complex number can be expressed in the form a + bi, where a and b are real numbers."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onClass sio:SIO_001441 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] [ a owl:Restriction ;
                        owl:onClass sio:SIO_001442 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] ) ],
        sio:SIO_000366 .

sio:SIO_010011 a owl:Class ;
    rdfs:label "lipid"@en ;
    dcterms:description "A lipid is a water-insoluable organic molecule."@en ;
    rdfs:subClassOf sio:SIO_010072 .

sio:SIO_010030 a owl:Class ;
    rdfs:label "monosaccharide"@en ;
    dcterms:description "A monosaccharide is an organic molecule that consists of a single polyhydroxy aldehyde or ketone group."@en ;
    rdfs:subClassOf sio:SIO_010072 .

sio:SIO_010047 a owl:Class ;
    rdfs:label "strong submolecular component"@en ;
    dcterms:description "A strong submolecular component is a submolecular component that strongly connects submolecular components."@en ;
    rdfs:subClassOf sio:SIO_010020 .

sio:SIO_010052 a owl:Class ;
    rdfs:label "female"@en ;
    dcterms:description "female is a biological sex of an individual with female sexual organs."@en ;
    rdfs:subClassOf sio:SIO_010029 .

sio:SIO_010059 a owl:Class ;
    rdfs:label "dead"@en ;
    dcterms:description "dead is the quality of an object in which there is a cessation of all biological functions."@en ;
    rdfs:subClassOf sio:SIO_010057 .

sio:SIO_010066 a owl:Class ;
    rdfs:label "sequence alignment"@en ;
    dcterms:description "A sequence alignment is the character-based alignment of sequences using some method."@en ;
    rdfs:subClassOf sio:SIO_000616 .

sio:SIO_010080 a owl:ObjectProperty ;
    rdfs:label "is transcribed into"@en ;
    dcterms:description "a relation between two information content entities in which one is transcribed into (an exact or similar kind) another through some process."@en ;
    rdfs:subPropertyOf sio:SIO_010078 ;
    owl:inverseOf sio:SIO_010081 ;
    skos:example "DNA is transcribed into RNA"@en .

sio:SIO_010082 a owl:ObjectProperty ;
    rdfs:label "is translated into"@en ;
    rdfs:subPropertyOf sio:SIO_010078 ;
    owl:inverseOf sio:SIO_010083 ;
    skos:example "RNA is translated into Protein"@en,
        "a relation between two information content entities in which one is translated into (a completely different kind of entity) another through some process."@en .

sio:SIO_010085 a owl:Class ;
    rdfs:label "gene regulatory component"@en ;
    dcterms:description "A gene regulatory component is a gene component that exerts a regulatory function."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000225 ;
            owl:someValuesFrom sio:SIO_000395 ],
        sio:SIO_010444 .

sio:SIO_010101 a owl:Class ;
    rdfs:label "rna gene"@en ;
    dcterms:description "A gene that is located on RNA."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_010009 ],
        sio:SIO_010035 .

sio:SIO_010287 a owl:Class ;
    rdfs:label "regulation of biochemical process"@en ;
    dcterms:description "regulation of biochemical process is a process that changes the frequency, rate or extent of a target biochemical process."@en ;
    rdfs:subClassOf sio:SIO_000609 .

sio:SIO_010296 a owl:Class ;
    rdfs:label "process down-regulation"@en ;
    dcterms:alternative "negative regulation"@en ;
    dcterms:description "process down-regulation is a process that decreases the frequency, rate or extent of one or more processes in relation to a reference state."@en ;
    rdfs:subClassOf sio:SIO_000609 .

sio:SIO_010302 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is homologous to"@en ;
    dcterms:description "a relation between two entities which indicates their common ancestry."@en ;
    rdfs:subPropertyOf sio:SIO_000272 .

sio:SIO_010308 a owl:Class ;
    rdfs:label "metabolism"@en ;
    dcterms:description "Metabolism is the set of chemical processes that occur within a living organism in order to maintain life."@en ;
    rdfs:subClassOf sio:SIO_010013 .

sio:SIO_010337 a owl:Class ;
    rdfs:label "ribonucleotide residue"@en ;
    dcterms:description "A ribonucleotide residue is a part of a molecule that derives from a ribonucleotide."@en ;
    rdfs:subClassOf sio:SIO_010075 .

sio:SIO_010338 a owl:Class ;
    rdfs:label "pharmaceutical ingredient"@en ;
    dcterms:title "A pharmaceutical ingredient is a part of a pharmaceutical preparation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_010039 ],
        sio:SIO_001428 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_001428 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000068 ;
                        owl:someValuesFrom sio:SIO_010039 ] ) ] .

sio:SIO_010343 a owl:Class ;
    rdfs:label "enzyme"@en ;
    dcterms:description "An enzyme is a protein or protein complex that realizes its disposition to covalently modify some molecule during a chemical reaction."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( sio:SIO_010043 sio:SIO_010497 ) ],
        sio:SIO_010043 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Class ;
                        owl:unionOf ( sio:SIO_010043 sio:SIO_010497 ) ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000225 ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( sio:SIO_010340 [ a owl:Restriction ;
                                            owl:onProperty sio:SIO_000356 ;
                                            owl:someValuesFrom sio:SIO_010345 ] [ a owl:Restriction ;
                                            owl:onProperty sio:SIO_000668 ;
                                            owl:someValuesFrom sio:SIO_010004 ] ) ] ] ) ] .

sio:SIO_010347 a owl:Class ;
    rdfs:label "to modify conformation of"@en ;
    dcterms:description "to modify conformation of is to affect the spatial arrangement of an entity."@en ;
    rdfs:subClassOf sio:SIO_000343 .

sio:SIO_010360 a owl:Class ;
    rdfs:label "to modify oxidation state of"@en ;
    dcterms:description "to modify the oxidation state of is to change the number of electrons of a molecule, atom or ion."@en ;
    rdfs:subClassOf sio:SIO_001087 .

sio:SIO_010366 a owl:Class ;
    rdfs:label "to be covalently modified"@en ;
    dcterms:description "to be covalently modified is the capability of a chemical entity to have bonds added or removed"@en ;
    rdfs:subClassOf sio:SIO_010364 .

sio:SIO_010369 a owl:Class ;
    rdfs:label "to be electronically modified"@en ;
    dcterms:description "to be electronically modified is the capability of a chemical entity to have electrons added or removed."@en ;
    rdfs:subClassOf sio:SIO_010364 .

sio:SIO_010374 a owl:Class ;
    rdfs:label "to be conformationally changed"@en ;
    dcterms:description "to be conformationally changed is the capability to be modified in such a way that the object's conformation is changed."@en ;
    rdfs:subClassOf sio:SIO_010364 .

sio:SIO_010417 a owl:Class ;
    rdfs:label "solvent"@en ;
    dcterms:description "A solvent is a substance that can dissolve other substances (solutes)."@en ;
    rdfs:subClassOf sio:SIO_010427 .

sio:SIO_010426 a owl:Class ;
    rdfs:label "centrifugation substance"@en ;
    dcterms:description "A centrifugation substance is a substance that is the target or product of centrifugation."@en ;
    rdfs:subClassOf sio:SIO_011126 .

sio:SIO_010428 a owl:Class ;
    rdfs:label "evaluation role"@en ;
    dcterms:description "An evaluation role is a processual role held by an entity during some evaluation."@en ;
    rdfs:subClassOf sio:SIO_000881 .

sio:SIO_010436 a owl:Class ;
    rdfs:label "molecular regulator"@en ;
    dcterms:description "A molecular regulator is a molecule that regulates the function of another chemical entity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000586 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000395 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000668 ;
                                owl:someValuesFrom sio:SIO_010004 ] ) ] ],
        sio:SIO_011125 .

sio:SIO_010437 a owl:Class ;
    rdfs:label "signal transducer"@en ;
    dcterms:description "A signal transducer is a molecule that responds to and amplifies a signal in a signalling system."@en ;
    rdfs:subClassOf sio:SIO_011125 .

sio:SIO_010448 a owl:Class ;
    rdfs:label "stop codon"@en ;
    dcterms:description "A stop codon (or termination codon) is a nucleotide triplet within messenger RNA that signals a termination of translation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_010099 ],
        sio:SIO_010095 .

sio:SIO_010508 a owl:Class ;
    rdfs:label "catalyzed reaction"@en ;
    dcterms:description "A catalyzed reaction is a chemical reaction that is facilitated by a catalyst."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000139 ;
            owl:someValuesFrom sio:SIO_010344 ],
        sio:SIO_010345 .

sio:SIO_010512 a owl:Class ;
    rdfs:label "displacement reaction"@en ;
    dcterms:description "A displacement reaction is an inorganic reaction in which a elementary substance displaces and sets free a constituent atom from a molecule."@en ;
    rdfs:subClassOf sio:SIO_010510 .

sio:SIO_010518 a owl:Class ;
    rdfs:label "addition reaction"@en ;
    dcterms:description """An addition reaction is an organic reaction where two or more molecules combine to form a larger one. Addition reactions are limited to chemical compounds that have multiply-bonded atoms:
    * Molecules with carbon-carbon double bonds or triple bonds
    * Molecules with carbon - hetero double bonds like C=O or C=N"""@en ;
    rdfs:subClassOf sio:SIO_010516 .

sio:SIO_010519 a owl:Class ;
    rdfs:label "polar addition reaction"@en ;
    dcterms:description "A polar addition reaction is an addition reaction involving polar residues."@en ;
    rdfs:subClassOf sio:SIO_010518 .

sio:SIO_010525 a owl:Class ;
    rdfs:label "biochemical pathway"@en ;
    dcterms:description "A biochemical pathway specifies a series of biochemical modifications and transformations towards achieving some biological outcome."@en ;
    rdfs:subClassOf sio:SIO_010526 .

sio:SIO_010533 a owl:Class ;
    rdfs:label "regulatory pathway"@en ;
    dcterms:description "A regulatory pathway is a series of biochemical reactions that lead to the increase or decrease of activity of participating molecular components."@en ;
    rdfs:subClassOf sio:SIO_010525 .

sio:SIO_010783 a owl:Class ;
    rdfs:label "homocyclic ring"@en ;
    dcterms:description "A homocyclic ring is a ring where the atoms are of a single type."@en ;
    rdfs:subClassOf sio:SIO_010780 .

sio:SIO_011121 a owl:Class ;
    rdfs:label "molecular structure descriptor"@en ;
    dcterms:description "molecular structure descriptor is data that describes some aspect of the molecular structure (composition) and is about some chemical entity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000332 ;
            owl:someValuesFrom sio:SIO_011125 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000210 ;
            owl:someValuesFrom sio:SIO_000626 ],
        sio:SIO_001011 ;
    skos:exactMatch "CHEMINF:000085" .

sio:SIO_000013 a owl:Class ;
    rdfs:label "geographic position"@en ;
    dcterms:description "A geographic position is the coordinate of an entity against some geographic coordinate system."@en ;
    rdfs:subClassOf sio:SIO_000056 .

sio:SIO_000014 a owl:Class ;
    rdfs:label "disposition"@en ;
    dcterms:description "A disposition is the tendency of a capability to be exhibited under certain conditions or in response to a certain stimulus (trigger)."@en ;
    sio:subset "core" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom sio:SIO_000638 ],
        sio:SIO_000112 ;
    skos:example "solubility (to dissolve when put in fluid); fragility (disposition to break when dropped)"@en .

sio:SIO_000030 a owl:Class ;
    rdfs:label "biopolymer sequence"@en ;
    dcterms:description "A sequence is a primary structure descriptor in which each of the letters in the string represents a monomeric unit (residue) in which adjacent letters represent the connectivity between the monomeric units."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000300 ;
            owl:someValuesFrom xsd:string ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000563 ;
            owl:someValuesFrom sio:SIO_000092 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000210 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000626 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000011 ;
                                owl:someValuesFrom sio:SIO_000092 ] ) ] ],
        sio:SIO_010014 .

sio:SIO_000048 a owl:Class ;
    rdfs:label "3D extent quantity"@en ;
    dcterms:description "A quantity that extends in three dimensions."@en ;
    rdfs:subClassOf sio:SIO_000037 .

sio:SIO_000089 a owl:Class ;
    rdfs:label "dataset"@en ;
    dcterms:alternative "data set"@en ;
    dcterms:description "A dataset is a data item that is a collection of data items."@en ;
    sio:equivalentTo "http://www.w3.org/ns/dcat#Dataset"^^xsd:anyURI ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000213 ;
            owl:someValuesFrom sio:SIO_000396 ],
        sio:SIO_000069 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000069 [ a owl:Restriction ;
                        owl:allValuesFrom sio:SIO_000069 ;
                        owl:onProperty sio:SIO_000059 ] ) ] .

sio:SIO_000092 a owl:Class ;
    rdfs:label "biopolymer"@en ;
    dcterms:description "A biopolymer is an organic polymer that are typically produced by the cells of living organisms."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( sio:SIO_000556 sio:SIO_010074 sio:SIO_010075 sio:SIO_010334 ) ] ],
        sio:SIO_010346 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_010346 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000273 ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( sio:SIO_000556 sio:SIO_010074 sio:SIO_010075 sio:SIO_010334 ) ] ] ) ] .

sio:SIO_000096 a owl:ObjectProperty ;
    rdfs:label "is boundary of"@en ;
    dcterms:description "is boundary of is a mereological relation between a boundary located at the periphery of a whole."@en ;
    rdfs:subPropertyOf sio:SIO_000093 .

sio:SIO_000104 a owl:Class ;
    rdfs:label "language"@en ;
    dcterms:description "Language is a language entity which is the result of encoding and decoding information through systematic creation and usage of systems of symbols, each pairing a specific sign with an intended meaning, established through social conventions"@en ;
    rdfs:subClassOf sio:SIO_000078 .

sio:SIO_000113 a owl:Class ;
    rdfs:label "sentence"@en ;
    dcterms:description "A sentence is a grammatical unit consisting of one or more words that bear minimal syntactic relation to the words that precede or follow it."@en ;
    rdfs:subClassOf sio:SIO_000483 .

sio:SIO_000129 a owl:Class ;
    rdfs:label "ontology document"@en ;
    dcterms:description "An ontology document is a document that contains an ontology."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_000130 a owl:Class ;
    rdfs:label "pattern"@en ;
    dcterms:description "A pattern is a generalized representation of some repeatable concrete or informational item."@en ;
    rdfs:subClassOf sio:SIO_000075 .

sio:SIO_000140 a owl:Class ;
    rdfs:label "web service"@en ;
    dcterms:description "A web service is a software application that can be accessed over a network, such as the Internet, and executed on a remote system hosting the requested services."@en ;
    rdfs:subClassOf sio:SIO_000101 .

sio:SIO_000145 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is location of"@en ;
    dcterms:description "A is location of B iff the spatialtemporal region occupied by A has the spatialtemporal region occupied by B as a part. [T][R]"@en ;
    sio:subset "nlp+" ;
    rdfs:subPropertyOf sio:SIO_000322 .

sio:SIO_000146 a owl:Class ;
    rdfs:label "monomer"@en ;
    dcterms:description "A monomer is a submolecule that is proper part of some polymer, and is a building block for such polymer."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000310 ;
            owl:someValuesFrom sio:SIO_000092 ],
        sio:SIO_010441 .

sio:SIO_000165 a owl:Class ;
    rdfs:label "thesis document"@en ;
    dcterms:description "A thesis document is the written research component of a post-secondary institution  that contains a statement supported by arguments."@en ;
    rdfs:subClassOf sio:SIO_000087 .

sio:SIO_000171 a owl:Class ;
    rdfs:label "document component"@en ;
    dcterms:description "A bibliographic attribute is an attribute related to publications."@en ;
    rdfs:subClassOf sio:SIO_000651 .

sio:SIO_000216 a owl:ObjectProperty ;
    rdfs:label "has measurement value"@en ;
    dcterms:description "has measurement value is a relation between a quality/realizable and a measurement value."@en ;
    sio:subset "core" ;
    rdfs:range sio:SIO_000070 ;
    rdfs:subPropertyOf sio:SIO_000008 .

sio:SIO_000224 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is property of"@en ;
    dcterms:description "is property of is a relation betweena  quality, capability or role and the entity that it and it alone bears."@en ;
    rdfs:subPropertyOf sio:SIO_000011 .

sio:SIO_000231 a owl:ObjectProperty ;
    rdfs:label "is input in"@en ;
    dcterms:description "is input in is a relation between an entity and a process, where the entity is present at the beginning of the process."@en ;
    sio:subset "sadi"@en ;
    rdfs:subPropertyOf sio:SIO_000062 ;
    skos:example "glucose and ATP are inputs in the hexokinase-mediated conversion of glucose to glucose-6-phosphate."@en .

sio:SIO_000253 a owl:ObjectProperty ;
    rdfs:label "has source"@en ;
    dcterms:description "has source is a relation between an entity and another entity from which it stems from."@en ;
    rdfs:subPropertyOf sio:SIO_000008 .

sio:SIO_000269 a owl:Class ;
    rdfs:label "true"@en ;
    dcterms:description "true is a truth value that indicates that it holds under all possible worlds."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue true ;
            owl:onProperty sio:SIO_000300 ],
        sio:SIO_000268 ;
    owl:disjointWith sio:SIO_000270 .

sio:SIO_000276 a owl:Class ;
    rdfs:label "emotion"@en ;
    dcterms:description "An emotion is a process (experience) that arises internally or from an involuntary physiological response to a stimulus."@en ;
    sio:subset "emotion++" ;
    rdfs:subClassOf sio:SIO_001195 .

sio:SIO_000292 a owl:ObjectProperty ;
    rdfs:label "is target in"@en ;
    dcterms:description "is target in is a relation between an entity and a process, where the entity is present at the beginning  of the process and undergoes a change or transformation in the process."@en ;
    rdfs:subPropertyOf sio:SIO_000231 ;
    skos:example "glucose is a target in the hexokinase-mediated conversion of glucose to glucose-6-phosphate."@en .

sio:SIO_000295 a owl:Class ;
    rdfs:label "collection of documents"@en ;
    dcterms:description "A collection of documents is a non-zero set of documents."@en ;
    sio:equivalentTo "http://purl.org/ontology/bibo/Collection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_000148 ;
            owl:onProperty sio:SIO_000369 ],
        sio:SIO_000616 .

sio:SIO_000313 a owl:ObjectProperty ;
    rdfs:label "is component part of"@en ;
    dcterms:description "is component part of is a relation between a component and a whole, where the component is instrinsic to the whole, and loss of the part would change the kind that the whole is."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000310 ;
    owl:inverseOf sio:SIO_000369 .

sio:SIO_000335 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is weakly interacting with"@en ;
    rdfs:subPropertyOf sio:SIO_000293,
        sio:SIO_000652 .

sio:SIO_000351 a owl:Class ;
    rdfs:label "to supply energy"@en ;
    dcterms:description "to supply energy is the capability to transfer energy from a source to a sink."@en ;
    rdfs:subClassOf sio:SIO_000385 .

sio:SIO_000356 a owl:ObjectProperty ;
    rdfs:label "is realized in"@en ;
    rdfs:subPropertyOf sio:SIO_000062 ;
    skos:example "the role of a patient is realized in medical examination"@en .

sio:SIO_000367 a owl:Class ;
    rdfs:label "variable"@en ;
    dcterms:description "A variable is a value that may change within the scope of a given problem or set of operations."@en ;
    rdfs:subClassOf sio:SIO_000075 .

sio:SIO_000378 a owl:Class ;
    rdfs:label "to change appearance"@en ;
    dcterms:description "to change appearance is the capability to change the visual attributes of an object."@en ;
    rdfs:subClassOf sio:SIO_000343 .

sio:SIO_000426 a owl:ObjectProperty ;
    rdfs:label "is manifestation of"@en ;
    rdfs:subPropertyOf sio:SIO_000425 .

sio:SIO_000443 a owl:Class ;
    rdfs:label "bar graph"@en ;
    dcterms:description "A bar graph is a statistical graph with rectangular bars of lengths proportional to that value that they represent."@en ;
    rdfs:subClassOf sio:SIO_000083 ;
    skos:example "Graphs 3,4,5 in http://tinyurl.com/opwnvm"@en .

sio:SIO_000448 a owl:Class ;
    rdfs:label "figure part"@en ;
    dcterms:description "A figure part is a part of a figure."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000080 ],
        sio:SIO_001194 .

sio:SIO_000451 a owl:Class ;
    rdfs:label "Cartesian coordinate axis"@en ;
    dcterms:description "A Cartesian coordinate axis is an axis whose behavior follows that of a Cartesian coordinate system."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000362 ;
            owl:someValuesFrom sio:SIO_000321 ],
        sio:SIO_000458 .

sio:SIO_000482 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is match to"@en ;
    dcterms:description "A is match to B iff A and B are terms with similar (related, broad, close, exact) meanings"@en ;
    sio:equivalentTo "http://www.w3.org/2004/02/skos/core#relatedMatch" ;
    rdfs:domain sio:SIO_000275 ;
    rdfs:range sio:SIO_000275 ;
    rdfs:subPropertyOf sio:SIO_000283 .

sio:SIO_000483 a owl:Class ;
    rdfs:label "phrase"@en ;
    dcterms:description "A phrase is a group of words functioning as a single unit in the syntax of a sentence."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_000114 ;
            owl:onProperty sio:SIO_000273 ],
        sio:SIO_000078 .

sio:SIO_000516 a owl:Class ;
    rdfs:label "ray"@en ;
    dcterms:description "A ray is a line which that is bounded by a startpoint and extends outwards infinitely along one dimension."@en ;
    rdfs:subClassOf sio:SIO_000511 .

sio:SIO_000527 a owl:Class ;
    rdfs:label "trend line"@en ;
    dcterms:description "A trend line is a line, line segment or ray that is part of a statistical graph which indicates a statistical or visual direction across categorical or value data."@en ;
    rdfs:subClassOf sio:SIO_000535 .

sio:SIO_000532 a owl:Class ;
    rdfs:label "terminal point"@en ;
    dcterms:description "A terminal point is a point that defines the finite extension of a line."@en ;
    rdfs:subClassOf sio:SIO_000507 .

sio:SIO_000536 a owl:Class ;
    rdfs:label "to regulate the rate of formation"@en ;
    dcterms:description "to regulate the rate of formation is to modify the rate at which an object is formed."@en ;
    rdfs:subClassOf sio:SIO_000395 .

sio:SIO_000537 a owl:Class ;
    rdfs:label "curvature"@en ;
    dcterms:description "curvature is a quality of a bearer that relates to the presence of curves, bends, or angles."@en ;
    rdfs:subClassOf sio:SIO_000055 .

sio:SIO_000542 a owl:Class ;
    rdfs:label "to serve as"@en ;
    dcterms:description "to serve as is the capability to act in a manner corresponding to some role."@en ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_000559 a owl:Class ;
    rdfs:label "chemical synthesis"@en ;
    dcterms:description "chemical synthesis is synthesis of a chemical entity from physical precursors through one or more chemical interactions or reactions."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000139 ;
            owl:someValuesFrom sio:SIO_010343 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_010004 ],
        sio:SIO_000588 .

sio:SIO_000564 a owl:Class ;
    rdfs:label "diffusion"@en ;
    dcterms:description "diffusion is motion of particles at temperatures above absolute zero."@en ;
    rdfs:subClassOf sio:SIO_000573 .

sio:SIO_000578 a owl:Class ;
    rdfs:label "secondary active transport"@en ;
    dcterms:description "secondary active transport or co-transport uses electrochemical potential difference created by pumping ions out of the cell to transport molecules across a membrane."@en ;
    rdfs:subClassOf sio:SIO_010284 .

sio:SIO_000608 a owl:Class ;
    rdfs:label "curve"@en ;
    dcterms:description "A curve is a geometric entity that may be located in n-dimensional spatial region whose extension may be n-dimensional,  is composed of at least two fully connected points and does not intersect itself."@en ;
    rdfs:subClassOf sio:SIO_000506 .

sio:SIO_000614 a owl:Class ;
    rdfs:label "attribute"@en ;
    dcterms:description "An attribute is a characteristic of some entity."@en ;
    sio:subset "core" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000000 .

sio:SIO_000632 a owl:ObjectProperty ;
    rdfs:label "is model of"@en ;
    dcterms:description "is model of is a relation between a model (an artifact) and the entity it purports to represent."@en ;
    rdfs:subPropertyOf sio:SIO_000210 ;
    owl:inverseOf sio:SIO_000633 ;
    skos:example "the architect builds a model that represents the building she envisions."@en .

sio:SIO_000640 a owl:Class ;
    rdfs:label "increased"@en ;
    dcterms:description "A quality that has a value that is increased compared to normal or average."@en ;
    sio:equivalentTo "PATO:0002300" ;
    rdfs:subClassOf sio:SIO_000555 ;
    owl:disjointWith sio:SIO_000751 .

sio:SIO_000643 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is realizable property of"@en ;
    rdfs:subPropertyOf sio:SIO_000224 ;
    owl:inverseOf sio:SIO_000644 .

sio:SIO_000646 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is capability of"@en ;
    dcterms:description "is capability of is a relation between a capability and the entity that bears it."@en ;
    rdfs:domain sio:SIO_000112 ;
    rdfs:subPropertyOf sio:SIO_000643 .

sio:SIO_000653 a owl:Class ;
    rdfs:label "version label"@en ;
    dcterms:description "A version label is a label for a particular form or variation of an earlier or original type." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000672 ;
            owl:someValuesFrom [ a owl:Restriction ;
                    owl:onProperty sio:SIO_000272 ;
                    owl:someValuesFrom sio:SIO_000000 ] ],
        sio:SIO_000115 .

sio:SIO_000654 a owl:Class ;
    rdfs:label "software version label"@en ;
    dcterms:description "A software version label is a version label for a piece of software."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000672 ;
            owl:someValuesFrom sio:SIO_000097 ],
        sio:SIO_000653 ;
    skos:example "major.minor[.build[.revision]]"@en .

sio:SIO_000675 a owl:Class ;
    rdfs:label "unique identifier"@en ;
    dcterms:description "A unique identifier is an identifier that uniquely identifies some thing."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000674 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000115 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000115 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000674 ;
                        owl:someValuesFrom sio:SIO_000000 ] ) ] .

sio:SIO_000679 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has time boundary"@en ;
    rdfs:range sio:SIO_000418 ;
    rdfs:subPropertyOf sio:SIO_000054 .

sio:SIO_000692 a owl:Class ;
    rdfs:label "to be actively interacted with"@en ;
    dcterms:description "to be actively interacted with is the capability to be manipulated by some device or agent."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000709 ;
            owl:someValuesFrom sio:SIO_000494 ],
        sio:SIO_000702 ;
    owl:disjointWith sio:SIO_000694 .

sio:SIO_000736 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is comparable to"@en ;
    dcterms:description "is comparable to is a relation between two entities that share at least one feature whose value can be compared."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000001 .

sio:SIO_000747 a owl:Class ;
    rdfs:label "investigation"@en ;
    dcterms:alternative "study" ;
    dcterms:description "investigation is the process of carrying out a plan or procedure so as to discover facts or information about the object of study."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000355 ;
            owl:someValuesFrom sio:SIO_000337 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_000776 ],
        sio:SIO_000999 .

sio:SIO_000762 a owl:Class ;
    rdfs:label "database key"@en ;
    dcterms:description "A database key is an informational entity whose value is constructed from one or more database columns."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000369 ;
            owl:someValuesFrom sio:SIO_000753 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000300 ;
            owl:someValuesFrom rdfs:Literal ],
        sio:SIO_000602 .

sio:SIO_000772 a owl:ObjectProperty ;
    rdfs:label "has evidence"@en ;
    dcterms:description "has evidence is a relation between a proposition and something that demonstrates the truth of the assertion."@en ;
    rdfs:subPropertyOf sio:SIO_000631 ;
    owl:inverseOf sio:SIO_000773 .

sio:SIO_000786 a owl:Class ;
    rdfs:label "verbal language entity"@en ;
    dcterms:description "A verbal language entity is a language entity that is manifested through sound."@en ;
    rdfs:subClassOf sio:SIO_000078 .

sio:SIO_000805 a owl:Class ;
    rdfs:label "charged"@en ;
    dcterms:description "The quality of having a charge."@en ;
    rdfs:subClassOf sio:SIO_010442 ;
    owl:disjointWith sio:SIO_000806 .

sio:SIO_000845 a owl:Class ;
    rdfs:label "hurt"@en ;
    dcterms:description "hurt is an unpleasant feeling, emotion or sensation."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000880 a owl:Class ;
    rdfs:label "regulator role"@en ;
    dcterms:description "The role of a chemical entity that modifies the rate of reaction."@en ;
    rdfs:subClassOf sio:SIO_000889 .

sio:SIO_000912 a owl:Class ;
    rdfs:label "measurement scale"@en ;
    dcterms:description "A measurement scale is a functional specification that specifies an allowed range of categories or values."@en ;
    rdfs:subClassOf sio:SIO_000315 .

sio:SIO_000915 a owl:Class ;
    rdfs:label "numeric scale"@en ;
    dcterms:description "A numeric scale of measurement is one that only specifies numeric values."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000000 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000300 ;
                                owl:someValuesFrom rdfs:Literal ] ) ] ],
        sio:SIO_000912 .

sio:SIO_000937 a owl:Class ;
    rdfs:label "textual chart"@en ;
    dcterms:description "A textual chart is a chart containing text."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_000651 ],
        sio:SIO_000904 .

sio:SIO_000949 a owl:Class ;
    rdfs:label "apprehension"@en ;
    dcterms:description "apprehension is the negative emotion that something unpleasant will occur."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000963 a owl:Class ;
    rdfs:label "not started"@en ;
    dcterms:description "not started is the status of a process that is predicted to exist but has not yet begun."@en ;
    rdfs:subClassOf sio:SIO_000033 .

sio:SIO_000967 a owl:Class ;
    rdfs:label "disagreement"@en ;
    dcterms:description "agreement is the result of consensus decision making when members of the group do not all agree."@en ;
    rdfs:subClassOf sio:SIO_000965 .

sio:SIO_000969 a owl:Class ;
    rdfs:label "communicating"@en ;
    dcterms:alternative "communication" ;
    dcterms:description "communicating is the process of conveying information through the exchange of thoughts, messages, or information, as by speech, visuals, signals, writing, or behaviour."@en ;
    rdfs:subClassOf sio:SIO_000593 .

sio:SIO_000975 a owl:ObjectProperty ;
    rdfs:label "is ordered part of"@en ;
    dcterms:description "is ordered part of is a proper part relation in which the part is one of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system."@en ;
    rdfs:subPropertyOf sio:SIO_000093 .

sio:SIO_001039 a owl:Class ;
    rdfs:label "written"@en ;
    dcterms:description "written is the quality of information that is embodied as visual glyphs in some material form."@en ;
    rdfs:subClassOf sio:SIO_001033 .

sio:SIO_001043 a owl:Class ;
    rdfs:label "experimental protocol"@en ;
    dcterms:description "An experimental protocol is an action specification with respect to the design and implementation of experiments. In addition to providing a detailed set of procedures and lists of required equipment and instruments, experimental protocols often include information on safety precautions, the calculation of results and reporting standards, including statistical analysis and rules for predefining and documenting excluded data to avoid bias."@en ;
    rdfs:subClassOf sio:SIO_000091 .

sio:SIO_001047 a owl:Class ;
    rdfs:label "non-polar"@en ;
    dcterms:description "non-polar is the quality of not having a dipole."@en ;
    rdfs:subClassOf sio:SIO_001045 .

sio:SIO_001092 a owl:Class ;
    rdfs:label "structural quality"@en ;
    dcterms:description "A structural quality is a quality of an object that describes its structure."@en ;
    rdfs:subClassOf sio:SIO_000026 .

sio:SIO_001108 a owl:Class ;
    rdfs:label "centrality measure"@en ;
    dcterms:description "A central tendency measure is a central value or a typical value for a probability distribution."@en ;
    rdfs:subClassOf sio:SIO_000052 .

sio:SIO_001121 a owl:Class ;
    rdfs:label "gene-disease biomarker association"@en ;
    dcterms:description "A gene-disease association in which the gene/protein is involved in the etiology or maintenance of the disease."@en ;
    rdfs:subClassOf sio:SIO_000983 .

sio:SIO_001122 a owl:Class ;
    rdfs:label "gene-disease association linked with genetic variation"@en ;
    dcterms:alternative "gene variant-disease association" ;
    dcterms:description "A gene-disease association in which a sequence variation (a mutation, a SNP) is associated with the disease."@en ;
    rdfs:subClassOf sio:SIO_001350 .

sio:SIO_001150 a owl:Class ;
    rdfs:label "regulation of object consumption"@en ;
    dcterms:description "A process that modulates the frequency, rate or extent of process involved in the consumption of an object."@en ;
    rdfs:subClassOf sio:SIO_001145 .

sio:SIO_001151 a owl:Class ;
    rdfs:label "regulation of object production"@en ;
    dcterms:description "regulation of a participant quantity is the regulation of a process in which the quantity of a selected participant is increased."@en ;
    rdfs:subClassOf sio:SIO_001145 .

sio:SIO_001177 a owl:Class ;
    rdfs:label "double stranded nucleic acid"@en ;
    dcterms:description "double stranded nucleic acid is a molecular complex composed of two weakly connected nucleic acids."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_010008 ;
            owl:onProperty sio:SIO_000053 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_010506 .

sio:SIO_001186 a owl:Class ;
    rdfs:label "hypothetical"@en ;
    dcterms:description "hypothetical is the quality of an entity that is conjectured to exist."@en ;
    rdfs:subClassOf sio:SIO_000959 .

sio:SIO_001196 a owl:Class ;
    rdfs:label "history"@en ;
    dcterms:description "history is a sequence of past events."@en ;
    rdfs:subClassOf sio:SIO_000136 .

sio:SIO_001210 a owl:Class ;
    rdfs:label "positive"@en ;
    dcterms:description "positive is an assertional qualifier that expresses the validity or truth of a basic assertion."@en ;
    rdfs:subClassOf sio:SIO_001209 ;
    owl:disjointWith sio:SIO_001211 .

sio:SIO_001236 a owl:Class ;
    rdfs:label "data collection device"@en ;
    dcterms:description "A data collection device is a device that collects information about one or more objects."@en ;
    rdfs:subClassOf sio:SIO_000956 .

sio:SIO_001271 a owl:Class ;
    rdfs:label "helicity"@en ;
    dcterms:description "helicity is the quality of being helical"@en ;
    rdfs:subClassOf sio:SIO_001092 .

sio:SIO_001350 a owl:Class ;
    rdfs:label "gene-disease association linked with genomic alterations"@en ;
    dcterms:description "a gene-disease association that is linked with some genomic alteration"@en ;
    rdfs:subClassOf sio:SIO_001121 .

sio:SIO_001353 a owl:Class ;
    rdfs:label "specialized object"@en ;
    rdfs:subClassOf sio:SIO_000776 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000776 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000644 ;
                        owl:someValuesFrom sio:SIO_000340 ] ) ] .

sio:SIO_001409 a owl:Class ;
    rdfs:label "object relational quality"@en ;
    dcterms:description "object relational quality refers to a quality in relation to one or more objects"@en ;
    rdfs:subClassOf sio:SIO_000026 .

sio:SIO_001429 a owl:Class ;
    rdfs:label "tensor"@en ;
    dcterms:description "a tensor is a n-dimensional array."@en ;
    rdfs:subClassOf sio:SIO_000075 .

sio:SIO_010016 a owl:Class ;
    rdfs:label "nucleic acid sequence"@en ;
    dcterms:description "A nucleic acid sequence is a symbolic representation of the sequence of nucleic acid residues in a nucleic acid."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_010008 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000210 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000626 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000011 ;
                                owl:someValuesFrom sio:SIO_010008 ] ) ] ],
        sio:SIO_000030 .

sio:SIO_010019 a owl:Class ;
    rdfs:label "biological data"@en ;
    dcterms:description "biological data is scientific data relevant to biology."@en ;
    rdfs:subClassOf sio:SIO_000472 .

sio:SIO_010020 a owl:Class ;
    rdfs:label "submolecular entity"@en ;
    dcterms:description "A submolecular entity is a chemical entity that is a part of a molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_010004 ],
        sio:SIO_010004 .

sio:SIO_010039 a owl:Class ;
    rdfs:label "pharmaceutical drug"@en ;
    dcterms:alternative "medicine" ;
    dcterms:description "A pharmaceutical preparation is a chemical substance that is approved for use in the medical diagnosis, cure, treatment, or prevention of disease."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_010077 ],
        sio:SIO_010038 .

sio:SIO_010049 a owl:Class ;
    rdfs:label "molecular site"@en ;
    dcterms:description "A moleclar site is a spatial region bounded (in part or in whole) by a molecule and may be occupied by other material entities (e.g. drugs)." ;
    rdfs:subClassOf sio:SIO_000019 .

sio:SIO_010057 a owl:Class ;
    rdfs:label "life status"@en ;
    dcterms:description "life status is the quality of whether something is alive or dead."@en ;
    rdfs:subClassOf sio:SIO_000475 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_010058 sio:SIO_010059 ) ] .

sio:SIO_010058 a owl:Class ;
    rdfs:label "alive"@en ;
    dcterms:description "alive is the state of a biological organism that exhibits biological functions."@en ;
    rdfs:subClassOf sio:SIO_010057 ;
    owl:disjointWith sio:SIO_010059 .

sio:SIO_010081 a owl:ObjectProperty ;
    rdfs:label "is transcribed from"@en ;
    rdfs:subPropertyOf sio:SIO_010079 .

sio:SIO_010088 a owl:Class ;
    rdfs:label "to serve as a template for molecular synthesis"@en ;
    dcterms:description "to serve as a template for molecular synthesis is the capability of a chemical entity to provide the necessary information or scaffold by which another molecule may be produced."@en ;
    rdfs:subClassOf sio:SIO_000542 .

sio:SIO_010091 a owl:Class ;
    rdfs:label "to serve as a template for DNA synthesis"@en ;
    dcterms:description "to serve as a template for DNA synthesis is the capability of a chemical entity to provide the necessary information or scaffold by which a DNA molecule may be produced."@en ;
    rdfs:subClassOf sio:SIO_010088 .

sio:SIO_010095 a owl:Class ;
    rdfs:label "RNA transcript component"@en ;
    dcterms:description "An RNA transcript component is a region of an RNA transcript. "@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_010450 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_010099 ],
        sio:SIO_010335 .

sio:SIO_010284 a owl:Class ;
    rdfs:label "active transport"@en ;
    dcterms:description "active transport is the movement of a substance across a membrane against its concentration gradient (from low to high concentration) and requires chemical energy."@en ;
    sio:equivalentTo "biopax:TransportWithBiochemicalReaction" ;
    rdfs:subClassOf sio:SIO_000576 .

sio:SIO_010334 a owl:Class ;
    rdfs:label "carbohydrate residue"@en ;
    dcterms:description "A carbohydrate residue is a part of a molecule that was derived from a monosaccharide molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000244 ;
            owl:someValuesFrom sio:SIO_010030 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_001395 ],
        sio:SIO_010071 .

sio:SIO_010340 a owl:Class ;
    rdfs:label "to covalently modify"@en ;
    dcterms:description "to covalently modify is to materially change a molecule by adding or removing covalent bonds between atoms."@en ;
    rdfs:subClassOf sio:SIO_000376 .

sio:SIO_010362 a owl:Class ;
    rdfs:label "substrate"@en ;
    dcterms:description "A substrate is a molecule that is consumed in the course of a biochemical reaction."@en ;
    rdfs:subClassOf sio:SIO_010423 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_011125 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000245 ;
                        owl:someValuesFrom sio:SIO_010363 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000292 ;
                        owl:someValuesFrom sio:SIO_010345 ] ) ] .

sio:SIO_010363 a owl:Class ;
    rdfs:label "product"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000232 ;
            owl:someValuesFrom sio:SIO_010345 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000244 ;
            owl:someValuesFrom sio:SIO_010362 ],
        sio:SIO_011125 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_011125 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000232 ;
                        owl:someValuesFrom sio:SIO_010345 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000244 ;
                        owl:someValuesFrom sio:SIO_010362 ] ) ] .

sio:SIO_010376 a owl:Class ;
    rdfs:label "unicellular organism"@en ;
    dcterms:description "A unicellular organism is a organism that is composed of a single cell."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:complementOf [ a owl:Restriction ;
                    owl:onProperty sio:SIO_000093 ;
                    owl:someValuesFrom sio:SIO_010046 ] ],
        sio:SIO_010001,
        sio:SIO_010377 .

sio:SIO_010377 a owl:Class ;
    rdfs:label "cellular organism"@en ;
    dcterms:description "A cellular organism is an organism that contains one or more cells."@en ;
    rdfs:subClassOf sio:SIO_010000 ;
    owl:disjointWith sio:SIO_010378 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_010375 sio:SIO_010376 ) ] .

sio:SIO_010441 a owl:Class ;
    rdfs:label "submolecule"@en ;
    dcterms:description "A submolecule is any part of a molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000313 ;
            owl:someValuesFrom sio:SIO_011125 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000369 ;
            owl:someValuesFrom sio:SIO_010044 ],
        sio:SIO_010020 .

sio:SIO_010442 a owl:Class ;
    rdfs:label "charge quality"@en ;
    dcterms:description "charge quality is the quality pertaining to electric charge."@en ;
    rdfs:subClassOf sio:SIO_001011 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_000805 sio:SIO_000806 ) ] .

sio:SIO_010451 a owl:Class ;
    rdfs:label "splice site"@en ;
    dcterms:description "A splice site is a region required for the excision of an intron and connection to another exon."@en ;
    rdfs:subClassOf sio:SIO_010095 .

sio:SIO_010455 a owl:Class ;
    rdfs:label "isomer"@en ;
    dcterms:description "An isomer is a molecule that is compositionally identical to another molecule as a result of a different atomic connectivity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000272 ;
            owl:someValuesFrom sio:SIO_011125 ],
        sio:SIO_011125 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_011125 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000272 ;
                        owl:someValuesFrom sio:SIO_011125 ] ) ] .

sio:SIO_010461 a owl:Class ;
    rdfs:label "positive charge"@en ;
    dcterms:description "A positive charge is a charge where the value is positive."@en ;
    rdfs:subClassOf sio:SIO_000810 ;
    owl:disjointWith sio:SIO_010464 .

sio:SIO_010463 a owl:Class ;
    rdfs:label "homogeneous substance"@en ;
    dcterms:description "A homogeneous substance is a substance that is composed of a uniform type of entity." ;
    rdfs:subClassOf sio:SIO_011126 .

sio:SIO_010497 a owl:Class ;
    rdfs:label "protein complex"@en ;
    dcterms:description "A protein complex is a molecular complex composed of at least two polypeptide chains."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010007 ;
            owl:onProperty sio:SIO_000369 ],
        sio:SIO_010506 .

sio:SIO_010510 a owl:Class ;
    rdfs:label "inorganic reaction"@en ;
    dcterms:description "An inorganic reaction is a chemical reaction that involves the transformation of inorganic molecules."@en ;
    rdfs:subClassOf sio:SIO_010345 .

sio:SIO_010526 a owl:Class ;
    rdfs:label "chemical reaction pathway"@en ;
    dcterms:description "A chemical reaction pathway specifies a series of chemical reactions towards producing some chemical product."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000632 ;
            owl:someValuesFrom sio:SIO_000006 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom [ a owl:Restriction ;
                    owl:onProperty sio:SIO_000053 ;
                    owl:someValuesFrom sio:SIO_010345 ] ],
        [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_010345 ;
            owl:onProperty sio:SIO_000059 ],
        sio:SIO_001107 .

sio:SIO_010780 a owl:Class ;
    rdfs:label "ring"@en ;
    dcterms:description "A ring is a submolecule with a circular topology."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "3"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010044 ;
            owl:onProperty sio:SIO_000369 ],
        sio:SIO_000624 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_010782 sio:SIO_010783 ) ] .

sio:SIO_011001 a owl:Class ;
    rdfs:label "carbon atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:27594" .

sio:SIO_000037 a owl:Class ;
    rdfs:label "spatial quantity"@en ;
    dcterms:alternative "physical dimensional quantity"@en ;
    dcterms:description "A spatial quantity is a quantity obtained from measuring the spatial extent of an entity "@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000216 ;
            owl:someValuesFrom sio:SIO_000052 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_000776 ],
        sio:SIO_000258 .

sio:SIO_000038 a owl:Class ;
    rdfs:label "1D extent quantity"@en ;
    dcterms:description "A quantity that extends in single dimension."@en ;
    rdfs:subClassOf sio:SIO_000037 .

sio:SIO_000074 a owl:Class ;
    rdfs:label "unit of measurement"@en ;
    dcterms:description "A unit of measurement is a definite magnitude of a physical quantity, defined and adopted by convention and/or by law, that is used as a standard for measurement of the same physical quantity."@en ;
    rdfs:subClassOf sio:SIO_000052 .

sio:SIO_000080 a owl:Class ;
    rdfs:label "figure"@en ;
    dcterms:alternative "diagram"@en ;
    dcterms:description "A figure is a graphical entity which consists of a visual (n-dimentional) arrangement of information entities."@en ;
    rdfs:subClassOf sio:SIO_001194 ;
    owl:disjointWith sio:SIO_000448 .

sio:SIO_000090 a owl:Class ;
    rdfs:label "specification"@en ;
    dcterms:description "A specification is a description of the essential technical attributes/requirements for an object or procedure, and may be used to determine that the object / procedure meets its requirements/attributes."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000420 ;
            owl:someValuesFrom sio:SIO_000015 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom sio:SIO_000000 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000369 ;
            owl:someValuesFrom sio:SIO_000337 ],
        sio:SIO_000136 .

sio:SIO_000095 a owl:ObjectProperty ;
    rdfs:label "is member of"@en ;
    dcterms:description "is member of is a mereological relation between a item and a collection."@en ;
    rdfs:subPropertyOf sio:SIO_000011 .

sio:SIO_000106 a owl:Class ;
    rdfs:label "book"@en ;
    dcterms:description "A book is a publication composed of a large number of entries."@en ;
    rdfs:subClassOf sio:SIO_000087 .

sio:SIO_000162 a owl:Class ;
    rdfs:label "periodical"@en ;
    dcterms:description "A periodical is a publication that appears on a regular schedule."@en ;
    sio:equivalentTo "http://purl.org/ontology/bibo/Periodical" ;
    rdfs:subClassOf sio:SIO_000295 .

sio:SIO_000225 a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has function"@en ;
    dcterms:description "has function is the relation between an entity and a function that is ascribed to it."@en ;
    rdfs:range sio:SIO_000017 ;
    rdfs:subPropertyOf sio:SIO_000235 ;
    owl:inverseOf sio:SIO_000226 .

sio:SIO_000232 a owl:ObjectProperty ;
    rdfs:label "is output of"@en ;
    dcterms:description "is output of is a relation between an entity and a process, where the entity is present at the end of the process."@en ;
    sio:subset "sadi"@en ;
    rdfs:subPropertyOf sio:SIO_000062 ;
    skos:example "glucose-6-phosphate and ADP are outputs in the hexokinase-mediated conversion of glucose to glucose-6-phosphate."@en .

sio:SIO_000236 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is disposition of"@en ;
    dcterms:description "is disposition of is a relation between a disposition and the entity that it is a property of."@en ;
    rdfs:domain sio:SIO_000014 ;
    rdfs:subPropertyOf sio:SIO_000646 .

sio:SIO_000238 a owl:Class ;
    rdfs:label "logical operator"@en ;
    dcterms:description "A logical operator is a unary or binary relation to construct logical expressions."@en ;
    rdfs:subClassOf sio:SIO_000075 .

sio:SIO_000243 a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "is causally related with"@en ;
    dcterms:description "A transitive, symmetric, temporal relation in which one entity is causally related with another non-identical entity."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000322 .

sio:SIO_000259 a owl:Class ;
    rdfs:label "argument"@en ;
    dcterms:description "An argument is a set of one or more declarative sentences (or propositions) known as the premises along with another declarative sentence (or proposition) known as the conclusion."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000053 ;
                        owl:someValuesFrom sio:SIO_000261 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000053 ;
                        owl:someValuesFrom sio:SIO_000262 ] ) ],
        sio:SIO_000256 .

sio:SIO_000262 a owl:Class ;
    rdfs:label "conclusion"@en ;
    dcterms:description "A conclusion is a proposition which is reached after considering the evidence, arguments or premises."@en ;
    rdfs:subClassOf sio:SIO_000256 .

sio:SIO_000270 a owl:Class ;
    rdfs:label "false"@en ;
    dcterms:description "false is a truth value in that indicates that it is not true."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue false ;
            owl:onProperty sio:SIO_000300 ],
        sio:SIO_000268 .

sio:SIO_000283 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is similar to"@en ;
    dcterms:description "is similar to is a relation between two entities that share one or more features."@en ;
    rdfs:subPropertyOf sio:SIO_000272 .

sio:SIO_000320 a owl:Class ;
    rdfs:label "coordinate system"@en ;
    dcterms:description "A coordinate system is a specification for spatial location that uses a set of numbers, or coordinates, to uniquely determine the position of a point or other geometric element."@en ;
    rdfs:subClassOf sio:SIO_000317 .

sio:SIO_000328 a owl:Class ;
    rdfs:label "positional identifier"@en ;
    dcterms:description "A positional description is a description of location using some system or frame of reference."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_000056 ],
        sio:SIO_000115 .

sio:SIO_000339 a owl:ObjectProperty ;
    rdfs:label "is specified by"@en ;
    dcterms:description "a relation between a product and the information content entity that specifies it."@en ;
    rdfs:subPropertyOf sio:SIO_000243,
        sio:SIO_000557 .

sio:SIO_000385 a owl:Class ;
    rdfs:label "to change energetically"@en ;
    dcterms:description "to change energetically is the capability to change the energetic aspects of an object."@en ;
    rdfs:subClassOf sio:SIO_000343 .

sio:SIO_000391 a owl:Class ;
    rdfs:label "time measurement"@en ;
    dcterms:description "time measurement is a measurement value of the duration of some interval of time or a particular instant of time (against some frame of reference)."@en ;
    schema1:comment "Time intervals are specified as date/datetime ranges." ;
    rdfs:subClassOf sio:SIO_000258 ;
    skos:example "the duration of my life; the duration of a surgical procedure, the moment of death"@en .

sio:SIO_000395 a owl:Class ;
    rdfs:label "to regulate"@en ;
    dcterms:alternative "to modulate"@en ;
    dcterms:description "to regulate is to control or maintain the rate or speed of an object or process."@en ;
    rdfs:subClassOf sio:SIO_000343 .

sio:SIO_000505 a owl:Class ;
    rdfs:label "polygon"@en ;
    dcterms:description "A polygon is a planar entity that is bounded by a closed path or circuit, composed of a finite connected sequence3 of straight line segments."@en ;
    rdfs:subClassOf sio:SIO_000506 .

sio:SIO_000520 a owl:Class ;
    rdfs:label "triangle"@en ;
    dcterms:description "A triangle is a polygon composed of three points and three line segments, in which each point is fully connected to another point along through the line segment."@en ;
    rdfs:subClassOf sio:SIO_000505 .

sio:SIO_000631 a owl:ObjectProperty ;
    rdfs:label "references"@en ;
    dcterms:alternative "mentions" ;
    dcterms:description "references is a relation between one entity and the entity that it makes reference to by name, but is not described by it."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000628 .

sio:SIO_000638 a owl:Class ;
    rdfs:label "probability measure"@en ;
    dcterms:description "A probability measure is quantity of how likely it is that some event will occur."@en ;
    rdfs:subClassOf sio:SIO_000257 .

sio:SIO_000639 a owl:Class ;
    rdfs:label "to passively interact with"@en ;
    dcterms:description "to passively interact with is the capability to interact with another entity in a way that does not require physical contact."@en ;
    rdfs:subClassOf sio:SIO_000701 .

sio:SIO_000652 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is directly connected to"@en ;
    dcterms:description "A is directly connected to B iff there exists a path direclty between A and B."@en ;
    rdfs:subPropertyOf sio:SIO_000203 .

sio:SIO_000674 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is unique identifier for"@en ;
    dcterms:description "is unique identifier for is a relation between an identifier and an entity that it uniquely identifies"@en ;
    rdfs:domain sio:SIO_000675 ;
    rdfs:subPropertyOf sio:SIO_000672 .

sio:SIO_000706 a owl:Class ;
    rdfs:label "occupational role"@en ;
    dcterms:description "An occupational role is a social role that pertains to an organizational structure."@en ;
    rdfs:subClassOf sio:SIO_000676 .

sio:SIO_000711 a owl:Class ;
    rdfs:label "academic role"@en ;
    dcterms:description "An academic role is a social role that pertains to the academic institution."@en ;
    rdfs:subClassOf sio:SIO_000706 .

sio:SIO_000712 a owl:Class ;
    rdfs:label "medical role"@en ;
    dcterms:description "A medical role is the role of an individual that is a participant in the delivery of medical care."@en ;
    rdfs:subClassOf sio:SIO_000706 .

sio:SIO_000721 a owl:Class ;
    rdfs:label "comparative role"@en ;
    dcterms:description "A comparative role is an abstract role which holds by comparing some attribute of another object of reference."@en ;
    rdfs:subClassOf sio:SIO_000678 .

sio:SIO_000737 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is numerically comparable to"@en ;
    dcterms:description "is numerically comparable to is a comparison relation between two quantities whose datatype value can be compared."@en ;
    rdfs:domain sio:SIO_000052 ;
    rdfs:range sio:SIO_000052 ;
    rdfs:subPropertyOf sio:SIO_000736 .

sio:SIO_000773 a owl:ObjectProperty ;
    rdfs:label "is evidence for"@en ;
    rdfs:subPropertyOf sio:SIO_000252 .

sio:SIO_000788 a owl:Class ;
    rdfs:label "linear position"@en ;
    dcterms:description "A linear position is the position of some object against a linear positioning system."@en ;
    rdfs:subClassOf sio:SIO_000056 .

sio:SIO_000825 a owl:Class ;
    rdfs:label "desire"@en ;
    dcterms:description "desire is a strong emotion of wanting to have something or wishing for something to happen."@en ;
    rdfs:subClassOf sio:SIO_000848 .

sio:SIO_000840 a owl:Class ;
    rdfs:label "happiness"@en ;
    dcterms:description "happiness is an emotion characterized by positive or pleasant emotions ranging from contentment to intense joy."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000888 a owl:Class ;
    rdfs:label "chemical substance role"@en ;
    dcterms:description "A chemical substance role is a chemical entity role held by a chemical substance."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000227 ;
            owl:someValuesFrom sio:SIO_011126 ],
        sio:SIO_000795 .

sio:SIO_000889 a owl:Class ;
    rdfs:label "molecular entity role"@en ;
    dcterms:description "A molecular entity role is a chemical entity role held by a molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000227 ;
            owl:someValuesFrom sio:SIO_011125 ],
        sio:SIO_000795 .

sio:SIO_000956 a owl:Class ;
    rdfs:label "device"@en ;
    dcterms:description "A device is usually a constructed tool."@en ;
    rdfs:subClassOf sio:SIO_010462 .

sio:SIO_000966 a owl:Class ;
    rdfs:label "agreement"@en ;
    dcterms:description "agreement is the result of consensus decision making when members of the group agree."@en ;
    rdfs:subClassOf sio:SIO_000965 ;
    owl:disjointWith sio:SIO_000967 .

sio:SIO_000994 a owl:Class ;
    rdfs:label "experiment"@en ;
    dcterms:alternative "study" ;
    dcterms:description "An experiment is an investigation that has the goal of verifying, falsifying, or establishing the validity of a hypothesis. "@en ;
    rdfs:subClassOf sio:SIO_000747 .

sio:SIO_000999 a owl:Class ;
    rdfs:label "procedure"@en ;
    dcterms:description "A procedure is a process that attempts to achieve one or more objectives by following an established set of actions."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000426 ;
            owl:someValuesFrom sio:SIO_000091 ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:unionOf ( sio:SIO_000112 sio:SIO_000337 ) ] ;
            owl:onProperty sio:SIO_000355 ],
        sio:SIO_000006 .

sio:SIO_001128 a owl:Class ;
    rdfs:label "regulation of molecular production"@en ;
    dcterms:description "A process that modulates the frequency, rate or extent of process involved in the production of a molecule."@en ;
    rdfs:subClassOf sio:SIO_001127 .

sio:SIO_001129 a owl:Class ;
    rdfs:label "regulation of molecular degradation"@en ;
    dcterms:description "A process that modulates the frequency, rate or extent of process involved in the destruction of a molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_001154 ;
            owl:someValuesFrom sio:SIO_000592 ],
        sio:SIO_001127 .

sio:SIO_001135 a owl:Class ;
    rdfs:label "regulation of process frequency"@en ;
    dcterms:description "regulation of a process duration is a process that modulates the frequency of another process relative to some reference process."@en ;
    rdfs:subClassOf sio:SIO_000609 .

sio:SIO_001136 a owl:Class ;
    rdfs:label "regulation of process duration"@en ;
    dcterms:description "regulation of a process duration is a process that modulates the duration of another process relative to some reference process."@en ;
    rdfs:subClassOf sio:SIO_000609 .

sio:SIO_001139 a owl:Class ;
    rdfs:label "regulation of process spatial extent"@en ;
    dcterms:description "regulation of a process spatial extent is a process that modulates the spatial extent of another process relative to some reference process."@en ;
    rdfs:subClassOf sio:SIO_000609 ;
    skos:example "heating the solution causes greater diffusion of a chemical."@en .

sio:SIO_001145 a owl:Class ;
    rdfs:label "regulation of object quantity"@en ;
    dcterms:description "regulation of a participant quantity is the regulation of a process in which the quantity of its partcipants is changed."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_001154 ;
            owl:someValuesFrom sio:SIO_000052 ],
        sio:SIO_000609 .

sio:SIO_001211 a owl:Class ;
    rdfs:label "negative"@en ;
    dcterms:description "negative is an assertional qualifier that expresses the falsity or lack of truth of a basic assertion."@en ;
    rdfs:subClassOf sio:SIO_001209 .

sio:SIO_001246 a owl:Class ;
    rdfs:label "interval"@en ;
    dcterms:description "an interval is a set of real numbers with the property that any number that lies between two numbers in the set is also included in the set."@en ;
    rdfs:subClassOf sio:SIO_000289 ;
    skos:example "The set of all numbers x satisfying 0<=x<=1 is an interval which contains 0 and 1, as well as numbers between them."@en .

sio:SIO_001260 a owl:Class ;
    rdfs:label "list item"@en ;
    dcterms:description "a list item is an item in a list." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000628 ;
            owl:someValuesFrom sio:SIO_000000 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000975 ;
            owl:someValuesFrom sio:SIO_000150 ],
        sio:SIO_001258 .

sio:SIO_001263 a owl:Class ;
    rdfs:label "zygosity"@en ;
    dcterms:description "zygosity is the quality pertaining to the allelic complement of a biological system at a single locus on the DNA." ;
    rdfs:subClassOf sio:SIO_000475 .

sio:SIO_001288 a owl:Class ;
    rdfs:label "temporal qualifier"@en ;
    dcterms:description "a temporal qualifier is pertains to the frequency of the event of interest." ;
    rdfs:subClassOf sio:SIO_000436 .

sio:SIO_001308 a owl:Class ;
    rdfs:label "satisfaction qualifier"@en ;
    rdfs:subClassOf sio:SIO_000436 .

sio:SIO_001319 a owl:Class ;
    rdfs:label "telephone number"@en ;
    dcterms:description "a telephone number is an identifier used to connect to a physical device capable of transfering voice or data over a network." ;
    rdfs:subClassOf sio:SIO_000731 .

sio:SIO_010013 a owl:Class ;
    rdfs:label "chemical interaction"@en ;
    dcterms:description "A chemical interaction is a biochemical process in which chemical entities interact through some set of attractive forces."@en ;
    sio:equivalentTo "biopax:Interaction" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000132 ;
            owl:someValuesFrom sio:SIO_010004 ],
        sio:SIO_000593 .

sio:SIO_010029 a owl:Class ;
    rdfs:label "biological sex"@en ;
    dcterms:description "biological sex is the quality of a biological organism based on reproductive function or organs."@en ;
    rdfs:subClassOf sio:SIO_000475 .

sio:SIO_010038 a owl:Class ;
    rdfs:label "drug"@en ;
    dcterms:description "A drug is a chemical substance that contains one or more active ingredients that regulate one or more biological processes."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000586 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000395 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000668 ;
                                owl:someValuesFrom sio:SIO_010046 ] ) ] ],
        sio:SIO_011126 .

sio:SIO_010299 a owl:Class ;
    rdfs:label "disease"@en ;
    dcterms:description "disease is the outward manifestation of one or more disorders."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000218 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000004 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000217 ;
                                owl:someValuesFrom sio:SIO_000555 ] ) ] ],
        sio:SIO_000475 .

sio:SIO_010378 a owl:Class ;
    rdfs:label "non-cellular organism"@en ;
    dcterms:description "A non-cellular organism is an organism that does not contain a cell."@en ;
    rdfs:subClassOf sio:SIO_010000 .

sio:SIO_010456 a owl:Class ;
    rdfs:label "ion"@en ;
    dcterms:description "An ion is an atom or molecule in which the total number of electrons is not equal to the total number of protons, giving it a net positive or negative electrical charge."@en ;
    rdfs:subClassOf sio:SIO_010004 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Class ;
                        owl:unionOf ( sio:SIO_010044 sio:SIO_011125 ) ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000217 ;
                        owl:someValuesFrom sio:SIO_010442 ] ) ] .

sio:SIO_010464 a owl:Class ;
    rdfs:label "negative charge"@en ;
    dcterms:description "A negative charge is a charge where the value is negative."@en ;
    rdfs:subClassOf sio:SIO_000810 .

sio:SIO_010775 a owl:Class ;
    rdfs:label "stereoisomer"@en ;
    dcterms:description "A stereoisomer is an isomer in which the atomic connectivity is the same, but differs in its spatial arrangement of atoms."@en ;
    rdfs:subClassOf sio:SIO_010455 .

sio:SIO_011118 a owl:Class ;
    rdfs:label "covalent bond"@en ;
    dcterms:description "A covalent bond is a strong submolecular interaction between atoms."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_010044 ;
            owl:onProperty sio:SIO_000369 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_010047 ;
    skos:exactMatch "CHEMINF:000063" .

sio:SIO_000012 a owl:Class ;
    rdfs:label "organization"@en ;
    dcterms:description "An organization is a collective with a complex articulation of tasks, roles and responsibilities."@en ;
    rdfs:subClassOf sio:SIO_000620 .

sio:SIO_000016 a owl:Class ;
    rdfs:label "role"@en ;
    dcterms:description "A role is a realizable entity that describes behaviours, rights and obligations of an entity in some particular circumstance."@en ;
    sio:subset "core" ;
    rdfs:subClassOf sio:SIO_000340 .

sio:SIO_000033 a owl:Class ;
    rdfs:label "process status"@en ;
    dcterms:description "process status is a process quality that describes the state of a process."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_000006 ],
        sio:SIO_000027 .

sio:SIO_000072 a owl:Class ;
    rdfs:label "cartesian coordinate"@en ;
    dcterms:description "A Cartesian coordinate is the signed distance of a point to some referent line."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000321 ],
        sio:SIO_000071 ;
    owl:disjointWith sio:SIO_000073 .

sio:SIO_000185 a owl:Class ;
    rdfs:label "title"@en ;
    dcterms:description "A title is a textual entity that summarily describes some entity."@en ;
    rdfs:subClassOf sio:SIO_000179 .

sio:SIO_000203 a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "is connected to"@en ;
    dcterms:alternative "interacts with"@en ;
    dcterms:description "A is connected to B iff there exists a fiat, material or temporal path between A and B. [S][T]"@en ;
    sio:subset "core",
        "nlp" ;
    rdfs:subPropertyOf sio:SIO_000322 .

sio:SIO_000212 a owl:ObjectProperty ;
    rdfs:label "is referred to by"@en ;
    dcterms:description "A is referred to by B iff B is an informational entity that makes reference to A."@en ;
    rdfs:subPropertyOf sio:SIO_000001 ;
    owl:inverseOf sio:SIO_000628 .

sio:SIO_000268 a owl:Class ;
    rdfs:label "truth value"@en ;
    dcterms:description "truth value is a quality of information that is claimed/verified to be true or false."@en ;
    rdfs:subClassOf sio:SIO_000436 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_000269 sio:SIO_000270 ) ] .

sio:SIO_000291 a owl:ObjectProperty ;
    rdfs:label "has target"@en ;
    dcterms:description "has target is a relation between a process and an entity, where the entity is present at the beginning  of the process and undergoes a change or transformation in the process."@en ;
    rdfs:subPropertyOf sio:SIO_000230 ;
    owl:inverseOf sio:SIO_000292 .

sio:SIO_000376 a owl:Class ;
    rdfs:label "to change materially"@en ;
    dcterms:description "to change appearance is the capability to change the material composition of an object."@en ;
    rdfs:subClassOf sio:SIO_000343 .

sio:SIO_000498 a owl:Class ;
    rdfs:label "person"@en ;
    dcterms:description "A person is an object that has certain capacities or attributes constituting personhood."@en ;
    rdfs:subClassOf sio:SIO_001353 .

sio:SIO_000563 a owl:ObjectProperty ;
    rdfs:label "describes"@en ;
    dcterms:description "describes is a relation between one entity and another entity that it provides a description (detailed account of)."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000628 .

sio:SIO_000620 a owl:Class ;
    rdfs:label "collective"@en ;
    dcterms:alternative "group" ;
    dcterms:description "A collective is a group of entities that share or are motivated by at least one common issue or interest, or work together on a specific project(s) to achieve a common objective."@en ;
    rdfs:subClassOf sio:SIO_000010 .

sio:SIO_000626 a owl:Class ;
    rdfs:label "molecular structure"@en ;
    dcterms:alternative "molecular geometry" ;
    dcterms:description "molecular structure is the spatial arrangement of atoms in a molecule and the chemical bonds that hold the atoms together."@en ;
    rdfs:subClassOf sio:SIO_000625 .

sio:SIO_000644 a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has realizable property"@en ;
    rdfs:subPropertyOf sio:SIO_000223 .

sio:SIO_000709 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is mutually related to"@en ;
    dcterms:description "a is mutually related to b if and only if the realization of the relation of a necessarily causes the realization of a relation to b."@en ;
    rdfs:subPropertyOf sio:SIO_000001 .

sio:SIO_000790 a owl:Class ;
    rdfs:label "non-protein coding RNA (ncRNA) gene"@en ;
    dcterms:alternative "ncRNA gene"@en ;
    dcterms:description "A non-protein coding RNA (ncRNA) gene is a gene that encodes for a RNA transcript that is not further translated into a protein product."@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/SO_0001263"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_010035 .

sio:SIO_000828 a owl:Class ;
    rdfs:label "disgust"@en ;
    dcterms:description "Disgust is a feeling of revulsion or profound disapproval aroused by something unpleasant or offensive."@en ;
    rdfs:subClassOf sio:SIO_000844 .

sio:SIO_000863 a owl:Class ;
    rdfs:label "sadness"@en ;
    dcterms:alternative "sad",
        "unhappiness",
        "unhappy" ;
    dcterms:description "sadness is emotional pain associated with, or characterized by feelings of disadvantage, loss, despair, helplessness, sorrow, and rage."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000959 a owl:Class ;
    rdfs:label "existence quality"@en ;
    dcterms:description "existence quality is the quality of an entity that describe in what environment it is known to exist."@en ;
    rdfs:subClassOf sio:SIO_000005 .

sio:SIO_001024 a owl:Class ;
    rdfs:label "medical procedure"@en ;
    dcterms:description "A medical procedure is a procedure to identify, examine, alleviate or eliminate an undesirable biological disease or disorder."@en ;
    rdfs:subClassOf sio:SIO_000999 .

sio:SIO_001235 a owl:Class ;
    rdfs:label "non-protein coding RNA (ncRNA)"@en ;
    dcterms:description "A non-protein coding RNA (ncRNA) is a RNA molecular that cannot be used as a template for generating a protein product."@en ;
    rdfs:subClassOf sio:SIO_010450 .

sio:SIO_001299 a owl:Class ;
    rdfs:label "quantity modifier"@en ;
    rdfs:subClassOf sio:SIO_000436 .

sio:SIO_001373 a owl:Class ;
    rdfs:label "legal document"@en ;
    dcterms:description "A legal document is a formally executed written document that can be formally attributed to its author, records and formally expresses a legally enforceable act, process, or contractual duty, obligation, or right, and therefore evidences that act, process, or agreement."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_001427 a owl:Class ;
    rdfs:label "amino acid polymer"@en ;
    dcterms:description "an amino acid polymer is an organic polymer composed of two or more amino acid residues."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010074 ;
            owl:onProperty sio:SIO_000273 ],
        sio:SIO_010346 .

sio:SIO_010074 a owl:Class ;
    rdfs:label "amino acid residue"@en ;
    dcterms:description "An amino acid residue is a submolecule of an amino acid that is part of a larger molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000244 ;
            owl:someValuesFrom sio:SIO_001224 ],
        sio:SIO_010471 .

sio:SIO_010079 a owl:ObjectProperty ;
    rdfs:label "is encoded by"@en ;
    dcterms:description "A relation between two objects, in which the first object is produced from the information contained in the second object."@en ;
    rdfs:subPropertyOf sio:SIO_000339 .

sio:SIO_010364 a owl:Class ;
    rdfs:label "to be modified"@en ;
    dcterms:description "to be modified is the capability to be actively interacted with in such a way that it leads to a physical reconfiguration."@en ;
    rdfs:subClassOf sio:SIO_000692 .

sio:SIO_010375 a owl:Class ;
    rdfs:label "multicellular organism"@en ;
    dcterms:description "A multi-cellular organism is an organism that consists of more than one cell."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010001 ;
            owl:onProperty sio:SIO_000053 ],
        sio:SIO_010377 ;
    owl:disjointWith sio:SIO_010376 .

sio:SIO_010427 a owl:Class ;
    rdfs:label "liquid solution component"@en ;
    dcterms:description "A liquid solution component is a part of a liquid solution."@en ;
    rdfs:subClassOf sio:SIO_010462 .

sio:SIO_010471 a owl:Class ;
    rdfs:label "amino acid polymer submolecule"@en ;
    dcterms:description "An amino acid polymer submolecule is a submolecule of an amino acid polymer."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_001427 ],
        sio:SIO_010071 .

sio:SIO_011119 a owl:Class ;
    rdfs:label "biomolecular structure descriptor"@en ;
    dcterms:description "A biomolecular structure descriptor is structure description for organic compounds."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000332 ;
            owl:someValuesFrom sio:SIO_010072 ],
        sio:SIO_011121 .

sio:SIO_000062 a owl:ObjectProperty ;
    rdfs:label "is participant in"@en ;
    dcterms:description "is participant in is a relation that describes the participation of the subject in the (processual) object."@en ;
    rdfs:range sio:SIO_000006 ;
    rdfs:subPropertyOf sio:SIO_000322 ;
    owl:inverseOf sio:SIO_000132 ;
    skos:example "a car is a participant in a car race; glucose is a participant in glycolysis"@en .

sio:SIO_000070 a owl:Class ;
    rdfs:label "measurement value"@en ;
    dcterms:description "A measurement value is a quantitative description that reflects the magnitude of some attribute."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000300 ;
                        owl:someValuesFrom xsd:boolean ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000300 ;
                        owl:someValuesFrom xsd:dateTime ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000300 ;
                        owl:someValuesFrom xsd:double ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000300 ;
                        owl:someValuesFrom xsd:float ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000300 ;
                        owl:someValuesFrom xsd:integer ] ) ],
        sio:SIO_000366 .

sio:SIO_000091 a owl:Class ;
    rdfs:label "action specification"@en ;
    dcterms:alternative "effective specification" ;
    dcterms:description "An action specification is a specification composed of a sequence of instructions to achieve some objective."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000006 ;
            owl:onProperty sio:SIO_000341 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom sio:SIO_000006 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000362 ;
            owl:someValuesFrom sio:SIO_000337 ],
        sio:SIO_000090 .

sio:SIO_000097 a owl:Class ;
    rdfs:label "software entity"@en ;
    dcterms:description "A software entity is a computational entity that can be interpreted by or directly executed by a processing unit."@en ;
    rdfs:subClassOf sio:SIO_000602 .

sio:SIO_000179 a owl:Class ;
    rdfs:label "label"@en ;
    dcterms:description "a label is a term that is associated with some entity"@en ;
    rdfs:subClassOf sio:SIO_000275 .

sio:SIO_000228 a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    dcterms:description "has role is a relation between an entity and a role that it bears."@en ;
    rdfs:range sio:SIO_000016 ;
    rdfs:subPropertyOf sio:SIO_000644 .

sio:SIO_000245 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "derives into"@en ;
    dcterms:description "a derives to b if and only if a or some part thereof is consumed in the formation of b."@en ;
    rdfs:domain sio:SIO_000776 ;
    rdfs:range sio:SIO_000776 ;
    rdfs:subPropertyOf sio:SIO_000294 .

sio:SIO_000257 a owl:Class ;
    rdfs:label "dimensionless quantity"@en ;
    dcterms:description "A dimensionless quantity is a quantity that has no associated unit."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:complementOf [ a owl:Restriction ;
                    owl:onProperty sio:SIO_000221 ;
                    owl:someValuesFrom sio:SIO_000074 ] ],
        sio:SIO_000052 ;
    owl:disjointWith sio:SIO_000258 .

sio:SIO_000289 a owl:Class ;
    rdfs:label "set"@en ;
    dcterms:description "A set is a collection of entities, for which there may be zero members."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000000 ;
            owl:onProperty sio:SIO_000059 ],
        sio:SIO_000075 .

sio:SIO_000294 a owl:ObjectProperty ;
    rdfs:label "is causally related to"@en ;
    dcterms:description "a is causally related to b iff there is a causal chain of events from a to b"@en ;
    rdfs:subPropertyOf sio:SIO_000243 ;
    owl:inverseOf sio:SIO_000352 .

sio:SIO_000332 a owl:ObjectProperty ;
    rdfs:label "is about"@en ;
    dcterms:description "is about is a relation between an information content entity and the entity that its primary subject."@en ;
    rdfs:subPropertyOf sio:SIO_000563 ;
    owl:inverseOf sio:SIO_000629 .

sio:SIO_000337 a owl:Class ;
    rdfs:label "objective"@en ;
    dcterms:description "An objective is a proposition that indicates a planned or anticipated outcome."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000006 ;
            owl:onProperty sio:SIO_000356 ],
        [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000091 ;
            owl:onProperty sio:SIO_000339 ],
        sio:SIO_000256 .

sio:SIO_000370 a owl:Class ;
    rdfs:label "spatial region"@en ;
    dcterms:alternative "region" ;
    dcterms:description "A spatial region is an object contained in some region of space."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000370 ;
            owl:onProperty sio:SIO_000028 ],
        sio:SIO_000776 ;
    skos:example "The airspace above Ottawa airport; the band around the northern hemisphere between 50 degrees N and 60 degrees N; the spatial region occupied by a bottle."@en .

sio:SIO_000400 a owl:Class ;
    rdfs:label "x cartesian coordinate"@en ;
    dcterms:description "An x cartesian coordinate is the coordinate of an object onto the x-axis of a cartesian coordinate system."@en ;
    rdfs:subClassOf sio:SIO_000072 .

sio:SIO_000401 a owl:Class ;
    rdfs:label "y cartesian coordinate"@en ;
    dcterms:description "An y cartesian coordinate is the coordinate of an object onto the y-axis of a cartesian coordinate system."@en ;
    rdfs:subClassOf sio:SIO_000072 .

sio:SIO_000402 a owl:Class ;
    rdfs:label "z cartesian coordinate"@en ;
    dcterms:description "A z cartesian coordinate is the coordinate of an object onto the z-axis of a cartesian coordinate system."@en ;
    rdfs:subClassOf sio:SIO_000072 .

sio:SIO_000415 a owl:Class ;
    rdfs:label "geopolitical region"@en ;
    dcterms:description "a geopolitical region is a geographic region recognized by social or legal convention."@en ;
    rdfs:subClassOf sio:SIO_000413 ;
    skos:example "The geographic region bounded by Canada; the spatial region occupied by the US embassy in Ottawa."@en .

sio:SIO_000425 a owl:ObjectProperty ;
    rdfs:label "is generically related with"@en ;
    dcterms:description "A is generically related with B iff A is an abstract entity or an information content entity and B is a information content entity or a physical entity, respectively."@en ;
    rdfs:subPropertyOf sio:SIO_000001 .

sio:SIO_000511 a owl:Class ;
    rdfs:label "line"@en ;
    dcterms:description "A line is curve that extends in a single dimension (e.g. straight line; exhibits no curvature), and is composed of at least two fully connected points."@en ;
    rdfs:subClassOf sio:SIO_000608 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_000512 sio:SIO_000516 sio:SIO_000539 ) ] .

sio:SIO_000512 a owl:Class ;
    rdfs:label "line segment"@en ;
    dcterms:description "A line segment is a line and a part of a curve that is (inclusively) bounded by two terminal points."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_000532 ;
            owl:onProperty sio:SIO_000369 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_000511 .

sio:SIO_000555 a owl:Class ;
    rdfs:label "abnormal"@en ;
    dcterms:description "A quality that has a value that is outside normal or average."@en ;
    rdfs:subClassOf sio:SIO_000307 .

sio:SIO_000649 a owl:Class ;
    rdfs:label "information processing"@en ;
    dcterms:description "information processing is a process that involves the generation or use of information."@en ;
    rdfs:subClassOf sio:SIO_000999 .

sio:SIO_000672 a owl:ObjectProperty ;
    rdfs:label "is identifier for"@en ;
    dcterms:alternative "identifies" ;
    dcterms:description "a relation between an identifier and an entity." ;
    rdfs:domain sio:SIO_000115 ;
    rdfs:subPropertyOf sio:SIO_000011 .

sio:SIO_000697 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is mutual disposition of"@en ;
    dcterms:description "a is mutual disposition of b if and only if the realization of the disposition  a necessarily causes the realization of the disposition b."@en ;
    rdfs:subPropertyOf sio:SIO_000709 .

sio:SIO_000701 a owl:Class ;
    rdfs:label "to interact with"@en ;
    dcterms:description "to interact with is a capabililty that involves another object."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000668 ;
            owl:someValuesFrom sio:SIO_000000 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000697 ;
            owl:someValuesFrom sio:SIO_000702 ],
        sio:SIO_000112 .

sio:SIO_000702 a owl:Class ;
    rdfs:label "to be interacted with"@en ;
    dcterms:description "to be interacted with is the capability of an object to be target of a physical interaction."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000668 ;
            owl:someValuesFrom sio:SIO_000000 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000697 ;
            owl:someValuesFrom sio:SIO_000701 ],
        sio:SIO_000112 .

sio:SIO_000731 a owl:Class ;
    rdfs:label "informational entity identifier"@en ;
    dcterms:description "An informational entity identifier is an identifier for an informational entity."@en ;
    rdfs:subClassOf sio:SIO_000115 .

sio:SIO_000755 a owl:Class ;
    rdfs:label "cell (informational)"@en ;
    dcterms:description "The minimal unit of a cellular automaton that can change state and has an associated behavior."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000628 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000602 .

sio:SIO_001011 a owl:Class ;
    rdfs:label "chemical quality"@en ;
    dcterms:description "chemical quality is the quality of a chemical entity."@en ;
    rdfs:subClassOf sio:SIO_000026 .

sio:SIO_001154 a owl:ObjectProperty ;
    rdfs:label "regulates"@en ;
    dcterms:description "x regulates y if and only if x is a process and y is either a process or a quality, and the progression of x exerts an effect on the frequency, rate or extent of y"@en ;
    rdfs:subPropertyOf sio:SIO_000294 ;
    owl:inverseOf sio:SIO_001155 .

sio:SIO_001212 a owl:Class ;
    rdfs:label "intensity"@en ;
    dcterms:description "intensity is a quality that represents the strength or degree of something."@en ;
    rdfs:subClassOf sio:SIO_000005 .

sio:SIO_001293 a owl:Class ;
    rdfs:label "quality descriptor"@en ;
    rdfs:subClassOf sio:SIO_000436 .

sio:SIO_010001 a owl:Class ;
    rdfs:label "cell"@en ;
    dcterms:description "A cell is a biological entity that is contained by a plasma membrane."@en ;
    rdfs:subClassOf sio:SIO_010046 .

sio:SIO_010005 a owl:Class ;
    rdfs:label "weak submolecular component"@en ;
    dcterms:description "A weak submolecular component is a submolecular component that weakly connects submolecular components."@en ;
    rdfs:subClassOf sio:SIO_010020 ;
    owl:disjointWith sio:SIO_010047 .

sio:SIO_010009 a owl:Class ;
    rdfs:label "ribonucleic acid"@en ;
    dcterms:description "A ribonucleic acid is an organic polymer composed of a sequence of ribonucleotide residues."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010337 ;
            owl:onProperty sio:SIO_000369 ],
        sio:SIO_010008 ;
    owl:disjointWith sio:SIO_010010 .

sio:SIO_010071 a owl:Class ;
    rdfs:label "organic submolecule"@en ;
    dcterms:description "An organic submolecule is connected region of a molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_010072 ],
        [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000028 ;
                        owl:someValuesFrom sio:SIO_011001 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000028 ;
                        owl:someValuesFrom sio:SIO_011007 ] ) ],
        sio:SIO_010441 .

sio:SIO_010099 a owl:Class ;
    rdfs:label "messenger RNA"@en ;
    dcterms:description "A messenger RNA is a ribonucleic acid that contains an untranslated region (UTR) and protein coding sequence and lacks introns."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010078 ;
            owl:someValuesFrom sio:SIO_010043 ],
        sio:SIO_010450 .

sio:SIO_010346 a owl:Class ;
    rdfs:label "organic polymer"@en ;
    dcterms:description "An organic polymer is an organic molecule composed of connected set of monomeric units."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_010071 ],
        sio:SIO_010072 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_010072 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000273 ;
                        owl:someValuesFrom sio:SIO_000146 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000273 ;
                        owl:someValuesFrom sio:SIO_010071 ] ) ] .

sio:SIO_000056 a owl:Class ;
    rdfs:label "position"@en ;
    dcterms:description "A measurement of a spatial location relative to a frame of reference or other objects."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom sio:SIO_000328 ],
        sio:SIO_000070 .

sio:SIO_000150 a owl:Class ;
    rdfs:label "list"@en ;
    dcterms:description "A list is any enumeration of a set of items."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000059 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000289 .

sio:SIO_000340 a owl:Class ;
    rdfs:label "realizable entity"@en ;
    dcterms:description "A realizable entity is an attribute that is exhibited under some condition and is realized in some process."@en ;
    sio:subset "core" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000000 ;
            owl:onProperty sio:SIO_000668 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000643 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000614 .

sio:SIO_000352 a owl:ObjectProperty ;
    rdfs:label "is causally related from"@en ;
    dcterms:description "a is causally related from b iff there is a causal chain of events from b to a"@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000243 .

sio:SIO_000436 a owl:Class ;
    rdfs:label "informational quality"@en ;
    dcterms:description "An informational quality is a quality that pertains to information."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000218 ;
            owl:someValuesFrom sio:SIO_000015 ],
        sio:SIO_000005 .

sio:SIO_000458 a owl:Class ;
    rdfs:label "value axis"@en ;
    dcterms:description "A value axis is an axis in which the position along the line is partioned into numeric values."@en ;
    schema1:comment "A value axis holds the properties of having a minimum and a maximum value, and is usually associated with tickmarks that indicate intervals along the axis."@en ;
    rdfs:subClassOf sio:SIO_000450 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_000459 sio:SIO_000460 sio:SIO_000902 sio:SIO_000903 ) ] ;
    skos:example """The value axis that ranges from 3.0 to 7.4 and corresponds to 
billions of dollars in Graph 1 of http://tinyurl.com/opwnvm"""@en .

sio:SIO_000613 a owl:Class ;
    rdfs:label "ordinal position"@en ;
    dcterms:alternative "offset" ;
    dcterms:description "A ordinal position is a number that designates the position of an entity from the first entity in an ordered sequence of entities."@en ;
    rdfs:subClassOf sio:SIO_000788 .

sio:SIO_010000 a owl:Class ;
    rdfs:label "organism"@en ;
    dcterms:description "A biological organisn is a biological entity that consists of one or more cells and is capable of genomic replication (independently or not)."@en ;
    rdfs:subClassOf sio:SIO_010046 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_010377 sio:SIO_010378 ) ] .

sio:SIO_010007 a owl:Class ;
    rdfs:label "polypeptide"@en ;
    dcterms:description "A polypeptide is an organic polymer composed of amino acid residues, typically of less than 50 amino acids in length."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010074 ;
            owl:onProperty sio:SIO_000369 ],
        sio:SIO_001427 ;
    owl:disjointWith sio:SIO_010008 .

sio:SIO_010072 a owl:Class ;
    rdfs:label "organic molecule"@en ;
    dcterms:description "An organic molecule is a molecule composed of organic atoms (at least carbon, hydrogen, and optionally oxygen, phosphorus, nitrogen, sulfur)"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000028 ;
                        owl:someValuesFrom sio:SIO_011001 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000028 ;
                        owl:someValuesFrom sio:SIO_011002 ] ) ],
        sio:SIO_011125 .

sio:SIO_010075 a owl:Class ;
    rdfs:label "nucleotide residue"@en ;
    dcterms:description "A nucleotide residue is a part of a molecule that derives from a nucleotide."@en ;
    rdfs:subClassOf sio:SIO_010335 .

sio:SIO_010078 a owl:ObjectProperty ;
    rdfs:label "encodes"@en ;
    dcterms:description "A relation between two objects, in which the first object contains information that is used to produce the second object."@en ;
    rdfs:subPropertyOf sio:SIO_000338 ;
    owl:inverseOf sio:SIO_010079 ;
    skos:example "an open reading frame encodes a protein (it contains information that specifies the amino acid composition and topology)"@en .

sio:SIO_010444 a owl:Class ;
    rdfs:label "gene component"@en ;
    dcterms:description "A gene component is a component of a gene." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_010035 ],
        sio:SIO_010335 .

sio:SIO_000087 a owl:Class ;
    rdfs:label "publication"@en ;
    dcterms:description "A publication is a document that has been made available by a publisher."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_000136 a owl:Class ;
    rdfs:label "description"@en ;
    dcterms:description "A description is language entity in which elements of a language (formal or natural) are used to characterize an entity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000000 ;
            owl:onProperty sio:SIO_000563 ],
        sio:SIO_000078 .

sio:SIO_000139 a owl:ObjectProperty ;
    rdfs:label "has agent"@en ;
    dcterms:description "has agent is a relation between a process and an entity, where the entity is present throughout the process and is a causal participant in the process."@en ;
    sio:equivalentTo "OBO_REL:has_agent" ;
    sio:subset "core",
        "sadi"@en ;
    rdfs:subPropertyOf sio:SIO_000132 .

sio:SIO_000315 a owl:Class ;
    rdfs:label "functional specification"@en ;
    dcterms:description "A functional specification is a specification that describes the characteristics of an object."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( sio:SIO_000004 sio:SIO_000015 ) ] ],
        sio:SIO_000090 .

sio:SIO_000506 a owl:Class ;
    rdfs:label "geometric entity"@en ;
    dcterms:description "A geometric entity is an information content entity that pertains to the structure and topology of a space." ;
    sio:subset "geometry+" ;
    rdfs:subClassOf sio:SIO_000015 .

sio:SIO_000586 a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has capability"@en ;
    dcterms:description "has capability is a relation between an entity and the capability that it bears."@en ;
    rdfs:range sio:SIO_000112 ;
    rdfs:subPropertyOf sio:SIO_000644 ;
    owl:inverseOf sio:SIO_000646 ;
    skos:example "SIO has the capability to semantically integrate data."@en .

sio:SIO_000588 a owl:Class ;
    rdfs:label "creating"@en ;
    dcterms:alternative "creation",
        "development",
        "formulation",
        "production",
        "synthesis" ;
    dcterms:description "creating is the process in which an entity comes into existence."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_000776 ],
        sio:SIO_000593 .

sio:SIO_000609 a owl:Class ;
    rdfs:label "regulation of process"@en ;
    dcterms:description "regulation of a process is a process that modulates the duration, frequency, spatial extent of a target process."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_001154 ;
            owl:someValuesFrom sio:SIO_000006 ],
        sio:SIO_000589 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_001135 sio:SIO_001136 sio:SIO_001139 sio:SIO_001145 ) ] .

sio:SIO_001018 a owl:Class ;
    rdfs:label "ratio"@en ;
    dcterms:description "A ratio is a relationship between two numbers of the same kind expressed arithmetically as a dimensionless quotient of the two which explicitly indicates how many times the first number contains the second."@en ;
    rdfs:subClassOf sio:SIO_000257 .

sio:SIO_001194 a owl:Class ;
    rdfs:label "media"@en ;
    dcterms:description "media are audo/visual/audiovisual modes of communicating information for mass consumption."@en ;
    rdfs:subClassOf sio:SIO_000015 .

sio:SIO_010450 a owl:Class ;
    rdfs:label "RNA transcript"@en ;
    dcterms:description "An RNA transcript is an RNA molecule that is produced from transcription of a nucleic acid template."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010081 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( sio:SIO_010010 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000068 ;
                                owl:someValuesFrom sio:SIO_010010 ] ) ] ],
        sio:SIO_010009 .

sio:SIO_010506 a owl:Class ;
    rdfs:label "molecular complex"@en ;
    dcterms:description "A molecular complex is a chemical complex composed of at least one weakly interacting molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_011125 ],
        sio:SIO_010342 .

sio:SIO_000001 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is related to"@en ;
    dcterms:description "A is related to B iff there is some relation between A and B."@en ;
    schema1:comment "'is related to' is the top level relation in SIO" ;
    sio:subset "core",
        "relations+" ;
    rdfs:domain sio:SIO_000000 ;
    rdfs:range sio:SIO_000000 .

sio:SIO_000004 a owl:Class ;
    rdfs:label "material entity"@en ;
    dcterms:description "A material entity is a physical entity that is spatially extended, exists as a whole at any point in time and has mass."@en ;
    sio:subset "core" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:unionOf ( sio:SIO_000004 sio:SIO_000370 ) ] ;
            owl:onProperty sio:SIO_000053 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom sio:SIO_000279 ],
        sio:SIO_000776 .

sio:SIO_000026 a owl:Class ;
    rdfs:label "object quality"@en ;
    dcterms:description "An object quality is quality of an object."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000218 ;
            owl:someValuesFrom sio:SIO_000776 ],
        sio:SIO_000005 .

sio:SIO_000069 a owl:Class ;
    rdfs:label "data item"@en ;
    dcterms:description "A data item consists of information that has been collected/generated towards some purpose."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000062 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000006 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000355 ;
                                owl:someValuesFrom sio:SIO_000337 ] ) ] ],
        sio:SIO_000602 .

sio:SIO_000132 a owl:ObjectProperty ;
    rdfs:label "has participant"@en ;
    dcterms:description "has participant is a relation that describes the participation of the object in the (processual) subject."@en ;
    sio:equivalentTo "OBO_REL:has_participant" ;
    sio:subset "core" ;
    rdfs:domain sio:SIO_000006 ;
    rdfs:subPropertyOf sio:SIO_000322 .

sio:SIO_000210 a owl:ObjectProperty ;
    rdfs:label "represents"@en ;
    dcterms:description "a represents b when a serves as a sign, symbol or model of b."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000628 .

sio:SIO_000227 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is role of"@en ;
    dcterms:description "is role of is a relation between a role and the entity that it is a property of."@en ;
    rdfs:domain sio:SIO_000016 ;
    rdfs:subPropertyOf sio:SIO_000643 ;
    owl:inverseOf sio:SIO_000228 .

sio:SIO_000258 a owl:Class ;
    rdfs:label "dimensional quantity"@en ;
    dcterms:description "A dimensional quantity is a quantity that has an associated unit."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000221 ;
            owl:someValuesFrom sio:SIO_000074 ],
        sio:SIO_000052 .

sio:SIO_000322 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is spatiotemporally related to"@en ;
    dcterms:description "A is spatiotemporally related to B iff A is in the spatial or temporal vicinity of B"@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000001 .

sio:SIO_000342 a owl:Class ;
    rdfs:label "term variant"@en ;
    dcterms:description "A term variant is a term that is a variant of another term."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000272 ;
            owl:someValuesFrom sio:SIO_000275 ],
        sio:SIO_000275 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000275 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000272 ;
                        owl:someValuesFrom sio:SIO_000275 ] ) ] .

sio:SIO_000343 a owl:Class ;
    rdfs:label "to modify"@en ;
    dcterms:description "to modify is the capability to change some entity."@en ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_000475 a owl:Class ;
    rdfs:label "biological quality"@en ;
    dcterms:description "A biological quality is a quality held by a biological entity."@en ;
    rdfs:subClassOf sio:SIO_000026 .

sio:SIO_000592 a owl:Class ;
    rdfs:label "chemical destruction"@en ;
    dcterms:description "chemical destruction is destruction of a chemical entity to its chemical constituents through one ormore chemical interactions or reactions."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000291 ;
            owl:someValuesFrom sio:SIO_010004 ],
        sio:SIO_000591 .

sio:SIO_010043 a owl:Class ;
    rdfs:label "protein"@en ;
    dcterms:description "A protein is an organic polymer that is composed of one or more linear polymers of amino acids."@en ;
    sio:equivalentTo "CHEBI:36080" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_010074 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000369 ;
            owl:someValuesFrom sio:SIO_010007 ],
        sio:SIO_001427 .

sio:SIO_010786 a owl:Class ;
    rdfs:label "carbon allotrope"@en ;
    dcterms:description "A carbon allotrope is a chemical substance composed of carbon."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_011001 ;
            owl:onProperty sio:SIO_000273 ],
        sio:SIO_010785 .

sio:SIO_000083 a owl:Class ;
    rdfs:label "statistical graph"@en ;
    dcterms:alternative "chart" ;
    dcterms:description "A statistical graph is a figure that displays the relationship among numeric data and/or mathematical functions."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000112 a owl:Class ;
    rdfs:label "capability"@en ;
    dcterms:description "A capability is a realizable entity whose basis lies in one or more parts or qualities and reflects possibility of an entity to behave in a specified way under certain conditions or in response to a certain stimulus (trigger)."@en ;
    sio:subset "capability+",
        "core" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom [ a owl:Restriction ;
                    owl:onProperty sio:SIO_000063 ;
                    owl:someValuesFrom sio:SIO_000006 ] ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000641 ;
            owl:someValuesFrom sio:SIO_000005 ],
        [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000006 ;
            owl:onProperty sio:SIO_000635 ],
        sio:SIO_000340 .

sio:SIO_000116 a owl:Class ;
    rdfs:label "name"@en ;
    dcterms:description "A name is a label used to identify an entity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000300 ;
            owl:someValuesFrom xsd:string ],
        sio:SIO_000179 .

sio:SIO_000310 a owl:ObjectProperty ;
    rdfs:label "is direct part of"@en ;
    dcterms:description "is direct part of is a relation between a specific part (at some level of granularity) and its whole."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000093 .

sio:SIO_000417 a owl:Class ;
    rdfs:label "time interval"@en ;
    dcterms:description "A time internval is a contiguous temporal region having some duration."@en ;
    rdfs:subClassOf sio:SIO_000391 .

sio:SIO_000507 a owl:Class ;
    rdfs:label "point"@en ;
    dcterms:description "A point is a geometric entity that is located in a zero-dimensional spatial region and whose position is defined by its coordinates in some coordinate system."@en ;
    rdfs:subClassOf sio:SIO_000506 .

sio:SIO_000651 a owl:Class ;
    rdfs:label "textual entity"@en ;
    dcterms:description "A textual entity is language entity that is manifested as a sequence of one or more distinct characters."@en ;
    rdfs:subClassOf sio:SIO_000078 .

sio:SIO_010335 a owl:Class ;
    rdfs:label "nucleic acid part"@en ;
    dcterms:description "A nucleic acid part is a component of a nucleic acid."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_010075 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_010008 ],
        sio:SIO_010071 .

sio:SIO_000015 a owl:Class ;
    rdfs:label "information content entity"@en ;
    dcterms:description "information content entity is an object that requires some background knowledge or procedure to correctly interpret."@en ;
    sio:subset "core",
        "ice+" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000015 ;
            owl:onProperty sio:SIO_000053 ],
        sio:SIO_000776 .

sio:SIO_000115 a owl:Class ;
    rdfs:label "identifier"@en ;
    dcterms:description "An identifier is a label that specifically refers to (identifies) an entity (instance/type)."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000672 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000179 .

sio:SIO_000244 a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is derived from"@en ;
    dcterms:description "A transitive temporal relation in which one entity was materially formed from another non-identical entity."@en ;
    sio:equivalentTo "OBO_REL:derives_from" ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000352 ;
    owl:inverseOf sio:SIO_000245 .

sio:SIO_000593 a owl:Class ;
    rdfs:label "interacting"@en ;
    dcterms:description "interacting is a process characterized by the interaction between two or more entities."@en ;
    sio:subset "core" ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                        owl:onClass sio:SIO_000701 ;
                        owl:onProperty sio:SIO_000355 ] [ a owl:Restriction ;
                        owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                        owl:onClass sio:SIO_000702 ;
                        owl:onProperty sio:SIO_000355 ] ) ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000132 ;
            owl:someValuesFrom sio:SIO_000776 ],
        sio:SIO_000006 .

sio:SIO_010008 a owl:Class ;
    rdfs:label "nucleic acid"@en ;
    dcterms:description "A nucleic acid is an organic polymer composed of a sequence of nucleotide residues."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010075 ;
            owl:onProperty sio:SIO_000369 ],
        sio:SIO_010346 .

sio:SIO_010462 a owl:Class ;
    rdfs:label "heterogeneous substance"@en ;
    dcterms:description "A heterogeneous substance is a chemical substance that is composed of more than one different kind of component."@en ;
    rdfs:subClassOf sio:SIO_011126 ;
    owl:disjointWith sio:SIO_010463 .

sio:SIO_000075 a owl:Class ;
    rdfs:label "mathematical entity"@en ;
    dcterms:description "A mathematical entity is an information content entity that are components of a mathematical system or can be defined in mathematical terms."@en ;
    sio:subset "math+" ;
    rdfs:subClassOf sio:SIO_000015 .

sio:SIO_000078 a owl:Class ;
    rdfs:label "language entity"@en ;
    dcterms:description "A language entity implements some language specification for the visual interpretation and is part of some document."@en ;
    sio:subset "nlp+" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000300 ;
            owl:someValuesFrom rdfs:Literal ],
        sio:SIO_000015 .

sio:SIO_000218 a owl:ObjectProperty ;
    rdfs:label "is quality of"@en ;
    dcterms:description "is quality of is a relation between a quality and the entity that it is a property of."@en ;
    rdfs:domain sio:SIO_000005 ;
    rdfs:subPropertyOf sio:SIO_000224 .

sio:SIO_000338 a owl:ObjectProperty ;
    rdfs:label "specifies"@en ;
    dcterms:description "A relation between an information content entity and a product that it (directly/indirectly) specifies"@en ;
    rdfs:subPropertyOf sio:SIO_000243,
        sio:SIO_000563 ;
    owl:inverseOf sio:SIO_000339 .

sio:SIO_000418 a owl:Class ;
    rdfs:label "time instant"@en ;
    dcterms:description "A time instant is a temporal region which occurs instantaneously, e.g. having no duration."@en ;
    rdfs:subClassOf sio:SIO_000391 ;
    skos:example "at this moment; the moment at which a finger is detached in an industrial accident; the moment at which a child is born; the moment of death"@en .

sio:SIO_000602 a owl:Class ;
    rdfs:label "computational entity"@en ;
    dcterms:description "A computational entity is an information content entity operated on using some computational system."@en ;
    rdfs:subClassOf sio:SIO_000015 .

sio:SIO_000668 a owl:ObjectProperty ;
    rdfs:label "in relation to"@en ;
    dcterms:description "in relation to is a comparative relation to indicate that the instance of the class holding the relation exists in relation to another entity."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000628 ;
    owl:inverseOf sio:SIO_000892 .

sio:SIO_000904 a owl:Class ;
    rdfs:label "chart"@en ;
    dcterms:description "A chart is a figure that displays the relationship among tabular numeric data, functions or some kinds of qualitative structures."@en ;
    rdfs:subClassOf sio:SIO_000080 .

sio:SIO_010010 a owl:Class ;
    rdfs:label "deoxyribonucleic acid"@en ;
    dcterms:description "A deoxyribonucleic acid is an organic polymer composed of a sequence of deoxyribonucleotide residues."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010336 ;
            owl:onProperty sio:SIO_000369 ],
        sio:SIO_010008 .

sio:SIO_000005 a owl:Class ;
    rdfs:label "quality"@en ;
    dcterms:description "A quality is an attribute that is intrinsically associated with its bearer (or its parts), but whose presence/absence and observed/measured value may vary."@en ;
    sio:subset "core" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000218 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000614 ;
    owl:disjointWith sio:SIO_000340 .

sio:SIO_000028 a owl:ObjectProperty,
        owl:ReflexiveProperty,
        owl:TransitiveProperty ;
    rdfs:label "has part"@en ;
    dcterms:description "has part is a transitive, reflexive and antisymmetric relation between a whole and itself or a whole and its part."@en ;
    rdfs:subPropertyOf sio:SIO_000145 ;
    owl:inverseOf sio:SIO_000068 ;
    skos:example "a collection of cars has as a car as a part;a car has an engine as a part; a car has a piston as a part;"@en .

sio:SIO_000229 a owl:ObjectProperty ;
    rdfs:label "has output"@en ;
    dcterms:description "has output is a relation between an process and an entity, where the entity is present at the end of the process."@en ;
    sio:subset "core",
        "sadi"@en ;
    rdfs:subPropertyOf sio:SIO_000132 ;
    owl:inverseOf sio:SIO_000232 .

sio:SIO_000230 a owl:ObjectProperty ;
    rdfs:label "has input"@en ;
    dcterms:description "has input is a relation between a process and an entity, where the entity is present at the beginning of the process."@en ;
    sio:subset "core",
        "sadi"@en ;
    rdfs:subPropertyOf sio:SIO_000132 ;
    owl:inverseOf sio:SIO_000231 .

sio:SIO_000831 a owl:Class ;
    rdfs:label "positive emotion"@en ;
    dcterms:description "A positive emotion is an emotion that feels good."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_001210 ],
        sio:SIO_000276 .

sio:SIO_000897 a owl:Class ;
    rdfs:label "association"@en ;
    dcterms:description "An association is a relationship between two or more entities derived by some informational analysis."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_000000 ;
            owl:onProperty sio:SIO_000628 ],
        sio:SIO_000075 .

sio:SIO_010345 a owl:Class ;
    rdfs:label "chemical reaction"@en ;
    dcterms:description "A chemical reaction is a process that leads to the transformation of one set of chemical substances to another."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000053 ;
                        owl:someValuesFrom sio:SIO_000559 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000053 ;
                        owl:someValuesFrom sio:SIO_000592 ] ) ],
        sio:SIO_010013 .

sio:SIO_000052 a owl:Class ;
    rdfs:label "quantity"@en ;
    dcterms:description "A quantity is an informational entity that gives the magnitude of a property."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000215 ;
            owl:someValuesFrom sio:SIO_000000 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000070 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_000257 sio:SIO_000258 ) ] .

sio:SIO_000059 a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "has member"@en ;
    dcterms:description "has member is a mereological relation between a collection and an item."@en ;
    sio:subset "core" ;
    rdfs:domain sio:SIO_000616 ;
    rdfs:subPropertyOf sio:SIO_000008 ;
    owl:inverseOf sio:SIO_000095 ;
    skos:example "a collection of cars has as a car as a member"@en .

sio:SIO_000272 a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "is variant of"@en ;
    dcterms:description "is variant of: a relationship indicating that two entities are different (by some measure), but either achieve the same objectives in different ways or are permutations of one another (temporal, logical or otherwise)"@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000736 .

sio:SIO_000355 a owl:ObjectProperty ;
    rdfs:label "realizes"@en ;
    dcterms:description "realizes is a relation between a process and a realizable entity (role, function, disposition)."@en ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000229 ;
    owl:inverseOf sio:SIO_000356 .

sio:SIO_000616 a owl:Class ;
    rdfs:label "collection"@en ;
    dcterms:description "A collection is a set for which there exists at least one member, although any member need not to exist at any point in the collection's existence."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000059 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000289 .

sio:SIO_000794 a owl:Class ;
    rdfs:label "count"@en ;
    dcterms:description "The number of elements of a finite set of objects."@en ;
    rdfs:subClassOf sio:SIO_000257 .

sio:SIO_010035 a owl:Class ;
    rdfs:label "gene"@en ;
    dcterms:description "A gene is part of a nucleic acid that contains all the necessary elements to encode a functional transcript."@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/SO_0000704"^^xsd:anyURI,
        "biopax:Gene" ;
    rdfs:subClassOf sio:SIO_010335 .

sio:SIO_011126 a owl:Class ;
    rdfs:label "chemical substance"@en ;
    dcterms:alternative "mixture"@en ;
    dcterms:description "A chemical substance is a chemical entity composed of two or more weakly (non-covalently) interacting chemical entities."@en ;
    rdfs:subClassOf sio:SIO_010004 ;
    owl:equivalentClass [ a owl:Class ;
            owl:unionOf ( sio:SIO_010462 sio:SIO_010463 ) ] ;
    skos:exactMatch "CHEMINF:440533" .

sio:SIO_000148 a owl:Class ;
    rdfs:label "document"@en ;
    dcterms:description "A document is a bounded physical or digital representation of a body of information designed with the capacity (and usually intent) to communicate."@en ;
    rdfs:subClassOf sio:SIO_000651 .

sio:SIO_000312 a owl:ObjectProperty ;
    rdfs:label "has product"@en ;
    dcterms:description "has product is a relation between an process and an entity, where a new entity exists at the end of the process."@en ;
    sio:subset "sadi"@en ;
    rdfs:subPropertyOf sio:SIO_000229 .

sio:SIO_000494 a owl:Class ;
    rdfs:label "to actively interact with"@en ;
    dcterms:description "to actively interact with is the capability to interact with another entity in a way that requires physical contact."@en ;
    rdfs:subClassOf sio:SIO_000701 .

sio:SIO_010046 a owl:Class ;
    rdfs:label "biological entity"@en ;
    dcterms:description "A biological entity is a heterogeneous substance that contains genomic material or is the product of a biological process."@en ;
    sio:subset "chemical-" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_010000 ],
        sio:SIO_010462 .

sio:SIO_000111 a owl:Class ;
    rdfs:label "document section"@en ;
    dcterms:description "A document section is a component of a document."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000148 ],
        sio:SIO_000171 .

sio:SIO_000256 a owl:Class ;
    rdfs:label "proposition"@en ;
    dcterms:description "A proposition is a sentence expressing something true or false."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000332 ;
            owl:someValuesFrom sio:SIO_000000 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_000268 ],
        sio:SIO_000136 .

sio:SIO_010004 a owl:Class ;
    rdfs:label "chemical entity"@en ;
    dcterms:description "A chemical entity is a material entity that pertains to chemistry."@en ;
    sio:equivalentTo "CHEBI:23367" ;
    sio:subset "chemical+" ;
    rdfs:subClassOf sio:SIO_000004 ;
    skos:example "atom, ion, molecule, chemical substance,"@en .

sio:SIO_000275 a owl:Class ;
    rdfs:label "term"@en ;
    dcterms:description "A term is a word or phrase used to denote one or more entities."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( sio:SIO_000114 sio:SIO_000483 ) ],
        sio:SIO_000078 .

sio:SIO_000006 a owl:Class ;
    rdfs:label "process"@en ;
    dcterms:description "A process is an entity that is identifiable only through the unfolding of time, has temporal parts, and unless otherwise specified/predicted, cannot be identified from any instant of time in which it exists."@en ;
    sio:subset "core",
        "process+" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000417 ;
            owl:onProperty sio:SIO_000687 ],
        [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000006 ;
            owl:onProperty sio:SIO_000053 ],
        sio:SIO_000000 .

sio:SIO_000832 a owl:Class ;
    rdfs:label "negative emotion"@en ;
    dcterms:description "negative emotion is an emotion that does not feel good."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_001211 ],
        sio:SIO_000276 .

sio:SIO_000300 a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has value"@en ;
    dcterms:description "A relation between a informational entity and its actual value (numeric, date, text, etc)."@en ;
    sio:subset "core",
        "nlp",
        "relations",
        "sadi"@en .

sio:SIO_000068 a owl:ObjectProperty,
        owl:ReflexiveProperty,
        owl:TransitiveProperty ;
    rdfs:label "is part of"@en ;
    dcterms:description "is part of is a transitive, reflexive and anti-symmetric mereological relation between a whole and itself or a part and its whole."@en ;
    sio:equivalentTo "OBO_REL:part_of" ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000061 .

sio:SIO_000217 a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has quality"@en ;
    dcterms:description "has quality is a relation between an entity and the quality that it bears."@en ;
    rdfs:range sio:SIO_000005 ;
    rdfs:subPropertyOf sio:SIO_000223 ;
    owl:inverseOf sio:SIO_000218 .

sio:SIO_000628 a owl:ObjectProperty ;
    rdfs:label "refers to"@en ;
    dcterms:description "refers to is a relation between one entity and the entity that it makes reference to."@en ;
    sio:subset "core",
        "nlp+" ;
    rdfs:subPropertyOf sio:SIO_000001 .

sio:SIO_000093 a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "is proper part of"@en ;
    dcterms:description "is proper part of is an asymmetric, irreflexive (normally transitive) relation between a part and its distinct whole."@en ;
    sio:equivalentTo "OBO_REL:proper_part_of" ;
    sio:subset "core" ;
    rdfs:subPropertyOf sio:SIO_000068 .

sio:SIO_000776 a owl:Class ;
    rdfs:label "object"@en ;
    dcterms:description "An object is an entity that is wholly identifiable at any instant of time during which it exists."@en ;
    sio:subset "core" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000776 ;
            owl:onProperty sio:SIO_000053 ],
        sio:SIO_000000 .

sio:SIO_000053 a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "has proper part"@en ;
    dcterms:description "has proper part is an antisymmetric, irreflexive (normally transitive) relation between a whole and a distinct part."@en ;
    rdfs:subPropertyOf sio:SIO_000028 ;
    owl:inverseOf sio:SIO_000093 ;
    skos:example "a car has an engine as a proper part; a car has a piston as a proper part;"@en .

sio:SIO_000008 a owl:ObjectProperty ;
    rdfs:label "has attribute"@en ;
    dcterms:description "has attribute is a relation that associates a entity with an attribute where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type."@en ;
    sio:subset "core" ;
    rdfs:domain sio:SIO_000000 ;
    rdfs:subPropertyOf sio:SIO_000001 ;
    owl:inverseOf sio:SIO_000011 .

sio:SIO_000011 a owl:ObjectProperty ;
    rdfs:label "is attribute of"@en ;
    dcterms:description "is attribute of is a relation that associates an attribute with an entity where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type."@en ;
    rdfs:subPropertyOf sio:SIO_000001 .

sio:SIO_011125 a owl:Class ;
    rdfs:label "molecule"@en ;
    dcterms:description "A molecule is a single chemical entity composed of fully covalently bonded atoms."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000028 ;
            owl:someValuesFrom sio:SIO_010044 ],
        sio:SIO_010004 ;
    skos:exactMatch "CHEBI:23367" .

sio:SIO_000273 a owl:ObjectProperty ;
    rdfs:label "has direct part"@en ;
    dcterms:description "has direct part is a relation to specify a part at a particular level of granularity"@en ;
    rdfs:subPropertyOf sio:SIO_000053 ;
    owl:inverseOf sio:SIO_000310 ;
    skos:example "a car has an engine as a direct part"@en .

sio:SIO_000369 a owl:ObjectProperty ;
    rdfs:label "has component part"@en ;
    dcterms:description "has component part is a relation between a whole and a component part where the component is instrinsic to the whole, and loss of the part would change the kind that it is."@en ;
    rdfs:subPropertyOf sio:SIO_000273 ;
    skos:example "a human has blood as a component part"@en .

sio:SIO_000000 a owl:Class ;
    rdfs:label "entity"@en ;
    dcterms:description "Every thing is an entity."@en ;
    sio:subset "core" .

sio:SIO_010044 a owl:Class ;
    rdfs:label "atom"@en ;
    dcterms:description "An atom is composed of a core of protons and/or neutrons which may be surrounded by a cloud of electrons."@en ;
    rdfs:subClassOf sio:SIO_010004 .

[] a owl:AllDisjointClasses ;
    owl:members ( sio:SIO_001213 sio:SIO_001214 sio:SIO_001215 sio:SIO_001216 sio:SIO_001217 sio:SIO_001218 ) .

