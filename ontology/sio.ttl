@prefix cito: <http://purl.org/spar/cito/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix protege: <http://protege.stanford.edu/plugins/owl/protege#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix sio: <http://semanticscience.org/resource/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

protege:defaultLanguage a owl:AnnotationProperty .

dc:contributor a owl:AnnotationProperty .

dc:creator a owl:AnnotationProperty .

dc:description a owl:AnnotationProperty .

dcterms:alternative a owl:AnnotationProperty .

dcterms:contributor a owl:AnnotationProperty .

dcterms:creator a owl:AnnotationProperty .

dcterms:description a owl:AnnotationProperty .

dcterms:issued a owl:AnnotationProperty .

dcterms:license a owl:AnnotationProperty .

dcterms:modified a owl:AnnotationProperty .

dcterms:rights a owl:AnnotationProperty .

dcterms:title a owl:AnnotationProperty .

cito:citesAsAuthority a owl:AnnotationProperty .

vann:preferredNamespacePrefix a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

schema1:comment a owl:AnnotationProperty .

<http://semanticscience.org/ontology/sio.owl> a owl:Ontology ;
    protege:defaultLanguage "en" ;
    dc:contributor """Contributors are those that engage in discussions in the context of SIO (in alphabetical order):
sivaram arabandi
christopher baker
joachim baran
jerven bolleman
matthew brush
alison callahan
leonid chepelev
kevin cohen
melanie courtot
geraint duck
laura furlong
elisa kendall
tatsuya kushida
luke mccarthy
jim mccusker
jose miguel cruz-toledo
chris mungall
robert hoehndorf
simon jupp
jin-dong kim
dana klassen
thomas luetteke
james malone
chris mungall
david osumi-sutherland
tazro ohta
nuria queralt
stephen reed
alexandre riazanov
matthias samwald
robert stevens
mark wilkinson
karin verspoor
natalia villanueva-rosales"""^^xsd:string ;
    dc:creator "Michel Dumontier"@en ;
    dcterms:creator "http://orcid.org/0000-0003-4727-9435"^^xsd:anyURI ;
    dcterms:description """The semanticscience integrated ontology (SIO) provides a simple, integrated ontology (types, relations) for objects, processes and their attributes.

This project provides foundational support for the Bio2RDF (http://bio2rdf.org) and SADI (http://sadiframework.org) projects. 

website: http://semanticscience.org
email: sio-ontology@googlegroups.com
mailing list: http://groups.google.com/group/sio-ontology
"""@en ;
    dcterms:issued "2010-03-29"^^xsd:date ;
    dcterms:license <http://creativecommons.org/licenses/by/4.0/> ;
    dcterms:rights "free to use,share,modify. modify with attribution [http://creativecommons.org/licenses/by/4.0/]."^^xsd:string ;
    dcterms:title "Semanticscience Integrated Ontology (SIO)"@en ;
    cito:citesAsAuthority "http://www.jbiomedsem.com/content/5/1/14"^^xsd:anyURI ;
    vann:preferredNamespacePrefix "sio"@en ;
    vann:preferredNamespaceUri "http://semanticscience.org/resource/"^^xsd:string ;
    schema1:comment """general class inclusion axioms:
'is part of' some 'physical entity' subClassOf 'is located in' some 'physical entity'

role chains:
'has capability' o 'is realized in' -> 'is participant in'"""^^xsd:string ;
    rdfs:seeAlso "http://sio.semanticscience.org"^^xsd:anyURI ;
    owl:versionInfo "1.59"^^xsd:string .

sio:SIO_000022 a owl:Class ;
    rdfs:label "material boundary"@en ;
    dcterms:description "A material boundary is the boundary of a material entity which exists as a lower dimensional entity at exactly the location where its parts no longer extend into space. Every material entity has a boundary, and a boundary is the boundary of exactly 1 material entity."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000096 ;
            owl:someValuesFrom sio:SIO_000004 ],
        sio:SIO_000783 ;
    skos:example "the external surface of the window; the surface of the p52 protein"@en .

sio:SIO_000031 a owl:Class ;
    rdfs:label "start date"@en ;
    dcterms:description "A start date is a time instant pertaining to the date of the beginning of a process."@en ;
    rdfs:subClassOf sio:SIO_000418 .

sio:SIO_000032 a owl:Class ;
    rdfs:label "end date"@en ;
    dcterms:description "An end date is a time instant pertaining to date of the end of a process."@en ;
    rdfs:subClassOf sio:SIO_000418 .

sio:SIO_000040 a owl:Class ;
    rdfs:label "height"@en ;
    dcterms:description "height is the one dimensional extent along the vertical projection of a 3D object from a base plane of reference."@en ;
    rdfs:subClassOf sio:SIO_000038 .

sio:SIO_000041 a owl:Class ;
    rdfs:label "length"@en ;
    dcterms:description "length is the longer dimensional extent along a 2D projection of the object."@en ;
    rdfs:subClassOf sio:SIO_000038 .

sio:SIO_000042 a owl:Class ;
    rdfs:label "width"@en ;
    dcterms:description "width is the shorter dimensional extent perpendicular to a 2D projection of the object."@en ;
    rdfs:subClassOf sio:SIO_000038 .

sio:SIO_000043 a owl:Class ;
    rdfs:label "thickness"@en ;
    dcterms:description "thickness is the shortest dimensional extent of a 3D projection of an object."@en ;
    rdfs:subClassOf sio:SIO_000039 .

sio:SIO_000047 a owl:Class ;
    rdfs:label "circumference"@en ;
    dcterms:description "circumference is the length of the outline of a circle or ellipse. it is defined as c = 2*pi*r, where r is the radius."@en ;
    rdfs:subClassOf sio:SIO_000046 .

sio:SIO_000049 a owl:Class ;
    rdfs:label "volume"@en ;
    dcterms:description "volume is the quantity of three-dimensional space enclosed by some closed boundary."@en ;
    rdfs:subClassOf sio:SIO_000048 .

sio:SIO_000057 a owl:Class ;
    rdfs:label "orientation"@en ;
    dcterms:description "orientation is an angle between the bearer and an axis, or the angle between the bearer and another object."@en ;
    rdfs:subClassOf sio:SIO_000056 .

sio:SIO_000064 a owl:ObjectProperty ;
    rdfs:label "is provider of"@en ;
    dcterms:description "is provider of is a relation between a source and the entity it makes available."@en ;
    rdfs:subPropertyOf sio:SIO_000219 ;
    owl:inverseOf sio:SIO_000066 .

sio:SIO_000067 a owl:Class ;
    rdfs:label "namespace"@en ;
    dcterms:description "A namespace is an informational entity that defines a logical container for a set of symbols or identifiers."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000115 ;
            owl:onProperty sio:SIO_000059 ],
        sio:SIO_000602 .

sio:SIO_000077 a owl:Class ;
    rdfs:label "generic name"@en ;
    dcterms:description "A generic name is the preferred name provided by manufacturer."@en ;
    rdfs:subClassOf sio:SIO_000116 .

sio:SIO_000079 a owl:Class ;
    rdfs:label "visual language entity"@en ;
    dcterms:description "A visual language entity is a language entity that is manifested within the spectrum of light and can be pereceived and processed by a visual system."@en ;
    rdfs:subClassOf sio:SIO_000078 .

sio:SIO_000085 a owl:Class ;
    rdfs:label "question"@en ;
    dcterms:description "A question is a linguistic expression used to make a request for information."@en ;
    rdfs:subClassOf sio:SIO_000113 .

sio:SIO_000098 a owl:Class ;
    rdfs:label "software method"@en ;
    dcterms:description "A software method (also called subroutine, subprogram, procedure, method, function, or routine) is software designed to execute a specific task."@en ;
    rdfs:subClassOf sio:SIO_000097 .

sio:SIO_000099 a owl:Class ;
    rdfs:label "software module"@en ;
    dcterms:description "A software module is software composed of a collection of software methods."@en ;
    rdfs:subClassOf sio:SIO_000097 .

sio:SIO_000100 a owl:Class ;
    rdfs:label "software library"@en ;
    dcterms:description "A software library is software composed of a collection of software modules and/or software methods in a form that can be statically or dynamically linked to some software application."@en ;
    rdfs:subClassOf sio:SIO_000097 .

sio:SIO_000102 a owl:Class ;
    rdfs:label "software interpreter"@en ;
    dcterms:description "A software interpreter is a software application that executes some specified input software."@en ;
    rdfs:subClassOf sio:SIO_000101 .

sio:SIO_000103 a owl:Class ;
    rdfs:label "software script"@en ;
    dcterms:description "A software script is software whose instructions can be executed using a software interpreter."@en ;
    rdfs:subClassOf sio:SIO_000097 .

sio:SIO_000105 a owl:Class ;
    rdfs:label "symbol"@en ;
    dcterms:description "A symbol is a proposition about what an entity represents."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000210 ;
            owl:someValuesFrom sio:SIO_000000 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000332 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000612 .

sio:SIO_000107 a owl:Class ;
    rdfs:label "chapter"@en ;
    dcterms:description "A chapter is a document section of a book or thesis."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000109 a owl:Class ;
    rdfs:label "novel"@en ;
    dcterms:description "A novel is a fictitious prose narrative of book length, typically representing character and action with some degree of realism."@en ;
    rdfs:subClassOf sio:SIO_000087 .

sio:SIO_000110 a owl:Class ;
    rdfs:label "paragraph"@en ;
    dcterms:description "A paragraph is a self-contained unit of written discourse consisting of one or more sentences."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_000113 ],
        sio:SIO_000651 .

sio:SIO_000117 a owl:Class ;
    rdfs:label "preferred name"@en ;
    dcterms:description "A preferred name is the name that is generally used by some organization. "@en ;
    rdfs:subClassOf sio:SIO_000116 .

sio:SIO_000118 a owl:Class ;
    rdfs:label "common name"@en ;
    dcterms:description "A common name is a name that is commonly used."@en ;
    rdfs:subClassOf sio:SIO_000116 .

sio:SIO_000119 a owl:Class ;
    rdfs:label "brand name"@en ;
    dcterms:description "A brand name is a trademarked and marketed name of a product."@en ;
    rdfs:subClassOf sio:SIO_000116 .

sio:SIO_000121 a owl:Class ;
    rdfs:label "magazine"@en ;
    dcterms:description "A magazine is a periodical that typically contains essays, stories, poems, etc., by many writers, and often photographs and drawings, frequently specializing in a particular subject or area, as hobbies, news, or sports."@en ;
    sio:equivalentTo "http://purl.org/ontology/bibo/Magazine" ;
    rdfs:subClassOf sio:SIO_000162 .

sio:SIO_000122 a owl:Class ;
    rdfs:label "synonym"@en ;
    dcterms:description "A synonym is a word with the same or very similar meanings."@en ;
    rdfs:subClassOf sio:SIO_000342 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000342 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000283 ;
                        owl:someValuesFrom sio:SIO_000275 ] ) ] .

sio:SIO_000123 a owl:Class ;
    rdfs:label "antonym"@en ;
    dcterms:description "An antonym is a word with opposite or nearly opposite meaning."@en ;
    rdfs:subClassOf sio:SIO_000342 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000342 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000496 ;
                        owl:someValuesFrom sio:SIO_000275 ] ) ] .

sio:SIO_000124 a owl:Class ;
    rdfs:label "hypernym"@en ;
    dcterms:description "A hypernym is a term with a broader meaning."@en ;
    rdfs:subClassOf sio:SIO_000342 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000342 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000477 ;
                        owl:someValuesFrom sio:SIO_000275 ] ) ] .

sio:SIO_000125 a owl:Class ;
    rdfs:label "hyponym"@en ;
    dcterms:description "A hyponym is a term with a narrower meaning."@en ;
    rdfs:subClassOf sio:SIO_000342 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000342 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000427 ;
                        owl:someValuesFrom sio:SIO_000275 ] ) ] .

sio:SIO_000126 a owl:Class ;
    rdfs:label "homonym"@en ;
    dcterms:description "A homonym is a word that sounds the same but has different meaning."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000495 ;
            owl:someValuesFrom sio:SIO_000275 ],
        sio:SIO_000342 .

sio:SIO_000127 a owl:Class ;
    rdfs:label "workflow"@en ;
    dcterms:description "A workflow is an algorithm that is is a depiction of a sequence of operations to achieve one or more objectives."@en ;
    rdfs:subClassOf sio:SIO_000094 .

sio:SIO_000131 a owl:Class ;
    rdfs:label "sequence motif"@en ;
    dcterms:description "A sequence motif is a pattern of nucleotides in a DNA sequence or amino acids in a protein."@en ;
    rdfs:subClassOf sio:SIO_000130 ;
    owl:disjointWith sio:SIO_001197 .

sio:SIO_000135 a owl:Class ;
    rdfs:label "definition"@en ;
    dcterms:description "A definition is a description that succintly characterizes an entity."@en ;
    rdfs:subClassOf sio:SIO_000136 .

sio:SIO_000137 a owl:Class ;
    rdfs:label "category"@en ;
    dcterms:description "A category is a class of entities having particular shared characteristics."@en ;
    rdfs:subClassOf sio:SIO_000326 .

sio:SIO_000138 a owl:Class ;
    rdfs:label "class"@en ;
    dcterms:description "A class is a collection of sets which can be unambiguously defined by a property that all its members share."@en ;
    rdfs:subClassOf sio:SIO_000289 .

sio:SIO_000142 a owl:Class ;
    rdfs:label "inclusion criterion"@en ;
    dcterms:description "An inclusion criterion is a criterion that must be present to satisfy some objective."@en ;
    rdfs:subClassOf sio:SIO_000141 ;
    owl:disjointWith sio:SIO_000143 .

sio:SIO_000147 a owl:Class ;
    rdfs:label "keyword"@en ;
    dcterms:description "A keyword is a descriptor in which the association of the word with the entity facilitates information retrieval."@en ;
    rdfs:subClassOf sio:SIO_000133 .

sio:SIO_000151 a owl:Class ;
    rdfs:label "manuscript"@en ;
    dcterms:description "A manuscript is a document prior to publication."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_000152 a owl:Class ;
    rdfs:label "note"@en ;
    dcterms:description "A note is a brief document."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_000153 a owl:Class ;
    rdfs:label "patent"@en ;
    dcterms:description "A patent is an information entity granted by a patent issuing authority which confers upon the patenter the sole right to make, use and sell an invention for a set period of time."@en ;
    rdfs:subClassOf sio:SIO_001373 .

sio:SIO_000155 a owl:Class ;
    rdfs:label "blog"@en ;
    dcterms:description "A blog is a publication accessible at some website and is typically about various experiences."@en ;
    rdfs:subClassOf sio:SIO_000087 .

sio:SIO_000156 a owl:Class ;
    rdfs:label "book volume"@en ;
    dcterms:description "A book volume is a book that is part of a collection."@en ;
    rdfs:subClassOf sio:SIO_000106 .

sio:SIO_000157 a owl:Class ;
    rdfs:label "conference proceedings"@en ;
    dcterms:description "A conference proceedings is a book composed of papers presented at a conference."@en ;
    rdfs:subClassOf sio:SIO_000106 .

sio:SIO_000158 a owl:Class ;
    rdfs:label "book series"@en ;
    dcterms:description "A book series is a collection of books that have been sequentially published."@en ;
    rdfs:subClassOf sio:SIO_000295 .

sio:SIO_000160 a owl:Class ;
    rdfs:label "journal"@en ;
    dcterms:description "A journal is a a peer-reviewed periodical in which scholarship relating to a particular academic discipline is published."@en ;
    sio:equivalentTo "http://purl.org/ontology/bibo/Journal"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_000162 .

sio:SIO_000161 a owl:Class ;
    rdfs:label "manual"@en ;
    dcterms:description "A manual is a document that instructs on the usage of a device."@en ;
    rdfs:subClassOf sio:SIO_000087 .

sio:SIO_000163 a owl:Class ;
    rdfs:label "newspaper"@en ;
    dcterms:description "A newspaper is a periodical publication containing news regarding current events, informative articles, diverse features, editorials, and advertising."@en ;
    sio:equivalentTo "http://purl.org/ontology/bibo/Newspaper" ;
    rdfs:subClassOf sio:SIO_000162 .

sio:SIO_000164 a owl:Class ;
    rdfs:label "technical report"@en ;
    dcterms:description "A technical report is a publication published by a school or other institution, usually numbered within a series."@en ;
    rdfs:subClassOf sio:SIO_000087 .

sio:SIO_000169 a owl:Class ;
    rdfs:label "booklet"@en ;
    dcterms:description "A booklet is a document that lacks a named publisher or sponsoring institution."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_000170 a owl:Class ;
    rdfs:label "diary"@en ;
    dcterms:description "A diary is a document which describes day-to-day experiences."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_000172 a owl:Class ;
    rdfs:label "address"@en ;
    dcterms:description "An address is a position that indicates the physical location of some entity using a social convention."@en ;
    rdfs:subClassOf sio:SIO_000328 .

sio:SIO_000173 a owl:Class ;
    rdfs:label "affiliation"@en ;
    dcterms:description "An affiliation is a social relation which indicates the partnership between two or more entities."@en ;
    rdfs:subClassOf sio:SIO_000287 .

sio:SIO_000174 a owl:Class ;
    rdfs:label "citation"@en ;
    dcterms:description "A citation is a textual entity which denotes a source described in the bibliography or reference section of a document."@en ;
    rdfs:subClassOf sio:SIO_000171 .

sio:SIO_000175 a owl:Class ;
    rdfs:label "document title"@en ;
    dcterms:description "A document title is a textual entity that summarizes the topic of the document in one sentence."@en ;
    rdfs:subClassOf sio:SIO_000185 .

sio:SIO_000176 a owl:Class ;
    rdfs:label "reference"@en ;
    dcterms:description "A reference is a textual entity that describes a single source used in the preparation or development of the work."@en ;
    rdfs:subClassOf sio:SIO_000171 .

sio:SIO_000177 a owl:Class ;
    rdfs:label "page range"@en ;
    dcterms:description "A page range denotes the start and end page in some document."@en ;
    rdfs:subClassOf sio:SIO_000944 .

sio:SIO_000178 a owl:Class ;
    rdfs:label "page total"@en ;
    dcterms:description "A page total is a textual entity that is about the number of pages in some informational entity."@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_000180 a owl:Class ;
    rdfs:label "language label"@en ;
    dcterms:description "A language label is a label that denotes the language of a textual entity."@en ;
    rdfs:subClassOf sio:SIO_000179 .

sio:SIO_000181 a owl:Class ;
    rdfs:label "first name"@en ;
    dcterms:description "A first name is a name that denotes a specific individual between members of a group of individuals, whose members usually share the same surname."@en ;
    rdfs:subClassOf sio:SIO_000116 .

sio:SIO_000182 a owl:Class ;
    rdfs:label "last name"@en ;
    dcterms:description "A last name (surname) is a name added to a given name and is part of a personal name and is often the family name."@en ;
    rdfs:subClassOf sio:SIO_000116 .

sio:SIO_000184 a owl:Class ;
    rdfs:label "legal name"@en ;
    dcterms:description "A legal name is a name given at birth, or which appears on their birth certificate, marriage certificate, or change of name certificate."@en ;
    rdfs:subClassOf sio:SIO_000183 .

sio:SIO_000186 a owl:Class ;
    rdfs:label "document version"@en ;
    dcterms:description "A document version is a version of a work in some sequence of derivative works."@en ;
    rdfs:subClassOf sio:SIO_000653 .

sio:SIO_000188 a owl:Class ;
    rdfs:label "abstract section"@en ;
    dcterms:description "An abstract section is a document section that provides brief summary of a document that explains the main argument(s), topic(s) or findings."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000189 a owl:Class ;
    rdfs:label "acknowledgements section"@en ;
    dcterms:description "An acknowledgements section is a document section that identifies individuals, groups or organizations for their support in the development of the work."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000190 a owl:Class ;
    rdfs:label "author contribution section"@en ;
    dcterms:description "An author contribution section is a document section that describes the contribution of the authors."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000191 a owl:Class ;
    rdfs:label "author section"@en ;
    dcterms:description "An author section is a document section that lists the contributing authors."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000192 a owl:Class ;
    rdfs:label "bibliography section"@en ;
    dcterms:description "A bibliography section is a document section that is composed of a list of references used in the development of the work."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000193 a owl:Class ;
    rdfs:label "copyright section"@en ;
    dcterms:description "A copyright section is a document section that contains a notice of copyright."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000194 a owl:Class ;
    rdfs:label "correspondence section"@en ;
    dcterms:description "A correspondence section is a document section that contains the details for contacting the corresponding author."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000195 a owl:Class ;
    rdfs:label "discussion section"@en ;
    dcterms:description "The discussion section is a document section containing a summary of the findings, a reflection on the significance of findings, comparison with related work, among others."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000196 a owl:Class ;
    rdfs:label "introduction section"@en ;
    dcterms:description "An introduction section is a document section that generally provides background, motivation and goals of the work."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000197 a owl:Class ;
    rdfs:label "materials and methods section"@en ;
    dcterms:description "The materials and methods section is a document section containing a description of the materials and methods used in the study."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000198 a owl:Class ;
    rdfs:label "materials section"@en ;
    dcterms:description "The materials section is a document section containing a description of the materials used in the study."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000199 a owl:Class ;
    rdfs:label "methods section"@en ;
    dcterms:description "The methods section is a document section containing a description of the methods used in the study."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000200 a owl:Class ;
    rdfs:label "results section"@en ;
    dcterms:description "The results section is a document section describing the main findings of the study."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000201 a owl:Class ;
    rdfs:label "table of contents"@en ;
    dcterms:description "The table of contents is a document section that lists all sections (and optionally subsections) in a sequential order along with their page number."@en ;
    rdfs:subClassOf sio:SIO_000111 .

sio:SIO_000204 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is adjacent to"@en ;
    dcterms:description "A is adjacent to B iff there is a small, but non-zero distance between A and B"@en ;
    sio:equivalentTo "OBO_REL:adjacent_to" ;
    sio:subset "core",
        "nlp" ;
    rdfs:subPropertyOf sio:SIO_000322 .

sio:SIO_000206 a owl:ObjectProperty ;
    rdfs:label "is supported by"@en ;
    dcterms:description "is supported by is a relation between a proposition and something that supports the truth of the assertion."@en ;
    rdfs:subPropertyOf sio:SIO_000772 ;
    owl:inverseOf sio:SIO_000208 .

sio:SIO_000207 a owl:ObjectProperty ;
    rdfs:label "is disputed by"@en ;
    dcterms:description "has disputing evidence is a relation between a proposition and something that disputes (does not directly support) the truth of the assertion."@en ;
    rdfs:subPropertyOf sio:SIO_000772 ;
    owl:inverseOf sio:SIO_000209 .

sio:SIO_000220 a owl:Class ;
    rdfs:label "implies (->)"@en ;
    dcterms:description "Implication is a logical operator that holds between a set T of propositions and a proposition B, when every model (or interpretation or valuation) of T is also a model of B."@en ;
    rdfs:subClassOf sio:SIO_000238 .

sio:SIO_000233 a owl:ObjectProperty ;
    rdfs:label "is implementation of"@en ;
    dcterms:description "is implementation of is a relation between an information entity and a specification that it conforms to."@en ;
    rdfs:subPropertyOf sio:SIO_000011 ;
    owl:inverseOf sio:SIO_000234 .

sio:SIO_000237 a owl:Class ;
    rdfs:label "namespace label"@en ;
    dcterms:description "A namespace label is a short name for a namespace."@en ;
    rdfs:subClassOf sio:SIO_000179 .

sio:SIO_000239 a owl:Class ;
    rdfs:label "conjunction (and)"@en ;
    dcterms:description "AND is a logical operator that has the value true if both of its operands are true, otherwise a value of false."@en ;
    rdfs:subClassOf sio:SIO_000238 .

sio:SIO_000241 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "is directly after"@en ;
    dcterms:description "is directly after is a relation between entities placed on a dimensional axis in which the projection of the position of the first entity is numerically greater than the projection of the position of the second entity, and the entities are adjacent to one another."@en ;
    rdfs:subPropertyOf sio:SIO_000211,
        sio:SIO_000652 ;
    owl:inverseOf sio:SIO_000242 .

sio:SIO_000246 a owl:ObjectProperty ;
    rdfs:label "immediately derives into"@en ;
    dcterms:description "a immediately derives into b if and only if a or some significant part thereof is consumed in the formation of b and there are no identifiable intermediate entities between a and b."@en ;
    rdfs:subPropertyOf sio:SIO_000245 ;
    owl:inverseOf sio:SIO_000247 .

sio:SIO_000250 a owl:ObjectProperty ;
    rdfs:label "immediately precedes"@en ;
    dcterms:description "A non-transitive temporal relation in which one process immediately precedes another process, such that there is no interval of time between the two processes."@en ;
    rdfs:subPropertyOf sio:SIO_000248 ;
    owl:inverseOf sio:SIO_000251 .

sio:SIO_000254 a owl:ObjectProperty ;
    rdfs:label "is annotation of"@en ;
    dcterms:description "is annotation of is a relation between some textual entity and the entity that it annotates."@en ;
    rdfs:domain sio:SIO_000078 ;
    rdfs:subPropertyOf sio:SIO_000011 ;
    owl:inverseOf sio:SIO_000255 .

sio:SIO_000263 a owl:Class ;
    rdfs:label "deductive argument"@en ;
    dcterms:description "A deductive argument is an argument that asserts that the truth of the conclusion is a logical consequence of the premises."@en ;
    rdfs:subClassOf sio:SIO_000259 .

sio:SIO_000264 a owl:Class ;
    rdfs:label "inductive argument"@en ;
    dcterms:description "An inductive argument is an argument that asserts that the truth of the conclusion is supported by the premises."@en ;
    rdfs:subClassOf sio:SIO_000259 .

sio:SIO_000265 a owl:Class ;
    rdfs:label "sound argument"@en ;
    dcterms:description "A sound argument is a valid argument with true premises."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000053 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000261 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000217 ;
                                owl:someValuesFrom sio:SIO_000269 ] ) ] ],
        sio:SIO_000266 .

sio:SIO_000267 a owl:Class ;
    rdfs:label "invalid argument"@en ;
    dcterms:description "An invalid argument is an argument where the truth of the conclusion is false because it is not a logical consequence of the premises."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000053 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000262 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000217 ;
                                owl:someValuesFrom sio:SIO_000270 ] ) ] ],
        sio:SIO_000259 .

sio:SIO_000274 a owl:ObjectProperty ;
    rdfs:label "is prior version of"@en ;
    dcterms:description "A is prior version of B iff A is a variant of B and B derives from A."@en ;
    rdfs:subPropertyOf sio:SIO_000244,
        sio:SIO_000497 ;
    owl:inverseOf sio:SIO_000286 .

sio:SIO_000277 a owl:ObjectProperty ;
    rdfs:label "cites"@en ;
    dcterms:description "cites is a relation to refer to by way of example, authority or proof."@en ;
    rdfs:subPropertyOf sio:SIO_000631 ;
    owl:inverseOf sio:SIO_000278 .

sio:SIO_000281 a owl:Class ;
    rdfs:label "negation (not)"@en ;
    dcterms:description "NOT is a logical operator in that has the value true if its operand is false."@en ;
    rdfs:subClassOf sio:SIO_000238 .

sio:SIO_000282 a owl:Class ;
    rdfs:label "exclusive disjunction (xor)"@en ;
    dcterms:description "XOR, also called exclusive disjunction or (symbolized XOR, EOR, EXOR, or ⊕), is a type of logical disjunction on two operands that results in a value of true if exactly one of the operands has a value of true."@en ;
    rdfs:subClassOf sio:SIO_000280 .

sio:SIO_000290 a owl:Class ;
    rdfs:label "university"@en ;
    dcterms:description "A university is an institution of higher education and research which grants academic degrees in a variety of subjects and provides both undergraduate education and postgraduate education. "@en ;
    rdfs:subClassOf sio:SIO_000285 .

sio:SIO_000296 a owl:Class ;
    rdfs:label "website"@en ;
    dcterms:description "A website is a collection of documents published on the World Wide Web."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_000302 ],
        sio:SIO_000295 .

sio:SIO_000297 a owl:Class ;
    rdfs:label "movie"@en ;
    dcterms:alternative "film"@en,
        "moving pictures"@en ;
    dcterms:description "A movie is a series of images that are displayed in rapid succession  to give the impression of movement."@en ;
    rdfs:subClassOf sio:SIO_001194 .

sio:SIO_000299 a owl:Class ;
    rdfs:label "quote"@en ;
    dcterms:description "A quote is a excerpt that is attributed to a particular source."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000244 ;
            owl:someValuesFrom sio:SIO_000651 ],
        sio:SIO_000298 .

sio:SIO_000301 a owl:Class ;
    rdfs:label "geographic image"@en ;
    dcterms:description "A geographic image is a photograph of some geographical area."@en ;
    rdfs:subClassOf sio:SIO_000082 .

sio:SIO_000304 a owl:Class ;
    rdfs:label "email"@en ;
    dcterms:description "Email message is a digital document that is composed of a header and a body and is transmitted using the SMTP protocol."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_000305 a owl:Class ;
    rdfs:label "process number"@en ;
    dcterms:description "process number is a number associated with a process that denotes its ordinal position in a set of processes."@en ;
    rdfs:subClassOf sio:SIO_000613 .

sio:SIO_000306 a owl:Class ;
    rdfs:label "letter"@en ;
    dcterms:description "A letter is a document that contains a personal communication from one part to another."@en ;
    rdfs:subClassOf sio:SIO_000148 .

sio:SIO_000308 a owl:Class ;
    rdfs:label "edition number"@en ;
    dcterms:description "An edition number is count of a literary work edited and published, as by a certain editor or in a certain manner including being printed during some interval of time."@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_000309 a owl:Class ;
    rdfs:label "volume number"@en ;
    dcterms:description "volume number is a count of a sequence of periodicals."@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_000314 a owl:Class ;
    rdfs:label "polymer"@en ;
    dcterms:description "A polymer is a molecule composed of a connected set of monomeric residues."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_000146 ],
        sio:SIO_011125 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_011125 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000273 ;
                        owl:someValuesFrom sio:SIO_000146 ] ) ] .

sio:SIO_000318 a owl:Class ;
    rdfs:label "longitude"@en ;
    dcterms:description "Longitude is a geographic position that refers to  the angle east or west of a reference meridian between the two geographical poles to another meridian that passes through an arbitrary point."@en ;
    rdfs:subClassOf sio:SIO_000013 ;
    owl:disjointWith sio:SIO_000319 .

sio:SIO_000323 a owl:ObjectProperty ;
    rdfs:label "is surrounded by"@en ;
    dcterms:description "A 'is surrounded by' B iff the A 'is contained by' B and A 'is adjacent to' B or A 'is directly connected to' B."@en ;
    rdfs:subPropertyOf sio:SIO_000128 ;
    owl:inverseOf sio:SIO_000324 .

sio:SIO_000329 a owl:Class ;
    rdfs:label "cylindrical coordinate system"@en ;
    dcterms:description "A cylindrical coordinate system is a three-dimensional coordinate system that specifies point positions by the distance from a chosen reference axis, the direction from the axis relative to a chosen reference direction, and the distance from a chosen reference plane perpendicular to the axis."@en ;
    rdfs:subClassOf sio:SIO_000320 .

sio:SIO_000330 a owl:Class ;
    rdfs:label "spherical coordinate system"@en ;
    dcterms:description "A spherical coordinate system is a coordinate system for three-dimensional space where the position of a point is specified by three numbers: the radial distance of that point from a fixed origin, its polar angle measured from a fixed zenith direction, and the azimuth angle of its orthogonal projection on a reference plane that passes through the origin and is orthogonal to the zenith, measured from a fixed reference direction on that plane."@en ;
    rdfs:subClassOf sio:SIO_000320 .

sio:SIO_000331 a owl:Class ;
    rdfs:label "OWL ontology"@en ;
    dcterms:description "An OWL ontology is an ontology as specified by the W3C OWL specification."@en ;
    rdfs:subClassOf sio:SIO_000129 .

sio:SIO_000334 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is covalently connected to"@en ;
    dcterms:description "is covalently connected to is a relation between an atom and another atom."@en ;
    rdfs:subPropertyOf sio:SIO_000288,
        sio:SIO_000652 .

sio:SIO_000345 a owl:Class ;
    rdfs:label "to magnify"@en ;
    dcterms:description "to magnify is the capability to increase the appearance of the size of an object."@en ;
    rdfs:subClassOf sio:SIO_000378 .

sio:SIO_000348 a owl:Class ;
    rdfs:label "to freeze"@en ;
    dcterms:description "to freeze is the capability to decrease the internal kinetic energy of a material such that it changes state from a gas or liquid to a solid."@en ;
    rdfs:seeAlso "http://purl.obolibrary.org/obo/OBI_0000375"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_000347 .

sio:SIO_000357 a owl:Class ;
    rdfs:label "fitness"@en ;
    dcterms:description "fitness is the quality of an object with respect to some stated functions or evolutionary adaptation."@en ;
    rdfs:subClassOf sio:SIO_000026 .

sio:SIO_000358 a owl:Class ;
    rdfs:label "intent"@en ;
    dcterms:description "intent is a desire to realize a particular outcome."@en ;
    rdfs:subClassOf sio:SIO_000825 .

sio:SIO_000359 a owl:Class ;
    rdfs:label "purpose"@en ;
    dcterms:description "purpose is the reason for which something is done or created or for which something exists."@en ;
    rdfs:subClassOf sio:SIO_001053 .

sio:SIO_000364 a owl:ObjectProperty ;
    rdfs:label "has creator"@en ;
    dcterms:alternative "is created by"@en,
        "was created by"@en ;
    dcterms:description "has creator is a relation between an entity and that which created it."@en ;
    sio:equivalentTo "dc:creator" ;
    rdfs:domain sio:SIO_000000 ;
    rdfs:range sio:SIO_000000 ;
    rdfs:subPropertyOf sio:SIO_000253 ;
    owl:inverseOf sio:SIO_000365 ;
    skos:example "the iPhone was created by Apple Inc"@en .

sio:SIO_000371 a owl:Class ;
    rdfs:label "to measure"@en ;
    dcterms:description "to measure is the capability to obtain information about some entity by examining its attributes in relation to some reference metric."@en ;
    rdfs:subClassOf sio:SIO_000408 .

sio:SIO_000373 a owl:Class ;
    rdfs:label "to boil"@en ;
    dcterms:description "to boil is the capability to increase the internal kinetic energy of a material such that it changes state from a solid or liquid to a gas."@en ;
    rdfs:subClassOf sio:SIO_000346 .

sio:SIO_000375 a owl:Class ;
    rdfs:label "to supply electricity"@en ;
    dcterms:description "to supply electricity is the capability to transfer electricity from a source to a sink."@en ;
    rdfs:subClassOf sio:SIO_000351 .

sio:SIO_000377 a owl:Class ;
    rdfs:label "to demagnify"@en ;
    dcterms:description "to demagnify is the capability to decrease the appearance of the size of an object."@en ;
    rdfs:subClassOf sio:SIO_000378 .

sio:SIO_000379 a owl:Class ;
    rdfs:label "perception"@en ;
    dcterms:description "perception is the organization, identification, and interpretation of sensory information in order to fabricate a mental representation through the process of transduction, which sensors in the body transform signals from the environment into encoded neural signals."@en ;
    rdfs:subClassOf sio:SIO_001055 .

sio:SIO_000381 a owl:Class ;
    rdfs:label "to immobilize"@en ;
    dcterms:description "to immobilize is the capability to contain an entity in such a way that it may not move in space."@en ;
    rdfs:subClassOf sio:SIO_000380 .

sio:SIO_000382 a owl:Class ;
    rdfs:label "to filter"@en ;
    dcterms:description "to filter is the capability to retain certain entities based on selected attribute(s) while allowing other entities to pass through."@en ;
    rdfs:subClassOf sio:SIO_000349 .

sio:SIO_000383 a owl:Class ;
    rdfs:label "to excite"@en ;
    dcterms:description "to excite is the capability to supply energy to a materila by bombarding it with energetic particles (e.g., photons)."@en ;
    rdfs:subClassOf sio:SIO_000351 .

sio:SIO_000384 a owl:Class ;
    rdfs:label "to emit"@en ;
    dcterms:description "to emit is the capability to release some physical entity (light, pollution, etc)."@en ;
    rdfs:subClassOf sio:SIO_000374 .

sio:SIO_000386 a owl:Class ;
    rdfs:label "to positively charge"@en ;
    dcterms:description "to positively charge is the capability to remove an electron or add a  positively charged ion to a chemical entity."@en ;
    rdfs:subClassOf sio:SIO_000350 .

sio:SIO_000387 a owl:Class ;
    rdfs:label "to negatively charge"@en ;
    dcterms:description "to negatively charge is the capability to add an electron or negatively charged ion to a chemical entity."@en ;
    rdfs:subClassOf sio:SIO_000350 .

sio:SIO_000388 a owl:Class ;
    rdfs:label "to assemble"@en ;
    dcterms:description "to assemble is the capability to combine entities together into a larger object that persists in time."@en ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_000389 a owl:Class ;
    rdfs:label "to extract"@en ;
    dcterms:description "to extract is the capability to remove certain entities based on selected attribute(s) while allowing other entities to remain."@en ;
    rdfs:subClassOf sio:SIO_000349 .

sio:SIO_000393 a owl:Class ;
    rdfs:label "patient"@en ;
    dcterms:description "A patient is an individual that is the recepient of medical care."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000228 ;
            owl:someValuesFrom sio:SIO_000715 ],
        sio:SIO_000498 .

sio:SIO_000394 a owl:Class ;
    rdfs:label "doctor"@en ;
    dcterms:description "A doctor is an individual who practices medicine, which is concerned with promoting, maintaining or restoring human health through the study, diagnosis, and treatment of disease, injury, and other physical and mental impairments."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000228 ;
            owl:someValuesFrom sio:SIO_000713 ],
        sio:SIO_000716 .

sio:SIO_000397 a owl:Class ;
    rdfs:label "to provide"@en ;
    dcterms:description "to provide is the capability to make available some object to another that requires it."@en ;
    rdfs:subClassOf sio:SIO_001358 .

sio:SIO_000398 a owl:Class ;
    rdfs:label "nurse"@en ;
    dcterms:description "A nurse is an individual that is involved in the protection, promotion, and optimization of health and abilities, prevention of illness and injury, alleviation of suffering through the diagnosis and treatment of human response, and advocacy in the care of individuals, families, communities, and populations."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000228 ;
            owl:someValuesFrom sio:SIO_000714 ],
        sio:SIO_000716 .

sio:SIO_000399 a owl:Class ;
    rdfs:label "study subject"@en ;
    dcterms:description "A study subject is an individual that is the subject of the study."@en ;
    rdfs:subClassOf sio:SIO_000498 .

sio:SIO_000407 a owl:Class ;
    rdfs:label "to increase the rate of formation"@en ;
    dcterms:description "to increase the rate of formation is to regulate the rate of formation in a manner that increases this rate relative to a reference process."@en ;
    rdfs:subClassOf sio:SIO_000536 .

sio:SIO_000411 a owl:Class ;
    rdfs:label "hate"@en ;
    dcterms:description "Hate is a deep and emotional extreme dislike, directed against a certain object or class of objects. "@en ;
    rdfs:subClassOf sio:SIO_000828 .

sio:SIO_000412 a owl:Class ;
    rdfs:label "love"@en ;
    dcterms:description "love is an emotion of a strong affection and personal attachment."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000419 a owl:Class ;
    rdfs:label "table"@en ;
    dcterms:description "A table is a figure that consists of an ordered arrangement of columns and rows."@en ;
    rdfs:subClassOf sio:SIO_000080 .

sio:SIO_000423 a owl:Class ;
    rdfs:label "scatterplot"@en ;
    dcterms:alternative "scatter chart"@en,
        "scatter diagram"@en,
        "scatter graph"@en ;
    dcterms:description "A scatterplot is a statistical graph which uses Cartesian coordinates to display values for two variables for a set of data. The data is displayed as a collection of points, each having the value of one variable determining the position on the horizontal axis and the value of the other variable determining the position on the vertical axis."@en ;
    rdfs:subClassOf sio:SIO_000083 .

sio:SIO_000437 a owl:Class ;
    rdfs:label "2D cartesian point"@en ;
    dcterms:description "A 2D cartesian point is a point whose position is specified along two  dimensions using Cartesian coordinates."@en ;
    rdfs:subClassOf sio:SIO_000507 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000507 [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( sio:SIO_000400 sio:SIO_000401 ) ] ;
                        owl:onProperty sio:SIO_000369 ] [ a owl:Restriction ;
                        owl:onClass sio:SIO_000400 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] [ a owl:Restriction ;
                        owl:onClass sio:SIO_000401 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] ) ] .

sio:SIO_000438 a owl:Class ;
    rdfs:label "altitude"@en ;
    dcterms:description "Altitude is a distance above sea level."@en ;
    rdfs:subClassOf sio:SIO_000056 .

sio:SIO_000439 a owl:Class ;
    rdfs:label "center of mass"@en ;
    dcterms:description "The center of mass (aka barycenter) is the weighted average location of all the mass in a body or group of bodies."@en ;
    rdfs:subClassOf sio:SIO_000056 .

sio:SIO_000440 a owl:Class ;
    rdfs:label "3D cartesian point"@en ;
    dcterms:description "A 3D cartesian point is a point whose position is specified along three  dimensions using Cartesian coordinates."@en ;
    rdfs:subClassOf sio:SIO_000507 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000507 [ a owl:Restriction ;
                        owl:onClass sio:SIO_000400 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] [ a owl:Restriction ;
                        owl:onClass sio:SIO_000401 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] [ a owl:Restriction ;
                        owl:onClass sio:SIO_000402 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] ) ] .

sio:SIO_000441 a owl:Class ;
    rdfs:label "1D cartesian point"@en ;
    dcterms:description "A 1D cartesian point is a point whose position is specified along a single dimension using Cartesian coordinates."@en ;
    rdfs:subClassOf sio:SIO_000507 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000507 [ a owl:Restriction ;
                        owl:allValuesFrom sio:SIO_000402 ;
                        owl:onProperty sio:SIO_000369 ] [ a owl:Restriction ;
                        owl:onClass sio:SIO_000402 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] ) ] .

sio:SIO_000442 a owl:Class ;
    rdfs:label "line graph"@en ;
    dcterms:alternative "line chart"@en ;
    dcterms:description "A line graph is a statistical graph in which lines contains the evaluation of functions or individual points connected by line segments."@en ;
    rdfs:subClassOf sio:SIO_000083 ;
    skos:example "Graph 1 in http://tinyurl.com/opwnvm"@en .

sio:SIO_000444 a owl:Class ;
    rdfs:label "horizontal bar graph"@en ;
    dcterms:description "A horizontal bar graph is a bar graph in which the rectangular bars are horizontally oriented in space."@en ;
    rdfs:subClassOf sio:SIO_000443 ;
    skos:example "Graph 3 in http://tinyurl.com/opwnvm"@en .

sio:SIO_000445 a owl:Class ;
    rdfs:label "vertical bar graph"@en ;
    dcterms:description "A vertical bar graph is a bar graph in which the rectangular bars are vertically oriented in space."@en ;
    rdfs:subClassOf sio:SIO_000443 ;
    skos:example "Graph 4,5 in http://tinyurl.com/opwnvm"@en .

sio:SIO_000446 a owl:Class ;
    rdfs:label "stacked bar graph"@en ;
    dcterms:description "A stacked bar graph is a bar graph in which each rectangular bar is partioned by the categorical value of each series of data."@en ;
    rdfs:subClassOf sio:SIO_000443 ;
    skos:example "Graphs 6,7 in http://tinyurl.com/opwnvm"@en .

sio:SIO_000449 a owl:Class ;
    rdfs:label "plot"@en ;
    dcterms:description "A plot is a part of a figure that corresponds to the spatial region between the set of axes."@en ;
    rdfs:subClassOf sio:SIO_000448 ;
    owl:disjointWith sio:SIO_000468 ;
    skos:example """The square portion of the chart bounded by lines that overlap with 
the two axes in Graph 1 of http://tinyurl.com/opwnvm"""@en .

sio:SIO_000452 a owl:Class ;
    rdfs:label "x-axis"@en ;
    dcterms:alternative "horizontal axis" ;
    dcterms:description "An x-axis is a Cartesian coordinate axis that is aligned with the horizon."@en ;
    schema1:comment "In most figures, this axis represents categories, such as months, market segments, or other non-numeric data."@en ;
    rdfs:subClassOf sio:SIO_000451 ;
    owl:disjointWith sio:SIO_000453,
        sio:SIO_000454 ;
    skos:example "The horizontal axis in http://tinyurl.com/opwnvm"@en .

sio:SIO_000462 a owl:Class ;
    rdfs:label "linear value axis"@en ;
    dcterms:description "A linear value axis is a value axis that corresponds to a scaling factor of 1 of the value range."@en ;
    rdfs:subClassOf sio:SIO_000461 ;
    owl:disjointWith sio:SIO_000463 .

sio:SIO_000464 a owl:Class ;
    rdfs:label "data series"@en ;
    dcterms:description "A data series is a data set composed of related values displayed in a statistical graph."@en ;
    rdfs:subClassOf sio:SIO_000150 ;
    skos:example "Example: The two series that correspond to \"Seasonally adjusted\" and \"Trend\" are composed of the seasonally adjusted value of permits in each month and values from a trend derived from some mathematical tranformation across those values, respectively, in  Graph 1 of http://tinyurl.com/opwnvm"@en .

sio:SIO_000466 a owl:Class ;
    rdfs:label "global maximal stationary point"@en ;
    dcterms:description "A global maximum stationary point is a data point that corresponds to a measurement value is larger than that of all other plotted datapoints."@en ;
    rdfs:subClassOf sio:SIO_000742 .

sio:SIO_000467 a owl:Class ;
    rdfs:label "global minimal stationary point"@en ;
    dcterms:description "A global minimum data point is a data point that corresponds to a measurement value is smaller than that of all other plotted datapoints."@en ;
    rdfs:subClassOf sio:SIO_000743 .

sio:SIO_000469 a owl:Class ;
    rdfs:label "graph title"@en ;
    dcterms:description "A graph title is a title that describes a graph."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000310 ;
            owl:someValuesFrom sio:SIO_000083 ],
        sio:SIO_000185 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000185 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000310 ;
                        owl:someValuesFrom sio:SIO_000083 ] ) ] ;
    skos:example "Total value of permits increased slightly in December\" in Graph 1 of http://tinyurl.com/opwnvm"@en .

sio:SIO_000471 a owl:Class ;
    rdfs:label "secondary title"@en ;
    dcterms:alternative "subtitle, alternative title" ;
    dcterms:description "A secondary title is a title of lesser importance that should be used after the first title in describing some entity."@en ;
    rdfs:subClassOf sio:SIO_000185 .

sio:SIO_000473 a owl:Class ;
    rdfs:label "primary graph title"@en ;
    dcterms:description "A primary graph title is a primary title that describes a statistical graph."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000310 ;
            owl:someValuesFrom sio:SIO_000083 ],
        sio:SIO_000470 ;
    skos:example "\"Total value of permits increased slightly in December\" in Graph 1 of http://tinyurl.com/opwnvm"@en .

sio:SIO_000474 a owl:Class ;
    rdfs:label "secondary graph title"@en ;
    dcterms:description "A secondary graph title is a secondary title that describes a statistical graph."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000310 ;
            owl:someValuesFrom sio:SIO_000083 ],
        sio:SIO_000470 .

sio:SIO_000480 a owl:Class ;
    rdfs:label "insertion variant role"@en ;
    dcterms:description "An insertion variant role is the role of an sequence that contains a sub-sequence that is considered to be an addition relative to the frame of reference."@en ;
    rdfs:subClassOf sio:SIO_000478 .

sio:SIO_000481 a owl:Class ;
    rdfs:label "deletion variant role"@en ;
    dcterms:description "A deletion variant role is the role of an sequence that lacks a sub-sequence relative to the frame of reference."@en ;
    rdfs:subClassOf sio:SIO_000478 .

sio:SIO_000484 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is exact match to"@en ;
    sio:equivalentTo "http://www.w3.org/2004/02/skos/core#exactMatch" ;
    rdfs:subPropertyOf sio:SIO_000482 .

sio:SIO_000485 a owl:Class ;
    rdfs:label "human"@en ;
    dcterms:description "A human is a primates of the family Hominidae and are characterized by having a large brain relative to body size, with a well developed neocortex, prefrontal cortex and temporal lobes, making them capable of abstract reasoning, language, introspection, problem solving and culture through social learning."@en ;
    rdfs:subClassOf sio:SIO_010375 .

sio:SIO_000486 a owl:Class ;
    rdfs:label "mouse"@en ;
    dcterms:description "A mouse is a small mammal belonging to the order of rodents, characteristically having a pointed snout, small rounded ears, and a long naked or almost hairless tail. "@en ;
    rdfs:subClassOf sio:SIO_010375 .

sio:SIO_000487 a owl:Class ;
    rdfs:label "rat"@en ;
    dcterms:description "A rat is a medium-sized, long-tailed rodent of the superfamily Muroidea."@en ;
    rdfs:subClassOf sio:SIO_010375 .

sio:SIO_000488 a owl:Class ;
    rdfs:label "worm"@en ;
    dcterms:description "A worm is a non-arthropod invertebrate animal that typically have a long cylindrical tube-like body and no legs."@en ;
    rdfs:subClassOf sio:SIO_010375 .

sio:SIO_000489 a owl:Class ;
    rdfs:label "e.coli"@en ;
    dcterms:description "Escherichia coli (e coli) is a Gram-negative, rod-shaped bacterium that is commonly found in the lower intestine of warm-blooded organisms."@en ;
    rdfs:subClassOf sio:SIO_010376 .

sio:SIO_000490 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is close match to"@en ;
    sio:equivalentTo "http://www.w3.org/2004/02/skos/core#closeMatch" ;
    rdfs:subPropertyOf sio:SIO_000482 .

sio:SIO_000491 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is broad match to"@en ;
    sio:equivalentTo "http://www.w3.org/2004/02/skos/core#broadMatch" ;
    rdfs:subPropertyOf sio:SIO_000482 .

sio:SIO_000493 a owl:Class ;
    rdfs:label "clause"@en ;
    dcterms:description "A clause consists of a subject and a predicate."@en ;
    rdfs:subClassOf sio:SIO_000113 .

sio:SIO_000502 a owl:Class ;
    rdfs:label "polyhedral skeleton"@en ;
    dcterms:description "A polyhedral skeleton is a collection of polygon edges."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_000501 ],
        sio:SIO_000506 .

sio:SIO_000504 a owl:Class ;
    rdfs:label "polyhedral surface"@en ;
    dcterms:description "A polyhedral surface is composed of polygonal faces."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000028 ;
            owl:someValuesFrom sio:SIO_000503 ],
        sio:SIO_000506 .

sio:SIO_000514 a owl:Class ;
    rdfs:label "major tick mark"@en ;
    dcterms:description "A major tick mark is a tick mark that indicates the position of a specific numeric value and is adjacent to its value label on the value axis, or is one of a pair of tick marks that delineates the boundary of a categorical value indicated by an adjacent category label on the categorical axis."@en ;
    rdfs:subClassOf sio:SIO_000513 .

sio:SIO_000515 a owl:Class ;
    rdfs:label "minor tick mark"@en ;
    dcterms:description "A minor tick mark is a tick mark that indicates the position of a specific numeric value but has no adjacent value label, or is one of a pair of tick marks that delineates the boundary of a categorical value but has no adjacent category label on the categorical axis."@en ;
    rdfs:subClassOf sio:SIO_000513 .

sio:SIO_000519 a owl:Class ;
    rdfs:label "bar"@en ;
    dcterms:description "A bar is a rectangle that is located in the plot of a statistical graph in which its length is proportional to the values that it represents."@en ;
    rdfs:subClassOf sio:SIO_000518 .

sio:SIO_000523 a owl:Class ;
    rdfs:label "single arrowed line segment"@en ;
    dcterms:description "A single arrowed line is directed line in which the endpoint is tangentially part of a triangle that bisects the line."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_000520 ;
            owl:onProperty sio:SIO_000369 ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        sio:SIO_000522 ;
    owl:disjointWith sio:SIO_000524 .

sio:SIO_000525 a owl:Class ;
    rdfs:label "horizontal line"@en ;
    dcterms:description "A horizontal line is a line that is positionally oriented with the horizon."@en ;
    rdfs:subClassOf sio:SIO_000534 .

sio:SIO_000526 a owl:Class ;
    rdfs:label "vertical line"@en ;
    dcterms:description "A vertical line is a line that is positionally oriented perpendicular to the horizon."@en ;
    rdfs:subClassOf sio:SIO_000534 .

sio:SIO_000528 a owl:Class ;
    rdfs:label "increasing line"@en ;
    dcterms:description "An increasing line is a line segment in which the startpoint and endpoint are ordered along one dimension and the difference of values in a second dimension is positive."@en ;
    rdfs:subClassOf sio:SIO_000527 .

sio:SIO_000529 a owl:Class ;
    rdfs:label "decreasing line"@en ;
    dcterms:description "An decreasing line is a line segment in which the startpoint and endpoint are ordered along one dimension and the difference of values in a second dimension is negative."@en ;
    rdfs:subClassOf sio:SIO_000527 .

sio:SIO_000530 a owl:Class ;
    rdfs:label "plateau line"@en ;
    dcterms:description "An plateau line is a line segment in which the startpoint and endpoint are ordered along one dimension and the difference of values in a second dimension is zero."@en ;
    rdfs:subClassOf sio:SIO_000527 .

sio:SIO_000531 a owl:Class ;
    rdfs:label "drop line"@en ;
    dcterms:description "A drop line is a statistical graph line that vertically or horizontally connects a data series line with a value axis in a statistical graph."@en ;
    rdfs:subClassOf sio:SIO_000535 .

sio:SIO_000533 a owl:Class ;
    rdfs:label "surface normal"@en ;
    dcterms:description "A surface normal is a vector that is perpendicular to a flat surface."@en ;
    rdfs:subClassOf sio:SIO_000540 .

sio:SIO_000543 a owl:Class ;
    rdfs:label "to serve as a host"@en ;
    dcterms:description "to serve as host is the capability to act in a manner that provides hospitality, serves to harbour an organism in or on itself."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000646 ;
            owl:someValuesFrom sio:SIO_010415 ],
        sio:SIO_000542 .

sio:SIO_000544 a owl:Class ;
    rdfs:label "to infect"@en ;
    dcterms:description "to infect is the capability to administer a disease-causing organism into some object."@en ;
    rdfs:subClassOf sio:SIO_000372 .

sio:SIO_000545 a owl:Class ;
    rdfs:label "polyline"@en ;
    dcterms:alternative "polygonal chain, polygonal curve, polygonal path, piecewise linear curve" ;
    dcterms:description "A polyline is a connected sequence of line segments."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_000512 ;
            owl:onProperty sio:SIO_000369 ],
        sio:SIO_000506 .

sio:SIO_000546 a owl:Class ;
    rdfs:label "collection of points"@en ;
    dcterms:description "A collection of points is a geometric entity that contains a non-zero set of geometric points. "@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_000507 ;
            owl:onProperty sio:SIO_000059 ],
        sio:SIO_000506,
        sio:SIO_000616 .

sio:SIO_000547 a owl:Class ;
    rdfs:label "to cause disease"@en ;
    dcterms:description "to cause disease is the capability to materially change a biological object in that it functions abnormally."@en ;
    rdfs:subClassOf sio:SIO_000376 .

sio:SIO_000561 a owl:Class ;
    rdfs:label "molecular orbital"@en ;
    dcterms:description "A molecular orbital (or MO) is a mathematical function describing the wave-like behavior of an electron in a molecule."@en ;
    rdfs:subClassOf sio:SIO_001011 .

sio:SIO_000562 a owl:Class ;
    rdfs:label "passive transport"@en ;
    dcterms:description "passive transport is the movement of a substance across a membrane and does not require chemical energy."@en ;
    rdfs:subClassOf sio:SIO_000576 ;
    owl:disjointWith sio:SIO_010284 .

sio:SIO_000565 a owl:Class ;
    rdfs:label "diffusion equation"@en ;
    dcterms:description "A diffusion equation describes density fluctuations in a material undergoing diffusion."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom sio:SIO_000564 ],
        sio:SIO_000566 .

sio:SIO_000567 a owl:Class ;
    rdfs:label "ordinary differential equation"@en ;
    dcterms:description "An ordinary differential equation (ODE) is a differential equation in which the unknown function (also known as the dependent variable) is a function of a single independent variable."@en ;
    rdfs:subClassOf sio:SIO_000569 .

sio:SIO_000568 a owl:Class ;
    rdfs:label "partial differential equation"@en ;
    dcterms:description "A partial differential equation (PDE) is a differential equation in which the unknown function is a function of multiple independent variables and the equation involves its partial derivatives."@en ;
    rdfs:subClassOf sio:SIO_000569 .

sio:SIO_000571 a owl:Class ;
    rdfs:label "brownian motion"@en ;
    dcterms:description "Brownian motion is the seemlingly random movement of particles suspended in a fluid."@en ;
    rdfs:subClassOf sio:SIO_000564 .

sio:SIO_000572 a owl:Class ;
    rdfs:label "osmosis"@en ;
    dcterms:description "osmosis is the movement of water molecules through a selectively-permeable membrane down a water potential gradient."@en ;
    rdfs:subClassOf sio:SIO_000564 .

sio:SIO_000577 a owl:Class ;
    rdfs:label "primary active transport"@en ;
    dcterms:description "primary active transport, also called direct active transport, directly uses energy to transport molecules across a membrane."@en ;
    rdfs:subClassOf sio:SIO_010284 ;
    owl:disjointWith sio:SIO_000578 .

sio:SIO_000579 a owl:Class ;
    rdfs:label "symport enabled secondary active transport"@en ;
    dcterms:description "symport enabled secondary active transport is a secondary active transfort in which both ion and molecule are transported in the same direction simultaneously."@en ;
    rdfs:subClassOf sio:SIO_000578 ;
    owl:disjointWith sio:SIO_000580 .

sio:SIO_000581 a owl:Class ;
    rdfs:label "locomotion"@en ;
    dcterms:description "The self-propelled movement of an object."@en ;
    sio:broaderThan "GO:0040011" ;
    rdfs:subClassOf sio:SIO_000574 .

sio:SIO_000582 a owl:Class ;
    rdfs:label "birthing"@en ;
    dcterms:description "birthing is the process by which a biological organism is brought into existence."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_010046 ],
        sio:SIO_000588 .

sio:SIO_000583 a owl:Class ;
    rdfs:label "dying"@en ;
    dcterms:description "dying is a process in which a biological entity ceases to exist."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000905 ;
            owl:someValuesFrom sio:SIO_010046 ],
        sio:SIO_000591 .

sio:SIO_000585 a owl:Class ;
    rdfs:label "idea"@en ;
    dcterms:description "An idea is a proposition about some object of conceptual thought."@en ;
    rdfs:subClassOf sio:SIO_000256 .

sio:SIO_000587 a owl:Class ;
    rdfs:label "biological reproduction"@en ;
    dcterms:description "biological reproduction is the biological process by which one or more biological organisms are produced from their \"parents\". "@en ;
    rdfs:subClassOf sio:SIO_000919 .

sio:SIO_000595 a owl:Class ;
    rdfs:label "parameterized data transformation"@en ;
    dcterms:description "A parameterized data transformation is a data transformation whose behaviour may be modified by one or more parameters."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000552 ;
            owl:someValuesFrom sio:SIO_000144 ],
        sio:SIO_000594 .

sio:SIO_000597 a owl:Class ;
    rdfs:label "solid state hard drive"@en ;
    dcterms:description "A solid-state drive (SSD) is a data storage device that uses solid-state memory to store persistent data."@en ;
    rdfs:subClassOf sio:SIO_000598 .

sio:SIO_000605 a owl:Class ;
    rdfs:label "sound wave"@en ;
    dcterms:description "A sound wave is a mechanical wave that is an oscillation of pressure transmitted through a solid, liquid, or gas, composed of frequencies within the range of hearing."@en ;
    rdfs:subClassOf sio:SIO_000650 .

sio:SIO_000617 a owl:Class ;
    rdfs:label "empty set"@en ;
    dcterms:description "An empty set is a set for which there are exactly 0 members."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_000000 ;
            owl:onProperty sio:SIO_000059 ;
            owl:qualifiedCardinality "0"^^xsd:nonNegativeInteger ],
        sio:SIO_000289 .

sio:SIO_000618 a owl:Class ;
    rdfs:label "standard"@en ;
    dcterms:description "A standard is a socially-agreed upon specification."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_000966 ],
        sio:SIO_000090 .

sio:SIO_000622 a owl:Class ;
    rdfs:label "RDFS ontology"@en ;
    dcterms:description "An RDFS ontology is an ontology that conforms to the syntax and semantics of the Resource Description Framework Schema (RDFS)."@en ;
    rdfs:subClassOf sio:SIO_000129 .

sio:SIO_000623 a owl:Class ;
    rdfs:label "OBO ontology"@en ;
    dcterms:description "An OBO ontology is an ontology document as specified by the Open Biological Ontology community."@en ;
    rdfs:subClassOf sio:SIO_000129 .

sio:SIO_000630 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is paralogous to"@en ;
    dcterms:description "is paralogous to is a relation between two entities which indicates their common ancestry as a result of a gene duplication."@en ;
    rdfs:subPropertyOf sio:SIO_010302 .

sio:SIO_000634 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is xenologous to"@en ;
    dcterms:description "a relation between two entities which indicates their common ancestry but due to horizontal gene transfer."@en ;
    rdfs:subPropertyOf sio:SIO_000558 .

sio:SIO_000647 a owl:Class ;
    rdfs:label "process model"@en ;
    dcterms:description "A process model is a representation of some process."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000632 ;
            owl:someValuesFrom sio:SIO_000006 ],
        sio:SIO_000510 ;
    owl:disjointWith sio:SIO_000648 .

sio:SIO_000656 a owl:ObjectProperty ;
    rdfs:label "immediately transforms into"@en ;
    dcterms:description "A  temporal relation in which an entity mainstains identity from one state to another."@en ;
    rdfs:subPropertyOf sio:SIO_000655 ;
    owl:inverseOf sio:SIO_000658 .

sio:SIO_000660 a owl:Class ;
    rdfs:label "hole"@en ;
    dcterms:description "A hole is a site that is opening into or through something."@en ;
    rdfs:subClassOf sio:SIO_000019 .

sio:SIO_000661 a owl:Class ;
    rdfs:label "province"@en ;
    dcterms:description "A province is a territorial unit, almost always an administrative division, within a country or state."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000664 ],
        sio:SIO_000415 .

sio:SIO_000662 a owl:Class ;
    rdfs:label "state"@en ;
    dcterms:description "A state is a set of governing and supportive institutions that have sovereignty over a definite territory and population."@en ;
    rdfs:subClassOf sio:SIO_000415 .

sio:SIO_000663 a owl:Class ;
    rdfs:label "territory"@en ;
    dcterms:description "A territory is a non-sovereign geographic region."@en ;
    rdfs:subClassOf sio:SIO_000415 .

sio:SIO_000665 a owl:Class ;
    rdfs:label "city"@en ;
    dcterms:description "A city is a relatively large and permanent settlement."@en ;
    rdfs:subClassOf sio:SIO_000415 .

sio:SIO_000666 a owl:Class ;
    rdfs:label "township"@en ;
    dcterms:description "A township is a rural or sub-urban settlement."@en ;
    rdfs:subClassOf sio:SIO_000415 .

sio:SIO_000669 a owl:Class ;
    rdfs:label "start time"@en ;
    dcterms:description "A start time is a time instant pertaining to the time at which a process begins."@en ;
    rdfs:subClassOf sio:SIO_000418 .

sio:SIO_000670 a owl:Class ;
    rdfs:label "end time"@en ;
    dcterms:description "An end time is a time instant pertaining to the time at which a process ends."@en ;
    rdfs:subClassOf sio:SIO_000418 .

sio:SIO_000680 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has start time"@en ;
    rdfs:range sio:SIO_000418 ;
    rdfs:subPropertyOf sio:SIO_000679 ;
    owl:inverseOf sio:SIO_000682 .

sio:SIO_000681 a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has end time"@en ;
    rdfs:range sio:SIO_000418 ;
    rdfs:subPropertyOf sio:SIO_000679 ;
    owl:inverseOf sio:SIO_000684 .

sio:SIO_000686 a owl:Class ;
    rdfs:label "academic department"@en ;
    dcterms:description "An academic department is a division of a university or school faculty devoted to a particular academic discipline."@en ;
    rdfs:subClassOf sio:SIO_000285 .

sio:SIO_000688 a owl:Class ;
    rdfs:label "institute"@en ;
    dcterms:description "institute is a society or organization having a object or common factor, and is normally applied to those with a scientific, educational, or social objective."@en ;
    rdfs:subClassOf sio:SIO_000012 .

sio:SIO_000689 a owl:Class ;
    rdfs:label "to be a part of"@en ;
    dcterms:description "to be a part of is the capability to be assembled into a larger structure that persists in time."@en ;
    rdfs:subClassOf sio:SIO_010367 .

sio:SIO_000693 a owl:Class ;
    rdfs:label "corporation"@en ;
    dcterms:description "A corporation is an organization that is granted a charter recognizing it as a separate legal entity."@en ;
    rdfs:subClassOf sio:SIO_000012 .

sio:SIO_000695 a owl:Class ;
    rdfs:label "to be recorded"@en ;
    dcterms:description "to be recorded is the capability of an object to be observed in such a way that information about it can be transcribed in a specified format on some physical medium."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000697 ;
            owl:someValuesFrom sio:SIO_000344 ],
        sio:SIO_000696 .

sio:SIO_000700 a owl:Class ;
    rdfs:label "to disassociate"@en ;
    dcterms:description "to disassociate is to cease or break association with some thing."@en ;
    rdfs:subClassOf sio:SIO_000343 .

sio:SIO_000703 a owl:Class ;
    rdfs:label "evolving"@en ;
    dcterms:description "evolving is a process that elicits change across successive generations in the inherited characteristics of biological populations."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000588 .

sio:SIO_000704 a owl:Class ;
    rdfs:label "positional role"@en ;
    dcterms:description "A positional role is an abstract role which holds by comparing position to another object of reference."@en ;
    rdfs:subClassOf sio:SIO_000678 ;
    owl:disjointWith sio:SIO_000721 .

sio:SIO_000717 a owl:Class ;
    rdfs:label "dentist role"@en ;
    dcterms:description "A dentist role is the role of an individual that that specializes in the diagnosis, prevention, and treatment of diseases and conditions of the oral cavity."@en ;
    rdfs:subClassOf sio:SIO_000712 .

sio:SIO_000727 a owl:Class ;
    rdfs:label "secretary role"@en ;
    dcterms:description "A secretary role is the role of an individual that performs administrative tasks to support one or more individuals of the same organization."@en ;
    rdfs:subClassOf sio:SIO_000726 .

sio:SIO_000738 a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "is equal to"@en ;
    dcterms:description "is equal to is a comparison relation between two quantities whose value are exactly the same."@en ;
    rdfs:subPropertyOf sio:SIO_000737 .

sio:SIO_000739 a owl:Class ;
    rdfs:label "planning"@en ;
    dcterms:description "planning is the agentive process of developing a plan that specifies a set of actions in order to meet a set of goals or objectives."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( sio:SIO_000076 sio:SIO_000705 ) ] ],
        sio:SIO_000588 .

sio:SIO_000740 a owl:Class ;
    rdfs:label "curve segment"@en ;
    dcterms:description "A curve segment is a part of a curve that consists of at least three points."@en ;
    rdfs:subClassOf sio:SIO_000608 .

sio:SIO_000744 a owl:Class ;
    rdfs:label "learning"@en ;
    dcterms:description "learning is the agentive process of acquiring knowledge."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_000256 ],
        sio:SIO_000588 .

sio:SIO_000745 a owl:Class ;
    rdfs:label "comparing"@en ;
    dcterms:alternative "comparison" ;
    dcterms:description "comparing is the process of examining a set of objects and determining their equality or inequality based on one or more features."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000355 ;
                        owl:someValuesFrom sio:SIO_000722 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000355 ;
                        owl:someValuesFrom sio:SIO_000723 ] ) ],
        sio:SIO_000593 .

sio:SIO_000746 a owl:Class ;
    rdfs:label "reasoning"@en ;
    dcterms:description "reasoning is the agentive process of using knowledge to evaluate the truth value of a proposition."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000268 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000218 ;
                                owl:someValuesFrom sio:SIO_000256 ] ) ] ],
        sio:SIO_000588 .

sio:SIO_000748 a owl:Class ;
    rdfs:label "predicting"@en ;
    dcterms:description "predicting is the process of formulating a proposition about a state of affairs which might be realized in the future."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_000256 ],
        sio:SIO_000588 .

sio:SIO_000749 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is inequal to"@en ;
    dcterms:description "is inequal to is a comparison relation between two quantities whose value are not the same."@en ;
    rdfs:subPropertyOf sio:SIO_000737 .

sio:SIO_000757 a owl:Class ;
    rdfs:label "database column"@en ;
    dcterms:description "A database collumn is a column in a database table."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000754 ],
        sio:SIO_000753 .

sio:SIO_000759 a owl:Class ;
    rdfs:label "unique cell"@en ;
    dcterms:description "A unique cell is a cell that contains a unique value in the cellular automaton."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom sio:SIO_000675 ],
        sio:SIO_000755 .

sio:SIO_000760 a owl:Class ;
    rdfs:label "referencing cell"@en ;
    dcterms:description "A referenceing cell is a cell of a cellular automata that refers to another cell."@en ;
    rdfs:subClassOf sio:SIO_000755 .

sio:SIO_000761 a owl:Class ;
    rdfs:label "referent cell"@en ;
    dcterms:description "A referent cell is a cell that is the referent of some function or pointer."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000212 ;
            owl:someValuesFrom sio:SIO_000755 ],
        sio:SIO_000755 .

sio:SIO_000763 a owl:Class ;
    rdfs:label "primary database key"@en ;
    dcterms:description "A primary database key is a database key that identifies every row of a table."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:complementOf [ a owl:Restriction ;
                    owl:hasValue "null" ;
                    owl:onProperty sio:SIO_000300 ] ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000674 ;
            owl:someValuesFrom sio:SIO_000752 ],
        sio:SIO_000762 .

sio:SIO_000764 a owl:Class ;
    rdfs:label "foreign database key"@en ;
    dcterms:description "A foreign database key is a database key that refers to a key in some table."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000631 ;
            owl:someValuesFrom sio:SIO_000762 ],
        sio:SIO_000762 .

sio:SIO_000765 a owl:Class ;
    rdfs:label "probability value"@en ;
    dcterms:alternative "p-value"@en ;
    dcterms:description "A p-value or probability value is the probability of obtaining a test statistic at least as extreme as the one that was actually observed, assuming that the null hypothesis is true"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000300 ;
            owl:someValuesFrom [ a rdfs:Datatype ;
                    owl:onDatatype xsd:double ;
                    owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] [ xsd:maxInclusive 1e+00 ] ) ] ],
        sio:SIO_000638 .

sio:SIO_000766 a owl:Class ;
    rdfs:label "street name"@en ;
    dcterms:description "A street name is the token given to identify a particular street."@en ;
    rdfs:subClassOf sio:SIO_000328 .

sio:SIO_000767 a owl:Class ;
    rdfs:label "postal code"@en ;
    dcterms:description "A postal code is a geographic coordinate composed of a series of letters and/or digits appended to a postal address for the purpose of sorting mail."@en ;
    rdfs:subClassOf sio:SIO_000013 .

sio:SIO_000768 a owl:Class ;
    rdfs:label "apartment number"@en ;
    dcterms:description "An apartment number is the number assigned to identify an apartment in a building of apartments."@en ;
    rdfs:subClassOf sio:SIO_000328 .

sio:SIO_000769 a owl:Class ;
    rdfs:label "uncertainty value"@en ;
    dcterms:description "The uncertainty value (margin of error) of a measurement is a range of values likely to enclose the true value. "@en ;
    rdfs:subClassOf sio:SIO_000052 .

sio:SIO_000770 a owl:Class ;
    rdfs:label "standard deviation"@en ;
    dcterms:description "A standard deviation (represented by the symbol σ) is the quantity of  variation from the average (mean, or expected value)."@en ;
    rdfs:subClassOf sio:SIO_000052 .

sio:SIO_000771 a owl:Class ;
    rdfs:label "versioned record"@en ;
    dcterms:description "A versioned record is a record for which there exists another variant based that was derived via modification of the facts."@en ;
    rdfs:subClassOf sio:SIO_000088 .

sio:SIO_000774 a owl:ObjectProperty ;
    rdfs:label "is refuted by"@en ;
    dcterms:description "has evidence is a relation between a proposition and something that refutes (is incompatible with) the truth of the assertion."@en ;
    rdfs:subPropertyOf sio:SIO_000772 ;
    owl:inverseOf sio:SIO_000775 .

sio:SIO_000777 a owl:Class ;
    rdfs:label "to be a member of"@en ;
    dcterms:description "to be a member of is the capability to be considered a part of a collection."@en ;
    rdfs:subClassOf sio:SIO_000639 .

sio:SIO_000778 a owl:Class ;
    rdfs:label "to distort"@en ;
    dcterms:description "to distort is the capability to change the appearance of an entity by some transformation."@en ;
    rdfs:subClassOf sio:SIO_000378 .

sio:SIO_000784 a owl:Class ;
    rdfs:label "hermaphrodite"@en ;
    dcterms:description "hermaphrodite is a biological sex of an individual with both male and female sexual organs."@en ;
    sio:equivalentTo "PATO:0001827" ;
    rdfs:subClassOf sio:SIO_001405 ;
    owl:disjointWith sio:SIO_010048 .

sio:SIO_000785 a owl:Class ;
    rdfs:label "answer"@en ;
    dcterms:description "An answer is a reply to a question."@en ;
    rdfs:subClassOf sio:SIO_000136 .

sio:SIO_000787 a owl:Class ;
    rdfs:label "page number"@en ;
    dcterms:description "A page number is the count of a page in a sequence of pages."@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_000791 a owl:Class ;
    rdfs:label "sequence start position"@en ;
    dcterms:description "A sequence start position is the start position for a sequence of characters."@en ;
    rdfs:subClassOf sio:SIO_000789,
        sio:SIO_000943 .

sio:SIO_000792 a owl:Class ;
    rdfs:label "sequence end position"@en ;
    dcterms:description "A sequence end position is the position of the last character in a sequence of characters relative to some linear frame of reference."@en ;
    rdfs:subClassOf sio:SIO_000789,
        sio:SIO_000953 .

sio:SIO_000793 a owl:ObjectProperty ;
    rdfs:label "measured at"@en ;
    dcterms:description "measured at is a relation between a measurement value and the time measurement."@en ;
    sio:subset "core" ;
    rdfs:range sio:SIO_000391 ;
    rdfs:subPropertyOf sio:SIO_000687 .

sio:SIO_000796 a owl:Class ;
    rdfs:label "catalytic role"@en ;
    dcterms:description "The role of a chemical participant that serves to increase the rate of reaction by lowering the activiation energy."@en ;
    rdfs:subClassOf sio:SIO_000880 .

sio:SIO_000798 a owl:Class ;
    rdfs:label "product role"@en ;
    dcterms:description "The role of a chemical entity present at the end of a chemical reaction."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000227 ;
            owl:someValuesFrom sio:SIO_010363 ],
        sio:SIO_000889 .

sio:SIO_000801 a owl:Class ;
    rdfs:label "prosthetic group role"@en ;
    dcterms:description "A coenzyme role of a chemical entity that is covalently bonded to the  enzyme."@en ;
    rdfs:subClassOf sio:SIO_000800 .

sio:SIO_000802 a owl:Class ;
    rdfs:label "co-substrate role"@en ;
    dcterms:description "A co-enzyme role of a chemical entity that is transiently associated, and is regenerated in a separate reaction."@en ;
    rdfs:subClassOf sio:SIO_000800 .

sio:SIO_000803 a owl:Class ;
    rdfs:label "inhibitor role"@en ;
    dcterms:description "The role of a chemical entity that reduces the rate of reaction."@en ;
    rdfs:subClassOf sio:SIO_000880 .

sio:SIO_000804 a owl:Class ;
    rdfs:label "activator role"@en ;
    dcterms:description "The role of a chemical entity that increases the rate of reaction."@en ;
    rdfs:subClassOf sio:SIO_000880 .

sio:SIO_000811 a owl:Class ;
    rdfs:label "URL"@en ;
    dcterms:alternative "Uniform Resource Locator"@en ;
    dcterms:description "A Uniform Resource Locator or Universal Resource Locator (URL) is a specific character string that constitutes a reference to an Internet resource."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000300 ;
            owl:someValuesFrom xsd:anyURI ],
        sio:SIO_000731 .

sio:SIO_000812 a owl:Class ;
    rdfs:label "affection"@en ;
    dcterms:description "affection is an emotion characterized with a feeling or type of love for another living thing."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000813 a owl:Class ;
    rdfs:label "angst"@en ;
    dcterms:description "angst is the intense feeling of apprehension, anxiety or inner turmoil."@en ;
    rdfs:subClassOf sio:SIO_000815 .

sio:SIO_000816 a owl:Class ;
    rdfs:label "apathy"@en ;
    dcterms:description "apathy is an emotion characterized by lack of interest, enthusiasm, or concern."@en ;
    rdfs:subClassOf sio:SIO_000847 .

sio:SIO_000817 a owl:Class ;
    rdfs:label "arousal"@en ;
    dcterms:description "arousal is an emotion characterized by state of reactive to stimuli. It involves the activation of the reticular activating system in the brain stem, the autonomic nervous system and the endocrine system, leading to increased heart rate and blood pressure and a condition of sensory alertness, mobility and readiness to respond."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000818 a owl:Class ;
    rdfs:label "awe"@en ;
    dcterms:description "awe is an emotion produced by that which is grand, sublime or powerful and is characterized by a combination of joy, fear and admiration/reverence/respect. "@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000819 a owl:Class ;
    rdfs:label "boldness"@en ;
    dcterms:description "boldness is the trait of being willing to undertake things that involve risk or danger."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000820 a owl:Class ;
    rdfs:label "boredom"@en ;
    dcterms:description "boredom is the emotion experience by those not interested in their surroundings or available activities."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000821 a owl:Class ;
    rdfs:label "contempt"@en ;
    dcterms:description "contempt is disgust towards a lower status individual."@en ;
    rdfs:subClassOf sio:SIO_000828 .

sio:SIO_000823 a owl:Class ;
    rdfs:label "curiosity"@en ;
    dcterms:description "curiosity is the strong desire to know or learn something."@en ;
    rdfs:subClassOf sio:SIO_000825 .

sio:SIO_000824 a owl:Class ;
    rdfs:label "depression"@en ;
    dcterms:alternative "depressed" ;
    dcterms:description "depression is an unpleasant emotion linked to aversion to activity that can affect a person's thoughts, behavior, feelings and physical well-being. Depressed individuals may feel sad, anxious, empty, hopeless, worried, helpless, worthless, guilty, irritable, or restless."@en ;
    rdfs:subClassOf sio:SIO_000863 .

sio:SIO_000826 a owl:Class ;
    rdfs:label "despair"@en ;
    dcterms:description "despair is depression, hopelessness or lack of hope."@en ;
    rdfs:subClassOf sio:SIO_000863 .

sio:SIO_000827 a owl:Class ;
    rdfs:label "disappointment"@en ;
    dcterms:alternative "disappointed",
        "disappointing" ;
    dcterms:description "disappointment is the feeling of dissatisfaction that follows the failure of expectations or hopes to manifest."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000830 a owl:Class ;
    rdfs:label "ecstasy"@en ;
    dcterms:description "ecstacy is an emotion characterized by a heightened state of consciousness with total involvement of a subject."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000833 a owl:Class ;
    rdfs:label "embarassment"@en ;
    dcterms:description "Embarrassment is the emotion of intense discomfort with oneself, experienced upon having a socially unacceptable act or condition witnessed by or revealed to other."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000835 a owl:Class ;
    rdfs:label "euphoria"@en ;
    dcterms:description "euphoria is an emotion characterized by intense feelings of well-being, elation, happiness, ecstasy, excitement, and joy."@en ;
    rdfs:subClassOf sio:SIO_000840 .

sio:SIO_000836 a owl:Class ;
    rdfs:label "excitement"@en ;
    dcterms:description "excitement is a positive emotion of feeling great enthusiasm and eagerness."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000838 a owl:Class ;
    rdfs:label "frustration"@en ;
    dcterms:description "Frustration is an emotion that arises from the perceived resistance to the fulfillment of individual will. "@en ;
    rdfs:subClassOf sio:SIO_000814 .

sio:SIO_000839 a owl:Class ;
    rdfs:label "gratitude"@en ;
    dcterms:alternative "appreciation",
        "gratefulness",
        "gratification",
        "thankfullness" ;
    dcterms:description "Gratitude, thankfulness, gratefulness, or appreciation is a feeling, emotion or attitude in acknowledgment of a benefit that one has received or will receive."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000841 a owl:Class ;
    rdfs:label "guilt"@en ;
    dcterms:alternative "guilty" ;
    dcterms:description "Guilt is the emotion borne from feeling responsible for the commission of an offense and arises out of public humiliation."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000842 a owl:Class ;
    rdfs:label "grief"@en ;
    dcterms:description "grief is an emotion in response to loss, whether physical or abstract including death, unemployment, ill health or the end of a relationship."@en ;
    rdfs:subClassOf sio:SIO_000863 .

sio:SIO_000843 a owl:Class ;
    rdfs:label "hope"@en ;
    dcterms:description "hope is an emotion of belief in a positive outcome related to events and circumstances in one's life."@en ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_000846 a owl:Class ;
    rdfs:label "hysteria"@en ;
    dcterms:description "Hysteria is an unmanageable emotion."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000849 a owl:Class ;
    rdfs:label "jealousy"@en ;
    dcterms:description "jealousy is an emotion and typically refers to the negative thoughts and feelings of insecurity, fear, and anxiety over an anticipated loss of something that the person values, particularly in reference to a human connection."@en ;
    rdfs:subClassOf sio:SIO_000834 .

sio:SIO_000850 a owl:Class ;
    rdfs:label "joy"@en ;
    dcterms:description "joy is an emotion of intense happiness."@en ;
    rdfs:subClassOf sio:SIO_000840 .

sio:SIO_000851 a owl:Class ;
    rdfs:label "loathing"@en ;
    dcterms:description "loathing is an intense dislike or disgust."@en ;
    rdfs:subClassOf sio:SIO_000828 .

sio:SIO_000852 a owl:Class ;
    rdfs:label "loneliness"@en ;
    dcterms:description "Loneliness is an unpleasant emotion in which a person feels a strong sense of emptiness, yearning distress and solitude resulting from inadequate quantity or quality of social relationships."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000853 a owl:Class ;
    rdfs:label "lust"@en ;
    dcterms:description "lust is the strong desire for sex."@en ;
    rdfs:subClassOf sio:SIO_000825 .

sio:SIO_000854 a owl:Class ;
    rdfs:label "misery"@en ;
    dcterms:description "misery is a feeling of great unhappiness, suffering and/or pain."@en ;
    rdfs:subClassOf sio:SIO_000863 .

sio:SIO_000855 a owl:Class ;
    rdfs:label "panic"@en ;
    dcterms:description "Panic is a sudden emotion of fear which is so strong as to dominate or prevent reason and logical thinking, replacing it with overwhelming feelings of anxiety and frantic agitation consistent with an animalistic fight-or-flight reaction."@en ;
    rdfs:subClassOf sio:SIO_000837 .

sio:SIO_000856 a owl:Class ;
    rdfs:label "passion"@en ;
    dcterms:description "passion is the intense desire for something."@en ;
    rdfs:subClassOf sio:SIO_000825 .

sio:SIO_000857 a owl:Class ;
    rdfs:label "pity"@en ;
    dcterms:description "Pity is the emotion of sadness or sorrow for another."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000858 a owl:Class ;
    rdfs:label "pleasure"@en ;
    dcterms:description "pleasure is an emotion of happy satisfaction and enjoyment."@en ;
    rdfs:subClassOf sio:SIO_000840 .

sio:SIO_000859 a owl:Class ;
    rdfs:label "pride"@en ;
    dcterms:description "pride is an emotion of satisfaction of attachment toward one's own or another's choices and actions, or toward a whole group of people, and is a product of praise, independent self-reflection, or a fulfilled feeling of belonging."@en ;
    rdfs:subClassOf sio:SIO_000864 .

sio:SIO_000860 a owl:Class ;
    rdfs:label "rage"@en ;
    dcterms:description "Rage is a feeling of intense anger that is associated with the Fight-or-flight response."@en ;
    rdfs:subClassOf sio:SIO_000410 .

sio:SIO_000862 a owl:Class ;
    rdfs:label "remorse"@en ;
    dcterms:description "remorse is an emotion of personal regret felt by a person after he or she has committed an act which they deem to be shameful, hurtful, or violent."@en ;
    rdfs:subClassOf sio:SIO_000861 .

sio:SIO_000865 a owl:Class ;
    rdfs:label "shame"@en ;
    dcterms:description "shame is the emotion borne from feeling responsible for the commission of an offense."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000866 a owl:Class ;
    rdfs:label "shock"@en ;
    dcterms:description "shock is an emotion of sudden upset or surprise."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000867 a owl:Class ;
    rdfs:label "shyness"@en ;
    dcterms:description "shyness is an emotion of apprehension, lack of comfort, or awkwardness experienced when in proximity to, approaching, or being approached by other individuals, especially in new situations or with unfamiliar individuals."@en ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_000868 a owl:Class ;
    rdfs:label "sorrow"@en ;
    dcterms:description "sorrow is the emotion that is characterized by a long term state of intense sadness, distress and a degree of resignation (not accepting)."@en ;
    rdfs:subClassOf sio:SIO_000863 .

sio:SIO_000869 a owl:Class ;
    rdfs:label "suffering"@en ;
    dcterms:description "Suffering is the unpleasant emotion and aversion associated with the perception of harm or threat of harm in an individual."@en ;
    rdfs:subClassOf sio:SIO_000845 .

sio:SIO_000871 a owl:Class ;
    rdfs:label "terror"@en ;
    dcterms:description "terror is the extreme feeling of fear."@en ;
    rdfs:subClassOf sio:SIO_000829 .

sio:SIO_000872 a owl:Class ;
    rdfs:label "wonder"@en ;
    dcterms:description "wonder is an emotion of perceiving something very rare or unexpected, but not threatening."@en ;
    rdfs:subClassOf sio:SIO_000870 .

sio:SIO_000875 a owl:Class ;
    rdfs:label "department chair role"@en ;
    dcterms:description "A department chain role is the role of an individual that heads a department at a academic organization."@en ;
    rdfs:subClassOf sio:SIO_000711 .

sio:SIO_000877 a owl:Class ;
    rdfs:label "undergraduate student advisor role"@en ;
    dcterms:description "An undergraduate student advisor role is the role of an individual employed at an academic organization that is involved in advising undergraduate students."@en ;
    rdfs:subClassOf sio:SIO_000876 .

sio:SIO_000878 a owl:Class ;
    rdfs:label "graduate student advisor role"@en ;
    dcterms:description "A graduate student advisor role is the role of an individual employed at an academic organization that is involved in advising graduate students."@en ;
    rdfs:subClassOf sio:SIO_000876 .

sio:SIO_000882 a owl:Class ;
    rdfs:label "host role"@en ;
    dcterms:description "The role of an organism in providing resources to maintain the survival and/or reproduction of another organism."@en ;
    rdfs:subClassOf sio:SIO_000888 .

sio:SIO_000883 a owl:Class ;
    rdfs:label "subject role"@en ;
    dcterms:description "A subject role is the role of an individual that is the target of the study."@en ;
    rdfs:subClassOf sio:SIO_000881 .

sio:SIO_000885 a owl:Class ;
    rdfs:label "publisher role"@en ;
    dcterms:description "A publisher role is the role of an individual that prepares and issues creative works."@en ;
    rdfs:subClassOf sio:SIO_000884 .

sio:SIO_000886 a owl:Class ;
    rdfs:label "author role"@en ;
    dcterms:description "An author role is the role of an individual that creates a creative, written work."@en ;
    rdfs:subClassOf sio:SIO_000884 .

sio:SIO_000887 a owl:Class ;
    rdfs:label "buffer role"@en ;
    dcterms:description "A buffer role is the role of a chemical substance which maintains a pH at a near constant value."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000227 ;
            owl:someValuesFrom sio:SIO_010416 ],
        sio:SIO_000888 .

sio:SIO_000890 a owl:Class ;
    rdfs:label "toxin role"@en ;
    dcterms:description "A toxin role is a toxic role of a chemical substance that is poisonous and is produced by an organism."@en ;
    rdfs:subClassOf sio:SIO_000968 .

sio:SIO_000893 a owl:Class ;
    rdfs:label "reagent role"@en ;
    dcterms:description "A role of a chemical substance that participates in a chemical reaction as part of some scientific investigation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000227 ;
            owl:someValuesFrom sio:SIO_010411 ],
        sio:SIO_000888 .

sio:SIO_000895 a owl:Class ;
    rdfs:label "to fluoresce"@en ;
    dcterms:description "to fluoresce is to emit light as a result of absorbing light or other electromagnetic radiation."@en ;
    rdfs:subClassOf sio:SIO_000894 .

sio:SIO_000896 a owl:Class ;
    rdfs:label "molecular tracer role"@en ;
    dcterms:description "A molecular tracer role is a reactant role of a molecular entity that serves as a marker for the presence, abundance, or location of a molecular target that it associates with."@en ;
    rdfs:subClassOf sio:SIO_000879 .

sio:SIO_000899 a owl:Class ;
    rdfs:label "chromosome"@en ;
    dcterms:description "A chromosome is a molecular complex of circular or linear DNA and bound proteins."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_010043 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000273 ;
            owl:someValuesFrom sio:SIO_010010 ],
        sio:SIO_010506 .

sio:SIO_000900 a owl:ObjectProperty ;
    rdfs:label "has frequency"@en ;
    dcterms:description "has frequency is a relation that specifies the occurence of an object or event"@en ;
    rdfs:subPropertyOf sio:SIO_000216 ;
    owl:inverseOf sio:SIO_000901 .

sio:SIO_000906 a owl:Class ;
    rdfs:label "map"@en ;
    dcterms:description "A map is a a visual representation of an area that depicts the relationship between elements of that space."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000908 a owl:Class ;
    rdfs:label "streamgraph"@en ;
    dcterms:description "A streamgraph is a multi-line stacked graph that yields the appearance of continuous y-values across the x-axis."@en ;
    rdfs:subClassOf sio:SIO_000934 .

sio:SIO_000909 a owl:Class ;
    rdfs:label "boxplot"@en ;
    dcterms:description "A boxplot (box-and-whisker diagram) is a convenient way of graphically depicting groups of numerical data through their five-number summaries: the smallest observation (sample minimum), lower quartile (Q1), median (Q2), upper quartile (Q3), and largest observation (sample maximum)."@en ;
    rdfs:subClassOf sio:SIO_000447 .

sio:SIO_000910 a owl:Class ;
    rdfs:label "geographic heatmap"@en ;
    dcterms:description "A geographic heatmap is a graphical representation of data over a geographic region where individual values are represented as colors."@en ;
    rdfs:subClassOf sio:SIO_000907 .

sio:SIO_000916 a owl:Class ;
    rdfs:label "decimal scale"@en ;
    dcterms:description "A decimal scale of measurement is one that only specifies decimal values."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000000 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000300 ;
                                owl:someValuesFrom xsd:decimal ] ) ] ],
        sio:SIO_000915 .

sio:SIO_000917 a owl:Class ;
    rdfs:label "integer scale"@en ;
    dcterms:description "An integer scale of measurement is one that only specifies integer values."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000338 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000000 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000300 ;
                                owl:someValuesFrom xsd:integer ] ) ] ],
        sio:SIO_000915 .

sio:SIO_000918 a owl:Class ;
    rdfs:label "modifying"@en ;
    dcterms:alternative "modification"@en ;
    dcterms:description "modifying is the process by which an entity gains or loses parts, qualities, roles, dispositions, functions, etc, but maintains their identity through these changes."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000291 ;
            owl:someValuesFrom sio:SIO_000776 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000229 ;
            owl:someValuesFrom sio:SIO_000776 ],
        sio:SIO_000593 .

sio:SIO_000921 a owl:Class ;
    rdfs:label "dependent variable"@en ;
    dcterms:description "A dependent variable is one whose value changes as a consequence of changes in other values in the system."@en ;
    rdfs:subClassOf sio:SIO_000367 .

sio:SIO_000922 a owl:Class ;
    rdfs:label "Gantt chart"@en ;
    dcterms:description "A Gantt chart is a bar chart that illustrates a project schedule."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000923 a owl:Class ;
    rdfs:label "correlation"@en ;
    dcterms:description "A correlation is a statistical relationship involving dependence between two random variables or datasets."@en ;
    rdfs:subClassOf sio:SIO_000898 .

sio:SIO_000924 a owl:Class ;
    rdfs:label "television program"@en ;
    dcterms:description "A television program is a audiovisual media that is produced and broadcast using a television."@en ;
    rdfs:subClassOf sio:SIO_001194 .

sio:SIO_000926 a owl:Class ;
    rdfs:label "radio receiver"@en ;
    dcterms:description "A radio receiver is a communication device that receives its input from an antenna, uses electronic filters to separate a wanted radio signal from all other signals picked up by this antenna, amplifies it to a level suitable for further processing, and finally converts through demodulation and decoding the signal into a form usable for the consumer, such as sound, pictures, digital data, measurement values, navigational positions."@en ;
    rdfs:subClassOf sio:SIO_000957 .

sio:SIO_000927 a owl:Class ;
    rdfs:label "telephone"@en ;
    dcterms:description "The telephone is a communications device that transmits and receives sounds, and are minimally composed of a microphone to speak into, a speaker'which reproduces the voice of the other person and a ringer which makes a sound to alert the owner when a call is coming in."@en ;
    rdfs:subClassOf sio:SIO_000957 .

sio:SIO_000928 a owl:Class ;
    rdfs:label "radar"@en ;
    dcterms:description "A radar is an object-detection system which uses radio waves to determine the range, altitude, direction, or speed of objects."@en ;
    rdfs:subClassOf sio:SIO_000956 .

sio:SIO_000929 a owl:Class ;
    rdfs:label "pie chart"@en ;
    dcterms:description "A pie chart is a circular chart divided into sectors each of whose length  is proportional to the quantity it represents."@en ;
    rdfs:subClassOf sio:SIO_000940 .

sio:SIO_000930 a owl:Class ;
    rdfs:label "matrix chart"@en ;
    dcterms:description "A matrix chart summarizes a multidimensional data set in a grid."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000932 a owl:Class ;
    rdfs:label "block histogram"@en ;
    dcterms:description "A block histogram contains an x-axis that is divided into bins which correspond to value ranges. Each item in the data set is drawn as a rectangular block, and the blocks are piled into the bins to show how many values in each range."@en ;
    rdfs:subClassOf sio:SIO_000911 .

sio:SIO_000933 a owl:Class ;
    rdfs:label "bubble chart"@en ;
    dcterms:description "A bubble chart contains circles whose area corresponds to a value. "@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000935 a owl:Class ;
    rdfs:label "treemap"@en ;
    dcterms:description "A treemap is a chart that fully partitions the area into a set of rectangles whose area represents its relative value."@en ;
    rdfs:subClassOf sio:SIO_000940 .

sio:SIO_000936 a owl:Class ;
    rdfs:label "word tree"@en ;
    dcterms:description "A word tree is a chart that links phrases with contexts through a tree-like branching structure."@en ;
    rdfs:subClassOf sio:SIO_000937 .

sio:SIO_000938 a owl:Class ;
    rdfs:label "tag cloud"@en ;
    dcterms:alternative "word cloud"@en ;
    dcterms:description "A tag cloud is a visualization of word frequencies."@en ;
    rdfs:subClassOf sio:SIO_000937 .

sio:SIO_000939 a owl:Class ;
    rdfs:label "phrase net diagram"@en ;
    dcterms:description "A phrase net diagram illustrates the relationship between different words used in a text."@en ;
    rdfs:subClassOf sio:SIO_000937 .

sio:SIO_000941 a owl:Class ;
    rdfs:label "conversing"@en ;
    dcterms:description "conversing a form of interactive, spontaneous communication between two or more agents who are following rules of etiquette."@en ;
    rdfs:subClassOf sio:SIO_000969 .

sio:SIO_000942 a owl:Class ;
    rdfs:label "numeric label"@en ;
    dcterms:description "A numeric label is a number used as a label."@en ;
    rdfs:subClassOf sio:SIO_000179 .

sio:SIO_000946 a owl:Class ;
    rdfs:label "flowchart"@en ;
    dcterms:description "A flowchart is a diagram that represents an algorithm or process, showing the steps as boxes of various kinds, and their order by connecting these with arrows."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000947 a owl:Class ;
    rdfs:label "venn diagram"@en ;
    dcterms:description "A Venn diagram is a chart that illustrates all possible logical relations between a finite collection of sets as overlapping circles."@en ;
    rdfs:subClassOf sio:SIO_000904 .

sio:SIO_000948 a owl:Class ;
    rdfs:label "dendrogram"@en ;
    dcterms:description "A dendrogram is a tree diagram used to illustrate the arrangement of the clusters produced by hierarchical clustering."@en ;
    rdfs:subClassOf sio:SIO_000945 .

sio:SIO_000950 a owl:Class ;
    rdfs:label "resentment"@en ;
    dcterms:description "resentment is disgust directed toward a higher status individual."@en ;
    rdfs:subClassOf sio:SIO_000828 .

sio:SIO_000951 a owl:Class ;
    rdfs:label "pain"@en ;
    dcterms:description "Pain is an unpleasant sensory and emotional experience associated with actual or potential tissue damage, or described in terms of such damage."@en ;
    rdfs:subClassOf sio:SIO_000845 .

sio:SIO_000952 a owl:Class ;
    rdfs:label "default parameter"@en ;
    dcterms:description "A default parameter is a parameter which has a default value."@en ;
    rdfs:subClassOf sio:SIO_000144 .

sio:SIO_000954 a owl:Class ;
    rdfs:label "sick"@en ;
    dcterms:description "sick is the status of a living organism that is behaving at a sub-optimal level."@en ;
    rdfs:subClassOf sio:SIO_010058 .

sio:SIO_000955 a owl:Class ;
    rdfs:label "environment"@en ;
    dcterms:description "An environment is a geographic region that hosts certain processes or objects." ;
    rdfs:subClassOf sio:SIO_000414 .

sio:SIO_000964 a owl:Class ;
    rdfs:label "standard operating procedure"@en ;
    dcterms:description "A standard operating procedure is a specification approved for use in specific environments."@en ;
    rdfs:subClassOf sio:SIO_001043 .

sio:SIO_000970 a owl:ObjectProperty ;
    rdfs:label "is first part of"@en ;
    dcterms:description "is first part of is a proper part relation in which the part is the first of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system."@en ;
    rdfs:subPropertyOf sio:SIO_000975 ;
    owl:inverseOf sio:SIO_000971 .

sio:SIO_000972 a owl:ObjectProperty ;
    rdfs:label "has last part"@en ;
    dcterms:description "has last part is a proper part relation in which the part is the last of a set of linearly ordered parts resulting from the projection of the whole on a linear coordinate system."@en ;
    rdfs:subPropertyOf sio:SIO_000974 ;
    owl:inverseOf sio:SIO_000973 .

sio:SIO_000977 a owl:Class ;
    rdfs:label "syllable"@en ;
    dcterms:description "A syllable is a verbal entity of language having one vowel sound, with or without surrounding consonants, forming the whole or a part of a word."@en ;
    rdfs:subClassOf sio:SIO_000786 .

sio:SIO_000978 a owl:Class ;
    rdfs:label "consonant"@en ;
    dcterms:description "A consonant is a verbal entity of language that is articulated with complete or partial closure of the vocal tract."@en ;
    rdfs:subClassOf sio:SIO_000786 .

sio:SIO_000979 a owl:Class ;
    rdfs:label "vowel"@en ;
    dcterms:description "A vowel is a verbal entity of language that is pronounced with an open vocal tract so that there is no build-up of air pressure at any point above the glottis."@en ;
    rdfs:subClassOf sio:SIO_000786 .

sio:SIO_000980 a owl:Class ;
    rdfs:label "sign language"@en ;
    dcterms:description "A sign language (also signed language) is a language that involves manual communication and body language to convey meaning. This can involve simultaneously combining hand shapes, orientation and movement of the hands, arms or body, and facial expressions to fluidly express a speaker's thoughts."@en ;
    rdfs:subClassOf sio:SIO_000104 .

sio:SIO_000981 a owl:Class ;
    rdfs:label "verbal language"@en ;
    dcterms:description "A verbal language is a language that uses sounds to communicate."@en ;
    rdfs:subClassOf sio:SIO_000104 .

sio:SIO_000982 a owl:Class ;
    rdfs:label "written language"@en ;
    dcterms:description "written language is a language that is communicated through a writing system."@en ;
    rdfs:subClassOf sio:SIO_000104 .

sio:SIO_000986 a owl:Class ;
    rdfs:label "functional rna coding gene"@en ;
    dcterms:description "A gene that codes for a functional RNA molecule."@en ;
    rdfs:subClassOf sio:SIO_010101 .

sio:SIO_000987 a owl:Class ;
    rdfs:label "predicted gene"@en ;
    dcterms:description "A predicted gene is a gene that was identified through computational method but has not been experimentally validated."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom sio:SIO_000036 ],
        sio:SIO_010035 .

sio:SIO_000988 a owl:Class ;
    rdfs:label "pseudogene"@en ;
    dcterms:description "A pseudo gene is a region of a nucleic acid that either cannot be transcribed, or its RNA transcript cannot be translated."@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/SO_0000336"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_010335 .

sio:SIO_000989 a owl:Class ;
    rdfs:label "sequence assembly"@en ;
    dcterms:description "A sequence assembly is a sequence that is produced as by the alignment of two or more sequences."@en ;
    rdfs:subClassOf sio:SIO_000030 .

sio:SIO_000991 a owl:Class ;
    rdfs:label "validated gene"@en ;
    dcterms:description "An experimentally validated gene is a gene whose existence has been demonstrated through experimental methods."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom sio:SIO_000960 ],
        sio:SIO_010035 .

sio:SIO_000992 a owl:Class ;
    rdfs:label "unsupported"@en ;
    dcterms:description "unsupported is an existence quality in which there is no evidence to support the existence of the entity in any world (real or hypothetical)"@en ;
    rdfs:subClassOf sio:SIO_000959 .

sio:SIO_000993 a owl:Class ;
    rdfs:label "chemical-disease association"@en ;
    dcterms:description "A chemical-disease association is an association between a chemical and a disease."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000628 ;
                        owl:someValuesFrom sio:SIO_010004 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000628 ;
                        owl:someValuesFrom sio:SIO_010299 ] ) ],
        sio:SIO_000897 .

sio:SIO_000996 a owl:Class ;
    rdfs:label "cancelled"@en ;
    dcterms:description "cancelled is a process status in which the process, while planned to occur, will not occur."@en ;
    rdfs:subClassOf sio:SIO_000963 .

sio:SIO_000998 a owl:Class ;
    rdfs:label "literature curation"@en ;
    dcterms:description "literature curation is the process of an agent selecting and extracting terms and phrases from a document."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000229 ;
            owl:someValuesFrom sio:SIO_000483 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000230 ;
            owl:someValuesFrom sio:SIO_000148 ],
        sio:SIO_000649 .

sio:SIO_001000 a owl:Class ;
    rdfs:label "clinical trial"@en ;
    dcterms:description "A clinical trial is an intervention trial to determine the safety and efficacy of  medical interventions (e.g., drugs, diagnostics, devices, therapy protocols). "@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000339 ;
            owl:someValuesFrom sio:SIO_001043 ],
        sio:SIO_001048 .

sio:SIO_001002 a owl:Class ;
    rdfs:label "differential diagnosis"@en ;
    dcterms:description "A differential diagnosis (sometimes abbreviated DDx, ddx, DD, D/Dx, or ΔΔ) is a systematic diagnostic method used to identify the presence of an entity where multiple alternatives are possible (and the process may be termed differential diagnostic procedure), and may also refer to any of the included candidate alternatives (which may also be termed candidate condition)."@en ;
    rdfs:subClassOf sio:SIO_001024 .

sio:SIO_001006 a owl:Class ;
    rdfs:label "drug drug interaction"@en ;
    dcterms:description "A drug-drug interaction is an interaction in which two drugs interact in such a way to produce a non-additive biological response."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010038 ;
            owl:onProperty sio:SIO_000132 ],
        sio:SIO_001005 .

sio:SIO_001007 a owl:Class ;
    rdfs:label "assay"@en ;
    dcterms:alternative "bioassay"@en ;
    dcterms:description "An assay is an investigative (analytic) procedure in laboratory medicine, pharmacology, environmental biology, and molecular biology for qualitatively assessing or quantitatively measuring the presence or amount or the functional activity of a target entity (the analyte) which can be a drug or biochemical substance or a cell in an organism or organic sample."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000230 ;
            owl:someValuesFrom sio:SIO_000776 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000229 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( [ a owl:Class ;
                                owl:unionOf ( sio:SIO_000070 sio:SIO_000959 ) ] [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000011 ;
                                owl:someValuesFrom sio:SIO_000000 ] ) ] ],
        sio:SIO_000999 .

sio:SIO_001012 a owl:Class ;
    rdfs:label "healthy"@en ;
    dcterms:description "healthy is an organismal state of complete physical, mental and social well-being."@en ;
    rdfs:subClassOf sio:SIO_010058 .

sio:SIO_001013 a owl:Class ;
    rdfs:label "age"@en ;
    dcterms:description "age is the length of time that a person has lived or a thing has existed."@en ;
    rdfs:subClassOf sio:SIO_000258 .

sio:SIO_001016 a owl:Class ;
    rdfs:label "ethnic group"@en ;
    dcterms:description "An ethnic group is a group of people whose members identify with each other through a common heritage, consisting of a common culture, including a shared language or dialect. "@en ;
    rdfs:subClassOf sio:SIO_001062 .

sio:SIO_001017 a owl:Class ;
    rdfs:label "syndrome"@en ;
    dcterms:description "A syndrome is composed of a set of several clinically recognizable features, signs (observed by someone other than the patient), symptoms (reported by the patient), phenomena or characteristics that often occur together."@en ;
    rdfs:subClassOf sio:SIO_000136 .

sio:SIO_001020 a owl:Class ;
    rdfs:label "effective dose"@en ;
    dcterms:description "effective dose is the amount of a substance required to produce an effect on a predefined percentage of a population."@en ;
    rdfs:subClassOf sio:SIO_001019 .

sio:SIO_001021 a owl:Class ;
    rdfs:label "expected value"@en ;
    dcterms:description "An expected value (or e-value) is the weighted average of all possible values that a random variable can take on."@en ;
    rdfs:subClassOf sio:SIO_000638 .

sio:SIO_001022 a owl:Class ;
    rdfs:label "diagnostic test"@en ;
    dcterms:alternative "clinical laboratory test"@en ;
    dcterms:description "A diagnostic test is a procedure performed to confirm, or determine the presence of disease in an individual suspected of having the disease, usually following the report of symptoms, or based on the results of other medical tests."@en ;
    rdfs:subClassOf sio:SIO_001024 .

sio:SIO_001023 a owl:Class ;
    rdfs:label "medical screening"@en ;
    dcterms:description "A medical screening is a medical test or series used to detect or predict the presence of disease in individuals at risk for disease within a defined group, such as a population, family, or workforce"@en ;
    rdfs:subClassOf sio:SIO_001024 .

sio:SIO_001025 a owl:Class ;
    rdfs:label "prognosis"@en ;
    dcterms:description "A prognosis is a proposition about the likely course of a disease, the chance of recovery or recurrence."@en ;
    rdfs:subClassOf sio:SIO_000256 .

sio:SIO_001027 a owl:Class ;
    rdfs:label "medical health record"@en ;
    dcterms:description "A medical health record is a record of a single patient's medical history."@en ;
    rdfs:subClassOf sio:SIO_000088 .

sio:SIO_001028 a owl:Class ;
    rdfs:label "medical report"@en ;
    dcterms:description "A medical report is a report prepared by a health care practioner about test outcomes or health status of an individual."@en ;
    rdfs:subClassOf sio:SIO_001026 .

sio:SIO_001029 a owl:Class ;
    rdfs:label "peer reviewed article"@en ;
    dcterms:description "A peer reviewed article is an article that has undergone peer-review and deemed acceptable for publication."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_001035 ],
        sio:SIO_000154 .

sio:SIO_001030 a owl:Class ;
    rdfs:label "major version number"@en ;
    dcterms:description "A major version number is a version of a software that exhibits a significant change in functionalilty from a prior version."@en ;
    rdfs:subClassOf sio:SIO_000654 .

sio:SIO_001031 a owl:Class ;
    rdfs:label "minor version number"@en ;
    dcterms:description "A minor version number is a version of a software that exhibits minor features or significant fix from a prior version."@en ;
    rdfs:subClassOf sio:SIO_000654 .

sio:SIO_001032 a owl:Class ;
    rdfs:label "revision number"@en ;
    dcterms:description "A revision number is a version of a software in which bugs have been fixed from a prior version."@en ;
    rdfs:subClassOf sio:SIO_000654 .

sio:SIO_001036 a owl:Class ;
    rdfs:label "draft"@en ;
    dcterms:alternative "drafted" ;
    dcterms:description "draft is the quality of text that has not yet complete."@en ;
    rdfs:subClassOf sio:SIO_001039 .

sio:SIO_001037 a owl:Class ;
    rdfs:label "finalized"@en ;
    dcterms:description "finalized is the quality of a textual entity that is in its final form."@en ;
    rdfs:subClassOf sio:SIO_001039 .

sio:SIO_001042 a owl:Class ;
    rdfs:label "recipe"@en ;
    dcterms:description "A recipe is a set of instructions that describe how to prepare or make something."@en ;
    rdfs:subClassOf sio:SIO_000091 .

sio:SIO_001044 a owl:Class ;
    rdfs:label "viroid"@en ;
    dcterms:description "A viroid is a molecule of RNA that does not code for and is not protected by a protein coat."@en ;
    rdfs:subClassOf sio:SIO_010378 .

sio:SIO_001049 a owl:Class ;
    rdfs:label "sampling"@en ;
    dcterms:description "sampling is the act of obtaining a sample, whether through selection, collection or preparation."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000229 ;
                        owl:someValuesFrom sio:SIO_001050 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000230 ;
                        owl:someValuesFrom sio:SIO_000776 ] ) ],
        sio:SIO_000593 .

sio:SIO_001051 a owl:Class ;
    rdfs:label "data analysis"@en ;
    dcterms:description "data analysis is a process of inspecting, cleaning, transforming, and modeling data with the goal of highlighting useful information, suggesting conclusions, and supporting decision making."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000229 ;
                        owl:someValuesFrom sio:SIO_000256 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000230 ;
                        owl:someValuesFrom sio:SIO_000069 ] ) ],
        sio:SIO_000649 .

sio:SIO_001052 a owl:Class ;
    rdfs:label "data collection"@en ;
    dcterms:description "data collection is the process of acquiring information."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_000069 ],
        sio:SIO_000649 .

sio:SIO_001054 a owl:Class ;
    rdfs:label "measuring"@en ;
    dcterms:alternative "measurement"@en ;
    dcterms:description "measuring is the process of determining the size, amount, or degree of (something) by using an instrument or device marked in standard units"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000230 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( sio:SIO_000005 sio:SIO_000006 sio:SIO_000776 ) ] ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000229 ;
            owl:someValuesFrom sio:SIO_000070 ],
        sio:SIO_000593 .

sio:SIO_001056 a owl:Class ;
    rdfs:label "character position"@en ;
    dcterms:alternative "character offset" ;
    dcterms:description "The ordinal position of a character in a sequence of characters."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty sio:SIO_000300 ],
        sio:SIO_000613 .

sio:SIO_001057 a owl:Class ;
    rdfs:label "word start position"@en ;
    dcterms:description "The position of the first character in a word as an offset from the first character of the text in which it is found."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_000651 ],
        sio:SIO_001071 .

sio:SIO_001058 a owl:Class ;
    rdfs:label "word end position"@en ;
    dcterms:description "word end position is the position of the last character in a word as an offset from the first character of the text in which it is found."@en ;
    rdfs:subClassOf sio:SIO_001072 .

sio:SIO_001059 a owl:Class ;
    rdfs:label "gesturing"@en ;
    dcterms:description "gesturing is a form of non-verbal communication in which visible bodily actions communicate particular messages, either in place of speech or together and in parallel with spoken words. Gestures include movement of the hands, face, or other parts of the body."@en ;
    rdfs:subClassOf sio:SIO_000969 .

sio:SIO_001060 a owl:Class ;
    rdfs:label "planned"@en ;
    dcterms:description "planned is a process status for a process that has not yet started, but is referred to in a plan."@en ;
    rdfs:subClassOf sio:SIO_000963 .

sio:SIO_001063 a owl:Class ;
    rdfs:label "family"@en ;
    dcterms:description "A group of people affiliated by consanguinity, affinity, or co-residence."@en ;
    rdfs:subClassOf sio:SIO_000620 .

sio:SIO_001064 a owl:Class ;
    rdfs:label "community"@en ;
    dcterms:description "A community is a sizeable social unit that shares common values."@en ;
    rdfs:subClassOf sio:SIO_000620 .

sio:SIO_001065 a owl:Class ;
    rdfs:label "speculation"@en ;
    dcterms:description "speculation is an opinion based on incomplete evidence."@en ;
    rdfs:subClassOf sio:SIO_001004 .

sio:SIO_001066 a owl:Class ;
    rdfs:label "study"@en ;
    dcterms:description "A study is a process that realizes the steps of a study design."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000355 ;
            owl:someValuesFrom sio:SIO_000337 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000426 ;
            owl:someValuesFrom sio:SIO_001041 ],
        sio:SIO_000747 .

sio:SIO_001067 a owl:Class ;
    rdfs:label "controlled observational cohort study"@en ;
    dcterms:description "In a controlled observational cohort study, two groups of subjects are selected from two populations that are thought to differ in only one characteristic. The groups of subjects are studied for a specific period and contrasted at the end of the study period."@en ;
    rdfs:subClassOf sio:SIO_000976 .

sio:SIO_001068 a owl:Class ;
    rdfs:label "control group"@en ;
    dcterms:description "A control group is a group of individuals that are not subject to an intervention of interest, but rather serve as a baseline to compare the outcomes in the intervention group."@en ;
    rdfs:subClassOf sio:SIO_000403 .

sio:SIO_001069 a owl:Class ;
    rdfs:label "intervention group"@en ;
    dcterms:description "An intervention group is a group of individuals that are subject to an intervention."@en ;
    rdfs:subClassOf sio:SIO_000403 .

sio:SIO_001070 a owl:Class ;
    rdfs:label "control variable"@en ;
    dcterms:alternative "controlled variable",
        "extraneous variable" ;
    dcterms:description "A control variable that is believed to alter the dependent or independent variables, but may not actually be the focus of the experiment. So that variable will be kept constant or monitored to try to minimise its effect on the experiment."@en ;
    rdfs:subClassOf sio:SIO_000367 .

sio:SIO_001073 a owl:Class ;
    rdfs:label "text span"@en ;
    dcterms:alternative "selector" ;
    dcterms:description "A text span is a subset of contiguous sequence of characters of a textual entity."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000008 ;
                        owl:someValuesFrom sio:SIO_001071 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000008 ;
                        owl:someValuesFrom sio:SIO_001072 ] ) ],
        sio:SIO_000651 .

sio:SIO_001075 a owl:Class ;
    rdfs:label "microarray probe set identifier"@en ;
    dcterms:description "A microarray probe set identifier is an identifier for a set of probe pairs selected to represent expressed sequences on an array. "@en ;
    rdfs:subClassOf sio:SIO_000732 .

sio:SIO_001076 a owl:Class ;
    rdfs:label "microarray experiment"@en ;
    dcterms:description "A microarray experiment is an experiment that involves a microarray device to measure the expression of one or more genes."@en ;
    rdfs:subClassOf sio:SIO_000994 .

sio:SIO_001077 a owl:Class ;
    rdfs:label "gene expression value"@en ;
    dcterms:description "A gene expression value is a measured value obtained from a gene expression experiment."@en ;
    rdfs:subClassOf sio:SIO_000258 .

sio:SIO_001079 a owl:Class ;
    rdfs:label "genotype"@en ;
    dcterms:description "A genotype is a functional specification of a biological entity in terms of its genetic composition (or lack thereof)."@en ;
    rdfs:subClassOf sio:SIO_000315 .

sio:SIO_001081 a owl:Class ;
    rdfs:label "t-statistic based increased differential gene expression"@en ;
    dcterms:description "A t-statistic based increased differential gene expression is a differential gene expression ratio in which the t-statistic is greater than zero."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_001074 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000300 ;
                                owl:someValuesFrom [ a rdfs:Datatype ;
                                        owl:onDatatype xsd:double ;
                                        owl:withRestrictions ( [ xsd:minExclusive 0e+00 ] ) ] ] ) ] ],
        sio:SIO_001078 .

sio:SIO_001082 a owl:Class ;
    rdfs:label "t-statistic based decreased differential gene expression"@en ;
    dcterms:description "A t-statistic based decreased differential gene expression is a differential gene expression ratio in which the t-statistic is less than zero."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_001074 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000300 ;
                                owl:someValuesFrom [ a rdfs:Datatype ;
                                        owl:onDatatype xsd:double ;
                                        owl:withRestrictions ( [ xsd:maxExclusive 0e+00 ] ) ] ] ) ] ],
        sio:SIO_001078 .

sio:SIO_001083 a owl:Class ;
    rdfs:label "date of database submission"@en ;
    dcterms:description "A date of database submission refers to the moment in time in which some information was submitted/received to a database system."@en ;
    rdfs:subClassOf sio:SIO_000418 .

sio:SIO_001084 a owl:Class ;
    rdfs:label "liquid solution"@en ;
    dcterms:description "A liquid solution is a heterogeneous substance in a liquid state."@en ;
    rdfs:subClassOf sio:SIO_010462 .

sio:SIO_001085 a owl:Class ;
    rdfs:label "to remove a covalent bond"@en ;
    dcterms:description "to remove a covalent bond is the capability to covalently modify a chemical entity by removing a covalent bond."@en ;
    rdfs:subClassOf sio:SIO_010340 .

sio:SIO_001086 a owl:Class ;
    rdfs:label "to add a covalent bond"@en ;
    dcterms:description "to add a covalent bond is the capability to covalently modify a chemical entity by adding a covalent bond."@en ;
    rdfs:subClassOf sio:SIO_010340 .

sio:SIO_001088 a owl:Class ;
    rdfs:label "concentration"@en ;
    dcterms:description "concentration is the amount of substance per unit volume of a solution"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_011126 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000093 ;
                                owl:someValuesFrom sio:SIO_010462 ] [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000668 ;
                                owl:someValuesFrom sio:SIO_011126 ] ) ] ],
        sio:SIO_000048 .

sio:SIO_001089 a owl:Class ;
    rdfs:label "pH"@en ;
    dcterms:description "pH is a measure of the activity of the (solvated) hydrogen ion. "@en ;
    schema1:comment "pH is defined as the decimal logarithm of the reciprocal of the hydrogen ion activity, aH+, in a solution." ;
    rdfs:subClassOf sio:SIO_000257 .

sio:SIO_001090 a owl:Class ;
    rdfs:label "homogeneous"@en ;
    dcterms:description "homogeneous is a quality that describes the uniform composition of an object."@en ;
    rdfs:subClassOf sio:SIO_000051 ;
    owl:disjointWith sio:SIO_001091 .

sio:SIO_001096 a owl:ObjectProperty ;
    rdfs:label "is specialization of"@en ;
    dcterms:description "is specialization of is a relation between a more specific instance (in terms of spatial/temporal localization & other attributres) than the other."@en ;
    sio:equivalentTo "http://www.w3.org/ns/prov#specializationOf"^^xsd:anyURI ;
    rdfs:subPropertyOf sio:SIO_000272 ;
    owl:inverseOf sio:SIO_001097 ;
    skos:example "a weather forecast for the city of London produced at a specific time is a specialization of a weather forecast for the city of London."@en .

sio:SIO_001099 a owl:Class ;
    rdfs:label "electronic structure"@en ;
    dcterms:alternative "electronic configuration" ;
    dcterms:description "electronic structure is the electron configuration is the distribution of electrons of an atom or molecule (or other physical structure) in atomic or molecular orbitals."@en ;
    rdfs:subClassOf sio:SIO_000625 ;
    skos:example "the electron configuration of the neon atom is 1s2 2s2 2p6."@en .

sio:SIO_001100 a owl:Class ;
    rdfs:label "crystal structure"@en ;
    dcterms:description "A crystal structure is the arrangement of atoms or molecules in a crystalline liquid or solid."@en ;
    rdfs:subClassOf sio:SIO_000626 .

sio:SIO_001101 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is mutual capability of"@en ;
    dcterms:description "a is mutual capability of b if and only if the realization of capability  a necessarily causes the realization of capability b."@en ;
    rdfs:subPropertyOf sio:SIO_000709 .

sio:SIO_001102 a owl:Class ;
    rdfs:label "to interact and to be interacted with"@en ;
    dcterms:description "to interact and to be interacted with is a mutual disposition of interacting objects."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000053 ;
                        owl:someValuesFrom sio:SIO_000701 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000053 ;
                        owl:someValuesFrom sio:SIO_000702 ] ) ],
        sio:SIO_000409 .

sio:SIO_001103 a owl:Class ;
    rdfs:label "to gain a covalent bond"@en ;
    dcterms:description "to gain a covalent bond is the capability of a chemical entity to have bonds added."@en ;
    rdfs:subClassOf sio:SIO_010366 .

sio:SIO_001104 a owl:Class ;
    rdfs:label "to lose a covalent bond"@en ;
    dcterms:description "to lose a covalent bond is the capability of a chemical entity to have bonds removed."@en ;
    rdfs:subClassOf sio:SIO_010366 .

sio:SIO_001105 a owl:Class ;
    rdfs:label "to ingest"@en ;
    dcterms:description "to ingest is the capability to take into the body by the mouth for digestion or absorption."@en ;
    rdfs:subClassOf sio:SIO_000492 .

sio:SIO_001106 a owl:Class ;
    rdfs:label "to produce"@en ;
    dcterms:description "to produce is the capability to create new objects"@en ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_001109 a owl:Class ;
    rdfs:label "mean"@en ;
    dcterms:alternative "arithmeritic mean",
        "average" ;
    dcterms:description "A mean is the central tendency of a collection of numbers taken as the sum of the numbers divided by the size of the collection."@en ;
    rdfs:subClassOf sio:SIO_001108 .

sio:SIO_001110 a owl:Class ;
    rdfs:label "median"@en ;
    dcterms:description "A median is the numerical value separating the higher half of a sample, a population, or a probability distribution, from the lower half. "@en ;
    rdfs:subClassOf sio:SIO_001108 .

sio:SIO_001111 a owl:Class ;
    rdfs:label "mode"@en ;
    dcterms:description "A mode is the value that appears most often in a set of data."@en ;
    rdfs:subClassOf sio:SIO_001108 .

sio:SIO_001112 a owl:Class ;
    rdfs:label "sum"@en ;
    dcterms:description "A sum is the result of adding a set of values together."@en ;
    rdfs:subClassOf sio:SIO_000052 .

sio:SIO_001113 a owl:Class ;
    rdfs:label "minimal value"@en ;
    dcterms:alternative "min" ;
    dcterms:description "A minimal value is smallest value of an attribute for the entities in the defined set."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_000616 ],
        sio:SIO_000052 .

sio:SIO_001114 a owl:Class ;
    rdfs:label "maximal value"@en ;
    dcterms:alternative "max" ;
    dcterms:description "A maximal value is largest value of an attribute for the entities in the defined set."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_000616 ],
        sio:SIO_000052 .

sio:SIO_001115 a owl:Class ;
    rdfs:label "member count"@en ;
    dcterms:description "A count of the instances of a class or members in a collection."@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_001116 a owl:Class ;
    rdfs:label "union"@en ;
    dcterms:description "A union is a list of all of the values of an attribute for the entities in the defined set."@en ;
    rdfs:subClassOf sio:SIO_000150 ;
    owl:disjointWith sio:SIO_001117 .

sio:SIO_001118 a owl:Class ;
    rdfs:label "sequence"@en ;
    dcterms:alternative "ordered list" ;
    dcterms:description "A sequence is an ordered list of entities. Like a set, it contains members (also called elements, or terms)."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000059 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000000 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000008 ;
                                owl:someValuesFrom sio:SIO_000613 ] [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000628 ;
                                owl:someValuesFrom sio:SIO_000000 ] ) ] ],
        sio:SIO_000150 ;
    skos:example "For example, (M, A, R, Y) is a sequence of letters that differs from (A, R, M, Y), as the ordering matters, and (1, 1, 2, 3, 5, 8), which contains the number 1 at two different positions, is a valid sequence. "@en .

sio:SIO_001120 a owl:Class ;
    rdfs:label "therapeutic gene-disease association"@en ;
    dcterms:alternative "gene-disease association arising from a therapeutic role of the gene/protein" ;
    dcterms:description "A gene disease association in which the gene is a therapeutic marker for the disease."@en ;
    rdfs:subClassOf sio:SIO_000983 .

sio:SIO_001123 a owl:Class ;
    rdfs:label "gene-disease association linked with altered gene expression"@en ;
    dcterms:description "A gene-disease association in which the disease phenotype is associated with an altered expression of the gene."@en ;
    rdfs:subClassOf sio:SIO_001121 .

sio:SIO_001124 a owl:Class ;
    rdfs:label "gene-disease association linked with post-translational modification"@en ;
    dcterms:description "A gene-disease association in which the disease phenotype is associated with post-translational modifications in the protein product."@en ;
    rdfs:subClassOf sio:SIO_001121 ;
    skos:example "methylation or phosphorylation of protein product"@en .

sio:SIO_001125 a owl:Class ;
    rdfs:label "regulation of transcription"@en ;
    dcterms:description "A process that modulates the frequency, rate or extent of transcription."@en ;
    rdfs:subClassOf sio:SIO_010287 .

sio:SIO_001130 a owl:Class ;
    rdfs:label "protein mediated regulation of translation"@en ;
    dcterms:description "A process mediated by a protein that modulates the frequency, rate or extent of translation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000139 ;
            owl:someValuesFrom sio:SIO_010043 ],
        sio:SIO_001126 .

sio:SIO_001131 a owl:Class ;
    rdfs:label "rna mediated regulation of translation"@en ;
    dcterms:description "A process mediated by rna that modulates the frequency, rate or extent of translation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000139 ;
            owl:someValuesFrom sio:SIO_010450 ],
        sio:SIO_001126 .

sio:SIO_001133 a owl:Class ;
    rdfs:label "increased frequency of process from increased regulation"@en ;
    dcterms:description "The increase of regulation leads to a increased occurence of processes of the target type."@en ;
    rdfs:subClassOf sio:SIO_001135 .

sio:SIO_001134 a owl:Class ;
    rdfs:label "decreased frequency of process from increased regulation"@en ;
    dcterms:description "The increase of regulation leads to a decreased occurence of processes of the target process type."@en ;
    rdfs:subClassOf sio:SIO_001135 .

sio:SIO_001137 a owl:Class ;
    rdfs:label "increased duration of process from increased regulation"@en ;
    dcterms:description "increased duration of process from increased regulation is a process in which the duration of the target process is increased as a result of increased regulation."@en ;
    rdfs:subClassOf sio:SIO_001136 .

sio:SIO_001138 a owl:Class ;
    rdfs:label "decreased duration of process from increased regulation"@en ;
    dcterms:description "decreased duration of process from increased regulation is a process in which the duration of the target process is decreased as a result of increased regulation."@en ;
    rdfs:subClassOf sio:SIO_001136 .

sio:SIO_001140 a owl:Class ;
    rdfs:label "increased spatial extent of process from increased regulation"@en ;
    dcterms:description "The increase of regulation leads to a increased spatial extent of the target process."@en ;
    rdfs:subClassOf sio:SIO_001139 .

sio:SIO_001141 a owl:Class ;
    rdfs:label "decreased spatial extent of process from decreased regulation"@en ;
    dcterms:description "The increase of regulation leads to a decreased spatial extent of the target process."@en ;
    rdfs:subClassOf sio:SIO_001139 .

sio:SIO_001142 a owl:Class ;
    rdfs:label "maintenance of spatial extent of process"@en ;
    dcterms:description "maintenance of spatial extent of process is a regulation of a process' spatial extent within some specified parameter."@en ;
    rdfs:subClassOf sio:SIO_001139 .

sio:SIO_001143 a owl:Class ;
    rdfs:label "maintenance of duration of process"@en ;
    dcterms:description "maintenance of duration of process is a process that regulates a target process to maintain its duration within an expected interval."@en ;
    rdfs:subClassOf sio:SIO_001136 .

sio:SIO_001144 a owl:Class ;
    rdfs:label "maintenance of frequency of process"@en ;
    dcterms:description "maintenance of frequency of process is a process that regulates the number of occurences of a target process type to a specified number or interval."@en ;
    rdfs:subClassOf sio:SIO_001135 .

sio:SIO_001146 a owl:Class ;
    rdfs:label "increased object production from increased regulation"@en ;
    dcterms:description "increased regulation leads to an increase in the number of target objects of a specified type."@en ;
    rdfs:subClassOf sio:SIO_001151 .

sio:SIO_001147 a owl:Class ;
    rdfs:label "decreased object production from increased regulation"@en ;
    dcterms:description "increased regulation leads to a decrease in the number of target objects of a specified type."@en ;
    rdfs:subClassOf sio:SIO_001151 .

sio:SIO_001148 a owl:Class ;
    rdfs:label "increased object consumption from increased regulation"@en ;
    dcterms:description "increased regulation leads to an increase in the consumption of an object of specified type."@en ;
    rdfs:subClassOf sio:SIO_001150 .

sio:SIO_001149 a owl:Class ;
    rdfs:label "decreased object consumption from increased regulation"@en ;
    dcterms:description "increased regulation leads to an decrease in the consumption of an object of specified type."@en ;
    rdfs:subClassOf sio:SIO_001150 .

sio:SIO_001152 a owl:Class ;
    rdfs:label "maintenance of quantity of object production"@en ;
    dcterms:description "maintenance of quantity of object production is a regulation of object production in which the number of objects produced is held more or less constant."@en ;
    rdfs:subClassOf sio:SIO_001151 .

sio:SIO_001153 a owl:Class ;
    rdfs:label "maintenance of level of object consumption"@en ;
    dcterms:description "regulation of a participant quantity is the regulation of a process in which the quantity of a selected participant is maintained at a steady level."@en ;
    rdfs:subClassOf sio:SIO_001150 .

sio:SIO_001160 a owl:Class ;
    rdfs:label "number of objects produced"@en ;
    dcterms:description "number of objects produced is a count of objects that were produced in some process."@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_001161 a owl:Class ;
    rdfs:label "number of objects consumed"@en ;
    dcterms:description "number of objects consumed is a count of objects that were consumed in some process."@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_001163 a owl:Class ;
    rdfs:label "increase in number of objects produced"@en ;
    dcterms:description "An increase in the number of objects produced is the positive value of a difference in number of objects produced."@en ;
    rdfs:subClassOf sio:SIO_001162 .

sio:SIO_001164 a owl:Class ;
    rdfs:label "decrease in number of objects produced"@en ;
    dcterms:description "An decrease in the number of objects produced is the negative value of a difference in number of objects produced."@en ;
    rdfs:subClassOf sio:SIO_001162 .

sio:SIO_001165 a owl:Class ;
    rdfs:label "user account"@en ;
    dcterms:description "user account allows a user to authenticate to system services and be granted authorization to access them."@en ;
    rdfs:subClassOf sio:SIO_000602 .

sio:SIO_001166 a owl:Class ;
    rdfs:label "annotation"@en ;
    dcterms:description "An annotation is a written explanatory or critical description, or other in-context information (e.g., pattern, motif, link), that has been associated with data or other types of information."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000668 ;
            owl:someValuesFrom sio:SIO_000000 ],
        sio:SIO_000136 .

sio:SIO_001167 a owl:Class ;
    rdfs:label "comment"@en ;
    dcterms:description "A comment is a verbal or written remark often related to an added piece of information, or an observation or statement."@en ;
    rdfs:subClassOf sio:SIO_000256 .

sio:SIO_001168 a owl:Class ;
    rdfs:label "audio recording"@en ;
    dcterms:description "An audio recording is an electrical or mechanical inscription and re-creation of sound waves, such as spoken voice, singing, instrumental music, or sound effects."@en ;
    rdfs:subClassOf sio:SIO_001194 .

sio:SIO_001169 a owl:Class ;
    rdfs:label "issue"@en ;
    dcterms:description "An issue is a single instance of a periodically published journal, magazine, or newspaper."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000162 ],
        sio:SIO_000159 .

sio:SIO_001170 a owl:Class ;
    rdfs:label "slideshow"@en ;
    dcterms:description "A slideshow is a visual presentation of information contained within a collection of slides."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000053 ;
            owl:someValuesFrom sio:SIO_001370 ],
        sio:SIO_001194 .

sio:SIO_001172 a owl:Class ;
    rdfs:label "exact cross-reference"@en ;
    dcterms:description "An exact cross-reference is a database cross-reference in which one entity is equivalent to the other based on all the entitie's attributes (minus the source)."@en ;
    rdfs:subClassOf sio:SIO_001171 .

sio:SIO_001173 a owl:Class ;
    rdfs:label "double stranded DNA"@en ;
    dcterms:description "double stranded nucleic acid is a molecular complex composed of two weakly connected deoxyribonucleic acids."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_010010 ;
            owl:onProperty sio:SIO_000053 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_001177 ;
    owl:disjointWith sio:SIO_001178 .

sio:SIO_001179 a owl:Class ;
    rdfs:label "full agreement"@en ;
    dcterms:description "full agreement is the result of consensus decision making when members of the group unanimously agree."@en ;
    rdfs:subClassOf sio:SIO_000966 .

sio:SIO_001180 a owl:Class ;
    rdfs:label "mass spectrometry experiment"@en ;
    dcterms:description "A mass spectrometry experiment is an experiment that involves the use of a mass spectrometer. "@en ;
    rdfs:subClassOf sio:SIO_000994 .

sio:SIO_001181 a owl:Class ;
    rdfs:label "full disagreement"@en ;
    dcterms:description "full agreement is the result of consensus decision making when members of the group unanimously disagree."@en ;
    rdfs:subClassOf sio:SIO_000967 .

sio:SIO_001182 a owl:Class ;
    rdfs:label "ribosomal RNA gene"@en ;
    dcterms:alternative "rRNA gene" ;
    dcterms:description "A ribosomal RNA gene is a gene that codes for a ribosomal RNA molecule."@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/SO_0001637"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_000790 .

sio:SIO_001184 a owl:Class ;
    rdfs:label "slope"@en ;
    dcterms:description "A slope or gradient of a line describes its steepness, incline, or grade. A higher slope value indicates a steeper incline. Slope is normally described by the ratio of the \"rise\" divided by the \"run\" between two points on a line."@en ;
    rdfs:subClassOf sio:SIO_001018 .

sio:SIO_001185 a owl:Class ;
    rdfs:label "software process identifier"@en ;
    dcterms:description "A software process identifier is an identifier for a software process in some operating system."@en ;
    rdfs:subClassOf sio:SIO_000731 .

sio:SIO_001187 a owl:Class ;
    rdfs:label "database row"@en ;
    dcterms:description "A database row is a row that is part of a database table."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000754 ],
        sio:SIO_000752 .

sio:SIO_001190 a owl:Class ;
    rdfs:label "REST web service"@en ;
    dcterms:description "a REST web service is a web service that provides functionality according to the Representational State Transfer (REST) specification."@en ;
    rdfs:seeAlso "http://en.wikipedia.org/wiki/REST"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_000140 .

sio:SIO_001191 a owl:Class ;
    rdfs:label "SOAP web service"@en ;
    dcterms:description "a SOAP web service is a web service that implements Simple Object Access Protocol (SOAP)."@en ;
    rdfs:seeAlso "http://en.wikipedia.org/wiki/SOAP"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_000140 .

sio:SIO_001193 a owl:Class ;
    rdfs:label "SADI web service invocation"@en ;
    dcterms:description "A SADI web service invocation is the excution of a SADI web service."@en ;
    sio:subset "sadi"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000139 ;
            owl:someValuesFrom sio:SIO_001188 ],
        sio:SIO_001192 .

sio:SIO_001198 a owl:Class ;
    rdfs:label "consensus"@en ;
    dcterms:description "consensus is an acceptable resolution, one that can be supported, even if not the preferred outcome for each individual."@en ;
    rdfs:subClassOf sio:SIO_000966 .

sio:SIO_001199 a owl:Class ;
    rdfs:label "increased molecular degradation from increased regulation"@en ;
    dcterms:description "A process that increases the frequency, rate or extent of process involved in the destruction of a molecule as a result of increased regulation."@en ;
    rdfs:subClassOf sio:SIO_001129 .

sio:SIO_001200 a owl:Class ;
    rdfs:label "decreased molecular degradation from decreased regulation"@en ;
    dcterms:description "A process that decreases the frequency, rate or extent of process involved in the destruction of a molecule as a result of decreased regulation."@en ;
    rdfs:subClassOf sio:SIO_001129 .

sio:SIO_001201 a owl:Class ;
    rdfs:label "increased molecular degradation from decreased regulation"@en ;
    dcterms:description "A process that increases the frequency, rate or extent of process involved in the destruction of a molecule as a result of decreased regulation."@en ;
    rdfs:subClassOf sio:SIO_001129 .

sio:SIO_001202 a owl:Class ;
    rdfs:label "decreased molecular degradation from increased regulation"@en ;
    dcterms:description "A process that decreases the frequency, rate or extent of process involved in the destruction of a molecule as a result of increased regulation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_000640 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_001156 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000592 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000217 ;
                                owl:someValuesFrom sio:SIO_000751 ] ) ] ],
        sio:SIO_001129 .

sio:SIO_001203 a owl:Class ;
    rdfs:label "increased molecular production from increased regulation"@en ;
    dcterms:description "A process that increases the frequency, rate or extent of process involved in the production of a molecule as a result of increased regulation."@en ;
    rdfs:subClassOf sio:SIO_001128 .

sio:SIO_001204 a owl:Class ;
    rdfs:label "decreased molecular production from increased regulation"@en ;
    dcterms:description "A process that decreases the frequency, rate or extent of process involved in the production of a molecule as a result of increased regulation."@en ;
    rdfs:subClassOf sio:SIO_001128 .

sio:SIO_001205 a owl:Class ;
    rdfs:label "increased molecular production from decreased regulation"@en ;
    dcterms:description "A process that increases the frequency, rate or extent of process involved in the production of a molecule as a result of decreased regulation."@en ;
    rdfs:subClassOf sio:SIO_001128 .

sio:SIO_001206 a owl:Class ;
    rdfs:label "decreased molecular production from decreased regulation"@en ;
    dcterms:description "A process that decreases the frequency, rate or extent of process involved in the production of a molecule as a result of decreased regulation."@en ;
    rdfs:subClassOf sio:SIO_001128 .

sio:SIO_001207 a owl:Class ;
    rdfs:label "increased chemical destruction"@en ;
    dcterms:description "increased chemical destruction is a process in which there is an increase in the amount of chemical destroyed relative to some reference process"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000794 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000734 ;
                                owl:someValuesFrom [ a owl:Class ;
                                        owl:intersectionOf ( sio:SIO_000794 [ a owl:Restriction ;
                                                    owl:onProperty sio:SIO_000011 ;
                                                    owl:someValuesFrom sio:SIO_000592 ] ) ] ] ) ] ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_000640 ],
        sio:SIO_000592 .

sio:SIO_001208 a owl:Class ;
    rdfs:label "decreased chemical destruction"@en ;
    dcterms:description "decreased chemical destruction is a process in which there is a decrease in the amount of chemical destroyed relative to some reference process"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_000640 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000668 ;
            owl:someValuesFrom sio:SIO_000592 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000794 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000734 ;
                                owl:someValuesFrom [ a owl:Class ;
                                        owl:intersectionOf ( sio:SIO_000794 [ a owl:Restriction ;
                                                    owl:onProperty sio:SIO_000011 ;
                                                    owl:someValuesFrom sio:SIO_000592 ] ) ] ] ) ] ],
        sio:SIO_000592 .

sio:SIO_001219 a owl:Class ;
    rdfs:label "to test a hypothesis"@en ;
    dcterms:description "to test a hypothesis is the capability to evaluate the truth value of a proposition based on gathered evidence."@en ;
    rdfs:subClassOf sio:SIO_000724 .

sio:SIO_001220 a owl:Class ;
    rdfs:label "to characterize"@en ;
    dcterms:description "to characterize is the capability to classify the attributes or features of an entity against a reference classification."@en ;
    rdfs:subClassOf sio:SIO_001221 .

sio:SIO_001222 a owl:Class ;
    rdfs:label "5' splice site"@en ;
    dcterms:description "The 5' splice site is the terminal region of an exon that is 5' to the intron that is to be excised."@en ;
    rdfs:subClassOf sio:SIO_010451 .

sio:SIO_001223 a owl:Class ;
    rdfs:label "3' splice site"@en ;
    dcterms:description "The 3' splice site is the terminal region of an exon that is 3' to the intron that is to be excised."@en ;
    rdfs:subClassOf sio:SIO_010451 .

sio:SIO_001225 a owl:Class ;
    rdfs:label "cis regulatory element"@en ;
    dcterms:description "A cisregulatory element is a DNA sequence located on the same DNA strand or chromosome as the gene whose expression it affects. "@en ;
    rdfs:subClassOf sio:SIO_010335 .

sio:SIO_001226 a owl:Class ;
    rdfs:label "trans-regulatory element"@en ;
    dcterms:description "A trans-regulatory element is a DNA sequence associated with the regulation of a gene located outside the genomic region supporting the corresponding structural DNA region of the trans-regulatory element (i.e., a different DNA strand or different chromosome)."@en ;
    rdfs:subClassOf sio:SIO_010335 .

sio:SIO_001228 a owl:Class ;
    rdfs:label "small nuclear RNA (snRNA) gene"@en ;
    dcterms:description "A small nuclear RNA (snRNA) gene is a gene that encodes a small niuclear RNA molecule."@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/SO_0001268"^^xsd:anyURI ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010078 ;
            owl:someValuesFrom sio:SIO_001233 ],
        sio:SIO_000790 .

sio:SIO_001229 a owl:Class ;
    rdfs:label "small nucleolar RNA (snoRNA) gene"@en ;
    dcterms:description "A small nucleolar RNA (snoRNA) gene is a gene that encodes a small RNA that are associated with the eukaryotic nucleus as components of small nucleolar ribonucleoproteins."@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/SO_0001267"^^xsd:anyURI ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010078 ;
            owl:someValuesFrom sio:SIO_001234 ],
        sio:SIO_000790 .

sio:SIO_001230 a owl:Class ;
    rdfs:label "transfer RNA (tRNA) gene"@en ;
    dcterms:alternative "solube RNA (sRNA) gene"@en,
        "tRNA gene"@en ;
    dcterms:description "A transfer RNA (tRNA) gene is a gene that codes for a tRNA used in the translation of a messenger RNA (mRNA) to produce a protein product."@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/SO_0001272"^^xsd:anyURI ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010078 ;
            owl:someValuesFrom sio:SIO_001232 ],
        sio:SIO_000790 .

sio:SIO_001237 a owl:Class ;
    rdfs:label "mass spectrometer"@en ;
    dcterms:description "A mass spectrometer is a device that identifies ions based on their mass to charge ratio using an electromagnetic field."@en ;
    sio:similarTo "http://purl.obolibrary.org/obo/OBI_0000049"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_001236 .

sio:SIO_001238 a owl:Class ;
    rdfs:label "microarray device"@en ;
    dcterms:alternative "microarray platform"@en ;
    dcterms:description "A microarray device is a device that identifies the binding of a target substance to a physically immobile substrate placed in an array or lattice."@en ;
    sio:similarTo "http://purl.obolibrary.org/obo/OBI_0000052"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_001236 .

sio:SIO_001239 a owl:Class ;
    rdfs:label "to identify"@en ;
    dcterms:description "to identify is the capability to determine the identity of something."@en ;
    rdfs:subClassOf sio:SIO_000408 .

sio:SIO_001240 a owl:Class ;
    rdfs:label "nmr device"@en ;
    dcterms:alternative "nuclear magnetic resonance device"@en ;
    dcterms:description "A nuclear magnetic resonance (NMR) device is a device that applies a magnetic field to perturb nuclei with an odd number of protons and/or of neutrons in order to hav them absort and re-emit electromagnetic radiation. "@en ;
    sio:equivalentTo "http://purl.obolibrary.org/obo/OBI_0000566"^^xsd:anyURI ;
    rdfs:subClassOf sio:SIO_001236 .

sio:SIO_001241 a owl:Class ;
    rdfs:label "catalog"@en ;
    dcterms:alternative "registry"@en ;
    dcterms:description "A catalog is a systemic collection of items of the same type."@en ;
    rdfs:subClassOf sio:SIO_000616 .

sio:SIO_001242 a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is identical to"@en ;
    dcterms:description "is identical to is a relation between two objects that are conceptually the same notwithstanding provenance or other non-intrinsic attributes."@en ;
    rdfs:subPropertyOf sio:SIO_000736 .

sio:SIO_001244 a owl:Class ;
    rdfs:label "log likelihood"@en ;
    dcterms:description "Log likelihood is the natural logarithm of the likelihood function"@en ;
    rdfs:subClassOf sio:SIO_001243 .

sio:SIO_001245 a owl:Class ;
    rdfs:label "standard score"@en ;
    dcterms:alternative "z-value, z-score, normal score, standardadized variable."@en ;
    dcterms:description "A standard score is the (signed) number of standard deviations an observation or datum is above the mean. "@en ;
    rdfs:subClassOf sio:SIO_000638 .

sio:SIO_001247 a owl:ObjectProperty,
        owl:SymmetricProperty,
        owl:TransitiveProperty ;
    rdfs:label "is transitively related to"@en ;
    schema1:comment "not implemented in standard distribution" ;
    sio:subset "ovopub" .

sio:SIO_001248 a owl:Class ;
    rdfs:label "open interval"@en ;
    dcterms:description "an open interval is an interval that does not include its endpoints."@en ;
    rdfs:subClassOf sio:SIO_001251,
        sio:SIO_001252 ;
    skos:example "(0,1) is an open interval that is greater than 0 and less than 1."@en .

sio:SIO_001249 a owl:Class ;
    rdfs:label "closed interval"@en ;
    dcterms:description "A closed interval is an interval that includes its endpoints, and is denoted with square brackets."@en ;
    rdfs:subClassOf sio:SIO_001253,
        sio:SIO_001254 ;
    skos:example "[0,1] is a closed interval that is greater than or equal to 0 and less than or equal to 1."@en .

sio:SIO_001250 a owl:Class ;
    rdfs:label "chemical-pathway association"@en ;
    dcterms:alternative "drug-pathway association"@en ;
    dcterms:description "a chemical-pathway association is an association between a chemical and a pathway."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000628 ;
            owl:someValuesFrom sio:SIO_001107 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000628 ;
            owl:someValuesFrom sio:SIO_010004 ],
        sio:SIO_000897 .

sio:SIO_001255 a owl:Class ;
    rdfs:label "pharmacokinetic pathway"@en ;
    dcterms:description "a pharmacokinetic pathway is a metabolic pathway which describes the metabolism of a drug molecule."@en ;
    rdfs:subClassOf sio:SIO_010532 .

sio:SIO_001256 a owl:Class ;
    rdfs:label "pharmacodynamic pathway"@en ;
    dcterms:description "a pharmacodynamic pathay is a regulatory pathway in which a drug molecule regulates the activity of one or more components organized in a pathway."@en ;
    rdfs:subClassOf sio:SIO_010533 .

sio:SIO_001257 a owl:Class ;
    rdfs:label "chemical-gene association"@en ;
    dcterms:description "a chemical-gene association is an association between a chemical and a gene."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000628 ;
            owl:someValuesFrom sio:SIO_010035 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000628 ;
            owl:someValuesFrom sio:SIO_010004 ],
        sio:SIO_000897 .

sio:SIO_001261 a owl:Class ;
    rdfs:label "ordered list item"@en ;
    dcterms:description "an ordered list item is an item in an ordered list." ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_001260 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000008 ;
                        owl:someValuesFrom sio:SIO_000613 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000068 ;
                        owl:someValuesFrom sio:SIO_000150 ] ) ],
        sio:SIO_001260 .

sio:SIO_001262 a owl:Class ;
    rdfs:label "anatomical entity"@en ;
    dcterms:description "an anatomical entity is an object that is a structural part (material or immaterial) of a biological entity."@en ;
    rdfs:subClassOf sio:SIO_001353 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Class ;
                        owl:unionOf ( sio:SIO_000004 sio:SIO_000370 ) ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000310 ;
                        owl:someValuesFrom sio:SIO_010046 ] ) ] .

sio:SIO_001269 a owl:Class ;
    rdfs:label "maternally transmitted"@en ;
    dcterms:description "maternally transmitted is the quality of a biological organism in which the (genetic) material is transmitted from the maternal line." ;
    rdfs:subClassOf sio:SIO_001268 ;
    owl:disjointWith sio:SIO_001270 .

sio:SIO_001272 a owl:Class ;
    rdfs:label "circularly helical"@en ;
    dcterms:description "a circularly helical quality is the quality of a helix that is connected in a circle or loop."@en ;
    rdfs:subClassOf sio:SIO_001271 .

sio:SIO_001273 a owl:Class ;
    rdfs:label "left-handed helical"@en ;
    dcterms:description "left-handed helical quality is the quality in which a clockwise screwing motion moves the helix towards the observed along the line of sight along the helix's axis."@en ;
    rdfs:subClassOf sio:SIO_001271 ;
    owl:disjointWith sio:SIO_001274 .

sio:SIO_001275 a owl:Class ;
    rdfs:label "coding frame offset"@en ;
    dcterms:description "a coding frame offset is a numeric value that indicates the number of bases from a reference start codon position."@en ;
    rdfs:subClassOf sio:SIO_001011 .

sio:SIO_001276 a owl:Class ;
    rdfs:label "coding sequence"@en ;
    dcterms:description "a coding sequence is a sequence of nucleotides which encode a RNA or protein product.."@en ;
    rdfs:subClassOf sio:SIO_010016 .

sio:SIO_001277 a owl:ObjectProperty ;
    rdfs:label "has data item"@en ;
    dcterms:description "has data item is a relation between a dataset and any described / referrenced entity." ;
    sio:subset "core" ;
    rdfs:domain sio:SIO_000089 ;
    rdfs:subPropertyOf sio:SIO_000628 ;
    owl:inverseOf sio:SIO_001278 .

sio:SIO_001279 a owl:ObjectProperty ;
    rdfs:label "has phenotype"@en ;
    dcterms:description "has phenotype is a relation between an object and an observable/measurable characteristic." ;
    rdfs:subPropertyOf sio:SIO_000008 ;
    owl:inverseOf sio:SIO_001280 .

sio:SIO_001281 a owl:Class ;
    rdfs:label "humiliation"@en ;
    dcterms:description "Humiliation is the abasement of pride, which creates mortification or leads to a state of being humbled or reduced to lowliness or submission." ;
    rdfs:subClassOf sio:SIO_000845 .

sio:SIO_001282 a owl:Class ;
    rdfs:label "hunger"@en ;
    dcterms:description "hunger is the craving for food." ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_001283 a owl:Class ;
    rdfs:label "discouragement"@en ;
    dcterms:alternative "discouraged" ;
    dcterms:description "Discouragement is the emtion of having lost confidence or enthusiasm." ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_001284 a owl:Class ;
    rdfs:label "satisfaction"@en ;
    dcterms:alternative "contentment",
        "pleasure" ;
    dcterms:description "satisfaction is the emotion of fulfillling one's wishes, expectations, or needs." ;
    rdfs:subClassOf sio:SIO_000831 .

sio:SIO_001285 a owl:Class ;
    rdfs:label "suicidal"@en ;
    dcterms:description "suicidal is the emotion of being deeply unhappy or depressed with thoughts of killing one's self." ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_001286 a owl:Class ;
    rdfs:label "irritability"@en ;
    dcterms:alternative "irritable" ;
    dcterms:description "irritability is the negative emotion of quick excitability to annoyance, impatience, or anger." ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_001287 a owl:Class ;
    rdfs:label "indecision"@en ;
    dcterms:alternative "indecisiveness" ;
    dcterms:description "indecision is the emotion of being unable to choose between two or more possible courses of action." ;
    rdfs:subClassOf sio:SIO_000832 .

sio:SIO_001301 a owl:Class ;
    rdfs:label "collection ovopub"@en ;
    dcterms:description "A collection ovopub is an ovopub that contains and links to one or more assertion subgraphs and/or ovopubs, as well as statements describing its provenance. It is used to share a specific set of items or restrict a search to the resources contained therein."@en ;
    rdfs:subClassOf sio:SIO_001300 ;
    owl:disjointWith sio:SIO_001302 .

sio:SIO_001303 a owl:Class ;
    rdfs:label "none quantifier"@en ;
    rdfs:subClassOf sio:SIO_001299 .

sio:SIO_001304 a owl:Class ;
    rdfs:label "a little quantifier"@en ;
    rdfs:subClassOf sio:SIO_001299 .

sio:SIO_001305 a owl:Class ;
    rdfs:label "moderately quantifier"@en ;
    rdfs:subClassOf sio:SIO_001299 .

sio:SIO_001306 a owl:Class ;
    rdfs:label "mostly quantifier"@en ;
    rdfs:subClassOf sio:SIO_001299 .

sio:SIO_001307 a owl:Class ;
    rdfs:label "completely quantifier"@en ;
    rdfs:subClassOf sio:SIO_001299 .

sio:SIO_001309 a owl:Class ;
    rdfs:label "very dissatisfied qualifier"@en ;
    rdfs:subClassOf sio:SIO_001308 .

sio:SIO_001310 a owl:Class ;
    rdfs:label "dissatisfied qualifier"@en ;
    rdfs:subClassOf sio:SIO_001308 .

sio:SIO_001311 a owl:Class ;
    rdfs:label "neither satisfied or dissatisfied qualifier"@en ;
    rdfs:subClassOf sio:SIO_001308 .

sio:SIO_001312 a owl:Class ;
    rdfs:label "satisfied qualifier"@en ;
    rdfs:subClassOf sio:SIO_001308 .

sio:SIO_001313 a owl:Class ;
    rdfs:label "excellent quality"@en ;
    rdfs:subClassOf sio:SIO_001293 .

sio:SIO_001314 a owl:Class ;
    rdfs:label "date of issue"@en ;
    dcterms:description "the date at which an information content entity was made public." ;
    rdfs:subClassOf sio:SIO_000418 .

sio:SIO_001315 a owl:Class ;
    rdfs:label "author list"@en ;
    dcterms:description "an ordered list of authors." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000053 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_001260 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000008 ;
                                owl:someValuesFrom sio:SIO_000613 ] [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000628 ;
                                owl:someValuesFrom [ a owl:Class ;
                                        owl:unionOf ( sio:SIO_000012 sio:SIO_000498 ) ] ] ) ] ],
        sio:SIO_001316 .

sio:SIO_001318 a owl:Class ;
    rdfs:label "middle initial"@en ;
    dcterms:description "a middle initial is an abbreviated middle name." ;
    rdfs:subClassOf sio:SIO_001317 .

sio:SIO_001320 a owl:Class ;
    rdfs:label "cellular phone number"@en ;
    dcterms:description "a cellular phone number is a number to connect to a mobile device" ;
    rdfs:subClassOf sio:SIO_001319 .

sio:SIO_001321 a owl:Class ;
    rdfs:label "fax number"@en ;
    dcterms:description "a fax number is a number to connect to fax device" ;
    rdfs:subClassOf sio:SIO_001319 .

sio:SIO_001322 a owl:Class ;
    rdfs:label "IP number"@en ;
    dcterms:alternative "IP address" ;
    dcterms:description "an IP number is an number to connect to a device on the internet." ;
    rdfs:subClassOf sio:SIO_000731 .

sio:SIO_001323 a owl:Class ;
    rdfs:label "email address"@en ;
    dcterms:description "an email address is an identifier to send mail to particular electronic mailbox." ;
    rdfs:subClassOf sio:SIO_000731 .

sio:SIO_001324 a owl:Class ;
    rdfs:label "work phone number"@en ;
    dcterms:description "a work phone number is the number to connect to an phone at a place of work." ;
    rdfs:subClassOf sio:SIO_001319 .

sio:SIO_001325 a owl:Class ;
    rdfs:label "home phone number"@en ;
    dcterms:description "a home phone number is the number to connect to an phone at a place of residence." ;
    rdfs:subClassOf sio:SIO_001319 .

sio:SIO_001326 a owl:Class ;
    rdfs:label "status descriptor"@en ;
    dcterms:description "status descriptor is a descriptor for the state of a process or object." ;
    rdfs:subClassOf sio:SIO_000436 .

sio:SIO_001327 a owl:Class ;
    rdfs:label "protein expression value"@en ;
    dcterms:description "A protein expression value is a quantity obtained from a protein expression experiment."@en ;
    rdfs:subClassOf sio:SIO_000258 .

sio:SIO_001328 a owl:Class ;
    rdfs:label "copy number variation"@en ;
    dcterms:alternative "CNV"@en ;
    dcterms:description "copy number variation refers to the number of deletions/duplications of a DNA region as compared to some reference state."@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_001329 a owl:Class ;
    rdfs:label "single nucleotide polymorphism"@en ;
    dcterms:alternative "SNP"@en,
        "SNV"@en,
        "single nucleotide variation"@en ;
    dcterms:description "a single nucleotide variation (SNV) is a nucleotide residue that is a variant compared to some reference nucleic acid sequence."@en ;
    rdfs:subClassOf sio:SIO_010075 .

sio:SIO_001330 a owl:Class ;
    rdfs:label "metadata"@en ;
    dcterms:description "metadata is data that provides information about data."@en ;
    rdfs:subClassOf sio:SIO_000069 .

sio:SIO_001331 a owl:Class ;
    rdfs:label "diagnosis"@en ;
    dcterms:description "A diagnosis is the result of a medical investigation to identify a disorder from its signs and symptoms."@en ;
    rdfs:subClassOf sio:SIO_000262 .

sio:SIO_001333 a owl:Class ;
    rdfs:label "arc"@en ;
    dcterms:description "an arc is a closed segment of a differentiable curve."@en ;
    rdfs:subClassOf sio:SIO_000608 .

sio:SIO_001334 a owl:Class ;
    rdfs:label "edge"@en ;
    dcterms:description "an edge is a line connecting two graph vertices."@en ;
    rdfs:subClassOf sio:SIO_000511 .

sio:SIO_001337 a owl:Class ;
    rdfs:label "epimer association"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_001336 ;
            owl:onProperty sio:SIO_000628 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_000897 .

sio:SIO_001339 a owl:Class ;
    rdfs:label "empty"@en ;
    dcterms:description "empty is the quality of not containing some thing"@en ;
    rdfs:subClassOf sio:SIO_001341 .

sio:SIO_001340 a owl:Class ;
    rdfs:label "full"@en ;
    dcterms:description "full is the quality of contain an entity such that there is no more space for any additional entity."@en ;
    rdfs:subClassOf sio:SIO_001341 .

sio:SIO_001343 a owl:Class ;
    rdfs:label "gene-disease association linked with susceptibility mutation"@en ;
    dcterms:description "A gene-disease association in which a germline mutation in the gene predisposes to the development of the disease, and it is necessary but not sufficient for the manifestation of the disease."@en ;
    rdfs:subClassOf sio:SIO_001122 .

sio:SIO_001344 a owl:Class ;
    rdfs:label "gene-disease association linked with germline causal mutation"@en ;
    dcterms:description "A gene-variant disease association in which a germline mutation in the gene/protein results in the development or maintenance of the disease, and it may be passed on to offspring."@en ;
    rdfs:subClassOf sio:SIO_001119 .

sio:SIO_001345 a owl:Class ;
    rdfs:label "gene-disease association linked with somatic causal mutation"@en ;
    dcterms:description "A gene-variant disease association in which a somatic mutation in the gene/protein results in the development or maintenance of the disease, and it may not be passed on to offspring."@en ;
    rdfs:subClassOf sio:SIO_001119 .

sio:SIO_001346 a owl:Class ;
    rdfs:label "gene-disease association linked with somatic modifying mutation"@en ;
    dcterms:description "A gene-variant disease association in which a somatic mutation in the gene modifies the clinical presentation of the disease, and it may not be passed on to offspring."@en ;
    rdfs:subClassOf sio:SIO_001342 .

sio:SIO_001347 a owl:Class ;
    rdfs:label "gene-disease association linked with germline modifying mutation"@en ;
    dcterms:description "A gene-variant disease association in which a germline mutation in the gene modifies the clinical presentation of the disease, and it may be passed on to offspring."@en ;
    rdfs:subClassOf sio:SIO_001342 .

sio:SIO_001348 a owl:Class ;
    rdfs:label "fusion gene-disease association"@en ;
    dcterms:description "A gene-disease association in which the fusion between two different genes (promotor and/or other coding DNA regions) is associated with the disease."@en ;
    rdfs:subClassOf sio:SIO_001350 .

sio:SIO_001349 a owl:Class ;
    rdfs:label "gene-disease association linked with chromosomal rearrangement"@en ;
    dcterms:description "A gene-disease association in which the gene is included in a chromosomal rearrangement associated with a particular manifestation of the disease."@en ;
    rdfs:subClassOf sio:SIO_001350 .

sio:SIO_001351 a owl:Class ;
    rdfs:label "DisGeNET disease specificity"@en ;
    dcterms:description """DisGeNET Disease specificity is a measure of disease coverage. It is calculated from the negative base 2 log of the ratio of number of diseases associated to the total number of diseases.

The measure is described here: http://www.disgenet.org/web/DisGeNET/menu/dbinfo#specificity"""@en ;
    rdfs:subClassOf sio:SIO_001018 .

sio:SIO_001352 a owl:Class ;
    rdfs:label "DisGeNET Pleiotropy Index"@en ;
    dcterms:description """The DisGeNET pleiotropy index is a measure of specificity as it pertains to classes of disease. The disease pleotropy index is computed from the ratio of the number of disease classes associated with an entity over the total number of disease classes multplied by 100. 

The measure is defined here: http://www.disgenet.org/web/DisGeNET/menu/dbinfo#pleiotropy"""@en ;
    rdfs:subClassOf sio:SIO_001018 .

sio:SIO_001354 a owl:Class ;
    rdfs:label "week"@en ;
    dcterms:description "A week is a period of 7 consecutive days."@en ;
    rdfs:subClassOf sio:SIO_000417 .

sio:SIO_001355 a owl:Class ;
    rdfs:label "specific gravity"@en ;
    dcterms:description "Specific gravity is the ratio of the density of a substance to the density of a reference substance; equivalently, it is the ratio of the mass of a substance to the mass of a reference substance for the same given volume." ;
    rdfs:subClassOf sio:SIO_001018 .

sio:SIO_001356 a owl:Class ;
    rdfs:label "information encoding"@en ;
    rdfs:subClassOf sio:SIO_001359 .

sio:SIO_001357 a owl:Class ;
    rdfs:label "speech"@en ;
    dcterms:description "speech is the expression of thoughts and feelings by sound." ;
    rdfs:subClassOf sio:SIO_000969 .

sio:SIO_001360 a owl:Class ;
    rdfs:label "information decoding"@en ;
    rdfs:subClassOf sio:SIO_001359 .

sio:SIO_001361 a owl:Class ;
    rdfs:label "to store"@en ;
    dcterms:description "to store is the capability to place an object into a medium in which it can be retrieved in the future." ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_001362 a owl:Class ;
    rdfs:label "to encode information"@en ;
    dcterms:description "the capability to encode information in a different representation" ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_001363 a owl:Class ;
    rdfs:label "to maintain information"@en ;
    dcterms:description "the capability to maintain information such that it can be retrieved in the future." ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_001364 a owl:Class ;
    rdfs:label "to decode information"@en ;
    dcterms:description "the ability to reverse an encoding operation" ;
    rdfs:subClassOf sio:SIO_000494 .

sio:SIO_001366 a owl:Class ;
    rdfs:label "information maintenance"@en ;
    dcterms:alternative "regulation of information" ;
    dcterms:description "the regulation or maintenance of information"@en ;
    rdfs:subClassOf sio:SIO_001132 .

sio:SIO_001367 a owl:Class ;
    rdfs:label "frequency"@en ;
    dcterms:description "Frequency is the number of occurrences of a repeating event per unit time"@en ;
    rdfs:subClassOf sio:SIO_001365 .

sio:SIO_001369 a owl:Class ;
    rdfs:label "velocity"@en ;
    dcterms:description "The rate of change of an object's position and the direction of that change"@en ;
    rdfs:subClassOf sio:SIO_001368 .

sio:SIO_001371 a owl:Class ;
    rdfs:label "statute"@en ;
    dcterms:description "A statute is a formal written enactment of a legislative authority that governs a state, city or country."@en ;
    rdfs:subClassOf sio:SIO_001373 .

sio:SIO_001372 a owl:Class ;
    rdfs:label "legislation"@en ;
    dcterms:description "A legal document proposing or enacting a law or a group of laws."@en ;
    rdfs:subClassOf sio:SIO_001373 .

sio:SIO_001374 a owl:Class ;
    rdfs:label "brief"@en ;
    dcterms:description "A brief is a written legal document used in various legal adversarial systems that is presented to a court arguing why one party to a particular case should prevail."@en ;
    rdfs:subClassOf sio:SIO_001373 .

sio:SIO_001375 a owl:Class ;
    rdfs:label "book section"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_000106 ],
        sio:SIO_000111 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000111 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000093 ;
                        owl:someValuesFrom sio:SIO_000106 ] ) ] .

sio:SIO_001376 a owl:Class ;
    rdfs:label "bill"@en ;
    dcterms:description "A bill is proposed legislation under consideration by a legislature."@en ;
    rdfs:subClassOf sio:SIO_001373 .

sio:SIO_001377 a owl:Class ;
    rdfs:label "versioned dataset"@en ;
    dcterms:description "a versioned dataset is a dataset with a particular release date or release number."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000008 ;
            owl:someValuesFrom sio:SIO_000653 ],
        sio:SIO_000089 .

sio:SIO_001378 a owl:Class ;
    rdfs:label "analyte"@en ;
    dcterms:description "an analyte is a substance or chemical constituent of interest in an analytical procedure."@en ;
    rdfs:subClassOf sio:SIO_011126 .

sio:SIO_001379 a owl:Class ;
    rdfs:label "protein domain"@en ;
    dc:description "A protein domain is a part of a protein that maintains its structure and function independently of the rest of the protein."@en ;
    rdfs:subClassOf sio:SIO_010471 .

sio:SIO_001380 a owl:Class ;
    rdfs:label "protein family"@en ;
    dc:description "a protein family is a collection of proteins that share a common evolutionary origin, reflected by their related function and similarity in composition or structure."@en ;
    rdfs:subClassOf sio:SIO_000616 .

sio:SIO_001382 a owl:Class ;
    rdfs:label "unigene cluster"@en ;
    dc:description "a unigene cluster is a collection of transcripts (ESTs and mRNAs) that map to a particular genomic region."@en ;
    dcterms:alternative "cluster of transcripts"@en ;
    rdfs:subClassOf sio:SIO_000616 .

sio:SIO_001383 a owl:Class ;
    rdfs:label "gene symbol"@en ;
    dc:description "a gene symbol is a short name assigned to a gene."@en ;
    rdfs:subClassOf sio:SIO_000120 .

sio:SIO_001384 a owl:Class ;
    rdfs:label "statement of consequence"@en ;
    dc:description "a statement of consequence is a statement concerning the result or effect of an action or condition."@en ;
    rdfs:subClassOf sio:SIO_001183 .

sio:SIO_001387 a owl:Class ;
    rdfs:label "InCHI notation"@en ;
    rdfs:subClassOf sio:SIO_001386 .

sio:SIO_001389 a owl:Class ;
    rdfs:label "hgvs notation"@en ;
    dc:description "The HGVS (human genome variation society) notation is a notation to specify a sequence variation in dna, rna, proteins, and other biomolecules."@en ;
    rdfs:subClassOf sio:SIO_001388 .

sio:SIO_001390 a owl:Class ;
    rdfs:label "protein coding sequence"@en ;
    dc:description "A protein coding sequence (CDS) is the region of DNA that is translated to form proteins. The CDS refers to those nucleotides (concatenated exons) that can be divided into codons which are actually translated into amino acids by the ribosomal translation machinery."@en ;
    dcterms:alternative "CDS"@en,
        "coding sequence"@en ;
    rdfs:subClassOf sio:SIO_010444 .

sio:SIO_001391 a owl:Class ;
    rdfs:label "ontology"@en ;
    dc:description "an ontology is a formal specification of entities, their attributes and relationships."@en ;
    rdfs:subClassOf sio:SIO_000621 .

sio:SIO_001392 a owl:Class ;
    rdfs:label "biologic"@en ;
    dc:description "A biologic,  also known as a biologic medical product, biological, or biopharmaceutical, is any pharmaceutical drug product manufactured in, extracted from, or semisynthesized from biological sources."@en ;
    rdfs:subClassOf sio:SIO_010039 .

sio:SIO_001393 a owl:Class ;
    rdfs:label "post-translational modification"@en ;
    dc:description "a post-translational modification is a part of a protein that was added, removed, or modified as a result of a chemical reaction after synthesis."@en ;
    rdfs:subClassOf sio:SIO_010471 .

sio:SIO_001394 a owl:Class ;
    rdfs:label "evidence"@en ;
    dc:description "evidence is the body of facts or information indicating whether a belief or proposition is true or valid."@en ;
    rdfs:subClassOf sio:SIO_000256 .

sio:SIO_001396 a owl:Class ;
    rdfs:label "terminology"@en ;
    dc:description "A terminology is a set of terms used for a specified application."@en ;
    rdfs:subClassOf sio:SIO_001080 .

sio:SIO_001397 a owl:Class ;
    rdfs:label "microRNA (miRNA)"@en ;
    dc:description "A microRNA (abbreviated miRNA) is a small non-coding RNA molecule (containing about 22 nucleotides) found in plants, animals and some viruses, that functions in RNA silencing and post-transcriptional regulation of gene expression."@en ;
    dcterms:alternative "miRNA"@en ;
    rdfs:subClassOf sio:SIO_001235 .

sio:SIO_001398 a owl:Class ;
    rdfs:label "medical intervention"@en ;
    dc:description "a medical intervention is a medical procedure to treat (to cure or alleviate) a health condition."@en ;
    rdfs:subClassOf sio:SIO_001024 .

sio:SIO_001399 a owl:Class ;
    rdfs:label "chemical exposure"@en ;
    dc:description "chemical exposure is a process to expose one or more individuals to a chemical substance."@en ;
    rdfs:subClassOf sio:SIO_010013 .

sio:SIO_001400 a owl:Class ;
    rdfs:label "subcellular entity"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000068 ;
            owl:someValuesFrom sio:SIO_010001 ],
        sio:SIO_010046 .

sio:SIO_001401 a owl:ObjectProperty ;
    rdfs:label "positively regulates"@en ;
    dc:description "x positively regulates y if and only if x is a process and y is either a process or a quality, and the progression of x exerts an effect that increases the frequency, rate or extent of y"@en ;
    rdfs:subPropertyOf sio:SIO_001154 .

sio:SIO_001402 a owl:ObjectProperty ;
    rdfs:label "negatively regulates"@en ;
    dc:description "x negatively regulates y if and only if x is a process and y is either a process or a quality, and the progression of x exerts an reduced effect on the frequency, rate or extent of y"@en ;
    rdfs:subPropertyOf sio:SIO_001154 .

sio:SIO_001404 a owl:ObjectProperty ;
    rdfs:label "is correlated with"@en ;
    dc:description "x is correlated with y when x holds a statistical relationship with y"@en ;
    rdfs:subPropertyOf sio:SIO_001403 .

sio:SIO_001406 a owl:Class ;
    rdfs:label "density"@en ;
    dcterms:description "Density (volumetric mass density) is the quantity of mass per unit volume of a substance."@en ;
    rdfs:subClassOf sio:SIO_000048 .

sio:SIO_001407 a owl:Class ;
    rdfs:label "surface area"@en ;
    dcterms:description "The surface area of a is a measure of the total area that the surface of the object occupies."@en ;
    rdfs:subClassOf sio:SIO_000045 .

sio:SIO_001408 a owl:Class ;
    rdfs:label "aspect ratio"@en ;
    dcterms:description "The aspect ratio of a geometric shape is the ratio of its sizes in different dimensions."@en ;
    rdfs:subClassOf sio:SIO_001018 .

sio:SIO_001410 a owl:Class ;
    rdfs:label "synthetic quality"@en ;
    dcterms:description "synthetic quality is the quality of a manufactured object that has similar properties as naturally occuring objects."@en ;
    rdfs:subClassOf sio:SIO_001409 .

sio:SIO_001411 a owl:Class ;
    rdfs:label "sample quality"@en ;
    dcterms:description "sample quality is the quality of an object that is drawn from a larger population."@en ;
    rdfs:subClassOf sio:SIO_001409 .

sio:SIO_001412 a owl:Class ;
    rdfs:label "replica quality"@en ;
    dcterms:description "replica quality is the quality of an object that is an exact copy of another object."@en ;
    rdfs:subClassOf sio:SIO_001409 .

sio:SIO_001413 a owl:Class ;
    rdfs:label "percentage"@en ;
    dcterms:description "A percentage is a number that is a ratio expressed as a fraction of 100. It is denoted using the percent sign \"%\"."@en ;
    rdfs:subClassOf sio:SIO_001018 .

sio:SIO_001415 a owl:Class ;
    rdfs:label "percentile"@en ;
    dcterms:description "A percentile (or a centile) is a quantile that divides the given probability distribution, or sample, into 100 equal-sized intervals."@en ;
    rdfs:subClassOf sio:SIO_001414 .

sio:SIO_001419 a owl:Class ;
    rdfs:label "a collection of replicates"@en ;
    dcterms:alternative "replicates"@en ;
    dcterms:description "a collection of replicates is a collection composed of items that are a facsimile, reproduction, or copy of other items in the collection."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000059 ;
            owl:someValuesFrom sio:SIO_001418 ],
        sio:SIO_000616 .

sio:SIO_001421 a owl:Class ;
    rdfs:label "a collection of duplicates"@en ;
    dcterms:alternative "duplicates"@en ;
    dcterms:description "a collection of duplicates is a collection composed of items that are an exact copy of other items in the collection."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000059 ;
            owl:someValuesFrom sio:SIO_001420 ],
        sio:SIO_000616 .

sio:SIO_001423 a owl:Class ;
    rdfs:label "strong chemical salt"@en ;
    dcterms:description "a strong chemical salt is a chemical salt that is composed of strong electrolytes. Strong chemical salts contain Na,K,NH4 or NO3, CIO4, CH3COO."@en ;
    rdfs:subClassOf sio:SIO_001422 .

sio:SIO_001424 a owl:Class ;
    rdfs:label "weak chemical salt"@en ;
    dcterms:description "a weak chemical salt is a chemical salt composed of weak eletrolytes."@en ;
    rdfs:subClassOf sio:SIO_001422 .

sio:SIO_001425 a owl:Class ;
    rdfs:label "peptide"@en ;
    dcterms:description "a peptide is an organic polymer composed of between two and fifty amino acids."@en ;
    rdfs:subClassOf sio:SIO_001427 .

sio:SIO_001426 a owl:Class ;
    rdfs:label "oligopeptide"@en ;
    dcterms:description "an oligopeptide is an organic polymer composed of fewer than 10 or 15 amino acids."@en ;
    rdfs:subClassOf sio:SIO_001427 .

sio:SIO_001433 a owl:Class ;
    rdfs:label "matrix"@en ;
    dcterms:alternative "rank 2 tensor"@en ;
    dcterms:description "a matrix is a rank 2 tensor. It is represented as a rectangular array or table of numbers, symbols, or expressions arranged in rows and columns."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom sio:SIO_001430 ;
            owl:onProperty sio:SIO_000053 ],
        sio:SIO_001434 .

sio:SIO_001435 a owl:Class ;
    rdfs:label "chemical-chemical association"@en ;
    dcterms:description "A chemical-chemical association is an association between two chemical entities."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_010004 ;
            owl:onProperty sio:SIO_000628 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_000897 .

sio:SIO_001436 a owl:Class ;
    rdfs:label "disease-disease association"@en ;
    rdfs:comment "A disease-disease association is an association between two diseases."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_010299 ;
            owl:onProperty sio:SIO_000628 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_000897 .

sio:SIO_001437 a owl:Class ;
    rdfs:label "gene-gene association"@en ;
    rdfs:comment "A gene-gene association is an association between two genes."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_010035 ;
            owl:onProperty sio:SIO_000628 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_000897 .

sio:SIO_001438 a owl:Class ;
    rdfs:label "protein-protein association"@en ;
    rdfs:comment "A protein-protein association is an association between two proteins."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_010043 ;
            owl:onProperty sio:SIO_000628 ;
            owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ],
        sio:SIO_000897 .

sio:SIO_001439 a owl:Class ;
    rdfs:label "protein-disease association"@en ;
    rdfs:comment "A protein-disease association is an association between a protein and a disease."@en ;
    rdfs:subClassOf sio:SIO_000897 .

sio:SIO_001440 a owl:Class ;
    rdfs:label "chemical-protein association"@en ;
    rdfs:comment "A chemical-protein association is an association between a chemical and a protein."@en ;
    rdfs:subClassOf sio:SIO_000897 .

sio:SIO_001444 a owl:Class ;
    rdfs:label "imaginary"@en ;
    dcterms:description "the quality of existing only in the imagination. it can be used to describe concepts, ideas, or things that are the product of a cognitive process."@en ;
    rdfs:subClassOf sio:SIO_001186 .

sio:SIO_001445 a owl:Class ;
    rdfs:label "protein isoform"@en ;
    dcterms:description "a protein isoform is a protein that is a structural variant (different sequence of amino acids and/or post-translational modifications) of another protein, but encoded by the same gene."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010079 ;
            owl:someValuesFrom sio:SIO_000985 ],
        sio:SIO_010043,
        sio:SIO_010455 .

sio:SIO_001446 a owl:Class ;
    rdfs:label "salt"@en ;
    dcterms:description "a salt is a heterogeneous substance that is coposed of positively charged ions (cations) and negatively charged ions (anions) held together by electrostatic forces."@en ;
    rdfs:subClassOf sio:SIO_010462 .

sio:SIO_010015 a owl:Class ;
    rdfs:label "protein sequence"@en ;
    dcterms:alternative "amino acid sequence"@en,
        "polypeptide sequence"@en ;
    dcterms:description "A protein acid sequence is the character representation of the molecular structure of a protein."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000210 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_000626 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000011 ;
                                owl:someValuesFrom sio:SIO_010007 ] ) ] ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000011 ;
            owl:someValuesFrom sio:SIO_010007 ],
        sio:SIO_000030 .

sio:SIO_010017 a owl:Class ;
    rdfs:label "ribonucleic acid sequence"@en ;
    dcterms:alternative "RNA sequence"@en ;
    dcterms:description "A ribonucleic acid sequence is a symbolic representation of the sequence of ribonucleic acid residues in a ribonucleic acid."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000332 ;
            owl:someValuesFrom sio:SIO_010009 ],
        sio:SIO_010016 .

sio:SIO_010018 a owl:Class ;
    rdfs:label "deoxyribonucleic acid sequence"@en ;
    dcterms:alternative "DNA sequence"@en ;
    dcterms:description "A deoxyribonucleic acid sequence is a symbolic representation of the sequence of deoxyribonucleic acid residues in a deoxyribonucleic acid."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000332 ;
            owl:someValuesFrom sio:SIO_010010 ],
        sio:SIO_010016 .

sio:SIO_010022 a owl:Class ;
    rdfs:label "secondary structure descriptor"@en ;
    dcterms:description "A secondary structure descriptor describes local topological patterns in  a biopolymer."@en ;
    rdfs:subClassOf sio:SIO_011119 .

sio:SIO_010024 a owl:Class ;
    rdfs:label "quaternary structure"@en ;
    dcterms:description "A quaternary structure descriptor describes topological patterns in a multi-unit biopolymer complex."@en ;
    rdfs:subClassOf sio:SIO_011119 .

sio:SIO_010026 a owl:Class ;
    rdfs:label "genetic polymorphism"@en ;
    dcterms:description "genetic polymorphism is the description of a difference in genetic composition at some location."@en ;
    rdfs:subClassOf sio:SIO_010335 .

sio:SIO_010028 a owl:Class ;
    rdfs:label "genetic data"@en ;
    dcterms:description "genetic data is data pertaining to genetics."@en ;
    rdfs:subClassOf sio:SIO_010019 .

sio:SIO_010031 a owl:Class ;
    rdfs:label "PDB chain identifier"@en ;
    dcterms:description "A PDB chain identifier is a alphabetical label to identify a molecule in a structure provided by the Protein DataBank ."@en ;
    rdfs:subClassOf sio:SIO_000732 .

sio:SIO_010032 a owl:Class ;
    rdfs:label "PDB record identifier"@en ;
    dcterms:description "A PDB record identifier is an identifier for a PDB generated record."@en ;
    rdfs:subClassOf sio:SIO_000729 .

sio:SIO_010034 a owl:Class ;
    rdfs:label "cation pi interaction"@en ;
    dcterms:description "A cation pi interaction is an ionic interaction between the localized negative charge of π orbital electrons, located above and below the plane of an aromatic ring, and a positive charge."@en ;
    rdfs:subClassOf sio:SIO_010496 .

sio:SIO_010036 a owl:Class ;
    rdfs:label "biochemical reaction"@en ;
    dcterms:description "A biochemical reaction is a biochemical process that involves the conversion of at least one chemical participant (target) into another (product) by an enzyme (agent)."@en ;
    sio:equivalentTo "biopax:BiochemicalReaction",
        "biopax:Conversion" ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_010508 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000139 ;
                        owl:someValuesFrom sio:SIO_010343 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000291 ;
                        owl:someValuesFrom sio:SIO_010362 ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000312 ;
                        owl:someValuesFrom sio:SIO_010363 ] ) ],
        sio:SIO_010508 .

sio:SIO_010041 a owl:Class ;
    rdfs:label "active site"@en ;
    dcterms:description "An active site is a molecular site in which a chemical event occurs (structural transformation or conformational change)."@en ;
    rdfs:subClassOf sio:SIO_010049 .

sio:SIO_010042 a owl:Class ;
    rdfs:label "haplotype"@en ;
    dcterms:description "A haplotype is one of a set of genomic sequence variants."@en ;
    rdfs:subClassOf sio:SIO_001381 .

sio:SIO_010045 a owl:Class ;
    rdfs:label "base pair"@en ;
    dcterms:description "A base pair is a weak molecular interaction composed of hydrogen bonds between nucleobases."@en ;
    rdfs:subClassOf sio:SIO_010005 .

sio:SIO_010050 a owl:Class ;
    rdfs:label "allosteric site"@en ;
    dcterms:description "An allosteric site is a binding site that when bound to particular ligand changes the conformational state and affects its functionality."@en ;
    rdfs:subClassOf sio:SIO_010040 .

sio:SIO_010053 a owl:Class ;
    rdfs:label "evolutionary lineage"@en ;
    dcterms:description "evolutionary lineage is a sequence of species, that form a line of descent, each new species the direct result of speciation from an immediate ancestral species."@en ;
    rdfs:subClassOf sio:SIO_001196 .

sio:SIO_010055 a owl:Class ;
    rdfs:label "strain"@en ;
    dcterms:description "A strain is a genetic variant or kind of microorganism."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000272 ;
            owl:someValuesFrom sio:SIO_010000 ],
        sio:SIO_010000 .

sio:SIO_010060 a owl:Class ;
    rdfs:label "family history"@en ;
    dcterms:description "family history is the systematic narrative and research of past events relating to a specific family, or specific families."@en ;
    rdfs:subClassOf sio:SIO_001196 .

sio:SIO_010061 a owl:Class ;
    rdfs:label "generation number"@en ;
    dcterms:description "generation number is a count of the number of biological reproduction events elapsed from some starting reference point."@en ;
    rdfs:subClassOf sio:SIO_000794 .

sio:SIO_010064 a owl:Class ;
    rdfs:label "5' untranslated region"@en ;
    dcterms:description "The five prime untranslated region (5' UTR) is a section of messenger RNA (mRNA) and the DNA that codes for it that starts at the +1 position (where transcription begins) and ends one nucleotide before the start codon (usually AUG) of the coding region."@en ;
    rdfs:subClassOf sio:SIO_010444 .

sio:SIO_010065 a owl:Class ;
    rdfs:label "bioinformatic data"@en ;
    dcterms:description "bioinformatic data is data genereated or used for computer-based investigations of biological phenomena."@en ;
    rdfs:subClassOf sio:SIO_010019 .

sio:SIO_010067 a owl:Class ;
    rdfs:label "multiple sequence alignment"@en ;
    dcterms:description "A multiple sequence alignment is a sequence alignment involving more than two sequences."@en ;
    rdfs:subClassOf sio:SIO_010066 .

sio:SIO_010068 a owl:Class ;
    rdfs:label "pairwise sequence alignment"@en ;
    dcterms:description "A pairwise sequence alignment is the alignment of exactly 2 sequences."@en ;
    rdfs:subClassOf sio:SIO_010066 .

sio:SIO_010070 a owl:Class ;
    rdfs:label "3' untranslated region"@en ;
    dcterms:description "A three prime untranslated region (3'-UTR) is the section of messenger RNA (mRNA) that immediately follows the translation termination codon. "@en ;
    rdfs:subClassOf sio:SIO_010444 .

sio:SIO_010073 a owl:Class ;
    rdfs:label "open reading frame"@en ;
    dcterms:description "An open reading frame (ORF) is a part of a gene that encodes a protein but does not contain a stop codon."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010080 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_010450 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_010082 ;
                                owl:someValuesFrom sio:SIO_010007 ] ) ] ],
        [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onClass sio:SIO_010447 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] [ a owl:Restriction ;
                        owl:onClass sio:SIO_010448 ;
                        owl:onProperty sio:SIO_000369 ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] ) ],
        sio:SIO_010444 .

sio:SIO_010084 a owl:Class ;
    rdfs:label "operon"@en ;
    dcterms:description "An operon is a collection of contiguous genes transcribed as a single (polycistronic) mRNA."@en ;
    sio:similarTo "SO:0000178" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_010080 ;
            owl:someValuesFrom sio:SIO_010450 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_010010 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000369 ;
            owl:someValuesFrom sio:SIO_010035 ],
        sio:SIO_010335 .

sio:SIO_010086 a owl:Class ;
    rdfs:label "gene enhancer"@en ;
    dcterms:description "A gene enhancer is a short region of DNA that can be bound with proteins to enhance transcription levels of genes in a gene cluster."@en ;
    rdfs:subClassOf sio:SIO_010085 .

sio:SIO_010087 a owl:Class ;
    rdfs:label "inactive ingredient"@en ;
    dcterms:description "Aninactive ingredient is a molecular entity that does not exhibit biological activity."@en ;
    rdfs:subClassOf sio:SIO_010338 .

sio:SIO_010089 a owl:Class ;
    rdfs:label "to serve as a template for protein synthesis"@en ;
    dcterms:description "to serve as a template for protein synthesis is the capability of a chemical entity to provide the necessary information or scaffold by which a protein may be produced."@en ;
    rdfs:subClassOf sio:SIO_010088 .

sio:SIO_010092 a owl:Class ;
    rdfs:label "deoxyribonucleic acid template"@en ;
    dcterms:description "A deoxyribonucleic acid template is a deoxyribonucleic acid that provides the template to synthesize a complementary strand of DNA through transcription."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000225 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:unionOf ( sio:SIO_010090 sio:SIO_010091 ) ] ],
        sio:SIO_010010 .

sio:SIO_010093 a owl:Class ;
    rdfs:label "deoxyribonucleic acid primer"@en ;
    dcterms:description "A deoxyribonucleic acid primer is a deoxyribonucleic acid that enables the synthesis of a complement strand of DNA by binding to it and acting as a point of transcription initiation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000225 ;
            owl:someValuesFrom sio:SIO_010091 ],
        sio:SIO_000779,
        sio:SIO_010010 .

sio:SIO_010097 a owl:Class ;
    rdfs:label "pre-mRNA"@en ;
    dcterms:description "Precursor mRNA (pre-mRNA) is a single strand of messenger ribonucleic acid (mRNA) that is synthesized from a DNA template throught transcription."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000245 ;
            owl:someValuesFrom sio:SIO_010096 ],
        sio:SIO_010099 .

sio:SIO_010098 a owl:Class ;
    rdfs:label "mRNA splice variant"@en ;
    dcterms:description "An mRNA splice variant is an mRNA molecule that varies from another mRNA molecule of the same gene origin but having a different final sequence due to differences in its assembly from splice sites."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000244 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_010099 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_000273 ;
                                owl:someValuesFrom sio:SIO_010451 ] ) ] ],
        sio:SIO_010099 .

sio:SIO_010100 a owl:Class ;
    rdfs:label "dna gene"@en ;
    dcterms:description "A gene that is located on DNA."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000093 ;
            owl:someValuesFrom sio:SIO_010010 ],
        sio:SIO_010035 ;
    owl:disjointWith sio:SIO_010101 .

sio:SIO_010277 a owl:Class ;
    rdfs:label "allele"@en ;
    dcterms:description "An allele is one of a set of sequence variants of a gene."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000272 ;
            owl:someValuesFrom sio:SIO_010035 ],
        sio:SIO_010035 .

sio:SIO_010278 a owl:Class ;
    rdfs:label "ploidy"@en ;
    dcterms:description "ploidy is the cellular quality relating to the amount of DNA contained in a cell."@en ;
    rdfs:subClassOf sio:SIO_000476 .

sio:SIO_010285 a owl:Class ;
    rdfs:label "molecular complex formation"@en ;
    dcterms:description "molecular complex formation is the process of forming a molecular complex from its constituent parts."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_010506 ],
        sio:SIO_000559 .

sio:SIO_010286 a owl:Class ;
    rdfs:label "molecular complex dissociation"@en ;
    dcterms:description "molecular complex disassociation is the process of dissambly of a molecular complex into its constitutent parts."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000291 ;
            owl:someValuesFrom sio:SIO_010506 ],
        sio:SIO_000592 .

sio:SIO_010288 a owl:Class ;
    rdfs:label "biochemical activation"@en ;
    dcterms:description "biochemical activation is a molecular interaction that increases the catalytic rate of the target enzyme."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000355 ;
            owl:someValuesFrom sio:SIO_000499 ],
        sio:SIO_000611 ;
    owl:disjointWith sio:SIO_010289 .

sio:SIO_010298 a owl:Class ;
    rdfs:label "medical data"@en ;
    dcterms:description "medical data is data of interest to medicine."@en ;
    rdfs:subClassOf sio:SIO_010019 .

sio:SIO_010300 a owl:Class ;
    rdfs:label "transcription"@en ;
    dcterms:description "transcription is the process of creating a complementary RNA copy of a sequence of DNA."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000230 ;
            owl:someValuesFrom sio:SIO_010010 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000229 ;
            owl:someValuesFrom [ a owl:Class ;
                    owl:intersectionOf ( sio:SIO_010009 [ a owl:Restriction ;
                                owl:onProperty sio:SIO_010081 ;
                                owl:someValuesFrom sio:SIO_010010 ] ) ] ],
        sio:SIO_000590 .

sio:SIO_010301 a owl:Class ;
    rdfs:label "translation"@en ;
    dcterms:description "translation is the process of producing a polypeptide from a ribonucleic acid by a ribosome."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000230 ;
            owl:someValuesFrom sio:SIO_010009 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000312 ;
            owl:someValuesFrom sio:SIO_010007 ],
        sio:SIO_000590 .

sio:SIO_010307 a owl:Class ;
    rdfs:label "molecular modification"@en ;
    dcterms:description "Molecular modification is chemical alteration of a known and previously characterized lead compound for the purpose of enhancing its usefulness as a drug. This could mean enhancing its specificity for a particular body target site, increasing its potency, improving its rate and extent of absorption, modifying to advantage its time course in the body, reducing its toxicity, changing its physical or chemical properties (like solubility) to provide desired features."@en ;
    rdfs:subClassOf sio:SIO_010345 .

sio:SIO_010309 a owl:Class ;
    rdfs:label "catabolism"@en ;
    dcterms:description "Anabolism is the set of metabolic processes that take apart larger chemical entities units into smaller chemical entities."@en ;
    rdfs:subClassOf sio:SIO_010308 ;
    owl:disjointWith sio:SIO_010310 .

sio:SIO_010349 a owl:Class ;
    rdfs:label "to cleave"@en ;
    dcterms:description "to cleave is to split or sever an object along a natural line or grain."@en ;
    rdfs:subClassOf sio:SIO_000698 .

sio:SIO_010351 a owl:Class ;
    rdfs:label "to combine"@en ;
    dcterms:description "to combine is the capability to modify a set of objects in a way that the object is merged with another object to form a new object or substance."@en ;
    rdfs:subClassOf sio:SIO_000376 .

sio:SIO_010353 a owl:Class ;
    rdfs:label "to breathe"@en ;
    dcterms:description "to breathe is the capability to inhale and exhale air into the body during respiration."@en ;
    rdfs:subClassOf sio:SIO_000112 .

sio:SIO_010354 a owl:Class ;
    rdfs:label "to conformationally activate"@en ;
    dcterms:description "to conformationally activate is to modify the conformation of an entity in such a way that it becomes activated or functional."@en ;
    rdfs:subClassOf sio:SIO_010347 .

sio:SIO_010355 a owl:Class ;
    rdfs:label "to conformationally inhibit"@en ;
    dcterms:description "to conformationally inhibit is to modify the conformation of an entity in such a way that it functionally is reduced or inhibited."@en ;
    rdfs:subClassOf sio:SIO_010347 .

sio:SIO_010365 a owl:Class ;
    rdfs:label "to be cleaved"@en ;
    dcterms:description "to be cleaved is the capability to be modified in a way that splits one part of the object from the other."@en ;
    rdfs:subClassOf sio:SIO_010364 .

sio:SIO_010370 a owl:Class ;
    rdfs:label "to gain an electron"@en ;
    dcterms:description "to gain an electron is the capability of a chemical entity to receive an electron."@en ;
    rdfs:subClassOf sio:SIO_010369 .

sio:SIO_010371 a owl:Class ;
    rdfs:label "to lose an electron"@en ;
    dcterms:description "to lose an electron is the capability of a chemical entity to lose an electron."@en ;
    rdfs:subClassOf sio:SIO_010369 .

sio:SIO_010372 a owl:Class ;
    rdfs:label "to be activated"@en ;
    dcterms:description "to be activated is the capability to be modified in such a way that the conformational change leads to an increase in another capability."@en ;
    rdfs:subClassOf sio:SIO_010374 .

sio:SIO_010373 a owl:Class ;
    rdfs:label "to be inhibited"@en ;
    dcterms:description "to be inhibited is the capability to be modified in such a way that the conformational change leads to an decrease in another capability."@en ;
    rdfs:subClassOf sio:SIO_010374 .

sio:SIO_010379 a owl:Class ;
    rdfs:label "virus"@en ;
    dcterms:description "A virus is a non-cellular organism that can replicate only inside the living cells of an organism."@en ;
    rdfs:subClassOf sio:SIO_010378 .

sio:SIO_010383 a owl:Class ;
    rdfs:label "drug regulatory authority"@en ;
    dcterms:description "A drug regulatory authority is a regulatory authority which acts to control what substances may be used to treat individuals."@en ;
    rdfs:subClassOf sio:SIO_000619 .

sio:SIO_010410 a owl:Class ;
    rdfs:label "specialized material entity"@en ;
    dcterms:description "A specialized material entity is a material entity that is defined by having some quality, role or capability."@en ;
    rdfs:subClassOf sio:SIO_001353 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_000004 [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000644 ;
                        owl:someValuesFrom sio:SIO_000340 ] ) ] .

sio:SIO_010412 a owl:Class ;
    rdfs:label "specimen"@en ;
    dcterms:description "A specimen is a portion of material for use in testing, examination, or study."@en ;
    rdfs:subClassOf sio:SIO_001050 .

sio:SIO_010414 a owl:Class ;
    rdfs:label "pathogen"@en ;
    dcterms:description "A pathogen or infectious agent  is a microorganism that causes disease in its host."@en ;
    rdfs:subClassOf sio:SIO_010000 .

sio:SIO_010418 a owl:Class ;
    rdfs:label "solute"@en ;
    dcterms:description "A solute is a substance that becomes dissolved in a solvent."@en ;
    rdfs:subClassOf sio:SIO_010427 .

sio:SIO_010419 a owl:Class ;
    rdfs:label "antigen"@en ;
    dcterms:description "An antigen is a molecule that can be bound by a major histocompatibility complex (MHC) and presented to a T-cell receptor."@en ;
    rdfs:subClassOf sio:SIO_011125 .

sio:SIO_010420 a owl:Class ;
    rdfs:label "receptor"@en ;
    dcterms:description "A receptor molecule is a molecule that has the capability to bind to a signal and propogate a response to that signal."@en ;
    rdfs:subClassOf sio:SIO_010437 .

sio:SIO_010424 a owl:Class ;
    rdfs:label "centrifugation pellet"@en ;
    dcterms:description "A centrifugation pellet is a solid substance that forms as a result of compaction by a centrifuge."@en ;
    rdfs:subClassOf sio:SIO_010426 ;
    owl:disjointWith sio:SIO_010425 .

sio:SIO_010429 a owl:Class ;
    rdfs:label "placebo"@en ;
    dcterms:description "A placebo is a medically ineffectual treatment for a medical condition intended to deceive the recipient."@en ;
    rdfs:subClassOf sio:SIO_010462 .

sio:SIO_010430 a owl:Class ;
    rdfs:label "test role"@en ;
    dcterms:description "A test role is the role of an individual that is a participant in the study and is the target of the intervention."@en ;
    rdfs:subClassOf sio:SIO_010428 .

sio:SIO_010431 a owl:Class ;
    rdfs:label "control role"@en ;
    dcterms:description "A control role is the role of an individual that is part of a study, but is not subject to the intervention that is to be tested."@en ;
    rdfs:subClassOf sio:SIO_010428 .

sio:SIO_010432 a owl:Class ;
    rdfs:label "ligand"@en ;
    dcterms:description "A ligand is a molecule that is part of a complex by weakly interacting with another molecule."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000310 ;
            owl:someValuesFrom sio:SIO_010506 ],
        [ a owl:Restriction ;
            owl:onProperty sio:SIO_000335 ;
            owl:someValuesFrom sio:SIO_011125 ],
        sio:SIO_011125 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( sio:SIO_011125 [ a owl:Class ;
                        owl:intersectionOf ( [ a owl:Restriction ;
                                    owl:onProperty sio:SIO_000310 ;
                                    owl:someValuesFrom sio:SIO_010506 ] [ a owl:Restriction ;
                                    owl:onProperty sio:SIO_000335 ;
                                    owl:someValuesFrom sio:SIO_011125 ] ) ] ) ] .

sio:SIO_010433 a owl:Class ;
    rdfs:label "low barrier hydrogen bond"@en ;
    dcterms:description "A low barrier hydrogen bond is a shorter, stronger hydrogen bond that is formed between both heteroatoms."@en ;
    rdfs:subClassOf sio:SIO_010033 .

sio:SIO_010434 a owl:Class ;
    rdfs:label "activator"@en ;
    dcterms:description "A molecular activator is a molecular regulator that realizes its disposition to conformationally change a target molecule and increase its functionality."@en ;
    rdfs:subClassOf sio:SIO_010436 .

sio:SIO_010435 a owl:Class ;
    rdfs:label "inhibitor"@en ;
    dcterms:description "A molecular inhibitor is a molecular regulator that realizes its disposition to conformationally change a target molecule and decrease its functionality."@en ;
    rdfs:subClassOf sio:SIO_010436 .

sio:SIO_010438 a owl:Class ;
    rdfs:label "signal"@en ;
    dcterms:description "A signal is an object that initiates a sequence of events."@en ;
    rdfs:subClassOf sio:SIO_011125 .

sio:SIO_010440 a owl:Class ;
    rdfs:label "second messenger"@en ;
    dcterms:description "A second messenger is a molecule that relay signals from receptors on the cell surface to target molecules inside the cell, in the cytoplasm or nucleus. "@en ;
    rdfs:subClassOf sio:SIO_010439 .

sio:SIO_010445 a owl:Class ;
    rdfs:label "exon"@en ;
    dcterms:description "An exon is a nucleotide sequence encoded by a gene that remains present within the final mature RNA product of that gene after introns have been removed by RNA splicing. "@en ;
    rdfs:subClassOf sio:SIO_010444 .

sio:SIO_010446 a owl:Class ;
    rdfs:label "gene promoter"@en ;
    dcterms:description "A gene promoter is a region of DNA that initiates transcription of a particular gene."@en ;
    rdfs:subClassOf sio:SIO_010085 .

sio:SIO_010452 a owl:Class ;
    rdfs:label "molecular pocket"@en ;
    dcterms:description "A molecular pocket is a site on a molecule that appears as a depression into the structure."@en ;
    rdfs:subClassOf sio:SIO_010049 .

sio:SIO_010453 a owl:Class ;
    rdfs:label "acid"@en ;
    dcterms:description "An acid is a molecular entity in solution capable of donating a hydron (Bronsted acid) or capable of forming a covalent bond with an electron pair (Lewis acid)."@en ;
    rdfs:subClassOf sio:SIO_010427 .

sio:SIO_010454 a owl:Class ;
    rdfs:label "base"@en ;
    dcterms:description "A base is a molecular entity dissolved in a solvent that is capable of accepting a proton (Bronsted base) or forming a covalent bond with a hydron (Lewis base) ."@en ;
    rdfs:subClassOf sio:SIO_010427 .

sio:SIO_010459 a owl:Class ;
    rdfs:label "polar solvent"@en ;
    dcterms:description "A polar solvent is a solvent that exhibits a polar quality."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sio:SIO_000217 ;
            owl:someValuesFrom sio:SIO_001046 ],
        sio:SIO_010417 ;
    owl:disjointWith sio:SIO_010460 .

sio:SIO_010465 a owl:Class ;
    rdfs:label "antibody"@en ;
    dcterms:description "An antibody (also known as immunoglobulins, abbreviated Ig) are gamma globulin proteins that are used by the immune system to identify and neutralize foreign objects. They are typically made of two large heavy chains and two small light chains."@en ;
    rdfs:subClassOf sio:SIO_010497 .

sio:SIO_010468 a owl:Class ;
    rdfs:label "alpha helix"@en ;
    dcterms:description "An alpha helix is structural region of a protein that is characterized by 3.6 residues per turn,  a translation of 1.5 angstroms along the helical axis in which backbone N-H groups form a hydrogen bond to the backbone carboxyl group of the amino acid four residues prior."@en ;
    rdfs:subClassOf sio:SIO_010471 .

sio:SIO_010469 a owl:Class ;
    rdfs:label "beta strand"@en ;
    dcterms:description """A beta strand is structural region of a protein that is characterized by a roughly planar sequence of amino acid residues forming hydrogen bonds between the N-O and the C=O  of another part of the peptide
and having their side chains perpendicular to the planar axis."""@en ;
    rdfs:subClassOf sio:SIO_010471 .

sio:SIO_010499 a owl:Class ;
    rdfs:label "double bond"@en ;
    dcterms:description "A double bond is a covalent bond between a pair of atoms in which two pairs of electrons are shared."@en ;
    rdfs:subClassOf sio:SIO_011118 .

sio:SIO_010500 a owl:Class ;
    rdfs:label "triple bond"@en ;
    dcterms:description "A triple bond is a covalent bond between a pair of atoms in which three pairs of electrons are shared."@en ;
    rdfs:subClassOf sio:SIO_011118 .

sio:SIO_010501 a owl:Class ;
    rdfs:label "aromatic bond"@en ;
    dcterms:description "An aromatic bond is an interaction between a set of atoms across which pairs of electrons are shared."@en ;
    rdfs:subClassOf sio:SIO_011118 .

sio:SIO_010502 a owl:Class ;
    rdfs:label "disulfide bond"@en ;
    dcterms:description "A disulfide bond is a bond between two sulfur atoms."@en ;
    rdfs:subClassOf sio:SIO_010498 .

sio:SIO_010503 a owl:Class ;
    rdfs:label "dipole-dipole interaction"@en ;
    dcterms:description "A dipole-dipole interaction is a weak submolecular interaction between strongly electronegative atoms."@en ;
    rdfs:subClassOf sio:SIO_010005 .

sio:SIO_010504 a owl:Class ;
    rdfs:label "van der Waals interaction"@en ;
    dcterms:description "van der Waals' interaction is an a weak submolecular interaction between an instantaneous dipole and induced dipole."@en ;
    rdfs:subClassOf sio:SIO_010005 .

sio:SIO_010505 a owl:Class ;
    rdfs:label "base stack"@en ;
    dcterms:description "A base stack is a stabilizing interaction of DNA and RNA between spatially adjacent nucleotides and possibly involving London dispersion, hydrophobic and electrostatic forces."@en ;
    rdfs:subClassOf sio:SIO_010005 .

sio:SIO_010507 a owl:Class ;
    rdfs:label "acid-base reaction"@en ;
    dcterms:description "An acid-base reaction is a chemical reaction between an acid and a base."@en ;
    rdfs:subClassOf sio:SIO_010345 .

sio:SIO_010509 a owl:Class ;
    rdfs:label "redox reaction"@en ;
    dcterms:description "A redox reaction is a chemical reaction in which there is a net movement of electrons from one reactant to another."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000355 ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( sio:SIO_010358 [ a owl:Restriction ;
                                            owl:onProperty sio:SIO_000236 ;
                                            owl:someValuesFrom sio:SIO_011125 ] ) ] ] [ a owl:Restriction ;
                        owl:onProperty sio:SIO_000355 ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( sio:SIO_010359 [ a owl:Restriction ;
                                            owl:onProperty sio:SIO_000236 ;
                                            owl:someValuesFrom sio:SIO_011125 ] ) ] ] ) ],
        sio:SIO_010345 .

sio:SIO_010511 a owl:Class ;
    rdfs:label "decomposition reaction"@en ;
    dcterms:description "A decomposition reaction is an inorganic reaction in which molecule is fragmented into submolecules or atoms."@en ;
    rdfs:subClassOf sio:SIO_010510 .

sio:SIO_010513 a owl:Class ;
    rdfs:label "double displacement reaction"@en ;
    dcterms:description "A double displacement reaction is a displacement reaction in which two molecules swap ions, effectively displacing each other to form two new molecules."@en ;
    rdfs:subClassOf sio:SIO_010512 .

sio:SIO_010514 a owl:Class ;
    rdfs:label "single displacement reaction"@en ;
    dcterms:description "A single displacement reaction where one atom is transferred out of one molecule and into another."@en ;
    rdfs:subClassOf sio:SIO_010512 .

sio:SIO_010515 a owl:Class ;
    rdfs:label "synthesis reaction"@en ;
    dcterms:description "A synthesis reaction is an inorganic reaction in which two or more molecules are chemically bonded together to produce a single product."@en ;
    rdfs:subClassOf sio:SIO_010510 .

sio:SIO_010517 a owl:Class ;
    rdfs:label "isomerization reaction"@en ;
    dcterms:description "An isomerization reaction is a chemical reaction in which a molecule is converted into its isomer."@en ;
    rdfs:subClassOf sio:SIO_010345 .

sio:SIO_010521 a owl:Class ;
    rdfs:label "free radical addition"@en ;
    dcterms:description "A free radical addition is a non-polar addition reaction involving free radicals."@en ;
    rdfs:subClassOf sio:SIO_010520 .

sio:SIO_010522 a owl:Class ;
    rdfs:label "nucleophilic addition reaction"@en ;
    dcterms:description "A nucleophilic addition reaction is an addition reaction where a pi bond is removed by the creation of two new covalent bonds by the addition from a nucleophile."@en ;
    rdfs:subClassOf sio:SIO_010519 .

sio:SIO_010523 a owl:Class ;
    rdfs:label "electrophilic addition reaction"@en ;
    dcterms:description "An electrophilic addition reaction is a polar addition reaction where a pi bond is removed by the creation of two new covalent bonds."@en ;
    rdfs:subClassOf sio:SIO_010519 .

sio:SIO_010527 a owl:Class ;
    rdfs:label "chemical synthesis pathway"@en ;
    dcterms:description "A chemical synthesis pathway is a pathway involved in the assembly of a chemical."@en ;
    rdfs:subClassOf sio:SIO_010526 .

sio:SIO_010528 a owl:Class ;
    rdfs:label "chemical degradation pathway"@en ;
    dcterms:description "A chemical degradation pathway is a pathway involved in the disassembly of a chemical."@en ;
    rdfs:subClassOf sio:SIO_010526 .

sio:SIO_010531 a owl:Class ;
    rdfs:label "sequence profile"@en ;
    dcterms:description "A sequence profile is provides the preference for a character at each position of an abstracted sequence."@en ;
    rdfs:subClassOf sio:SIO_000130 .

sio:SIO_010673 a owl:Class ;
    rdfs:label "medical history"@en ;
    dcterms:description "A medical history is a record of the events of a recipient of medical care."@en ;
    rdfs:subClassOf sio:SIO_001196 .

sio:SIO_010776 a owl:Class ;
    rdfs:label "diastereomer"@en ;
    dcterms:description "A diastereomer is a stereoisomer that is not a mirror image of its isomer."@en ;
    rdfs:subClassOf sio:SIO_010775 .

sio:SIO_010777 a owl:Class ;
    rdfs:label "enantiomer"@en ;
    dcterms:description "An enantiomer is a stereoisomer that is a mirror image of its isomer."@en ;
    rdfs:subClassOf sio:SIO_010775 .

sio:SIO_010778 a owl:Class ;
    rdfs:label "optical isomer"@en ;
    dcterms:description "An optical isomer is a stereoisomer that rotates the plane of polarization of a beam of plane polarized light."@en ;
    rdfs:subClassOf sio:SIO_010775 .

sio:SIO_010779 a owl:Class ;
    rdfs:label "structural isomer"@en ;
    dcterms:description "A structural isomer is an isomer in which the atoms are joined together in different ways."@en ;
    rdfs:subClassOf sio:SIO_010455 .

sio:SIO_010781 a owl:Class ;
    rdfs:label "aromatic ring"@en ;
    dcterms:description "An aromatic ring is a ring in which the electrons are delocalized across all atoms in the ring."@en ;
    rdfs:subClassOf sio:SIO_010780 .

sio:SIO_010784 a owl:Class ;
    rdfs:label "ionic compound"@en ;
    dcterms:description "An ionic compound is a mereological maximal sum of weakly connected paired positive and negative ions."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass sio:SIO_010458 ;
            owl:onProperty sio:SIO_000273 ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass sio:SIO_010457 ;
            owl:onProperty sio:SIO_000273 ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        sio:SIO_010674 .

sio:SIO_010787 a owl:Class ;
    rdfs:label "diamond"@en ;
    dcterms:description "diamond is a carbon allotrope in which each carbon atom in diamond is covalently bonded to four other carbons in a tetrahedron. These tetrahedrons together form a 3-dimensional network of puckered six-membered rings of atoms."@en ;
    rdfs:subClassOf sio:SIO_010786 .

sio:SIO_010788 a owl:Class ;
    rdfs:label "graphite"@en ;
    dcterms:description "graphite is an allotrope of carbon which is a conductor, and is the most stable form of solid carbon."@en ;
    rdfs:subClassOf sio:SIO_010786 .

sio:SIO_010789 a owl:Class ;
    rdfs:label "fullerene"@en ;
    dcterms:description "fullerene is a carbon allotrope which take the form of a hollow sphere, ellipsoid, or tube."@en ;
    rdfs:subClassOf sio:SIO_010786 .

sio:SIO_010790 a owl:Class ;
    rdfs:label "aggregated carbon nanorods"@en ;
    dcterms:description "aggregate of carbon nanorods is an allotrope of carbon considered to be the least compressible material known, as measured by its isothermal bulk modulus; aggregated diamond nanorods have a modulus of 491 gigapascals (GPa), while a conventional diamond has a modulus of 442 GPa. ADNRs are also 0.3% denser than regular diamond."@en ;
    rdfs:subClassOf sio:SIO_010786 .

sio:SIO_010791 a owl:Class ;
    rdfs:label "amorphous carbon"@en ;
    dcterms:description "amorphous carbon is an allotrope of carbon that does not have any crystalline structure. As with all glassy materials, some short-range order can be observed, but there is no long-range pattern of atomic positions."@en ;
    rdfs:subClassOf sio:SIO_010786 .

sio:SIO_010792 a owl:Class ;
    rdfs:label "carbon nanofoam"@en ;
    dcterms:description "carbon nanofoam is an allotrope of carbon that consists of a low-density cluster-assembly of carbon atoms strung together in a loose three-dimensional web. Each cluster is about 6 nanometers wide and consists of about 4000 carbon atoms linked in graphite-like sheets that are given negative curvature by the inclusion of heptagons among the regular hexagonal pattern."@en ;
    rdfs:subClassOf sio:SIO_010786 .

sio:SIO_010793 a owl:Class ;
    rdfs:label "chaoite"@en ;
    dcterms:description "chaoite is an allotrope of carbon that is slightly harder than graphite with a reflection colour of grey to white."@en ;
    rdfs:subClassOf sio:SIO_010786 .

sio:SIO_010794 a owl:Class ;
    rdfs:label "glassy carbon"@en ;
    dcterms:description "glassy carbon is an allotrope of carbon which is widely used as an electrode material in electrochemistry, as well as for high temperature crucibles and as a component of some prosthetic devices."@en ;
    rdfs:subClassOf sio:SIO_010786 .

sio:SIO_010795 a owl:Class ;
    rdfs:label "ionsdaleite"@en ;
    dcterms:description "ionsdaleite is a hexagonal allotrope of the carbon allotrope diamond."@en ;
    rdfs:subClassOf sio:SIO_010786 .

sio:SIO_011000 a owl:Class ;
    rdfs:label "boron atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:27560" .

sio:SIO_011003 a owl:Class ;
    rdfs:label "helium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:30217" .

sio:SIO_011004 a owl:Class ;
    rdfs:label "lithium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:30145" .

sio:SIO_011005 a owl:Class ;
    rdfs:label "beryllium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:30501" .

sio:SIO_011006 a owl:Class ;
    rdfs:label "nitrogen atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:25555" .

sio:SIO_011008 a owl:Class ;
    rdfs:label "fluorine atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:24061" .

sio:SIO_011009 a owl:Class ;
    rdfs:label "neon atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:33310" .

sio:SIO_011010 a owl:Class ;
    rdfs:label "sodium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:26708" .

sio:SIO_011011 a owl:Class ;
    rdfs:label "magnesium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:25107" .

sio:SIO_011012 a owl:Class ;
    rdfs:label "aluminium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:28984" .

sio:SIO_011013 a owl:Class ;
    rdfs:label "silicon atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:27573" .

sio:SIO_011014 a owl:Class ;
    rdfs:label "phosphorus atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:28659" .

sio:SIO_011015 a owl:Class ;
    rdfs:label "sulfur atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:26833" .

sio:SIO_011016 a owl:Class ;
    rdfs:label "chlorine atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:23116" .

sio:SIO_011017 a owl:Class ;
    rdfs:label "argon atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:49475" .

sio:SIO_011018 a owl:Class ;
    rdfs:label "potassium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:26216" .

sio:SIO_011019 a owl:Class ;
    rdfs:label "calcium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:22984" .

sio:SIO_011020 a owl:Class ;
    rdfs:label "scandium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:33330" .

sio:SIO_011021 a owl:Class ;
    rdfs:label "titanium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:33341" .

sio:SIO_011022 a owl:Class ;
    rdfs:label "vanadium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:27698" .

sio:SIO_011023 a owl:Class ;
    rdfs:label "chromium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:28073" .

sio:SIO_011024 a owl:Class ;
    rdfs:label "manganese atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:18291" .

sio:SIO_011025 a owl:Class ;
    rdfs:label "iron atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:18248" .

sio:SIO_011026 a owl:Class ;
    rdfs:label "cobalt atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:27638" .

sio:SIO_011027 a owl:Class ;
    rdfs:label "nickel atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:28112" .

sio:SIO_011028 a owl:Class ;
    rdfs:label "copper atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:28694" .

sio:SIO_011029 a owl:Class ;
    rdfs:label "zinc atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:27363" .

sio:SIO_011030 a owl:Class ;
    rdfs:label "gallium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:49631" .

sio:SIO_011031 a owl:Class ;
    rdfs:label "germanium atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:30441" .

sio:SIO_011032 a owl:Class ;
    rdfs:label "arsenic atom"@en ;
    rdfs:subClassOf sio:SIO_010044 ;
    skos:exactMatch "CHEBI:27563" .

sio:SIO_011033 a owl:Class ;
